{
  "cleanUrls": true,
  "trailingSlash": false,
  "i18n": {
    "defaultLocale": "en",
    "locales": ["en", "zh-TW", "zh-CN"]
  },
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/paddle-return",
      "destination": "https://app.aitroop.net/billing",
      "permanent": false
    }
  ]
}
