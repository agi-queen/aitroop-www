---
/*
  OrbitingCircles — concentric orbits with brand glyphs revolving around a
  centre. Inspired by https://magicui.design/docs/components/orbiting-circles

  Pure CSS animation. Items at the same radius share one duration + direction;
  each item gets a negative animation-delay so it starts at its own angle.
  The keyframe combines an outer rotate + translateX + inner counter-rotate
  so each chip stays upright as it travels.
*/

export interface OrbitItem {
  label: string;
  /** Inner SVG markup (paths, etc.) rendered with viewBox 0 0 24 24. */
  svg?: string;
  /** Brand colour for the glyph. Falls back to text colour. */
  color?: string;
  /** Fallback short text if no svg is provided. */
  text?: string;
}

export interface OrbitRing {
  radius: number;
  duration?: number;
  reverse?: boolean;
  items: OrbitItem[];
}

export interface Props {
  size?: number;
  iconSize?: number;
  centerSize?: number;
  rings: OrbitRing[];
  centerSrc?: string;
  centerAlt?: string;
  class?: string;
}

const {
  size = 500,
  iconSize = 56,
  centerSize = 88,
  rings = [],
  centerSrc,
  centerAlt = '',
  class: className = '',
} = Astro.props;
---

<div
  class:list={['orbits', className]}
  style={`--orbit-box:${size}px;--orbit-icon:${iconSize}px;--orbit-center:${centerSize}px;`}
>
  {rings.map((r) => (
    <div
      class="orbit-ring"
      style={`width:${r.radius * 2}px;height:${r.radius * 2}px;`}
      aria-hidden="true"
    ></div>
  ))}

  <div class="orbit-center" aria-hidden="true">
    {centerSrc ? (
      <img src={centerSrc} alt={centerAlt} />
    ) : (
      <span>A</span>
    )}
  </div>

  {rings.map((r) => {
    const duration = r.duration ?? 24;
    const dir = r.reverse ? 'reverse' : 'normal';
    const count = r.items.length;
    return r.items.map((item, i) => {
      const angle = (360 / count) * i;
      const delay = -(angle / 360) * duration;
      return (
        <div
          class="orbit-item"
          style={`--radius:${r.radius}px;animation-duration:${duration}s;animation-delay:${delay}s;animation-direction:${dir};`}
          title={item.label}
          aria-label={item.label}
        >
          <span class="orbit-chip" style={item.color ? `color:${item.color};` : undefined}>
            {item.svg ? (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={item.svg}></svg>
            ) : (
              <span class="orbit-chip__text">{item.text ?? item.label.slice(0, 2)}</span>
            )}
          </span>
        </div>
      );
    });
  })}
</div>

<style>
  .orbits {
    position: relative;
    width: var(--orbit-box);
    height: var(--orbit-box);
    max-width: 100%;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    color: var(--aw-color-text-default);
  }

  .orbit-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 1px dashed rgba(82, 153, 97, 0.22);
    border-radius: 50%;
    pointer-events: none;
  }

  .orbit-center {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--orbit-center);
    height: var(--orbit-center);
    margin-top: calc(var(--orbit-center) / -2);
    margin-left: calc(var(--orbit-center) / -2);
    border-radius: 22%;
    background: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 0 0 6px rgba(82, 153, 97, 0.10),
      0 0 0 14px rgba(82, 153, 97, 0.05),
      0 18px 40px -10px rgba(20, 50, 30, 0.30);
    animation: orbit-center-pulse 4.5s ease-in-out infinite;
  }
  .orbit-center img {
    width: 72%;
    height: 72%;
    display: block;
  }

  .orbit-item {
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--orbit-icon);
    height: var(--orbit-icon);
    margin-top: calc(var(--orbit-icon) / -2);
    margin-left: calc(var(--orbit-icon) / -2);
    animation-name: orbit;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    will-change: transform;
  }
  .orbit-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    background: #ffffff;
    border: 1px solid var(--aw-color-border);
    color: var(--aw-color-text-default);
    box-shadow: 0 8px 18px -10px rgba(20, 50, 30, 0.25);
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .orbit-chip svg {
    width: 56%;
    height: 56%;
    display: block;
  }
  .orbit-chip__text {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }
  .orbit-item:hover .orbit-chip {
    border-color: rgba(82, 153, 97, 0.5);
    transform: scale(1.10);
    box-shadow: 0 12px 24px -10px rgba(20, 50, 30, 0.30);
  }

  @keyframes orbit {
    from {
      transform: rotate(0deg) translateX(var(--radius)) rotate(0deg);
    }
    to {
      transform: rotate(360deg) translateX(var(--radius)) rotate(-360deg);
    }
  }

  @keyframes orbit-center-pulse {
    0%, 100% {
      box-shadow:
        0 0 0 6px rgba(82, 153, 97, 0.10),
        0 0 0 14px rgba(82, 153, 97, 0.05),
        0 18px 40px -10px rgba(20, 50, 30, 0.30);
    }
    50% {
      box-shadow:
        0 0 0 10px rgba(82, 153, 97, 0.14),
        0 0 0 22px rgba(82, 153, 97, 0.06),
        0 18px 40px -10px rgba(20, 50, 30, 0.30);
    }
  }
</style>
