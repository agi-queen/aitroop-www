---
/*
  BentoGrid — Aceternity-inspired varied-size tile grid.

  Children are rendered as <li> tiles. Each item can request a span via
  `span: 'wide' | 'tall' | 'large'` to break the uniform rhythm.

  Usage:
    <BentoGrid items={features} />
  where each item supports: { title, desc, icon (svg path), span?, accent? }.

  Pure Astro + CSS. No JS. Mouse-tracked spotlight is delegated to the
  existing `data-spotlight` system via the Spotlight widget.
*/
export interface BentoItem {
  title: string;
  desc: string;
  icon?: string;        // SVG path d
  span?: 'wide' | 'tall' | 'large';
  accent?: string;      // optional small tag above title
  href?: string;
}

export interface Props {
  items: BentoItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<ul class:list={['bento-grid', className]} role="list">
  {items.map((it) => {
    const TagName = it.href ? 'a' : 'div';
    return (
      <li class:list={['bento-tile spotlight-card', it.span && `bento-${it.span}`]} data-spotlight>
        <TagName href={it.href} class="bento-inner">
          <div class="bento-grid-bg" aria-hidden="true"></div>
          {it.icon && (
            <span class="bento-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d={it.icon} />
              </svg>
            </span>
          )}
          {it.accent && <span class="bento-accent">{it.accent}</span>}
          <h3 class="bento-title">{it.title}</h3>
          <p class="bento-desc">{it.desc}</p>
        </TagName>
      </li>
    );
  })}
</ul>

<style>
  .bento-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(180px, auto);
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: minmax(210px, auto);
      gap: 1rem;
    }
  }

  /* span variants apply only on the wider grid */
  @media (min-width: 960px) {
    .bento-wide  { grid-column: span 2; }
    .bento-tall  { grid-row: span 2; }
    .bento-large { grid-column: span 2; grid-row: span 2; }
  }

  .bento-tile {
    position: relative;
    border-radius: 16px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    overflow: hidden;
    transition: border-color 240ms ease, transform 260ms ease, box-shadow 260ms ease;
  }
  .bento-tile:hover {
    border-color: rgba(82, 153, 97, 0.32);
    transform: translateY(-2px);
    box-shadow: 0 22px 50px -28px rgba(10, 10, 10, 0.18);
  }

  .bento-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.5rem 1.625rem;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  /* subtle dot/grid backdrop, masked toward the bottom for depth */
  .bento-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(82, 153, 97, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(82, 153, 97, 0.05) 1px, transparent 1px);
    background-size: 28px 28px;
    -webkit-mask-image: radial-gradient(ellipse 70% 90% at 100% 100%, #000 0%, transparent 70%);
            mask-image: radial-gradient(ellipse 70% 90% at 100% 100%, #000 0%, transparent 70%);
    opacity: 0;
    transition: opacity 360ms ease;
    z-index: 0;
  }
  .bento-tile:hover .bento-grid-bg { opacity: 1; }

  .bento-icon {
    position: relative;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(82, 153, 97, 0.10);
    color: var(--aw-color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.35rem;
    z-index: 1;
  }
  .bento-icon svg { width: 20px; height: 20px; }

  .bento-accent {
    position: relative;
    z-index: 1;
    align-self: flex-start;
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--aw-color-primary);
    padding: 2px 8px;
    border-radius: 9999px;
    background: rgba(82, 153, 97, 0.10);
  }

  .bento-title {
    position: relative;
    z-index: 1;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .bento-large .bento-title,
  .bento-wide  .bento-title {
    font-size: 1.25rem;
  }

  .bento-desc {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    text-wrap: pretty;
  }
</style>
