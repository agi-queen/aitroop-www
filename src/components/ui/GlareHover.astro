---
/*
  GlareHover — Aceternity-inspired diagonal shine sweep.

  Apply by adding `class="glare-hover"` to any element with overflow-clip
  rounded corners. A pseudo-element sweeps a soft white-to-transparent
  band across on hover. Pure CSS, no JS, no layout shift.

  Designed to layer cleanly with Spotlight: the glare goes on the
  card surface; spotlight glows under it. Both can coexist.
*/
---

<style is:global>
  .glare-hover {
    position: relative;
    overflow: hidden;
  }
  .glare-hover::after {
    content: '';
    position: absolute;
    top: 0;
    left: -120%;
    width: 60%;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 0%,
      transparent 35%,
      rgba(82, 153, 97, 0.08) 48%,
      rgba(255, 255, 255, 0.45) 50%,
      rgba(82, 153, 97, 0.08) 52%,
      transparent 65%,
      transparent 100%
    );
    transform: skewX(-18deg);
    transition: left 720ms cubic-bezier(0.22, 0.61, 0.36, 1);
    mix-blend-mode: overlay;
    opacity: 0;
    z-index: 3;
  }
  .glare-hover:hover::after {
    left: 130%;
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .glare-hover::after { transition: none; opacity: 0 !important; }
  }
</style>
