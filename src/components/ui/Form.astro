---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const { inputs, textarea, disclaimer, button = 'Contact us', description = '' } = Astro.props;
---

<form class="aw-form">
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="aw-field">
              {label && (
                <label class="aw-field-label" for={name}>
                  {label}
                </label>
              )}
              <input
                class="aw-input"
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div class="aw-field">
        <label class="aw-field-label" for="textarea">
          {textarea.label}
        </label>
        <textarea
          class="aw-textarea"
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
        />
      </div>
    )
  }

  {
    disclaimer && (
      <label class="aw-disclaimer">
        <input id="disclaimer" name="disclaimer" type="checkbox" />
        <span>{disclaimer.label}</span>
      </label>
    )
  }

  {
    button && (
      <div class="aw-form-submit">
        <Button variant="primary" type="submit">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <p class="aw-form-desc">{description}</p>
    )
  }
</form>

<style>
  .aw-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .aw-disclaimer {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    line-height: 1.55;
    cursor: pointer;
    margin-top: 0.25rem;
  }
  .aw-disclaimer input {
    margin-top: 0.18rem;
    accent-color: var(--aw-color-primary);
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
  .aw-form-submit {
    margin-top: 0.75rem;
    display: flex;
  }
  .aw-form-desc {
    margin: 0.75rem 0 0;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    line-height: 1.55;
  }
</style>
