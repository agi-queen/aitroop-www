---
/**
 * PopText — cartoon impact reveal.
 * Overshoot scale + sequential stagger + optional starburst on each letter.
 * Inspired by shadcn.io /text/pop-text.
 */
interface Props {
  text: string;
  /** ms between each letter */
  stagger?: number;
  /** ms delay before the whole sequence starts */
  delay?: number;
  /** ms duration for a single letter */
  duration?: number;
  /** show comic starburst behind each letter */
  burst?: boolean;
  /** extra class on the wrapper */
  class?: string;
}

const {
  text,
  stagger = 32,
  delay = 0,
  duration = 480,
  burst = false,
  class: className = '',
} = Astro.props;

const chars = Array.from(text);
---

<span class={`pop-text ${className}`} aria-label={text}>
  {chars.map((ch, i) => {
    const style = `--pop-delay:${delay + i * stagger}ms;--pop-duration:${duration}ms;`;
    if (ch === ' ') {
      return <span class="pop-space" aria-hidden="true">&nbsp;</span>;
    }
    return (
      <span class="pop-char" style={style} aria-hidden="true">
        {burst && (
          <svg class="pop-burst" viewBox="0 0 60 60" aria-hidden="true">
            <polygon points="30,2 34,18 48,8 42,24 58,22 44,32 58,42 42,40 48,56 34,46 30,60 26,46 12,56 18,40 2,42 16,32 2,22 18,24 12,8 26,18" />
          </svg>
        )}
        <span class="pop-glyph">{ch}</span>
      </span>
    );
  })}
</span>

<style>
  .pop-text {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    line-height: inherit;
  }

  .pop-space {
    display: inline-block;
    width: 0.28em;
  }

  .pop-char {
    position: relative;
    display: inline-block;
    transform-origin: 50% 70%;
    opacity: 0;
    transform: translateY(0.32em) scale(0.96);
    animation: pop-in var(--pop-duration, 480ms) cubic-bezier(0.25, 1, 0.5, 1) both;
    animation-delay: var(--pop-delay, 0ms);
    will-change: transform, opacity;
  }

  .pop-glyph {
    display: inline-block;
  }

  /* Comic starburst — fades + scales as the letter snaps in, then disappears */
  .pop-burst {
    position: absolute;
    inset: -45% -45% auto -45%;
    margin: auto;
    width: 190%;
    height: 190%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    color: currentColor;
    fill: currentColor;
    opacity: 0;
    pointer-events: none;
    z-index: -1;
    animation: pop-burst var(--pop-duration, 480ms) cubic-bezier(0.19, 1, 0.22, 1) both;
    animation-delay: var(--pop-delay, 0ms);
    filter: drop-shadow(0 0 8px rgba(82, 153, 97, 0.35));
  }

  @keyframes pop-in {
    0%   { opacity: 0; transform: translateY(0.32em) scale(0.96); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes pop-burst {
    0%   { opacity: 0;   transform: translate(-50%, -50%) scale(0)   rotate(-30deg); }
    35%  { opacity: 0.35; transform: translate(-50%, -50%) scale(1.1) rotate(0deg); }
    70%  { opacity: 0.18; transform: translate(-50%, -50%) scale(1.25) rotate(15deg); }
    100% { opacity: 0;   transform: translate(-50%, -50%) scale(1.4) rotate(25deg); }
  }

</style>
