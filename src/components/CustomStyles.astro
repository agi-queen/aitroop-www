---
// Inter Variable — matches aitroop-system font stack exactly
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    /* ── Font stacks ────────────────────────────────────────────── */
    --aw-font-sans:    'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei UI', ui-sans-serif, sans-serif;
    --aw-font-serif:   'Inter Variable', 'Inter', ui-sans-serif, sans-serif;
    --aw-font-heading: 'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, ui-sans-serif, sans-serif;
    --aw-font-mono:    ui-monospace, SFMono-Regular, 'JetBrains Mono', Menlo, Monaco, Consolas, monospace;

    /* ── Primary green ─────────────────────────────────────────── */
    --aw-color-primary:        rgb(82 153 97);         /* #529961 */
    --aw-color-secondary:      rgb(61 133 79);         /* #3d854f */
    --aw-color-accent:         rgb(45 110 63);         /* #2d6e3f */
    --aw-color-primary-tint:   rgba(82, 153, 97, 0.08);
    --aw-color-primary-tint-2: rgba(82, 153, 97, 0.16);

    /* ── Text ──────────────────────────────────────────────────── */
    --aw-color-text-heading: rgb(10 10 10);
    --aw-color-text-default: rgb(18 18 18);
    --aw-color-text-muted:   rgb(110 110 110);

    /* ── Surfaces & borders ────────────────────────────────────── */
    --aw-color-bg-page:      rgb(255 255 255);
    --aw-color-bg-subtle:    rgb(247 247 246);
    --aw-color-bg-elevated:  rgb(255 255 255);
    --aw-color-border:       rgb(228 228 226);
    --aw-color-border-strong: rgb(200 200 198);
    --aw-color-bg-page-dark: rgb(12 12 14);

    /* ── Focus / shadow ────────────────────────────────────────── */
    --aw-shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.04);
    --aw-shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.03);
    --aw-shadow-md: 0 4px 12px -2px rgba(0, 0, 0, 0.06), 0 2px 4px -1px rgba(0, 0, 0, 0.04);
    --aw-shadow-lg: 0 12px 32px -10px rgba(0, 0, 0, 0.10), 0 4px 12px -4px rgba(0, 0, 0, 0.06);
    --aw-ring-focus: 0 0 0 2px var(--aw-color-bg-page), 0 0 0 4px rgba(82, 153, 97, 0.45);
  }

  ::selection {
    background-color: rgba(82, 153, 97, 0.20);
    color: var(--aw-color-text-heading);
  }

  /* ── Base — 14px body, matches aitroop-system ─────────────────── */
  html { font-size: 14px; scroll-behavior: smooth; }

  body {
    font-family: var(--aw-font-sans);
    font-size: 1rem;                /* 14px */
    font-weight: 400;
    line-height: 1.55;
    color: var(--aw-color-text-default);
    background-color: var(--aw-color-bg-page);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: 'calt', 'cv01', 'ss03';
    letter-spacing: -0.003em;
  }

  h1, h2, h3, h4, h5, h6 {
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
  }

  /* ── Default focus-visible ring (anything focusable) ──────────── */
  :where(a, button, input, select, textarea, [tabindex]):focus-visible {
    outline: none;
    box-shadow: var(--aw-ring-focus);
    border-radius: 4px;
  }

  /* ── Scrollbar — thin, modest hover reveal ────────────────────── */
  ::-webkit-scrollbar            { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track      { background: transparent; }
  ::-webkit-scrollbar-thumb {
    border-radius: 9999px;
    background-color: transparent;
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  *:hover::-webkit-scrollbar-thumb {
    background-color: rgba(0, 0, 0, 0.16);
    background-clip: padding-box;
  }
  ::-webkit-scrollbar-thumb:hover {
    background-color: rgba(0, 0, 0, 0.28);
    background-clip: padding-box;
  }

  /* ── Prose (blog / markdown) ──────────────────────────────────── */
  .prose {
    --tw-prose-body:    var(--aw-color-text-default);
    --tw-prose-headings:var(--aw-color-text-heading);
    --tw-prose-lead:    var(--aw-color-text-muted);
    --tw-prose-links:   var(--aw-color-primary);
    --tw-prose-bold:    var(--aw-color-text-heading);
    --tw-prose-counters:var(--aw-color-text-muted);
    --tw-prose-bullets: var(--aw-color-text-muted);
    --tw-prose-hr:      var(--aw-color-border);
    --tw-prose-quotes:  var(--aw-color-text-default);
    --tw-prose-quote-borders: var(--aw-color-primary);
    --tw-prose-captions:var(--aw-color-text-muted);
    --tw-prose-code:    var(--aw-color-text-heading);
    --tw-prose-pre-code: var(--aw-color-text-default);
    --tw-prose-pre-bg:  var(--aw-color-bg-subtle);
    --tw-prose-th-borders: var(--aw-color-border);
    --tw-prose-td-borders: var(--aw-color-border);
  }
  .prose blockquote {
    border-left: 3px solid var(--aw-color-primary);
    background-color: rgba(82, 153, 97, 0.06);
    border-radius: 0 8px 8px 0;
    padding: 0.875rem 1.125rem;
    font-style: normal;
    color: var(--aw-color-text-default);
    margin: 1.25rem 0;
  }
  .prose blockquote p { margin-top: 0.2rem; margin-bottom: 0.2rem; }

  .prose thead { background-color: var(--aw-color-primary); }
  .prose thead th { color: #fff !important; font-weight: 600; }
  .prose tbody tr:nth-child(even) { background-color: rgba(82, 153, 97, 0.04); }
  .prose table { border-radius: 8px; overflow: hidden; }
  .prose hr { border-color: var(--aw-color-border); }

  .prose a {
    color: var(--aw-color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: rgba(82, 153, 97, 0.4);
    font-weight: 500;
    transition: text-decoration-color 160ms ease;
  }
  .prose a:hover { text-decoration-color: var(--aw-color-primary); }

  /* ── Default link styling (outside .prose) ─────────────────────── */
  a { color: inherit; }
</style>
