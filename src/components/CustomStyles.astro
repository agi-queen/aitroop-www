---
// Inter Variable — matches aitroop-system font stack exactly
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans:    'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei UI', ui-sans-serif, sans-serif;
    --aw-font-serif:   'Inter Variable', 'Inter', ui-sans-serif, sans-serif;
    --aw-font-heading: 'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, ui-sans-serif, sans-serif;

    /* ── Primary green — matches system --primary oklch(0.595 0.107 148) ── */
    --aw-color-primary:   rgb(82 153 97);       /* #529961  oklch(0.595 0.107 148) */
    --aw-color-secondary: rgb(61 133 79);       /* #3d854f  hover state            */
    --aw-color-accent:    rgb(45 110 63);       /* #2d6e3f  active/deep            */

    /* ── Text — matches system foreground tokens ── */
    --aw-color-text-heading: rgb(10 10 10);     /* oklch(0.100 0 0) near-black      */
    --aw-color-text-default: rgb(18 18 18);     /* oklch(0.100 0 0) body text       */
    --aw-color-text-muted:   rgb(112 112 112);  /* oklch(0.550 0 0) muted-foreground*/

    /* ── Backgrounds & borders — matches system surface tokens ── */
    --aw-color-bg-page:   rgb(255 255 255);     /* pure white                       */
    --aw-color-bg-subtle: rgb(245 245 245);     /* oklch(0.958 0 0) secondary/muted */
    --aw-color-border:    rgb(226 226 226);     /* oklch(0.882 0 0) border/input    */

    --aw-color-bg-page-dark: rgb(12 12 14);

    ::selection {
      background-color: rgb(82 153 97 / 15%);
      color: rgb(10 10 10);
    }
  }

  .dark {
    --aw-font-sans:    'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, ui-sans-serif, sans-serif;
    --aw-font-serif:   'Inter Variable', 'Inter', ui-sans-serif, sans-serif;
    --aw-font-heading: 'Inter Variable', 'Inter', -apple-system, BlinkMacSystemFont, ui-sans-serif, sans-serif;

    --aw-color-primary:   rgb(107 186 117);     /* lighter green on dark            */
    --aw-color-secondary: rgb(82 153 97);
    --aw-color-accent:    rgb(127 186 104);

    --aw-color-text-heading: rgb(245 245 245);
    --aw-color-text-default: rgb(212 212 212);
    --aw-color-text-muted:   rgb(145 145 145);

    --aw-color-bg-page:   rgb(12 12 14);
    --aw-color-bg-subtle: rgb(24 24 26);
    --aw-color-border:    rgb(42 42 44);

    ::selection {
      background-color: rgb(107 186 117 / 22%);
      color: rgb(245 245 245);
    }
  }

  /* ── Base: 14px body — matches aitroop-system exactly ── */
  html {
    font-size: 14px;
  }

  body {
    font-family: var(--aw-font-sans);
    font-size: 1rem;               /* 14px */
    font-weight: 400;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: 'calt', 'cv01', 'ss03';
    letter-spacing: -0.003em;
  }

  /* ── Headings — compact letter-spacing ── */
  h1, h2, h3, h4, h5, h6 {
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* ── Thin scrollbar — matches system exactly ── */
  ::-webkit-scrollbar            { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track      { background: transparent; }
  ::-webkit-scrollbar-thumb      { border-radius: 9999px; background-color: transparent; }
  *:hover::-webkit-scrollbar-thumb { background-color: rgba(0, 0, 0, 0.14); }
  ::-webkit-scrollbar-thumb:hover { background-color: rgba(0, 0, 0, 0.26); }

  /* ── Blog prose ── */
  .prose blockquote {
    border-left: 3px solid rgb(82 153 97);
    background-color: rgb(82 153 97 / 6%);
    border-radius: 0 6px 6px 0;
    padding: 0.75rem 1rem;
    font-style: normal;
    color: var(--aw-color-text-default);
  }
  .prose blockquote p { margin-top: 0.2rem; margin-bottom: 0.2rem; }
  .dark .prose blockquote {
    border-left-color: rgb(107 186 117);
    background-color: rgb(107 186 117 / 8%);
  }

  .prose thead { background-color: rgb(82 153 97); }
  .prose thead th { color: #fff !important; font-weight: 600; }
  .prose tbody tr:nth-child(even) { background-color: rgb(82 153 97 / 5%); }
  .dark .prose tbody tr:nth-child(even) { background-color: rgb(107 186 117 / 7%); }
  .prose table { border-radius: 8px; overflow: hidden; }

  .prose hr { border-color: var(--aw-color-border); }
  .dark .prose hr { border-color: var(--aw-color-border); }

  .prose a { color: rgb(82 153 97); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; text-decoration-color: rgba(82,153,97,0.4); font-weight: 500; }
  .prose a:hover { text-decoration-color: rgb(82 153 97); }
  .dark .prose a { color: rgb(107 186 117); text-decoration-color: rgba(107,186,117,0.4); }
  .dark .prose a:hover { text-decoration-color: rgb(107 186 117); }
</style>
