---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* AITroop brand greens, Peerlist-aligned neutral palette */
    --aw-color-primary: rgb(82 153 97);      /* #529961 brand green */
    --aw-color-secondary: rgb(61 133 79);    /* #3d854f darker green */
    --aw-color-accent: rgb(45 110 63);       /* #2d6e3f forest green */

    --aw-color-text-heading: rgb(10 10 12);  /* neutral near-black */
    --aw-color-text-default: rgb(28 32 36);  /* neutral dark gray */
    --aw-color-text-muted: rgb(28 32 36 / 58%);
    --aw-color-bg-page: rgb(255 255 255);    /* pure white */

    --aw-color-bg-page-dark: rgb(12 14 16);  /* neutral dark */

    ::selection {
      background-color: rgb(82 153 97 / 18%);
      color: rgb(10 10 12);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(107 186 117);    /* #6bba75 light green */
    --aw-color-secondary: rgb(82 153 97);    /* #529961 */
    --aw-color-accent: rgb(127 186 104);     /* #7fba68 */

    --aw-color-text-heading: rgb(245 246 247);
    --aw-color-text-default: rgb(210 215 220);
    --aw-color-text-muted: rgb(210 215 220 / 60%);
    --aw-color-bg-page: rgb(12 14 16);

    ::selection {
      background-color: rgb(107 186 117 / 28%);
      color: rgb(245 246 247);
    }
  }

  /* ── Blog content: blockquote → styled callout box ── */
  .prose blockquote {
    border-left: 4px solid rgb(82 153 97);
    background-color: rgb(82 153 97 / 7%);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.875rem 1.25rem;
    font-style: normal;
  }
  .prose blockquote p {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .dark .prose blockquote {
    border-left-color: rgb(107 186 117);
    background-color: rgb(107 186 117 / 10%);
  }

  /* ── Blog content: tables with green header row ── */
  .prose thead {
    background-color: rgb(45 110 63);
  }
  .prose thead th {
    color: #ffffff !important;
    font-weight: 600;
  }
  .prose tbody tr:nth-child(even) {
    background-color: rgb(82 153 97 / 6%);
  }
  .dark .prose tbody tr:nth-child(even) {
    background-color: rgb(107 186 117 / 8%);
  }
  .prose table {
    border-radius: 0.5rem;
    overflow: hidden;
  }

  /* ── Blog content: hr separator ── */
  .prose hr {
    border-color: rgb(82 153 97 / 20%);
  }
  .dark .prose hr {
    border-color: rgb(107 186 117 / 25%);
  }
</style>
