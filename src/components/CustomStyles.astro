---
// Geist Variable font — loaded from public/fonts/
// Inter Variable kept as fallback during transition
import '@fontsource-variable/inter';
---

<style is:inline>
  /* ── Geist Variable font-face ── */
  @font-face {
    font-family: 'Geist';
    src: url('/fonts/Geist-Variable.woff2') format('woff2');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --aw-font-sans: 'Geist', 'Inter Variable', ui-sans-serif, system-ui, -apple-system, sans-serif;
    --aw-font-serif: 'Geist', 'Inter Variable', ui-sans-serif, system-ui, sans-serif;
    --aw-font-heading: 'Geist', 'Inter Variable', ui-sans-serif, system-ui, -apple-system, sans-serif;

    /* ── Peerlist-aligned green palette ── */
    --aw-color-primary:   rgb(39 174 96);     /* #27ae60  Peerlist brand green  */
    --aw-color-secondary: rgb(22 163 74);     /* #16a34a  slightly darker       */
    --aw-color-accent:    rgb(21 128 61);     /* #15803d  forest green          */

    /* ── Peerlist neutral text ── */
    --aw-color-text-heading: rgb(10 10 11);   /* #0a0a0b  near-black            */
    --aw-color-text-default: rgb(28 28 30);   /* #1c1c1e  primary body text     */
    --aw-color-text-muted:   rgb(115 115 115);/* #737373  neutral-500           */

    /* ── Peerlist backgrounds & borders ── */
    --aw-color-bg-page:    rgb(255 255 255);  /* pure white                     */
    --aw-color-bg-subtle:  rgb(250 250 250);  /* #fafafa  off-white panel bg    */
    --aw-color-border:     rgb(229 229 229);  /* #e5e5e5  neutral-200           */

    /* dark-page kept for compatibility */
    --aw-color-bg-page-dark: rgb(17 17 19);   /* #111113                        */

    ::selection {
      background-color: rgb(39 174 96 / 15%);
      color: rgb(10 10 11);
    }
  }

  .dark {
    --aw-font-sans: 'Geist', 'Inter Variable', ui-sans-serif, system-ui, -apple-system, sans-serif;
    --aw-font-serif: 'Geist', 'Inter Variable', ui-sans-serif, system-ui, sans-serif;
    --aw-font-heading: 'Geist', 'Inter Variable', ui-sans-serif, system-ui, -apple-system, sans-serif;

    --aw-color-primary:   rgb(74 222 128);    /* #4ade80  emerald-400 on dark   */
    --aw-color-secondary: rgb(52 211 153);    /* #34d399                        */
    --aw-color-accent:    rgb(110 231 183);   /* #6ee7b7                        */

    --aw-color-text-heading: rgb(250 250 250);/* #fafafa                        */
    --aw-color-text-default: rgb(212 212 212);/* #d4d4d4  neutral-300           */
    --aw-color-text-muted:   rgb(163 163 163);/* #a3a3a3  neutral-400           */

    --aw-color-bg-page:    rgb(17 17 19);     /* #111113  Peerlist dark bg      */
    --aw-color-bg-subtle:  rgb(24 24 27);     /* #18181b  zinc-900              */
    --aw-color-border:     rgb(39 39 42);     /* #27272a  zinc-800              */

    ::selection {
      background-color: rgb(74 222 128 / 20%);
      color: rgb(250 250 250);
    }
  }

  /* ── Base: apply Peerlist body font-size (15px) ── */
  body {
    font-size: 0.9375rem; /* 15px */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    letter-spacing: -0.005em;
  }

  /* ── Heading letter-spacing (Peerlist tight tracking) ── */
  h1, h2, h3, h4, h5, h6 {
    letter-spacing: -0.03em;
    font-feature-settings: 'ss01' 1; /* Geist stylistic set */
  }

  /* ── Blog: blockquote → Peerlist-style callout ── */
  .prose blockquote {
    border-left: 3px solid rgb(39 174 96);
    background-color: rgb(39 174 96 / 6%);
    border-radius: 0 6px 6px 0;
    padding: 0.875rem 1.25rem;
    font-style: normal;
    color: var(--aw-color-text-default);
  }
  .prose blockquote p {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .dark .prose blockquote {
    border-left-color: rgb(74 222 128);
    background-color: rgb(74 222 128 / 8%);
  }

  /* ── Blog: tables ── */
  .prose thead {
    background-color: rgb(39 174 96);
  }
  .prose thead th {
    color: #ffffff !important;
    font-weight: 600;
  }
  .prose tbody tr:nth-child(even) {
    background-color: rgb(39 174 96 / 5%);
  }
  .dark .prose tbody tr:nth-child(even) {
    background-color: rgb(74 222 128 / 7%);
  }
  .prose table {
    border-radius: 8px;
    overflow: hidden;
  }

  /* ── Blog: hr ── */
  .prose hr {
    border-color: var(--aw-color-border);
  }
  .dark .prose hr {
    border-color: var(--aw-color-border);
  }

  /* ── Link style matching Peerlist ── */
  .prose a {
    color: rgb(39 174 96);
    text-decoration: none;
    font-weight: 500;
  }
  .prose a:hover {
    text-decoration: underline;
  }
  .dark .prose a {
    color: rgb(74 222 128);
  }
</style>
