---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Primary: indigo-blue #3D46FB · Secondary: emerald green #1db954 · Accent: forest green #2b674b */
    --aw-color-primary: rgb(61 70 251);
    --aw-color-secondary: rgb(29 185 84);
    --aw-color-accent: rgb(43 103 75);

    --aw-color-text-heading: rgb(15 23 42);
    --aw-color-text-default: rgb(30 41 59);
    --aw-color-text-muted: rgb(30 41 59 / 64%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: rgb(61 70 251 / 15%);
      color: rgb(15 23 42);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(99 102 241);
    --aw-color-secondary: rgb(52 211 153);
    --aw-color-accent: rgb(34 197 94);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(226 232 240 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: rgb(99 102 241 / 30%);
      color: rgb(248 250 252);
    }
  }

  /* ── Blog content: blockquote → styled callout box ── */
  .prose blockquote {
    border-left: 4px solid rgb(61 70 251);
    background-color: rgb(61 70 251 / 6%);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.875rem 1.25rem;
    font-style: normal;
  }
  .prose blockquote p {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .dark .prose blockquote {
    border-left-color: rgb(99 102 241);
    background-color: rgb(99 102 241 / 12%);
  }

  /* ── Blog content: tables with green header row ── */
  .prose thead {
    background-color: rgb(43 103 75);
  }
  .prose thead th {
    color: #ffffff !important;
    font-weight: 600;
  }
  .prose tbody tr:nth-child(even) {
    background-color: rgb(29 185 84 / 6%);
  }
  .dark .prose tbody tr:nth-child(even) {
    background-color: rgb(52 211 153 / 8%);
  }
  .prose table {
    border-radius: 0.5rem;
    overflow: hidden;
  }

  /* ── Blog content: hr separator ── */
  .prose hr {
    border-color: rgb(61 70 251 / 20%);
  }
  .dark .prose hr {
    border-color: rgb(99 102 241 / 30%);
  }
</style>
