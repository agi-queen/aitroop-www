---
import { Icon } from 'astro-icon/components';

import { UI } from 'astrowind:config';

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
}

const {
  label = 'Toggle between Dark and Light mode',
  class:
    className = 'aw-theme-toggle inline-flex items-center justify-center w-9 h-9 rounded-md text-muted hover:text-heading transition-colors duration-150',
  iconClass = 'w-[18px] h-[18px]',
} = Astro.props;

const themeSetting: string = (UI as { theme?: string })?.theme ?? 'system';
const isLocked = typeof themeSetting === 'string' && themeSetting.endsWith(':only');
---

{
  !isLocked && (
    <button type="button" class={className} aria-label={label} data-aw-toggle-color-scheme>
      <Icon name="tabler:sun" class={`aw-theme-toggle-sun ${iconClass}`} />
      <Icon name="tabler:moon" class={`aw-theme-toggle-moon ${iconClass}`} />
    </button>
  )
}

<style is:global>
  .aw-theme-toggle .aw-theme-toggle-sun,
  .aw-theme-toggle .aw-theme-toggle-moon { display: none; }
  html[data-theme='dark'] .aw-theme-toggle .aw-theme-toggle-sun { display: inline-block; }
  html:not([data-theme='dark']) .aw-theme-toggle .aw-theme-toggle-moon { display: inline-block; }
  .aw-theme-toggle:hover { background-color: var(--aw-color-bg-subtle); }
</style>
