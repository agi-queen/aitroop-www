---
/*
  AmbientMotion — global page chrome motion.

  Provides:
    1. A thin scroll-progress bar pinned under the sticky header.
    2. A scroll-reveal IntersectionObserver that fades any element
       carrying class `ds-reveal` into view (6px rise + opacity).

  Plug once in PageLayout — no per-page wiring needed.
  Honors `prefers-reduced-motion`.
*/
---

<div class="ds-scrollbar" aria-hidden="true">
  <div class="ds-scrollbar-fill" data-scroll-progress></div>
</div>

<style is:global>
  /* ── Scroll-progress bar — under sticky header ─────────────── */
  .ds-scrollbar {
    position: fixed;
    top: 52px;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 39;
    pointer-events: none;
    background: transparent;
  }
  .ds-scrollbar-fill {
    height: 100%;
    width: 0%;
    background: var(--ds-accent);
    transform-origin: left center;
    transition: width 80ms linear;
    box-shadow: 0 0 6px rgba(82, 153, 97, 0.35);
  }

  /* ── Scroll reveal — opt-in via class ──────────────────────── */
  .ds-reveal {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 600ms var(--ds-ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
                transform 600ms var(--ds-ease-out, cubic-bezier(0.22, 1, 0.36, 1));
    will-change: opacity, transform;
  }
  .ds-reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  /* Staggered children — opt in by adding .ds-reveal-stagger to a parent.
     Direct children animate in sequence with 80ms steps. */
  .ds-reveal-stagger > * {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 600ms var(--ds-ease-out, cubic-bezier(0.22, 1, 0.36, 1)),
                transform 600ms var(--ds-ease-out, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .ds-reveal-stagger.is-visible > * { opacity: 1; transform: none; }
  .ds-reveal-stagger.is-visible > *:nth-child(1) { transition-delay: 0ms; }
  .ds-reveal-stagger.is-visible > *:nth-child(2) { transition-delay: 80ms; }
  .ds-reveal-stagger.is-visible > *:nth-child(3) { transition-delay: 160ms; }
  .ds-reveal-stagger.is-visible > *:nth-child(4) { transition-delay: 240ms; }
  .ds-reveal-stagger.is-visible > *:nth-child(5) { transition-delay: 320ms; }
  .ds-reveal-stagger.is-visible > *:nth-child(6) { transition-delay: 400ms; }

  @media (prefers-reduced-motion: reduce) {
    .ds-reveal,
    .ds-reveal-stagger > * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .ds-scrollbar-fill { transition: none; }
  }
</style>

<script>
  function initScrollProgress() {
    const fill = document.querySelector<HTMLElement>('[data-scroll-progress]');
    if (!fill || fill.dataset.scrollInit === '1') return;
    fill.dataset.scrollInit = '1';

    let ticking = false;
    const update = () => {
      const h = document.documentElement;
      const total = Math.max(1, h.scrollHeight - h.clientHeight);
      const pct = Math.min(100, Math.max(0, (window.scrollY / total) * 100));
      fill.style.width = pct + '%';
      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
    update();
  }

  function initReveal() {
    const els = document.querySelectorAll<HTMLElement>('.ds-reveal:not([data-reveal-init]), .ds-reveal-stagger:not([data-reveal-init])');
    if (!els.length) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
    );
    els.forEach((el) => {
      el.dataset.revealInit = '1';
      observer.observe(el);
    });
  }

  // Run on initial load and after Astro view transitions.
  function bootAll() {
    initScrollProgress();
    initReveal();
  }
  bootAll();
  document.addEventListener('astro:page-load', bootAll);
</script>
