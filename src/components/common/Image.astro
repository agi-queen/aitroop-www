---
import type { HTMLAttributes } from 'astro/types';
import { findImage } from '~/utils/images';
import {
  getImagesOptimized,
  astroAssetsOptimizer,
  unpicOptimizer,
  isUnpicCompatible,
  type ImageProps,
} from '~/utils/images-optimization';

type Props = ImageProps;
type ImageType = {
  src: string;
  attributes: HTMLAttributes<'img'>;
};

const props = Astro.props;

if (props.alt === undefined || props.alt === null) {
  throw new Error();
}

if (typeof props.width === 'string') {
  props.width = parseInt(props.width);
}

if (typeof props.height === 'string') {
  props.height = parseInt(props.height);
}

if (!props.loading) {
  props.loading = 'lazy';
}

if (!props.decoding) {
  props.decoding = 'async';
}

const _image = await findImage(props.src);

let image: ImageType | undefined = undefined;

if (
  typeof _image === 'string' &&
  (_image.startsWith('http://') || _image.startsWith('https://')) &&
  isUnpicCompatible(_image)
) {
  image = await getImagesOptimized(_image, props, unpicOptimizer);
} else if (typeof _image === 'string' && _image.startsWith('/') && _image.endsWith('.svg')) {
  // SVG files in public/ don't need optimization — serve directly, preserving all props
  const { src: _src, widths: _widths, aspectRatio, layout: _layout, objectPosition: _op, format: _fmt, sizes: _sizes, ...rest } = props;
  const svgWidth = (props.width as number) || undefined;
  // Compute height from aspectRatio so object-fit: cover works correctly
  let svgHeight = (props.height as number) || undefined;
  if (!svgHeight && svgWidth && aspectRatio) {
    const ratio = typeof aspectRatio === 'number'
      ? aspectRatio
      : (() => { const m = String(aspectRatio).match(/(\d+)[:/](\d+)/); return m ? Number(m[1]) / Number(m[2]) : undefined; })();
    if (ratio) svgHeight = Math.round(svgWidth / ratio);
  }
  image = { src: _image, attributes: { ...rest, width: svgWidth, height: svgHeight, alt: props.alt ?? '' } };
} else if (_image) {
  image = await getImagesOptimized(_image, props, astroAssetsOptimizer);
}
---

{
  !image ? (
    <Fragment />
  ) : (
    <img src={image.src} crossorigin="anonymous" referrerpolicy="no-referrer" {...image.attributes} />
  )
}
