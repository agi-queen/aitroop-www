---
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  prevUrl?: string;
  nextUrl?: string;
  prevText?: string;
  nextText?: string;
}

const { prevUrl, nextUrl, prevText = 'Newer posts', nextText = 'Older posts' } = Astro.props;
---

{
  (prevUrl || nextUrl) && (
    <nav class="mt-12 pt-8 border-t border-[var(--aw-color-border)] flex items-center justify-between gap-3" aria-label="Pagination">
      {prevUrl ? (
        <a href={getPermalink(prevUrl)} class="page-btn">
          <Icon name="tabler:arrow-left" class="w-4 h-4" />
          <span>{prevText}</span>
        </a>
      ) : (
        <span class="page-btn page-btn--disabled" aria-hidden="true">
          <Icon name="tabler:arrow-left" class="w-4 h-4" />
          <span>{prevText}</span>
        </span>
      )}

      {nextUrl ? (
        <a href={getPermalink(nextUrl)} class="page-btn">
          <span>{nextText}</span>
          <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </a>
      ) : (
        <span class="page-btn page-btn--disabled" aria-hidden="true">
          <span>{nextText}</span>
          <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </span>
      )}
    </nav>
  )
}

<style>
  .page-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 2.5rem;
    padding: 0 1rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    color: var(--aw-color-text-default);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1;
    transition: border-color 160ms ease;
  }
  .page-btn:hover {
    border-color: rgba(0, 0, 0, 0.28);
  }
  .page-btn--disabled {
    opacity: 0.35;
    pointer-events: none;
  }
</style>
