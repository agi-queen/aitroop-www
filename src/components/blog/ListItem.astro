---
import { Icon } from 'astro-icon/components';
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

const locale = Astro.currentLocale ?? 'en';
const rawLink = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
const link = rawLink && locale !== 'en' ? `/${locale}${rawLink}` : rawLink;
---

<article class="group border-b border-[var(--aw-color-border)] last:border-0 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
  {post.featured && (
    <div class="pt-4 pb-1">
      <span class="inline-flex items-center gap-1 text-xs font-medium text-primary bg-[rgba(82,153,97,0.08)] border border-[rgba(82,153,97,0.18)] px-2 py-0.5 rounded-full">
        <Icon name="tabler:pin" class="w-3 h-3" />
        Pinned
      </span>
    </div>
  )}
  <a href={link} class="flex items-start justify-between gap-4 py-2.5 hover:bg-[var(--aw-color-bg-subtle)] -mx-2 px-2 rounded-md transition-colors duration-150">
    <div class="flex-1 min-w-0">
      <h2 class="text-sm font-medium text-[var(--aw-color-text-default)] group-hover:text-primary transition-colors duration-150 leading-snug mb-1">
        {post.title}
      </h2>
      {post.category && (
        <span class="text-xs text-[var(--aw-color-text-muted)]">{post.category.title}</span>
      )}
    </div>
    <time
      datetime={String(post.publishDate)}
      class="text-xs text-[var(--aw-color-text-muted)] shrink-0 mt-0.5 tabular-nums"
    >
      {getFormattedDate(post.publishDate)}
    </time>
  </a>
</article>
