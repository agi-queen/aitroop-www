---
import { Icon } from 'astro-icon/components';
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

const locale = Astro.currentLocale ?? 'en';
const rawLink = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
const link = rawLink && locale !== 'en' ? `/${locale}${rawLink}` : rawLink;
const pinLabel = locale === 'zh-CN' ? '置顶' : locale === 'zh-TW' ? '置頂' : 'Pinned';
const readLabel =
  locale === 'zh-CN' ? '分钟阅读' : locale === 'zh-TW' ? '分鐘閱讀' : 'min read';
---

<article class="post-row intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
  <a href={link} class="post-row__link">
    <div class="post-row__main">
      <div class="post-row__meta">
        {post.featured && (
          <span class="post-row__pin">
            <Icon name="tabler:pin" class="w-3 h-3" />
            <span>{pinLabel}</span>
          </span>
        )}
        {post.category && (
          <span class="post-row__category">{post.category.title}</span>
        )}
        <time datetime={String(post.publishDate)} class="post-row__date">
          {getFormattedDate(post.publishDate)}
        </time>
        {post.readingTime && (
          <span class="post-row__reading">{post.readingTime} {readLabel}</span>
        )}
      </div>

      <h2 class="post-row__title">{post.title}</h2>

      {post.excerpt && (
        <p class="post-row__excerpt">{post.excerpt}</p>
      )}
    </div>

    <Icon name="tabler:arrow-up-right" class="post-row__arrow" />
  </a>
</article>

<style>
  .post-row {
    position: relative;
    border-bottom: 1px solid var(--aw-color-border);
  }
  .post-row:last-child {
    border-bottom: 0;
  }
  .post-row__link {
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.625rem 0.25rem;
    transition: background 160ms ease, padding 160ms ease;
  }
  .post-row__link::before {
    content: '';
    position: absolute;
    left: -0.25rem;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 0;
    background: var(--aw-color-primary);
    border-radius: 9999px;
    transition: height 220ms ease;
  }
  .post-row__link:hover::before {
    height: 60%;
  }
  .post-row__link:hover {
    padding-left: 1rem;
  }

  .post-row__main {
    flex: 1;
    min-width: 0;
  }

  .post-row__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    line-height: 1;
    margin-bottom: 0.625rem;
  }
  .post-row__pin {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.1875rem 0.5rem;
    border-radius: 9999px;
    border: 1px solid rgba(82, 153, 97, 0.22);
    background: rgba(82, 153, 97, 0.08);
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .post-row__category {
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .post-row__date,
  .post-row__reading {
    color: var(--aw-color-text-muted);
    letter-spacing: 0.01em;
  }
  .post-row__date::before,
  .post-row__reading::before {
    content: '·';
    margin-right: 0.75rem;
    opacity: 0.5;
  }
  .post-row__meta > :first-child::before {
    content: none;
  }

  .post-row__title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.015em;
    line-height: 1.35;
    margin: 0 0 0.375rem;
    transition: color 200ms ease;
  }
  @media (min-width: 640px) {
    .post-row__title { font-size: 1.125rem; }
  }
  .post-row__link:hover .post-row__title {
    color: var(--aw-color-primary);
  }

  .post-row__excerpt {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-wrap: pretty;
  }

  .post-row__arrow {
    flex-shrink: 0;
    width: 1.125rem;
    height: 1.125rem;
    margin-top: 0.25rem;
    color: var(--aw-color-text-muted);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: opacity 200ms ease, transform 200ms ease, color 200ms ease;
  }
  .post-row__link:hover .post-row__arrow {
    opacity: 1;
    transform: translate(0, 0);
    color: var(--aw-color-primary);
  }
</style>
