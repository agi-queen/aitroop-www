---
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;

const locale = Astro.currentLocale ?? 'en';
const rawLink = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
const link = rawLink && locale !== 'en' ? `/${locale}${rawLink}` : rawLink;
const pinLabel = locale === 'zh-CN' ? '置顶' : locale === 'zh-TW' ? '置頂' : 'Pinned';
const readLabel =
  locale === 'zh-CN' ? '分钟阅读' : locale === 'zh-TW' ? '分鐘閱讀' : 'min read';
---

<article class="post-row">
  <a href={link} class="post-row__link">
    <div class="post-row__meta">
      {post.featured && <span class="post-row__pin">{pinLabel}</span>}
      {post.category && (
        <span class="post-row__category">{post.category.title}</span>
      )}
      <time datetime={String(post.publishDate)} class="post-row__date">
        {getFormattedDate(post.publishDate)}
      </time>
      {post.readingTime && (
        <span class="post-row__reading">{post.readingTime} {readLabel}</span>
      )}
    </div>

    <h2 class="post-row__title">{post.title}</h2>

    {post.excerpt && (
      <p class="post-row__excerpt">{post.excerpt}</p>
    )}
  </a>
</article>

<style>
  .post-row {
    border-bottom: 1px solid var(--aw-color-border);
  }
  .post-row:last-child {
    border-bottom: 0;
  }
  .post-row__link {
    display: block;
    padding: 1.75rem 0;
  }

  .post-row__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    color: var(--aw-color-text-muted);
  }
  .post-row__pin {
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
  }
  .post-row__category {
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
  }
  .post-row__date,
  .post-row__reading {
    letter-spacing: 0.01em;
  }
  .post-row__date::before,
  .post-row__reading::before {
    content: '·';
    margin-right: 0.75rem;
    opacity: 0.45;
  }
  .post-row__meta > :first-child::before {
    content: none;
  }

  .post-row__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.015em;
    line-height: 1.35;
    margin: 0 0 0.4rem;
  }
  @media (min-width: 640px) {
    .post-row__title { font-size: 1.1875rem; }
  }

  .post-row__excerpt {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-wrap: pretty;
    max-width: 64ch;
  }
</style>
