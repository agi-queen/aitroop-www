---
import { Icon } from 'astro-icon/components';
import { getBlogPermalink } from '~/utils/permalinks';
import { I18N } from 'astrowind:config';

const { textDirection } = I18N;

const locale = Astro.currentLocale ?? 'en';
const blogHref = locale !== 'en' ? `/${locale}${getBlogPermalink()}` : getBlogPermalink();
const backLabel = locale === 'zh-TW' ? '返回部落格' : locale === 'zh-CN' ? '返回博客' : 'Back to Blog';
const isRtl = textDirection === 'rtl';
---

<div class="mx-auto px-4 sm:px-6 max-w-3xl pt-2 pb-12 md:pb-16">
  <a href={blogHref} class="back-link">
    {isRtl ? (
      <Icon name="tabler:arrow-right" class="w-4 h-4" />
    ) : (
      <Icon name="tabler:arrow-left" class="w-4 h-4 back-arrow" />
    )}
    <span>{backLabel}</span>
  </a>
</div>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 2.25rem;
    padding: 0 0.875rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    color: var(--aw-color-text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1;
    transition: border-color 160ms ease;
  }
  .back-link:hover {
    border-color: rgba(0, 0, 0, 0.28);
  }
</style>
