---
import PostTags from '~/components/blog/Tags.astro';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';
import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post } = Astro.props;

const locale = Astro.currentLocale ?? 'en';
const readLabel =
  locale === 'zh-CN' ? '分钟阅读' : locale === 'zh-TW' ? '分鐘閱讀' : 'min read';
const tagsLabel =
  locale === 'zh-CN' ? '标签' : locale === 'zh-TW' ? '標籤' : 'TAGS';
const eyebrow = post.category?.title || (locale === 'zh-CN' ? '文章' : locale === 'zh-TW' ? '文章' : 'ARTICLE');
---

<section class="single-post-section">
  <div class="aw-container">
    <article class="single-post">
      <header class="single-post__header">
        <!-- Eyebrow / category -->
        <p class="single-post__eyebrow">
          {post.category ? (
            <a href={getPermalink(post.category.slug, 'category')} class="single-post__eyebrow-link">
              {eyebrow}
            </a>
          ) : (
            <span>{eyebrow}</span>
          )}
        </p>

        <!-- Title -->
        <h1 class="single-post__title">
          {post.title}
        </h1>

        {post.excerpt && (
          <p class="single-post__excerpt">
            {post.excerpt}
          </p>
        )}

        <!-- Meta row -->
        <div class="single-post__meta">
          <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
          {post.readingTime && (
            <>
              <span class="single-post__meta-dot">·</span>
              <span>{post.readingTime} {readLabel}</span>
            </>
          )}
          {post.author && (
            <>
              <span class="single-post__meta-dot">·</span>
              <span class="single-post__author">{post.author}</span>
            </>
          )}
        </div>
      </header>

      <!-- Content (first h1 hidden — title already rendered in header above) -->
      <div class="single-post__content prose prose-sm sm:prose-base max-w-none prose-headings:font-bold prose-headings:tracking-tighter prose-headings:font-heading prose-a:text-primary prose-img:rounded-md prose-headings:scroll-mt-[80px] prose-li:my-0 [&>h1:first-child]:hidden [&_table]:block [&_table]:overflow-x-auto [&_table]:w-full [&_pre]:overflow-x-auto">
        <slot />
      </div>

      {post.tags?.length && (
        <div class="single-post__tags">
          <PostTags tags={post.tags} title={tagsLabel} />
        </div>
      )}
    </article>
  </div>
</section>

<style>
  .single-post-section {
    position: relative;
  }
  .single-post-section::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 320px;
    pointer-events: none;
    z-index: -1;
    background: linear-gradient(
      180deg,
      rgba(82, 153, 97, 0.04) 0%,
      rgba(82, 153, 97, 0.015) 60%,
      transparent 100%
    );
  }

  /* Article fills the page chrome — same width as the rest of the site.
     prose max-width is overridden via the .max-w-none utility on the
     content node itself (see the JSX class list). */
  .single-post__header {
    padding: 4rem 0 2rem;
    max-width: 56rem;
  }
  @media (min-width: 640px) {
    .single-post__header { padding: 5rem 0 2.5rem; }
  }
  .single-post__content {
    margin-top: 1.5rem;
  }
  .single-post__tags {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--aw-color-border);
  }

  .single-post__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--aw-color-primary);
    margin: 0 0 1.25rem;
    line-height: 1;
  }
  .single-post__eyebrow::before {
    content: '';
    width: 18px;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
    display: inline-block;
  }
  .single-post__eyebrow-link {
    color: inherit;
    transition: opacity 160ms ease;
  }
  .single-post__eyebrow-link:hover {
    opacity: 0.75;
  }

  .single-post__title {
    font-size: clamp(1.75rem, 4.2vw, 2.625rem);
    font-weight: 800;
    letter-spacing: -0.032em;
    line-height: 1.1;
    color: var(--aw-color-text-heading);
    margin: 0 0 1rem;
    text-wrap: balance;
  }

  .single-post__excerpt {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 0 0 1.5rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .single-post__excerpt { font-size: 1.125rem; }
  }

  .single-post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--aw-color-border);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    line-height: 1.4;
    letter-spacing: 0.01em;
  }
  .single-post__meta-dot {
    opacity: 0.4;
  }
  .single-post__author {
    color: var(--aw-color-text-default);
  }
</style>
