---
import PostTags from '~/components/blog/Tags.astro';
import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';
import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post } = Astro.props;
---

<section class="mx-auto py-10 sm:py-14">
  <article>
    <header class="max-w-3xl mx-auto px-4 sm:px-6 mb-8">
      <!-- Meta row -->
      <div class="flex items-center gap-2 text-xs text-[var(--aw-color-text-muted)] mb-4">
        <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
        {post.category && (
          <>
            <span class="opacity-40">·</span>
            <a
              href={getPermalink(post.category.slug, 'category')}
              class="hover:text-[var(--aw-color-text-default)] transition-colors duration-150"
            >
              {post.category.title}
            </a>
          </>
        )}
        {post.readingTime && (
          <>
            <span class="opacity-40">·</span>
            <span>{post.readingTime} min read</span>
          </>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tighter leading-tight text-[var(--aw-color-text-heading)] mb-4">
        {post.title}
      </h1>

      {post.excerpt && (
        <p class="text-base text-[var(--aw-color-text-muted)] leading-relaxed">
          {post.excerpt}
        </p>
      )}

      <div class="mt-6 border-t border-[var(--aw-color-border)]" />
    </header>

    <!-- Content (first h1 hidden — title already rendered in header above) -->
    <div class="mx-auto px-4 sm:px-6 max-w-3xl prose prose-sm sm:prose-base prose-headings:font-bold prose-headings:tracking-tighter prose-headings:font-heading prose-a:text-primary prose-img:rounded-md mt-8 prose-headings:scroll-mt-[80px] prose-li:my-0 [&>h1:first-child]:hidden">
      <slot />
    </div>

    {post.tags?.length && (
      <div class="mx-auto px-4 sm:px-6 max-w-3xl mt-10 pt-6 border-t border-[var(--aw-color-border)]">
        <PostTags tags={post.tags} />
      </div>
    )}
  </article>
</section>
