---
/*
  Self-playing 20s loop that demonstrates the product story:
    Chat (explore) → Save → Apps (gallery) → App (form + run) → Artifact

  Pure CSS — no JS. Plays for everyone (including reduced-motion users) by
  design choice so every viewer sees the full narrative.

  Three cross-fading panes, one shared timeline. All timings are percentages
  of the 20s loop so adjusting the loop length only requires updating one
  number per animation rule.
*/
import { Icon } from 'astro-icon/components';
import LogoAssemble from './LogoAssemble.astro';

export interface Props {
  // Mode labels (top-left chrome)
  modeChatLabel?: string;
  modeAppsLabel?: string;
  modeAppLabel?: string;
  liveLabel?: string;
  // Chat pane
  youLabel?: string;
  agentLabel?: string;
  promptParts?: [string, string, string];
  promptCode?: string;
  skillTagLabel?: string;
  connectTagLabel?: string;
  toolSkillName?: string;
  toolSkillStatusLoading?: string;
  toolSkillStatusDone?: string;
  toolConnectName?: string;
  toolConnectStatus?: string;
  agentReplyText?: string;
  saveAsAppLabel?: string;
  savedToastLabel?: string;
  // Apps grid pane
  appsHeaderLabel?: string;
  appsCount?: string;
  newBadgeLabel?: string;
  justNowLabel?: string;
  // App pane
  appTitle?: string;
  appVersion?: string;
  skillsLabel?: string;
  connectsLabel?: string;
  skills?: [string, string];
  connects?: [string, string];
  dateRangeLabel?: string;
  repoLabel?: string;
  langLabel?: string;
  langValue?: string;
  runLabel?: string;
  runningLabel?: string;
  artifactLabel?: string;
  artifactRows?: string[];
  exportLabel?: string;
}

const {
  modeChatLabel = 'Mode 1 · Chat',
  modeAppsLabel = 'Mode 2 · Apps',
  modeAppLabel = 'Mode 3 · App',
  liveLabel = 'live · auto-loop',
  youLabel = 'You',
  agentLabel = 'Agent',
  promptParts = [
    'Pull commits from 2025-05-01 to 05-07 in',
    'summarize as a daily report in English.',
    'Group by repo, include PR titles. Skip merges.',
  ],
  promptCode = 'shop-frontend',
  skillTagLabel = 'skill',
  connectTagLabel = 'connect',
  toolSkillName = 'github-mcp',
  toolSkillStatusLoading = '→ pulling commits…',
  toolSkillStatusDone = '✓ 142 commits',
  toolConnectName = 'github',
  toolConnectStatus = '✓ authorized',
  agentReplyText = 'Done — drafted daily-report.md from 12 PRs across 4 repos.',
  saveAsAppLabel = 'Save as App',
  savedToastLabel = 'Saved to your Apps',
  appsHeaderLabel = 'Your Apps',
  appsCount = '6',
  newBadgeLabel = 'NEW',
  justNowLabel = 'just now',
  appTitle = 'Daily Report',
  appVersion = 'v1 · public',
  skillsLabel = 'SKILLS',
  connectsLabel = 'CONNECTS',
  skills = ['github-mcp', 'web-scrape'],
  connects = ['github', 'google-drive'],
  dateRangeLabel = 'Date range',
  repoLabel = 'Repository',
  langLabel = 'Output language',
  langValue = 'English',
  runLabel = 'Run',
  runningLabel = 'Running…',
  artifactLabel = 'daily-report.md',
  artifactRows = [
    '## Mon · 12 PRs across 4 repos',
    '- feat(api): pagination on /v2/orders',
    '- fix(ui): cart total off by rounding',
    '- chore(deps): bump astro 5.2 → 5.4',
    '- perf(cart): memoize line totals',
  ],
  exportLabel = 'Export to Drive',
} = Astro.props;

// Illustrative app catalog for the grid pane — names stay English across
// locales since they read as product identifiers.
const otherApps = [
  { icon: 'tabler:chart-bar', name: 'Sales Weekly',  meta: 'v2 · 2d' },
  { icon: 'tabler:user-plus', name: 'Lead Enrich',   meta: 'v5 · 1h' },
  { icon: 'tabler:mail',      name: 'Email Drip',    meta: 'v3 · 4d' },
  { icon: 'tabler:messages',  name: 'Stand-up Bot',  meta: 'v7 · 3h' },
  { icon: 'tabler:receipt',   name: 'Invoice Match', meta: 'v1 · 1w' },
];

const appVersionShort = appVersion.split(' · ')[0];
---

<div class="demo" aria-label="Live product demo: chat to saved app">
  <!-- Head bar — mode label cross-fades through three modes -->
  <div class="demo-head">
    <div class="demo-head-left">
      <LogoAssemble size={24} class="demo-mark" label="Aitroop" />
      <div class="dots" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <div class="mode-label">
        <span class="ml ml-chat">{modeChatLabel}</span>
        <span class="ml ml-apps">{modeAppsLabel}</span>
        <span class="ml ml-app">{modeAppLabel}</span>
      </div>
    </div>
    <span class="live">
      <span class="live-dot"></span>
      {liveLabel}
    </span>
  </div>

  <div class="demo-body">

    <!-- ── CHAT PANE ───────────────────────────────────────────── -->
    <div class="pane pane-chat" aria-hidden="true">
      <div class="row row-you">
        <span class="who">{youLabel}</span>
      </div>
      <p class="prompt">
        <span class="seg seg-1">{promptParts[0]} <code>{promptCode}</code>,<span class="caret c-1" aria-hidden="true"></span></span>
        <span class="seg seg-2"> {promptParts[1]}<span class="caret c-2" aria-hidden="true"></span></span>
        <span class="seg seg-3"> {promptParts[2]}<span class="caret c-3" aria-hidden="true"></span></span>
      </p>

      <div class="row row-agent">
        <span class="who">{agentLabel}</span>
      </div>
      <div class="thinking" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>

      <!-- Agent's tool calls — skill in-flight, then completes; connect already authorized -->
      <div class="tools">
        <div class="tool tool-1">
          <span class="tool-kind tk-skill">
            <Icon name="tabler:puzzle" class="w-3 h-3" />
            {skillTagLabel}
          </span>
          <code>{toolSkillName}</code>
          <span class="tool-msg">
            <span class="msg msg-loading">{toolSkillStatusLoading}</span>
            <span class="msg msg-done">{toolSkillStatusDone}</span>
          </span>
        </div>
        <div class="tool tool-2">
          <span class="tool-kind tk-connect">
            <Icon name="tabler:plug-connected" class="w-3 h-3" />
            {connectTagLabel}
          </span>
          <code>{toolConnectName}</code>
          <span class="tool-msg">{toolConnectStatus}</span>
        </div>
      </div>

      <p class="agent-reply">{agentReplyText}</p>

      <div class="save-cta">
        <button type="button" class="save-btn" tabindex="-1">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
          {saveAsAppLabel}
        </button>
        <span class="save-ripple" aria-hidden="true"></span>
        <span class="saved-toast">
          <Icon name="tabler:check" class="w-3 h-3" />
          {savedToastLabel}
        </span>
      </div>
    </div>

    <!-- ── APPS GRID PANE ──────────────────────────────────────── -->
    <div class="pane pane-grid" aria-hidden="true">
      <div class="grid-head">
        <span class="grid-title">{appsHeaderLabel}</span>
        <span class="grid-count">· {appsCount}</span>
      </div>
      <div class="apps">
        <!-- The just-saved app — first card, primary border, NEW badge, pulse -->
        <article class="card card-new">
          <span class="card-hover" aria-hidden="true"></span>
          <div class="card-row">
            <div class="card-icon card-icon-primary">
              <Icon name="tabler:report" class="w-4 h-4" />
            </div>
            <span class="new-badge">{newBadgeLabel}</span>
          </div>
          <h4 class="card-name">{appTitle}</h4>
          <p class="card-meta">{appVersionShort} · <span class="meta-fresh">{justNowLabel}</span></p>
        </article>

        {otherApps.map((a, i) => (
          <article class={`card card-existing card-${i + 2}`}>
            <div class="card-row">
              <div class="card-icon">
                <Icon name={a.icon} class="w-4 h-4" />
              </div>
            </div>
            <h4 class="card-name">{a.name}</h4>
            <p class="card-meta">{a.meta}</p>
          </article>
        ))}
      </div>
    </div>

    <!-- ── APP PANE ────────────────────────────────────────────── -->
    <div class="pane pane-app" aria-hidden="true">
      <div class="app-head">
        <div class="app-icon">
          <Icon name="tabler:report" class="w-3.5 h-3.5" />
        </div>
        <span class="app-title">{appTitle}</span>
        <span class="app-version">{appVersion}</span>
      </div>

      <div class="wired">
        <span class="wired-label">{skillsLabel}</span>
        <span class="wchip wchip-skill wchip-1">
          <Icon name="tabler:puzzle" class="w-2.5 h-2.5" />
          {skills[0]}
        </span>
        <span class="wchip wchip-skill wchip-2">
          <Icon name="tabler:puzzle" class="w-2.5 h-2.5" />
          {skills[1]}
        </span>
        <span class="wired-sep">·</span>
        <span class="wired-label">{connectsLabel}</span>
        <span class="wchip wchip-connect wchip-3">
          <Icon name="tabler:plug-connected" class="w-2.5 h-2.5" />
          {connects[0]}
        </span>
        <span class="wchip wchip-connect wchip-4">
          <Icon name="tabler:plug-connected" class="w-2.5 h-2.5" />
          {connects[1]}
        </span>
      </div>

      <div class="field field-1">
        <label>{dateRangeLabel}</label>
        <div class="row-2">
          <div class="input mono">2025-05-01</div>
          <span class="arrow">→</span>
          <div class="input mono">2025-05-07</div>
        </div>
      </div>

      <div class="field field-2">
        <label>{repoLabel}</label>
        <div class="input between">
          <span class="mono">{promptCode}</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>

      <div class="field field-3">
        <label>{langLabel}</label>
        <div class="input between">
          <span>{langValue}</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>

      <button type="button" class="run-btn" tabindex="-1">
        <span class="run-text run-text-default">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          {runLabel}
        </span>
        <span class="run-text run-text-running">
          <span class="spinner" aria-hidden="true"></span>
          {runningLabel}
        </span>
      </button>

      <div class="artifact">
        <div class="artifact-head">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span class="mono">{artifactLabel}</span>
          <span class="export-hint">
            <Icon name="tabler:cloud-upload" class="w-2.5 h-2.5" />
            {exportLabel}
          </span>
        </div>
        {artifactRows.map((r, i) => (
          <div class={`a-row a-row-${i + 1}`}>{r}</div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  /* ============================================================
     Container chrome
     ============================================================ */
  .demo {
    position: relative;
    width: 100%;
    border: 1px solid var(--aw-color-border);
    border-radius: 14px;
    background: var(--aw-color-bg-page);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.65) inset,
      0 20px 56px -22px rgba(82, 153, 97, 0.22),
      0 8px 22px -10px rgba(0, 0, 0, 0.07),
      0 2px 6px -2px rgba(0, 0, 0, 0.04);
    overflow: hidden;
  }

  .demo-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--aw-color-border);
    background: linear-gradient(to bottom, rgba(82, 153, 97, 0.025), transparent);
  }
  .demo-head-left { display: flex; align-items: center; gap: 10px; }
  .demo-mark {
    flex-shrink: 0;
    filter: drop-shadow(0 2px 6px rgba(82, 153, 97, 0.22));
  }
  .dots {
    display: flex;
    gap: 4px;
    padding-left: 10px;
    margin-left: 2px;
    border-left: 1px solid var(--aw-color-border);
  }
  .dots span {
    width: 7px; height: 7px; border-radius: 9999px;
    background: rgba(0, 0, 0, 0.08);
  }

  .mode-label {
    position: relative;
    height: 14px;
    min-width: 140px;
    overflow: hidden;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
  }
  .ml {
    position: absolute;
    inset: 0;
    white-space: nowrap;
  }
  .ml-chat { opacity: 1; }
  .ml-apps { opacity: 0; color: var(--aw-color-primary); }
  .ml-app  { opacity: 0; color: var(--aw-color-primary); }

  .live {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
  }
  .live-dot {
    width: 6px; height: 6px; border-radius: 9999px;
    background: var(--aw-color-primary);
    box-shadow: 0 0 0 0 rgba(82, 153, 97, 0.45);
  }

  /* ============================================================
     Body — three panes overlap, cross-fade
     ============================================================ */
  .demo-body {
    position: relative;
    height: 520px;
    padding: 20px 22px;
  }
  @media (max-width: 640px) {
    .demo-body { height: 560px; padding: 18px 18px; }
  }
  .pane {
    position: absolute;
    inset: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transform-origin: 50% 40%;
  }
  @media (max-width: 640px) {
    .pane { inset: 18px 18px; }
  }

  /* ============================================================
     CHAT pane
     ============================================================ */
  .pane-chat .row {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
  }
  .pane-chat .row-agent { margin-top: 4px; }

  .prompt {
    position: relative;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--aw-color-text-default);
    margin: 0;
  }
  .prompt code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    background: rgba(82, 153, 97, 0.08);
    color: var(--aw-color-primary);
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .seg { opacity: 0; display: inline; }
  .caret {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: var(--aw-color-primary);
    margin-left: 2px;
    vertical-align: text-bottom;
    border-radius: 1px;
    opacity: 0;
  }

  .thinking {
    display: flex; gap: 5px; align-items: center;
    height: 14px;
  }
  .thinking span {
    width: 6px; height: 6px; border-radius: 9999px;
    background: rgba(82, 153, 97, 0.55);
    opacity: 0;
  }

  /* Tools — skill flips status mid-flight, connect already authorized */
  .tools {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 2px;
  }
  .tool {
    opacity: 0;
    transform: translateX(-4px);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tool-kind {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 7px;
    border-radius: 9999px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    color: var(--aw-color-primary);
    background: rgba(82, 153, 97, 0.10);
    border: 1px solid rgba(82, 153, 97, 0.20);
  }
  .tk-connect {
    background: rgba(82, 153, 97, 0.05);
    border-color: rgba(82, 153, 97, 0.14);
    color: rgb(61, 133, 79);
  }
  .tool code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    color: var(--aw-color-text-default);
  }
  /* Two-state status — both occupy the same grid cell, swap via opacity */
  .tool-1 .tool-msg {
    display: inline-grid;
    grid-template-areas: 'm';
    font-size: 0.6875rem;
  }
  .tool-1 .msg {
    grid-area: m;
    white-space: nowrap;
    color: var(--aw-color-text-muted);
  }
  .tool-1 .msg-done {
    color: var(--aw-color-primary);
    font-weight: 500;
    opacity: 0;
  }
  .tool-2 .tool-msg {
    font-size: 0.6875rem;
    color: var(--aw-color-primary);
    font-weight: 500;
  }

  .agent-reply {
    opacity: 0;
    margin: 4px 0 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
    padding: 8px 10px 9px;
    background: rgba(82, 153, 97, 0.06);
    border-radius: 6px;
    border-left: 2px solid var(--aw-color-primary);
  }

  .save-cta {
    margin-top: auto;
    position: relative;
    padding-top: 14px;
    border-top: 1px dashed var(--aw-color-border);
    min-height: 50px;
  }
  .save-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 12px;
    border-radius: 8px;
    background: rgba(82, 153, 97, 0.10);
    color: var(--aw-color-primary);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid rgba(82, 153, 97, 0.18);
    pointer-events: none;
  }
  .save-ripple {
    position: absolute;
    left: 0;
    top: 14px;
    width: 132px;
    height: 30px;
    border-radius: 8px;
    border: 1.5px solid var(--aw-color-primary);
    opacity: 0;
    pointer-events: none;
  }
  .saved-toast {
    position: absolute;
    left: 142px;
    top: 14px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 0 10px;
    border-radius: 6px;
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    border: 1px solid rgba(82, 153, 97, 0.22);
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-6px);
    pointer-events: none;
  }

  /* ============================================================
     APPS GRID pane
     ============================================================ */
  .pane-grid { opacity: 0; }
  .grid-head {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding-bottom: 10px;
    margin-bottom: 6px;
    border-bottom: 1px solid var(--aw-color-border);
  }
  .grid-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.005em;
  }
  .grid-count {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    color: var(--aw-color-text-muted);
  }

  .apps {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    flex: 1;
    align-content: start;
  }

  .card {
    position: relative;
    padding: 12px 14px 11px;
    border: 1px solid var(--aw-color-border);
    border-radius: 8px;
    background: var(--aw-color-bg-page);
    display: flex;
    flex-direction: column;
    gap: 8px;
    opacity: 0;
    transform: translateY(6px);
  }
  .card-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .card-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--aw-color-bg-subtle);
    color: var(--aw-color-text-muted);
    display: flex; align-items: center; justify-content: center;
  }
  .card-icon-primary {
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
  }
  .card-name {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.005em;
    line-height: 1.25;
  }
  .card-meta {
    margin: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    color: var(--aw-color-text-muted);
  }
  .meta-fresh {
    color: var(--aw-color-primary);
    font-weight: 500;
  }

  /* The new card — slightly stronger border baseline, halo on pulse */
  .card-new {
    border-color: rgba(82, 153, 97, 0.35);
    z-index: 1;
  }
  .new-badge {
    padding: 2px 6px;
    border-radius: 9999px;
    background: var(--aw-color-primary);
    color: #fff;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.4;
    opacity: 0;
    transform: scale(0.7);
  }
  .card-hover {
    position: absolute;
    inset: -2px;
    border-radius: 10px;
    border: 1.5px solid var(--aw-color-primary);
    opacity: 0;
    pointer-events: none;
  }

  /* ============================================================
     APP pane
     ============================================================ */
  .pane-app { opacity: 0; }
  .app-head {
    display: flex; align-items: center; gap: 8px;
    padding-bottom: 12px;
    margin-bottom: 4px;
    border-bottom: 1px solid var(--aw-color-border);
    opacity: 0;
    transform: translateY(-4px);
  }
  .app-icon {
