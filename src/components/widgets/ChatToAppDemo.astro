---
/*
  Self-playing 20s loop that demonstrates the product story:
    Chat (compose → send → tools → reply → distill) → Apps (gallery) → App (form → run → artifact)

  Pure CSS, no JS. The loop always plays — system-level reduced-motion
  preferences are intentionally not honored so the narrative is consistent
  across visitors regardless of OS animation settings.

  Three cross-fading panes share one 20s timeline. All timings are percentages
  of the 20s loop so adjusting loop length only requires editing one number
  per rule.

  Chat pane mirrors the real product surface — rounded composer pill at the
  bottom with a Distill-to-App / model / send toolbar, user prompts render
  as right-aligned bubbles, tool calls render as inline cards with spinner →
  check status, agent reply renders as a left-aligned bubble.
*/
import { Icon } from 'astro-icon/components';
import LogoAssemble from './LogoAssemble.astro';

export interface Props {
  // Mode labels (top-left chrome)
  modeChatLabel?: string;
  modeAppsLabel?: string;
  modeAppLabel?: string;
  // Sidebar
  newChatLabel?: string;
  navAppsLabel?: string;
  navArtifactsLabel?: string;
  toolsLabel?: string;
  navConnectLabel?: string;
  navSkillsLabel?: string;
  navSchedulesLabel?: string;
  navSettingsLabel?: string;
  // Chat pane
  composerPlaceholder?: string;
  modelLabel?: string;
  promptParts?: [string, string, string];
  promptCode?: string;
  skillTagLabel?: string;
  connectTagLabel?: string;
  toolSkillName?: string;
  toolSkillStatusLoading?: string;
  toolSkillStatusDone?: string;
  toolConnectName?: string;
  toolConnectStatus?: string;
  agentReplyText?: string;
  saveAsAppLabel?: string;
  savedToastLabel?: string;
  // Apps grid pane
  appsHeaderLabel?: string;
  appsCount?: string;
  newBadgeLabel?: string;
  justNowLabel?: string;
  // App pane
  appTitle?: string;
  appVersion?: string;
  skillsLabel?: string;
  connectsLabel?: string;
  skills?: [string, string];
  connects?: [string, string];
  dateRangeLabel?: string;
  repoLabel?: string;
  langLabel?: string;
  langValue?: string;
  runLabel?: string;
  runningLabel?: string;
  artifactLabel?: string;
  artifactRows?: string[];
  exportLabel?: string;
}

const {
  modeChatLabel = '01 · Chat',
  modeAppsLabel = '02 · Apps',
  modeAppLabel = '03 · App',
  newChatLabel = 'New Chat',
  navAppsLabel = 'Apps',
  navArtifactsLabel = 'Artifacts',
  toolsLabel = 'Tools',
  navConnectLabel = 'Connect',
  navSkillsLabel = 'Skills',
  navSchedulesLabel = 'Schedules',
  navSettingsLabel = 'Settings',
  composerPlaceholder = 'Ask AITroop anything…',
  modelLabel = 'claude',
  promptParts = [
    'Pull commits from 2025-05-01 to 05-07 in',
    'summarize as a daily report in English.',
    'Group by repo, include PR titles. Skip merges.',
  ],
  promptCode = 'shop-frontend',
  skillTagLabel = 'skill',
  connectTagLabel = 'connect',
  toolSkillName = 'github-mcp',
  toolSkillStatusLoading = 'pulling commits…',
  toolSkillStatusDone = '142 commits fetched',
  toolConnectName = 'github',
  toolConnectStatus = 'authorized',
  agentReplyText = 'Done. Drafted daily-report.md from 12 PRs across 4 repos.',
  saveAsAppLabel = 'Distill to App',
  savedToastLabel = 'Saved to your Apps',
  appsHeaderLabel = 'Your Apps',
  appsCount = '6',
  newBadgeLabel = 'NEW',
  justNowLabel = 'just now',
  appTitle = 'Daily Report',
  appVersion = 'v1 · public',
  skillsLabel = 'SKILLS',
  connectsLabel = 'CONNECTS',
  skills = ['github-mcp', 'web-scrape'],
  connects = ['github', 'google-drive'],
  dateRangeLabel = 'Date range',
  repoLabel = 'Repository',
  langLabel = 'Output language',
  langValue = 'English',
  runLabel = 'Run',
  runningLabel = 'Running…',
  artifactLabel = 'daily-report.md',
  artifactRows = [
    '## Mon · 12 PRs across 4 repos',
    '- feat(api): pagination on /v2/orders',
    '- fix(ui): cart total off by rounding',
    '- chore(deps): bump astro 5.2 → 5.4',
    '- perf(cart): memoize line totals',
  ],
  exportLabel = 'Export to Drive',
} = Astro.props;

const otherApps = [
  { icon: 'tabler:chart-bar', name: 'Sales Weekly', meta: 'v2 · 2d' },
  { icon: 'tabler:user-plus', name: 'Lead Enrich',  meta: 'v5 · 1h' },
  { icon: 'tabler:mail',      name: 'Email Drip',   meta: 'v3 · 4d' },
];

const appVersionShort = appVersion.split(' · ')[0];
---

<figure class="demo-figure">
  <div class="demo" aria-label="Live product demo: chat to saved app">
  <!-- Top chrome — logo, cross-fading stage label, loop indicator -->
  <div class="demo-head">
    <div class="demo-head-left">
      <LogoAssemble size={22} class="demo-mark" label="Aitroop" />
      <span class="head-rule" aria-hidden="true"></span>
      <div class="mode-label">
        <span class="ml ml-chat">{modeChatLabel}</span>
        <span class="ml ml-apps">{modeAppsLabel}</span>
        <span class="ml ml-app">{modeAppLabel}</span>
      </div>
    </div>
    <div class="demo-head-right" aria-hidden="true">
      <span class="loop-dot"></span>
      <span class="loop-text">LOOP</span>
    </div>
  </div>

  <div class="demo-body">

    <!-- ══════════════════════════════════════════════════════════
         LEFT SIDEBAR — mirrors the real product's TreeSidebar
         ══════════════════════════════════════════════════════════ -->
    <aside class="sidebar" aria-hidden="true">
      <div class="sb-workspace">
        <div class="sb-ws-avatar">P</div>
        <span class="sb-ws-name">Personal</span>
        <Icon name="tabler:chevron-down" class="sb-ws-chev" />
      </div>

      <button type="button" class="sb-new-chat" tabindex="-1">
        <Icon name="tabler:edit" class="w-3 h-3" />
        <span class="sb-label">{newChatLabel}</span>
      </button>

      <nav class="sb-nav">
        <a class="sb-item sb-item-apps" tabindex="-1">
          <span class="sb-accent" aria-hidden="true"></span>
          <Icon name="tabler:layout-grid" class="w-3.5 h-3.5" />
          <span class="sb-label">{navAppsLabel}</span>
        </a>
      </nav>

      <div class="sb-section">
        <div class="sb-section-label">{toolsLabel}</div>
        <nav class="sb-nav">
          <a class="sb-item" tabindex="-1">
            <Icon name="tabler:wand" class="w-3.5 h-3.5" />
            <span class="sb-label">{navSkillsLabel}</span>
          </a>
          <a class="sb-item" tabindex="-1">
            <Icon name="tabler:plug" class="w-3.5 h-3.5" />
            <span class="sb-label">{navConnectLabel}</span>
          </a>
          <a class="sb-item" tabindex="-1">
            <Icon name="tabler:clock" class="w-3.5 h-3.5" />
            <span class="sb-label">{navSchedulesLabel}</span>
          </a>
        </nav>
      </div>

      <div class="sb-spacer"></div>

      <div class="sb-user">
        <div class="sb-user-avatar">Y</div>
        <span class="sb-label sb-user-name">you@team</span>
      </div>
    </aside>

    <!-- ══════════════════════════════════════════════════════════
         MAIN — the three cross-fading panes
         ══════════════════════════════════════════════════════════ -->
    <div class="demo-main">

    <!-- ══════════════════════════════════════════════════════════
         CHAT PANE — message stream on top, composer pill on bottom
         ══════════════════════════════════════════════════════════ -->
    <div class="pane pane-chat" aria-hidden="true">

      <div class="chat-stream">
        <!-- User's sent prompt — right-aligned bubble (appears after send) -->
        <div class="bubble-row bubble-row-user">
          <div class="bubble bubble-user">
            {promptParts[0]} <code class="bubble-code">{promptCode}</code>, {promptParts[1]} {promptParts[2]}
          </div>
        </div>

        <!-- Agent activity row — thinking dots that fade once tools land -->
        <div class="thinking-row">
          <div class="thinking" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
        </div>

        <!-- Tool call card 1 — spinner that flips to a check + status text crossfade -->
        <div class="tool-card tool-1">
          <span class="tc-icon">
            <span class="tc-spin" aria-hidden="true"></span>
            <Icon name="tabler:check" class="tc-check" />
          </span>
          <div class="tc-body">
            <div class="tc-head">
              <span class="tc-kind tc-kind-skill">{skillTagLabel}</span>
              <code class="tc-tool">{toolSkillName}</code>
            </div>
            <div class="tc-msg">
              <span class="tc-status tc-status-loading">{toolSkillStatusLoading}</span>
              <span class="tc-status tc-status-done">{toolSkillStatusDone}</span>
            </div>
          </div>
        </div>

        <!-- Tool call card 2 — already authorized, lands with a check -->
        <div class="tool-card tool-2">
          <span class="tc-icon tc-icon-done">
            <Icon name="tabler:check" />
          </span>
          <div class="tc-body">
            <div class="tc-head">
              <span class="tc-kind tc-kind-connect">{connectTagLabel}</span>
              <code class="tc-tool">{toolConnectName}</code>
            </div>
            <div class="tc-msg">{toolConnectStatus}</div>
          </div>
        </div>

        <!-- Final assistant reply — left-aligned bubble -->
        <div class="bubble-row bubble-row-agent">
          <div class="bubble bubble-agent">{agentReplyText}</div>
        </div>
      </div>

      <!-- Composer pill — matches real product (rounded-3xl, toolbar w/ Distill + model + send) -->
      <div class="composer">
        <div class="composer-content">
          <span class="composer-placeholder">{composerPlaceholder}</span>
          <p class="composer-prompt">
            <span class="seg seg-1">{promptParts[0]} <code>{promptCode}</code>,<span class="caret c-1" aria-hidden="true"></span></span>
            <span class="seg seg-2"> {promptParts[1]}<span class="caret c-2" aria-hidden="true"></span></span>
            <span class="seg seg-3"> {promptParts[2]}<span class="caret c-3" aria-hidden="true"></span></span>
          </p>
        </div>
        <div class="composer-toolbar">
          <div class="tb-left">
            <button type="button" class="tb-btn distill-btn" tabindex="-1">
              <Icon name="tabler:sparkles" class="w-3 h-3 distill-icon" />
              <span class="distill-label">{saveAsAppLabel}</span>
            </button>
            <button type="button" class="tb-btn model-btn" tabindex="-1">
              <Icon name="tabler:robot" class="w-3 h-3" />
              <span class="model-text">{modelLabel}</span>
            </button>
          </div>
          <button type="button" class="send-btn" tabindex="-1">
            <Icon name="tabler:arrow-up" class="w-3.5 h-3.5 send-arrow" />
            <span class="send-glow" aria-hidden="true"></span>
          </button>
        </div>
        <span class="distill-ripple" aria-hidden="true"></span>
        <span class="saved-toast">
          <Icon name="tabler:check" class="w-3 h-3" />
          {savedToastLabel}
        </span>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════
         APPS GRID PANE
         ══════════════════════════════════════════════════════════ -->
    <div class="pane pane-grid" aria-hidden="true">
      <div class="grid-head">
        <span class="grid-title">{appsHeaderLabel}</span>
        <span class="grid-count">· {appsCount}</span>
      </div>
      <div class="apps">
        <article class="card card-new">
          <span class="card-hover" aria-hidden="true"></span>
          <div class="card-row">
            <div class="card-icon card-icon-primary">
              <Icon name="tabler:report" class="w-4 h-4" />
            </div>
            <span class="new-badge">{newBadgeLabel}</span>
          </div>
          <h4 class="card-name">{appTitle}</h4>
          <p class="card-meta">{appVersionShort} · <span class="meta-fresh">{justNowLabel}</span></p>
        </article>

        {otherApps.map((a, i) => (
          <article class={`card card-existing card-${i + 2}`}>
            <div class="card-row">
              <div class="card-icon">
                <Icon name={a.icon} class="w-4 h-4" />
              </div>
            </div>
            <h4 class="card-name">{a.name}</h4>
            <p class="card-meta">{a.meta}</p>
          </article>
        ))}
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════
         APP PANE — saved app's form + run + artifact
         ══════════════════════════════════════════════════════════ -->
    <div class="pane pane-app" aria-hidden="true">
      <div class="app-head">
        <div class="app-icon">
          <Icon name="tabler:report" class="w-3.5 h-3.5" />
        </div>
        <span class="app-title">{appTitle}</span>
        <span class="app-version">{appVersion}</span>
      </div>

      <div class="wired">
        <span class="wired-label">{skillsLabel}</span>
        <span class="wchip wchip-skill wchip-1">
          <Icon name="tabler:puzzle" class="w-2.5 h-2.5" />
          {skills[0]}
        </span>
        <span class="wchip wchip-skill wchip-2">
          <Icon name="tabler:puzzle" class="w-2.5 h-2.5" />
          {skills[1]}
        </span>
        <span class="wired-sep">·</span>
        <span class="wired-label">{connectsLabel}</span>
        <span class="wchip wchip-connect wchip-3">
          <Icon name="tabler:plug-connected" class="w-2.5 h-2.5" />
          {connects[0]}
        </span>
        <span class="wchip wchip-connect wchip-4">
          <Icon name="tabler:plug-connected" class="w-2.5 h-2.5" />
          {connects[1]}
        </span>
      </div>

      <div class="field field-1">
        <label>{dateRangeLabel}</label>
        <div class="row-2">
          <div class="input mono">2025-05-01</div>
          <span class="arrow">→</span>
          <div class="input mono">2025-05-07</div>
        </div>
      </div>

      <div class="field field-2">
        <label>{repoLabel}</label>
        <div class="input between">
          <span class="mono">{promptCode}</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>

      <div class="field field-3">
        <label>{langLabel}</label>
        <div class="input between">
          <span>{langValue}</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>

      <button type="button" class="run-btn" tabindex="-1">
        <span class="run-text run-text-default">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          {runLabel}
        </span>
        <span class="run-text run-text-running">
          <span class="spinner" aria-hidden="true"></span>
          {runningLabel}
        </span>
      </button>

      <div class="artifact">
        <div class="artifact-head">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span class="mono">{artifactLabel}</span>
          <span class="export-hint">
            <Icon name="tabler:cloud-upload" class="w-2.5 h-2.5" />
            {exportLabel}
          </span>
        </div>
        {artifactRows.map((r, i) => (
          <div class={`a-row a-row-${i + 1}`}>{r}</div>
        ))}
      </div>
    </div>

    </div><!-- /.demo-main -->
  </div>
  </div><!-- /.demo -->

  <figcaption class="demo-caption">
    Chat → distill → reuse. Cross-faded across three stages.
  </figcaption>
</figure>

<style>
  /* ============================================================
     Editorial figure frame — wraps the live demo like a print figure
     ============================================================ */
  .demo-figure {
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .demo-caption {
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 0.6875rem;
    line-height: 1.6;
    letter-spacing: 0.06em;
    color: var(--aw-color-text-muted);
    padding-top: 0.75rem;
    border-top: 1px solid var(--aw-color-border);
  }

  /* ============================================================
     Demo container chrome — flat editorial frame, no marketing glow
     ============================================================ */
  .demo {
    position: relative;
    width: 100%;
    border: 1px solid var(--aw-color-border);
    border-radius: 8px;
    background: var(--aw-color-bg-page);
    box-shadow:
      0 1px 2px rgba(10, 10, 10, 0.03),
      0 10px 28px -18px rgba(10, 10, 10, 0.10);
    overflow: hidden;
  }

  .demo-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 16px;
    border-bottom: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
  }
  .demo-head-left { display: flex; align-items: center; gap: 12px; }
  .demo-mark {
    flex-shrink: 0;
  }
  .head-rule {
    width: 1px;
    height: 16px;
    background: var(--aw-color-border);
    flex-shrink: 0;
  }

  /* Right side of head — quiet "loop is alive" marker */
  .demo-head-right {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
    font-weight: 600;
  }
  .loop-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--aw-color-primary);
    box-shadow: 0 0 0 0 rgba(82, 153, 97, 0.5);
    animation: loop-pulse 2.4s ease-in-out infinite;
  }
  @keyframes loop-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(82, 153, 97, 0.5); }
    50%      { box-shadow: 0 0 0 4px rgba(82, 153, 97, 0); }
  }

  /* Stage label — matches AnatomyFlow .step-num cadence */
  .mode-label {
    position: relative;
    height: 14px;
    min-width: 86px;
    overflow: hidden;
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .ml {
    position: absolute;
    inset: 0;
    white-space: nowrap;
  }
  .ml-chat { opacity: 1; }
  .ml-apps { opacity: 0; color: var(--aw-color-primary); }
  .ml-app  { opacity: 0; color: var(--aw-color-primary); }

  /* ============================================================
     Body — left sidebar + main column with three cross-fading panes
     ============================================================ */
  .demo-body {
    position: relative;
    height: 580px;
    display: flex;
    align-items: stretch;
  }
  @media (max-width: 640px) {
    .demo-body { height: 620px; }
  }

  .demo-main {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    padding: 22px 26px;
  }
  @media (max-width: 640px) {
    .demo-main { padding: 18px 18px; }
  }

  .pane {
    position: absolute;
    inset: 22px 26px;
    display: flex;
    flex-direction: column;
    gap: 11px;
    transform-origin: 50% 40%;
  }
  .pane > * { flex-shrink: 0; }
  @media (max-width: 640px) {
    .pane { inset: 18px 18px; gap: 10px; }
  }

  /* ============================================================
     LEFT SIDEBAR — TreeSidebar-style nav
     ============================================================ */
  .sidebar {
    flex-shrink: 0;
    width: 152px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px 10px 12px;
    border-right: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    font-size: 0.6875rem;
  }
  @media (max-width: 640px) {
    .sidebar { width: 46px; padding: 14px 6px 12px; align-items: center; }
    .sidebar .sb-label { display: none; }
    .sidebar .sb-section-label { display: none; }
    .sidebar .sb-ws-chev { display: none; }
    .sidebar .sb-ws-name { display: none; }
    .sidebar .sb-new-chat { padding: 0; width: 28px; justify-content: center; }
    .sidebar .sb-item { padding: 6px 0; justify-content: center; width: 28px; }
    .sidebar .sb-user { padding: 4px 0; }
  }

  /* Workspace switcher */
  .sb-workspace {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 6px;
    border-radius: 6px;
    background: var(--aw-color-bg-subtle);
    border: 1px solid var(--aw-color-border);
  }
  .sb-ws-avatar {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    border-radius: 4px;
    background: rgba(82, 153, 97, 0.18);
    color: var(--aw-color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .sb-ws-name {
    flex: 1;
    color: var(--aw-color-text-heading);
    font-weight: 600;
    font-size: 0.6875rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sb-ws-chev {
    color: var(--aw-color-text-muted);
    flex-shrink: 0;
  }

  /* New Chat button */
  .sb-new-chat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 26px;
    padding: 0 9px;
    border-radius: 6px;
    background: rgba(82, 153, 97, 0.10);
    border: 1px solid rgba(82, 153, 97, 0.20);
    color: var(--aw-color-primary);
    font-size: 0.6875rem;
    font-weight: 600;
    cursor: pointer;
    pointer-events: none;
    white-space: nowrap;
    transition: background-color 200ms ease, box-shadow 240ms ease;
  }

  /* Nav lists */
  .sb-nav {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .sb-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 8px;
    border-radius: 5px;
    color: var(--aw-color-text-default);
    font-size: 0.6875rem;
    font-weight: 500;
    cursor: pointer;
    pointer-events: none;
    transition: background-color 200ms ease, color 200ms ease;
  }
  .sb-item svg {
    color: var(--aw-color-text-muted);
    flex-shrink: 0;
    transition: color 200ms ease;
  }
  .sb-accent {
    position: absolute;
    left: -2px;
    top: 5px;
    bottom: 5px;
    width: 2px;
    border-radius: 2px;
    background: var(--aw-color-primary);
    opacity: 0;
  }

  /* Section header (e.g., TOOLS) */
  .sb-section {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 6px;
    padding-top: 8px;
    border-top: 1px dashed var(--aw-color-border);
  }
  .sb-section-label {
    padding: 0 8px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--aw-color-text-muted);
  }

  .sb-spacer { flex: 1; }

  /* User row at bottom */
  .sb-user {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 8px;
    border-top: 1px solid var(--aw-color-border);
    margin-top: 4px;
  }
  .sb-user-avatar {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    border-radius: 9999px;
    background: var(--aw-color-bg-subtle);
    border: 1px solid var(--aw-color-border);
    color: var(--aw-color-text-default);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 600;
  }
  .sb-user-name {
    color: var(--aw-color-text-muted);
    font-size: 0.625rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Active states driven by the 20s timeline */
  .sb-new-chat { animation: sb-newchat-active 20s infinite; }
  @keyframes sb-newchat-active {
    0%, 32%   { background: rgba(82, 153, 97, 0.16); box-shadow: 0 0 0 1px rgba(82, 153, 97, 0.20); }
    34%, 100% { background: rgba(82, 153, 97, 0.10); box-shadow: 0 0 0 0 rgba(82, 153, 97, 0); }
  }
  .sb-item-apps { animation: sb-apps-active 20s infinite; }
  @keyframes sb-apps-active {
    0%, 32%   { background: transparent; color: var(--aw-color-text-default); }
    34%, 92%  { background: rgba(82, 153, 97, 0.08); color: var(--aw-color-text-heading); }
    94%, 100% { background: transparent; color: var(--aw-color-text-default); }
  }
  .sb-item-apps svg { animation: sb-apps-icon 20s infinite; }
  @keyframes sb-apps-icon {
    0%, 32%   { color: var(--aw-color-text-muted); }
    34%, 92%  { color: var(--aw-color-primary); }
    94%, 100% { color: var(--aw-color-text-muted); }
  }
  .sb-item-apps .sb-accent { animation: sb-apps-accent 20s infinite; }
  @keyframes sb-apps-accent {
    0%, 32%   { opacity: 0; transform: scaleY(0.4); }
    34%, 92%  { opacity: 1; transform: scaleY(1); }
    94%, 100% { opacity: 0; transform: scaleY(0.4); }
  }

  /* ============================================================
     CHAT pane — stream + composer
     ============================================================ */
  .chat-stream {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: flex-end;
    overflow: hidden;
  }
  .chat-stream > * { flex-shrink: 0; }

  /* ── Message bubbles ── */
  .bubble-row {
    display: flex;
  }
  .bubble-row-user { justify-content: flex-end; }
  .bubble-row-agent { justify-content: flex-start; }

  .bubble {
    max-width: 86%;
    padding: 9px 13px;
    border-radius: 14px;
    font-size: 0.875rem;
    line-height: 1.55;
    word-wrap: break-word;
    opacity: 0;
  }
  .bubble-user {
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    color: var(--aw-color-text-default);
    border-bottom-right-radius: 6px; /* tail toward composer */
  }
  .bubble-agent {
    background: var(--aw-color-bg-subtle);
    color: var(--aw-color-text-default);
    border-bottom-left-radius: 6px;
  }
  .bubble-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    background: rgba(82, 153, 97, 0.10);
    color: var(--aw-color-primary);
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 0.85em;
  }

  /* ── Thinking indicator ── */
  .thinking-row {
    display: flex;
    align-items: center;
    padding: 4px 4px;
  }
  .thinking {
    display: flex; gap: 5px; align-items: center;
    height: 14px;
  }
  .thinking span {
    width: 6px; height: 6px; border-radius: 9999px;
    background: rgba(82, 153, 97, 0.55);
    opacity: 0;
  }

  /* ── Tool call cards (inline in stream) ── */
  .tool-card {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    padding: 8px 10px 8px 9px;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    border-radius: 10px;
    font-size: 0.75rem;
    opacity: 0;
    transform: translateY(4px);
  }
  .tc-icon {
    position: relative;
    width: 14px; height: 14px;
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--aw-color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .tc-spin {
    position: absolute;
    inset: 0;
    border: 1.5px solid rgba(82, 153, 97, 0.25);
    border-top-color: var(--aw-color-primary);
    border-radius: 9999px;
    animation: spin 0.75s linear infinite;
  }
  .tc-check {
    position: absolute;
    inset: 0;
    opacity: 0;
    color: var(--aw-color-primary);
  }
  .tc-icon-done .tc-spin { opacity: 0; }
  .tc-icon-done .tc-check { opacity: 1; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .tc-body {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tc-head {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    line-height: 1.4;
  }
  .tc-kind {
    padding: 1px 6px;
    border-radius: 9999px;
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--aw-color-primary);
    background: rgba(82, 153, 97, 0.10);
    border: 1px solid rgba(82, 153, 97, 0.22);
    line-height: 1.45;
  }
  .tc-kind-connect {
    color: var(--aw-color-text-default);
    background: var(--aw-color-bg-subtle);
    border-color: var(--aw-color-border);
  }
  .tc-tool {
    color: var(--aw-color-text-heading);
    font-weight: 500;
  }
  .tc-msg {
    position: relative;
    font-size: 0.6875rem;
    color: var(--aw-color-text-muted);
    line-height: 1.4;
    min-height: 1em;
  }
  .tool-1 .tc-msg {
    display: grid;
    grid-template-areas: 's';
  }
  .tool-1 .tc-status {
    grid-area: s;
    white-space: nowrap;
  }
  .tool-1 .tc-status-done {
    color: var(--aw-color-primary);
    font-weight: 500;
    opacity: 0;
  }

  /* ============================================================
     CHAT pane — composer pill (rounded-3xl, like real product)
     ============================================================ */
  .composer {
    position: relative;
    border: 1px solid var(--aw-color-border);
    border-radius: 18px;
    background: var(--aw-color-bg-page);
    box-shadow:
      0 2px 6px rgba(10, 10, 10, 0.03),
      0 1px 2px rgba(10, 10, 10, 0.025);
    padding: 12px 14px 9px 16px;
    flex-shrink: 0;
  }
  .composer-content {
    display: grid;
    grid-template-areas: 'c';
    min-height: 38px;
    padding: 2px 2px 6px;
  }
  .composer-placeholder,
  .composer-prompt {
    grid-area: c;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
    margin: 0;
  }
  .composer-placeholder {
    color: var(--aw-color-text-muted);
  }
  .composer-prompt {
    position: relative;
  }
  .composer-prompt code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    background: rgba(82, 153, 97, 0.08);
    color: var(--aw-color-primary);
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .seg { opacity: 0; display: inline; }
  .caret {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: var(--aw-color-primary);
    margin-left: 2px;
    vertical-align: text-bottom;
    border-radius: 1px;
    opacity: 0;
  }

  .composer-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding-top: 6px;
  }
  .tb-left {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tb-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 26px;
    padding: 0 10px;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    color: var(--aw-color-text-default);
    font-size: 0.6875rem;
    font-weight: 500;
    cursor: pointer;
    pointer-events: none;
    white-space: nowrap;
    transition: border-color 200ms ease, color 200ms ease, background-color 200ms ease, box-shadow 220ms ease;
  }
  .distill-btn {
    color: var(--aw-color-text-default);
  }
  .distill-icon { color: var(--aw-color-primary); }
  .distill-label { font-weight: 600; }
  .model-btn { color: var(--aw-color-text-muted); }
  .model-btn svg { color: var(--aw-color-text-muted); }

  .send-btn {
    position: relative;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: var(--aw-color-text-muted);
    color: #fff;
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: none;
    transition: background-color 200ms ease, transform 180ms ease, box-shadow 220ms ease;
    flex-shrink: 0;
  }
  .send-glow {
    position: absolute;
    inset: -3px;
    border-radius: 9999px;
    box-shadow: 0 0 0 0 rgba(82, 153, 97, 0);
    pointer-events: none;
  }
  .send-arrow { color: #fff; }

  /* Distill button — pulse + ripple at the "save" moment */
  .distill-ripple {
    position: absolute;
    /* matches Distill button position relative to .composer padding */
    left: 12px;
    bottom: 8px;
    width: 110px;
    height: 26px;
    border-radius: 9999px;
    border: 1.5px solid var(--aw-color-primary);
    opacity: 0;
    pointer-events: none;
  }

  /* Saved toast — slides in from below the composer after distill */
  .saved-toast {
    position: absolute;
    left: 50%;
    bottom: -34px;
    transform: translateX(-50%) translateY(-4px);
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 9999px;
    background: var(--aw-color-primary);
    color: #fff;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    box-shadow:
      0 4px 14px -4px rgba(82, 153, 97, 0.28),
      0 1px 2px rgba(10, 10, 10, 0.06);
  }

  /* ============================================================
     APPS GRID pane (unchanged from previous)
     ============================================================ */
  .pane-grid { opacity: 0; }
  .grid-head {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding-bottom: 10px;
    margin-bottom: 6px;
    border-bottom: 1px solid var(--aw-color-border);
  }
  .grid-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.005em;
  }
  .grid-count {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    color: var(--aw-color-text-muted);
  }

  .apps {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    flex: 1;
    align-content: start;
  }

  .card {
    position: relative;
    padding: 14px 16px 13px;
    border: 1px solid var(--aw-color-border);
    border-radius: 8px;
    background: var(--aw-color-bg-page);
    display: flex;
    flex-direction: column;
    gap: 9px;
    opacity: 0;
    transform: translateY(6px);
  }
  .card-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .card-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--aw-color-bg-subtle);
    color: var(--aw-color-text-muted);
    display: flex; align-items: center; justify-content: center;
  }
  .card-icon-primary {
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
  }
  .card-name {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.005em;
    line-height: 1.25;
  }
  .card-meta {
    margin: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    color: var(--aw-color-text-muted);
  }
  .meta-fresh {
    color: var(--aw-color-primary);
    font-weight: 500;
  }

  .card-new {
    border-color: rgba(82, 153, 97, 0.35);
    z-index: 1;
  }
  .new-badge {
    padding: 2px 6px;
    border-radius: 9999px;
    background: var(--aw-color-primary);
    color: #fff;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.4;
    opacity: 0;
    transform: scale(0.7);
  }
  .card-hover {
    position: absolute;
    inset: -2px;
    border-radius: 10px;
    border: 1.5px solid var(--aw-color-primary);
    opacity: 0;
    pointer-events: none;
  }

  /* ============================================================
     APP pane (unchanged from previous)
     ============================================================ */
  .pane-app { opacity: 0; }
  .app-head {
    display: flex; align-items: center; gap: 8px;
    padding-bottom: 12px;
    margin-bottom: 4px;
    border-bottom: 1px solid var(--aw-color-border);
    opacity: 0;
    transform: translateY(-4px);
  }
  .app-icon {
    width: 22px; height: 22px;
    border-radius: 6px;
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
    display: flex; align-items: center; justify-content: center;
  }
  .app-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
  }
  .app-version {
    margin-left: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    color: var(--aw-color-text-muted);
  }

  .wired {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 5px;
    padding-bottom: 10px;
    margin-bottom: 2px;
    border-bottom: 1px dashed var(--aw-color-border);
  }
  .wired-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
    color: var(--aw-color-text-muted);
  }
  .wired-sep {
    color: var(--aw-color-border);
    font-size: 0.75rem;
    padding: 0 2px;
  }
  .wchip {
    opacity: 0;
    transform: scale(0.94);
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 2px 7px;
    border-radius: 9999px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    line-height: 1.4;
    border: 1px solid rgba(82, 153, 97, 0.20);
    background: rgba(82, 153, 97, 0.08);
    color: var(--aw-color-primary);
  }
  .wchip-connect {
    border-color: var(--aw-color-border);
    background: var(--aw-color-bg-subtle);
    color: var(--aw-color-text-default);
  }
  .wchip-connect svg { color: var(--aw-color-primary); }

  .field {
    opacity: 0;
    transform: translateY(6px);
  }
  .field label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--aw-color-text-muted);
    margin-bottom: 5px;
  }
  .input {
    height: 30px;
    padding: 0 11px;
    border: 1px solid var(--aw-color-border);
    border-radius: 6px;
    display: flex; align-items: center;
    font-size: 0.75rem;
    color: var(--aw-color-text-default);
    background: var(--aw-color-bg-page);
  }
  .input.between { justify-content: space-between; }
  .input.between svg { color: var(--aw-color-text-muted); }
  .input.mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
  .row-2 { display: flex; gap: 8px; align-items: center; }
  .row-2 .input { flex: 1; }
  .arrow { color: var(--aw-color-text-muted); font-size: 0.75rem; }

  .run-btn {
    opacity: 0;
    transform: translateY(6px);
    width: 100%;
    height: 34px;
    border-radius: 6px;
    background: var(--aw-color-primary);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    border: none;
    pointer-events: none;
    position: relative;
    overflow: hidden;
  }
  .run-text {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  .run-text-running { opacity: 0; }
  .run-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    box-shadow: 0 0 0 0 rgba(82, 153, 97, 0.45);
    pointer-events: none;
  }
  .spinner {
    width: 11px;
    height: 11px;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    border-radius: 9999px;
    display: inline-block;
    animation: spin 0.7s linear infinite;
  }

  .artifact {
    opacity: 0;
    margin-top: 4px;
    padding: 10px 12px;
    border: 1px solid var(--aw-color-border);
    border-radius: 8px;
    background: var(--aw-color-bg-subtle);
  }
  .artifact-head {
    display: flex; align-items: center; gap: 6px;
    color: var(--aw-color-text-muted);
    padding-bottom: 6px;
    margin-bottom: 6px;
    border-bottom: 1px dashed var(--aw-color-border);
    font-size: 0.6875rem;
  }
  .export-hint {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 3px;
    color: var(--aw-color-primary);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    opacity: 0;
  }
  .a-row {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    color: var(--aw-color-text-default);
    line-height: 1.6;
    opacity: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ============================================================
     ANIMATIONS — one 20s timeline drives everything.
     Percentages map to seconds: 1% = 0.2s, 5% = 1s, 25% = 5s, 50% = 10s.
     Storyboard:
       0  – 33%   CHAT
              0 – 12%   type in composer (placeholder fades, carets track segs)
             12 – 14%   send (button glows → click → composer clears)
             14 – 15%   user bubble appears in stream
             15 – 23%   agent thinks; tool 1 (loading → done) + tool 2 land
             25 – 28%   agent reply bubble appears
             28 – 32%   Distill button pulse → click → saved toast
       33 – 53%   APPS — grid populates, NEW Daily Report lands, click bloom
       53 – 92%   APP  — form → run → artifact → export hint
       92 – 100%  reset
     ============================================================ */

  /* Mode labels */
  .ml-chat { animation: ml-chat 20s infinite; }
  .ml-apps { animation: ml-apps 20s infinite; }
  .ml-app  { animation: ml-app  20s infinite; }
  @keyframes ml-chat {
    0%, 32%   { opacity: 1; }
    34%, 96%  { opacity: 0; }
    100%      { opacity: 1; }
  }
  @keyframes ml-apps {
    0%, 32%   { opacity: 0; }
    34%, 52%  { opacity: 1; }
    54%, 100% { opacity: 0; }
  }
  @keyframes ml-app {
    0%, 52%   { opacity: 0; }
    54%, 92%  { opacity: 1; }
    94%, 100% { opacity: 0; }
  }

  /* Pane cross-fade */
  .pane-chat { animation: chat-fade 20s infinite; }
  .pane-grid { animation: grid-fade 20s infinite; }
  .pane-app  { animation: app-fade  20s infinite; }
  @keyframes chat-fade {
    0%, 32%   { opacity: 1; transform: scale(1); }
    34%       { opacity: 0; transform: scale(0.97); }
    96%       { opacity: 0; transform: scale(1); }
    100%      { opacity: 1; }
  }
  @keyframes grid-fade {
    0%, 32%   { opacity: 0; transform: scale(1.02); }
    34%, 52%  { opacity: 1; transform: scale(1); }
    54%, 100% { opacity: 0; transform: scale(0.98); }
  }
  @keyframes app-fade {
    0%, 52%   { opacity: 0; transform: scale(0.98); }
    54%, 92%  { opacity: 1; transform: scale(1); }
    94%, 100% { opacity: 0; transform: scale(1.01); }
  }

  /* ── Composer: placeholder fades when typing starts ── */
  .composer-placeholder { animation: placeholder-out 20s infinite; }
  @keyframes placeholder-out {
    0%, 1.5% { opacity: 1; }
