---
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';
import LanguagePicker from '~/components/widgets/LanguagePicker.astro';

import { trimSlash } from '~/utils/permalinks';
import { getLocaleFromPath } from '~/i18n/utils';
import type { CallToAction } from '~/types';

interface MenuLink {
  text?: string;
  href?: string;
  desc?: string;
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
const currentLocale = getLocaleFromPath(currentPath);
const homeHref = currentLocale === 'en' ? '/' : `/${currentLocale}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky },
    'aw-header top-0 z-40 w-full transition-[background-color,box-shadow,border-color] duration-200 ease-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-4">
    <!-- Logo -->
    <a class="aw-header-logo flex items-center gap-2 shrink-0" href={homeHref} aria-label="Home">
      <Logo />
    </a>

    <!-- Desktop: nav + lang + actions -->
    <div class="hidden md:flex items-center gap-1">
      {links.length > 0 && (
        <nav class="flex items-center mr-1" aria-label="Primary">
          {links.map((link) => {
            const hasChildren = Array.isArray(link.links) && link.links.length > 0;
            const isActive =
              link.href === currentPath ||
              (hasChildren && link.links!.some((c) => c.href === currentPath || (c.href && currentPath.startsWith(c.href + '/'))));
            const baseLink = 'aw-nav-link px-3 py-1.5 text-sm rounded-md inline-flex items-center gap-1 transition-colors duration-150';
            const linkClasses = [
              baseLink,
              isActive ? 'is-active' : '',
            ];
            return hasChildren ? (
              <div class="relative group">
                <a href={link.href} class:list={linkClasses}>
                  {link.text}
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover:rotate-180 transition-transform duration-200"><polyline points="6 9 12 15 18 9"/></svg>
                </a>
                <div class="absolute left-0 top-full pt-2 z-50 invisible opacity-0 -translate-y-1 pointer-events-none group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 group-focus-within:pointer-events-auto transition-all duration-180">
                  <div class="aw-dropdown rounded-xl p-1.5 min-w-[260px]">
                    {link.links!.map((sub) => (
                      <a
                        href={sub.href}
                        class:list={[
                          'aw-dropdown-item block px-3 py-2 rounded-lg transition-colors duration-150',
                          sub.href === currentPath ? 'is-current' : '',
                        ]}
                      >
                        <div class="aw-dropdown-title">{sub.text}</div>
                        {sub.desc && (
                          <div class="aw-dropdown-desc">{sub.desc}</div>
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a href={link.href} class:list={linkClasses}>
                {link.text}
              </a>
            );
          })}
        </nav>
      )}
      <LanguagePicker />
      {actions.map((btnProps) => (
        <Button {...btnProps} class="aw-header-action ml-1.5 h-8 px-3.5 text-sm font-semibold" />
      ))}
    </div>

    <!-- Mobile: lang + hamburger -->
    <div class="flex items-center gap-1 md:hidden">
      <LanguagePicker />
      {links.length > 0 ? (
        <ToggleMenu />
      ) : (
        actions.map((btnProps) => (
          <Button {...btnProps} class="aw-header-action h-8 px-3 text-sm font-semibold" />
        ))
      )}
    </div>
  </div>

  <!-- Mobile nav drawer -->
  {links.length > 0 && (
    <nav
      id="mobile-nav"
      class="hidden md:hidden px-4 pb-3 border-t border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)]"
      aria-label="Mobile navigation"
    >
      {links.map((link) => {
        const hasChildren = Array.isArray(link.links) && link.links.length > 0;
        const isActive =
          link.href === currentPath ||
          (hasChildren && link.links!.some((c) => c.href === currentPath));
        return (
          <div>
            <a
              href={link.href}
              class:list={[
                'block py-2 text-sm transition-colors duration-150',
                isActive
                  ? 'text-[var(--aw-color-text-heading)] font-semibold'
                  : 'text-[var(--aw-color-text-muted)] hover:text-[var(--aw-color-text-default)]',
              ]}
            >
              {link.text}
            </a>
            {hasChildren && (
              <div class="pl-3 pb-1 border-l border-[var(--aw-color-border)] ml-1">
                {link.links!.map((sub) => (
                  <a
                    href={sub.href}
                    class:list={[
                      'block py-1.5 text-[0.8125rem] transition-colors duration-150',
                      sub.href === currentPath
                        ? 'text-[var(--aw-color-primary)] font-medium'
                        : 'text-[var(--aw-color-text-muted)] hover:text-[var(--aw-color-text-default)]',
                    ]}
                  >
                    {sub.text}
                  </a>
                ))}
              </div>
            )}
          </div>
        );
      })}
      <div class="pt-2 border-t border-[var(--aw-color-border)] mt-2">
        {actions.map((btnProps) => (
          <Button {...btnProps} class="w-full h-9 text-sm font-semibold mb-1" />
        ))}
      </div>
    </nav>
  )}
</header>

<style>
  /* Sticky header — glass that strengthens on scroll. */
  .aw-header {
    background-color: rgb(255 255 255 / 0.70);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
            backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid transparent;
  }
  .aw-header[data-aw-sticky-header].scroll {
    background-color: rgb(255 255 255 / 0.88);
    border-bottom-color: var(--aw-color-border);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.02),
      0 6px 18px -10px rgba(0, 0, 0, 0.08);
  }
  /* Logo hover */
  .aw-header-logo { transition: opacity 160ms ease; }
  .aw-header-logo:hover { opacity: 0.78; }

  /* Nav link states */
  :global(.aw-nav-link) {
    color: var(--aw-color-text-muted);
  }
  :global(.aw-nav-link:hover) {
    color: var(--aw-color-text-heading);
    background-color: var(--aw-color-bg-subtle);
  }
  :global(.aw-nav-link.is-active) {
    color: var(--aw-color-text-heading);
    font-weight: 500;
    background-color: var(--aw-color-bg-subtle);
  }

  /* Dropdown surface */
  :global(.aw-dropdown) {
    background-color: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.02),
      0 14px 38px -14px rgba(0, 0, 0, 0.12),
      0 6px 14px -6px rgba(0, 0, 0, 0.06);
  }
  :global(.aw-dropdown-item) {
    color: var(--aw-color-text-default);
  }
  :global(.aw-dropdown-item:hover) {
    background-color: var(--aw-color-bg-subtle);
  }
  :global(.aw-dropdown-item.is-current) {
    background-color: rgba(82, 153, 97, 0.08);
  }
  :global(.aw-dropdown-title) {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.005em;
    line-height: 1.3;
  }
  :global(.aw-dropdown-item.is-current .aw-dropdown-title) {
    color: var(--aw-color-primary);
  }
  :global(.aw-dropdown-desc) {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    margin-top: 0.125rem;
    line-height: 1.45;
  }
</style>
