---
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';
import LanguagePicker from '~/components/widgets/LanguagePicker.astro';

import { trimSlash } from '~/utils/permalinks';
import { getLocaleFromPath } from '~/i18n/utils';
import type { CallToAction } from '~/types';

interface MenuLink {
  text?: string;
  href?: string;
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
const currentLocale = getLocaleFromPath(currentPath);
const homeHref = currentLocale === 'en' ? '/' : `/${currentLocale}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky },
    'top-0 z-40 w-full bg-page border-b border-[var(--aw-color-border)] transition-[opacity] ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a class="flex items-center gap-2 shrink-0" href={homeHref}>
      <Logo />
    </a>

    <!-- Desktop: lang + nav links + actions -->
    <div class="hidden md:flex items-center gap-1">
      {links.length > 0 && (
        <nav class="flex items-center mr-2">
          {links.map(({ text, href }) => (
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 text-sm rounded-md transition-colors duration-150',
                href === currentPath
                  ? 'text-[var(--aw-color-text-default)] font-medium'
                  : 'text-[var(--aw-color-text-muted)] hover:text-[var(--aw-color-text-default)] hover:bg-[var(--aw-color-bg-subtle)]',
              ]}
            >
              {text}
            </a>
          ))}
        </nav>
      )}
      <LanguagePicker />
      {actions.map((btnProps) => (
        <Button {...btnProps} class="ml-1 h-8 px-4 text-sm font-semibold" />
      ))}
    </div>

    <!-- Mobile: lang + hamburger (only if links exist) -->
    <div class="flex items-center gap-1 md:hidden">
      <LanguagePicker />
      {links.length > 0 ? (
        <ToggleMenu />
      ) : (
        actions.map((btnProps) => (
          <Button {...btnProps} class="h-8 px-3 text-sm font-semibold" />
        ))
      )}
    </div>
  </div>

  <!-- Mobile nav (only rendered if links exist) -->
  {links.length > 0 && (
    <nav
      id="mobile-nav"
      class="hidden md:hidden px-4 pb-3 border-t border-[var(--aw-color-border)] bg-page"
      aria-label="Mobile navigation"
    >
      {links.map(({ text, href }) => (
        <a
          href={href}
          class="block py-2 text-sm text-[var(--aw-color-text-muted)] hover:text-[var(--aw-color-text-default)]"
        >
          {text}
        </a>
      ))}
      <div class="pt-2 border-t border-[var(--aw-color-border)] mt-2">
        {actions.map((btnProps) => (
          <Button {...btnProps} class="w-full h-9 text-sm font-semibold mb-1" />
        ))}
      </div>
    </nav>
  )}
</header>
