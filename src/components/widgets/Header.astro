---
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import LanguagePicker from '~/components/widgets/LanguagePicker.astro';

import { trimSlash } from '~/utils/permalinks';
import { getLocaleFromPath } from '~/i18n/utils';
import type { CallToAction } from '~/types';

interface MenuLink {
  text?: string;
  href?: string;
  desc?: string;
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
const currentLocale = getLocaleFromPath(currentPath);
const homeHref = currentLocale === 'en' ? '/' : `/${currentLocale}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky },
    'ds-header top-0 z-40 w-full transition-[background-color,border-color] duration-200 ease-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-[52px] flex items-center justify-between gap-6">
    <!-- Logo -->
    <a class="ds-header-logo flex items-center gap-2 shrink-0" href={homeHref} aria-label="Home">
      <Logo />
    </a>

    <!-- Desktop: nav + lang + action -->
    <div class="hidden md:flex items-center gap-1">
      {links.length > 0 && (
        <nav class="flex items-center gap-0.5" aria-label="Primary">
          {links.map((link) => {
            const hasChildren = Array.isArray(link.links) && link.links.length > 0;
            const isActive =
              link.href === currentPath ||
              (hasChildren && link.links!.some((c) => c.href === currentPath || (c.href && currentPath.startsWith(c.href + '/'))));
            const linkClasses = [
              'ds-nav-link',
              isActive ? 'is-active' : '',
            ];
            return hasChildren ? (
              <div class="relative group">
                <a href={link.href} class:list={linkClasses}>
                  <span class="ds-nav-dot" aria-hidden="true"></span>
                  <span>{link.text}</span>
                  <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ds-nav-chev" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </a>
                <div class="absolute left-0 top-full pt-2 z-50 invisible opacity-0 -translate-y-1 pointer-events-none group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 group-focus-within:pointer-events-auto transition-all duration-200">
                  <div class="ds-dropdown">
                    {link.links!.map((sub, i) => (
                      <a
                        href={sub.href}
                        class:list={[
                          'ds-dropdown-item',
                          sub.href === currentPath ? 'is-current' : '',
                        ]}
                      >
                        <span class="ds-dropdown-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                        <span class="ds-dropdown-body">
                          <span class="ds-dropdown-title">{sub.text}</span>
                          {sub.desc && <span class="ds-dropdown-desc">{sub.desc}</span>}
                        </span>
                        <svg class="ds-dropdown-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a href={link.href} class:list={linkClasses}>
                <span class="ds-nav-dot" aria-hidden="true"></span>
                <span>{link.text}</span>
              </a>
            );
          })}
        </nav>
      )}
      <span class="ds-header-divider" aria-hidden="true"></span>
      <LanguagePicker />
      {actions.map((btnProps) => (
        <a
          href={btnProps.href}
          class="ds-header-action"
          {...btnProps.target ? { target: btnProps.target, rel: 'noopener noreferrer' } : {}}
        >
          <span>{btnProps.text}</span>
          <kbd class="ds-kbd ds-kbd--on-dark" aria-hidden="true">↵</kbd>
        </a>
      ))}
    </div>

    <!-- Mobile -->
    <div class="flex items-center gap-1 md:hidden">
      <LanguagePicker />
      {links.length > 0 ? (
        <ToggleMenu />
      ) : (
        actions.map((btnProps) => (
          <a
            href={btnProps.href}
            class="ds-header-action ds-header-action--mobile"
            {...btnProps.target ? { target: btnProps.target, rel: 'noopener noreferrer' } : {}}
          >
            {btnProps.text}
          </a>
        ))
      )}
    </div>
  </div>

  <!-- Mobile drawer -->
  {links.length > 0 && (
    <nav
      id="mobile-nav"
      class="hidden md:hidden"
      aria-label="Mobile navigation"
    >
      <div class="ds-mobile-nav-inner">
        <ul class="ds-mobile-nav-list">
          {links.map((link, idx) => {
            const hasChildren = Array.isArray(link.links) && link.links.length > 0;
            const isActive =
              link.href === currentPath ||
              (hasChildren && link.links!.some((c) => c.href === currentPath));
            return (
              <li class="ds-mobile-nav-item">
                {hasChildren ? (
                  <>
                    <a
                      href={link.href}
                      class:list={['ds-mobile-nav-group', isActive ? 'is-active' : '']}
                    >
                      <span class="ds-mobile-nav-index" aria-hidden="true">{`0.${idx}`}</span>
                      <span>{link.text}</span>
                    </a>
                    <ul class="ds-mobile-nav-sublist">
                      {link.links!.map((sub) => (
                        <li>
                          <a
                            href={sub.href}
                            class:list={['ds-mobile-nav-sublink', sub.href === currentPath ? 'is-active' : '']}
                          >
                            {sub.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </>
                ) : (
                  <a
                    href={link.href}
                    class:list={['ds-mobile-nav-link', isActive ? 'is-active' : '']}
                  >
                    <span class="ds-mobile-nav-index" aria-hidden="true">{`0.${idx}`}</span>
                    <span>{link.text}</span>
                  </a>
                )}
              </li>
            );
          })}
        </ul>
        {actions.length > 0 && (
          <div class="ds-mobile-nav-actions">
            {actions.map((btnProps) => (
              <a
                href={btnProps.href}
                class="ds-header-action ds-header-action--mobile w-full justify-center"
                {...btnProps.target ? { target: btnProps.target, rel: 'noopener noreferrer' } : {}}
              >
                <span>{btnProps.text}</span>
                <kbd class="ds-kbd ds-kbd--on-dark" aria-hidden="true">↵</kbd>
              </a>
            ))}
          </div>
        )}
      </div>
    </nav>
  )}
</header>

<style>
  /* ── Header surface ────────────────────────────────────────── */
  .ds-header {
    background-color: var(--ds-ground);
    border-bottom: 1px solid var(--ds-hairline);
  }
  .ds-header[data-aw-sticky-header].scroll {
    background-color: rgba(250, 250, 249, 0.86);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
            backdrop-filter: saturate(180%) blur(14px);
  }
  .ds-header-logo { transition: opacity 160ms ease; }
  .ds-header-logo:hover { opacity: 0.7; }

  /* ── Nav link ──────────────────────────────────────────────── */
  :global(.ds-nav-link) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ds-text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 150ms ease;
  }
  :global(.ds-nav-link:hover) { color: var(--ds-text); }
  :global(.ds-nav-link.is-active) { color: var(--ds-text); }
  :global(.ds-nav-dot) {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--ds-accent);
    opacity: 0;
    transform: scale(0.7);
    transition: opacity 180ms var(--ds-ease-out), transform 180ms var(--ds-ease-out);
  }
  :global(.ds-nav-link.is-active .ds-nav-dot) {
    opacity: 1;
    transform: scale(1);
  }
  :global(.ds-nav-link:hover .ds-nav-dot) { opacity: 0.4; transform: scale(1); }
  :global(.ds-nav-chev) {
    opacity: 0.5;
    transition: transform 200ms ease, opacity 200ms ease;
  }
  :global(.group:hover .ds-nav-chev) { transform: rotate(180deg); opacity: 0.85; }

  .ds-header-divider {
    width: 1px;
    height: 16px;
    background: var(--ds-hairline-strong);
    margin: 0 0.5rem;
    opacity: 0.7;
  }

  /* ── Action (Login) ────────────────────────────────────────── */
  :global(.ds-header-action) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 32px;
    padding: 0 0.5rem 0 0.875rem;
    border-radius: 8px;
    background: var(--ds-text);
    color: var(--ds-surface);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 150ms ease, transform 150ms ease;
    white-space: nowrap;
  }
  :global(.ds-header-action:hover) { background: #1f1f1f; }
  :global(.ds-header-action:active) { transform: translateY(0.5px); }
  :global(.ds-header-action--mobile) { height: 38px; padding: 0 0.625rem 0 1rem; }

  /* ── Dropdown ──────────────────────────────────────────────── */
  :global(.ds-dropdown) {
    min-width: 300px;
    padding: 0.375rem;
    background: var(--ds-surface);
    border: 1px solid var(--ds-hairline);
    border-radius: 14px;
    box-shadow: var(--ds-shadow-2);
  }
  :global(.ds-dropdown-item) {
    display: grid;
    grid-template-columns: auto 1fr auto;
    column-gap: 0.75rem;
    align-items: start;
    padding: 0.625rem 0.75rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 150ms ease;
  }
  :global(.ds-dropdown-item:hover) { background: var(--ds-surface-2); }
  :global(.ds-dropdown-item.is-current) { background: var(--ds-accent-tint); }
  :global(.ds-dropdown-index) {
    font-family: var(--ds-font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--ds-text-quiet);
    padding-top: 0.21rem;
  }
  :global(.ds-dropdown-item.is-current .ds-dropdown-index) { color: var(--ds-accent); }
  :global(.ds-dropdown-body) {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }
  :global(.ds-dropdown-title) {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ds-text);
    letter-spacing: -0.005em;
    line-height: 1.3;
  }
  :global(.ds-dropdown-item.is-current .ds-dropdown-title) { color: var(--ds-accent); }
  :global(.ds-dropdown-desc) {
    font-size: 0.75rem;
    color: var(--ds-text-muted);
    line-height: 1.45;
  }
  :global(.ds-dropdown-arrow) {
    color: var(--ds-text-quiet);
    opacity: 0;
    transform: translateX(-2px);
    transition: opacity 180ms var(--ds-ease-out), transform 180ms var(--ds-ease-out);
    align-self: center;
  }
  :global(.ds-dropdown-item:hover .ds-dropdown-arrow) {
    opacity: 1;
    transform: translateX(0);
    color: var(--ds-text);
  }
  :global(.ds-dropdown-item.is-current .ds-dropdown-arrow) {
    opacity: 1;
    color: var(--ds-accent);
  }

  /* ── Mobile drawer ─────────────────────────────────────────── */
  :global(.ds-mobile-nav-inner) {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 0.5rem 1rem calc(env(safe-area-inset-bottom, 0px) + 1rem);
  }
  :global(.ds-mobile-nav-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1 1 auto;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  :global(.ds-mobile-nav-item + .ds-mobile-nav-item) {
    border-top: 1px solid var(--ds-hairline);
  }
  :global(.ds-mobile-nav-link),
  :global(.ds-mobile-nav-group) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 48px;
    padding: 0.625rem 0.25rem;
    font-size: 0.9375rem;
    color: var(--ds-text-body);
    text-decoration: none;
    transition: color 120ms ease;
  }
  :global(.ds-mobile-nav-group) { font-weight: 600; color: var(--ds-text); }
  :global(.ds-mobile-nav-link.is-active),
  :global(.ds-mobile-nav-group.is-active) { color: var(--ds-accent); }
  :global(.ds-mobile-nav-index) {
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--ds-text-quiet);
    min-width: 26px;
  }
  :global(.ds-mobile-nav-link.is-active .ds-mobile-nav-index),
  :global(.ds-mobile-nav-group.is-active .ds-mobile-nav-index) { color: var(--ds-accent); }
  :global(.ds-mobile-nav-sublist) {
    list-style: none;
    margin: 0 0 0.5rem;
    padding: 0 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  :global(.ds-mobile-nav-sublink) {
    display: flex;
    align-items: center;
    min-height: 40px;
    padding: 0.375rem 0.625rem;
    font-size: 0.875rem;
    color: var(--ds-text-muted);
    text-decoration: none;
    border-radius: 6px;
    border-left: 2px solid var(--ds-hairline);
    margin-left: 0.5rem;
    transition: color 120ms ease, background-color 120ms ease, border-color 120ms ease;
  }
  :global(.ds-mobile-nav-sublink:hover) { color: var(--ds-text-body); }
  :global(.ds-mobile-nav-sublink.is-active) {
    color: var(--ds-accent);
    background-color: var(--ds-accent-tint);
    border-left-color: var(--ds-accent);
    font-weight: 500;
  }
  :global(.ds-mobile-nav-actions) {
    margin-top: auto;
    padding-top: 0.875rem;
    border-top: 1px solid var(--ds-hairline);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>
