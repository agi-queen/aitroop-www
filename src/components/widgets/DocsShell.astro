---
// Shared sidebar + content shell for /docs/* pages.
//
// Usage:
//   <DocsShell current="quickstart">
//     <!-- page content -->
//   </DocsShell>

interface Props {
  current: string;
}

const { current } = Astro.props;

const sections = [
  {
    label: 'Getting started',
    items: [
      { slug: 'index',       title: 'Introduction',  href: '/docs' },
      { slug: 'quickstart',  title: 'Quickstart',    href: '/docs/quickstart' },
      { slug: 'concepts',    title: 'Core concepts', href: '/docs/concepts' },
    ],
  },
  {
    label: 'Building',
    items: [
      { slug: 'chat',        title: 'Chat mode',     href: '/docs/chat' },
      { slug: 'apps',        title: 'Apps',          href: '/docs/apps' },
      { slug: 'skills',      title: 'Skills',        href: '/docs/skills' },
      { slug: 'connects',    title: 'Connects',      href: '/docs/connects' },
      { slug: 'schedules',   title: 'Schedules',     href: '/docs/schedules' },
    ],
  },
  {
    label: 'Reference',
    items: [
      { slug: 'artifacts',   title: 'Artifact formats', href: '/docs/artifacts' },
    ],
  },
];
---

<div class="mx-auto max-w-6xl px-6 md:px-10 py-10 md:py-14">
  <div class="grid md:grid-cols-[220px_1fr] gap-8 md:gap-12 items-start">

    <!-- ── SIDEBAR ─────────────────────────────────────────────────────── -->
    <aside class="md:sticky md:top-24 self-start">
      <p class="text-[0.6875rem] font-mono uppercase tracking-[0.2em] text-[var(--aw-color-text-muted)] mb-4">Docs</p>
      <nav class="space-y-7">
        {sections.map((section) => (
          <div>
            <div class="text-[0.6875rem] font-mono uppercase tracking-[0.15em] text-[var(--aw-color-text-muted)] mb-2.5 opacity-70">
              {section.label}
            </div>
            <ul class="space-y-1">
              {section.items.map((item) => {
                const active = item.slug === current;
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`block text-[0.875rem] leading-[1.5] py-1 px-2.5 -mx-2.5 rounded-md transition-colors ${
                        active
                          ? 'text-primary font-medium bg-primary/[0.06]'
                          : 'text-[var(--aw-color-text-default)] hover:text-primary hover:bg-[rgba(0,0,0,0.025)]'
                      }`}
                    >
                      {item.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- ── CONTENT ─────────────────────────────────────────────────────── -->
    <main class="docs-content min-w-0">
      <slot />
    </main>
  </div>
</div>

<style is:global>
  .docs-content h1 {
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.12;
    color: var(--aw-color-text-heading);
    margin-bottom: 1rem;
  }
  .docs-content > .lead {
    font-size: 1.0625rem;
    color: var(--aw-color-text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 640px;
  }
  .docs-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--aw-color-text-heading);
    margin-top: 3rem;
    margin-bottom: 0.875rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--aw-color-border);
    padding-top: 1.75rem;
  }
  .docs-content h3 {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--aw-color-text-heading);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .docs-content p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--aw-color-text-default);
    margin-bottom: 1rem;
    max-width: 720px;
  }
  .docs-content ul, .docs-content ol {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--aw-color-text-default);
    margin-bottom: 1rem;
    padding-left: 1.25rem;
    max-width: 720px;
  }
  .docs-content ul { list-style: disc; }
  .docs-content ol { list-style: decimal; }
  .docs-content li { margin-bottom: 0.375rem; }
  .docs-content li::marker { color: var(--aw-color-text-muted); }
  .docs-content code:not(pre code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.85em;
    padding: 0.1em 0.4em;
    background: var(--aw-color-bg-subtle);
    border: 1px solid var(--aw-color-border);
    border-radius: 4px;
    color: var(--aw-color-text-default);
  }
  .docs-content a {
    color: var(--aw-color-primary, #529961);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .docs-content a:hover { opacity: 0.8; }
  .docs-content strong {
    color: var(--aw-color-text-heading);
    font-weight: 600;
  }
  .docs-content .callout {
    border-left: 3px solid var(--aw-color-primary, #529961);
    background: rgba(82, 153, 97, 0.04);
    padding: 0.875rem 1.125rem;
    border-radius: 0 8px 8px 0;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--aw-color-text-default);
    max-width: 720px;
  }
  .docs-content .callout strong { font-weight: 600; }
  .docs-content .code-block {
    background: var(--aw-color-bg-subtle);
    border: 1px solid var(--aw-color-border);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--aw-color-text-default);
    margin: 1.25rem 0;
    overflow-x: auto;
    max-width: 720px;
  }
  .docs-content .next-up {
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--aw-color-border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  .docs-content .next-up .label {
    font-size: 0.6875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aw-color-text-muted);
  }
  .docs-content .next-up a {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
  }
  .docs-content .next-up a::after {
    content: '→';
    transition: transform 0.15s;
  }
  .docs-content .next-up a:hover::after { transform: translateX(2px); }
</style>
