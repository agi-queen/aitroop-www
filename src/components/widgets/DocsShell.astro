---
// Shared docs shell with sidebar, content, in-page TOC (right rail),
// and an auto prev/next pager built from the sections list.
//
// Usage:
//   <DocsShell current="quickstart">
//     <!-- page content -->
//   </DocsShell>

interface Props {
  current: string;
  locale?: 'en' | 'zh-CN' | 'zh-TW';
}

const { current, locale = 'en' } = Astro.props;

const sectionLabels = {
  en:      { gs: 'Getting started', build: 'Building', run: 'Running', ref: 'Reference' },
  'zh-CN': { gs: '入门',           build: '构建',    run: '运行',    ref: '参考'    },
  'zh-TW': { gs: '入門',           build: '建構',    run: '執行',    ref: '參考'    },
};

const itemTitles = {
  en: {
    index: 'Introduction', quickstart: 'Quickstart', concepts: 'Core concepts',
    chat: 'Chat mode', apps: 'Apps', skills: 'Skills', connects: 'Connects',
    executions: 'Executions', schedules: 'Schedules', sandbox: 'Sandbox',
    artifacts: 'Artifact formats',
  },
  'zh-CN': {
    index: '简介', quickstart: '快速开始', concepts: '核心概念',
    chat: '对话模式', apps: '应用', skills: '技能', connects: '连接',
    executions: '执行记录', schedules: '定时任务', sandbox: '沙箱',
    artifacts: '产物格式',
  },
  'zh-TW': {
    index: '簡介', quickstart: '快速開始', concepts: '核心概念',
    chat: '對話模式', apps: '應用', skills: '技能', connects: '連接',
    executions: '執行記錄', schedules: '排程', sandbox: '沙盒',
    artifacts: '產物格式',
  },
};

const uiText = {
  en:      { docsKicker: 'Documentation', onThisPage: 'On this page', docsCrumb: 'Docs', prev: 'Previous', next: 'Next' },
  'zh-CN': { docsKicker: '文档',           onThisPage: '本页内容',     docsCrumb: '文档',  prev: '上一篇',   next: '下一篇' },
  'zh-TW': { docsKicker: '文件',           onThisPage: '本頁內容',     docsCrumb: '文件',  prev: '上一篇',   next: '下一篇' },
};

const localePrefix = locale === 'en' ? '' : `/${locale}`;
const docsRoot = `${localePrefix}/docs`;

const labels = sectionLabels[locale];
const titles = itemTitles[locale];
const ui = uiText[locale];

const sections = [
  {
    label: labels.gs,
    items: [
      { slug: 'index',       title: titles.index,      href: docsRoot },
      { slug: 'quickstart',  title: titles.quickstart, href: `${docsRoot}/quickstart` },
      { slug: 'concepts',    title: titles.concepts,   href: `${docsRoot}/concepts` },
    ],
  },
  {
    label: labels.build,
    items: [
      { slug: 'chat',        title: titles.chat,     href: `${docsRoot}/chat` },
      { slug: 'apps',        title: titles.apps,     href: `${docsRoot}/apps` },
      { slug: 'skills',      title: titles.skills,   href: `${docsRoot}/skills` },
      { slug: 'connects',    title: titles.connects, href: `${docsRoot}/connects` },
    ],
  },
  {
    label: labels.run,
    items: [
      { slug: 'executions',  title: titles.executions, href: `${docsRoot}/executions` },
      { slug: 'schedules',   title: titles.schedules,  href: `${docsRoot}/schedules` },
      { slug: 'sandbox',     title: titles.sandbox,    href: `${docsRoot}/sandbox` },
    ],
  },
  {
    label: labels.ref,
    items: [
      { slug: 'artifacts',   title: titles.artifacts, href: `${docsRoot}/artifacts` },
    ],
  },
];

// Flatten for prev/next pager
const flat = sections.flatMap((s) => s.items.map((it) => ({ ...it, sectionLabel: s.label })));
const currentIndex = flat.findIndex((i) => i.slug === current);
const prevItem = currentIndex > 0 ? flat[currentIndex - 1] : null;
const nextItem = currentIndex < flat.length - 1 && currentIndex !== -1 ? flat[currentIndex + 1] : null;
const currentItem = currentIndex !== -1 ? flat[currentIndex] : null;
---

<div class="docs-layout">
  <!-- ── SIDEBAR ───────────────────────────────────────────── -->
  <aside class="docs-sidebar" data-docs-sidebar>
    <div class="docs-sidebar-inner">
      <div class="docs-sidebar-brand">
        <span class="docs-sidebar-kicker">{ui.docsKicker}</span>
      </div>
      <button
        type="button"
        class="docs-sidebar-toggle"
        aria-expanded="false"
        aria-controls="docs-nav"
        data-docs-sidebar-toggle
      >
        <span class="docs-sidebar-toggle-kicker">{ui.docsKicker}</span>
        <span class="docs-sidebar-toggle-current">
          {currentItem ? (
            <>
              {current !== 'index' && (
                <>
                  <span class="docs-sidebar-toggle-section">{currentItem.sectionLabel}</span>
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </>
              )}
              <span class="docs-sidebar-toggle-title">{currentItem.title}</span>
            </>
          ) : (
            <span class="docs-sidebar-toggle-title">{ui.docsCrumb}</span>
          )}
        </span>
        <svg class="docs-sidebar-toggle-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
      <nav class="docs-nav" id="docs-nav">
        {sections.map((section) => (
          <div class="docs-nav-section">
            <div class="docs-nav-label">{section.label}</div>
            <ul class="docs-nav-list">
              {section.items.map((item) => {
                const active = item.slug === current;
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`docs-nav-link ${active ? 'is-active' : ''}`}
                      aria-current={active ? 'page' : undefined}
                    >
                      <span class="docs-nav-bar" aria-hidden="true"></span>
                      <span class="docs-nav-text">{item.title}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </nav>
    </div>
  </aside>

  <!-- ── CONTENT ───────────────────────────────────────────── -->
  <div class="docs-main">
    {currentItem && current !== 'index' && (
      <div class="docs-breadcrumb">
        <a href={docsRoot}>{ui.docsCrumb}</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        <span class="docs-breadcrumb-section">{currentItem.sectionLabel}</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        <span class="docs-breadcrumb-current">{currentItem.title}</span>
      </div>
    )}

    <article class="docs-content min-w-0">
      <slot />
    </article>

    {(prevItem || nextItem) && (
      <nav class="docs-pager" aria-label="Page navigation">
        {prevItem ? (
          <a href={prevItem.href} class="docs-pager-link docs-pager-prev">
            <span class="docs-pager-meta">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
              {ui.prev}
            </span>
            <span class="docs-pager-title">{prevItem.title}</span>
          </a>
        ) : <span></span>}
        {nextItem ? (
          <a href={nextItem.href} class="docs-pager-link docs-pager-next">
            <span class="docs-pager-meta">
              {ui.next}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </span>
            <span class="docs-pager-title">{nextItem.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}
  </div>

  <!-- ── RIGHT RAIL (TOC) ──────────────────────────────────── -->
  <aside class="docs-toc-rail" aria-label={ui.onThisPage}>
    <div class="docs-toc-inner">
      <div class="docs-toc-kicker">{ui.onThisPage}</div>
      <ol class="docs-toc" id="docs-toc"></ol>
    </div>
  </aside>
</div>

<script is:inline>
  (function () {
    function slugify(text) {
      return String(text)
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_]+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
    }

    function init() {
      var content = document.querySelector('.docs-content');
      var toc = document.getElementById('docs-toc');
      if (!content || !toc) return;

      // Idempotent across navigations — clear any prior build, restore rail visibility.
      toc.innerHTML = '';
      var rail = document.querySelector('.docs-toc-rail');
      if (rail) rail.style.display = '';

      var headings = content.querySelectorAll('h2, h3');
      var entries = [];

      headings.forEach(function (h) {
        if (!h.id) {
          var base = slugify(h.textContent || '');
          var id = base || 'section';
          var n = 2;
          while (document.getElementById(id)) {
            id = base + '-' + n++;
          }
          h.id = id;
        }

        // Anchor link inside heading (visible on hover)
        if (!h.querySelector('.heading-anchor')) {
          var anchor = document.createElement('a');
          anchor.href = '#' + h.id;
          anchor.className = 'heading-anchor';
          anchor.setAttribute('aria-label', 'Link to ' + (h.textContent || 'section'));
          anchor.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.72"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.72-1.72"/></svg>';
          h.appendChild(anchor);
        }

        entries.push({ id: h.id, text: h.textContent.replace(/#$/, '').trim(), level: h.tagName === 'H3' ? 3 : 2, el: h });
      });

      if (entries.length === 0) {
        if (rail) rail.style.display = 'none';
        return;
      }

      // Build TOC list
      entries.forEach(function (e) {
        var li = document.createElement('li');
        li.className = 'docs-toc-item level-' + e.level;
        var a = document.createElement('a');
        a.href = '#' + e.id;
        a.textContent = e.text;
        a.dataset.tocFor = e.id;
        li.appendChild(a);
        toc.appendChild(li);
      });

      // Scroll-spy via IntersectionObserver
      var links = {};
      toc.querySelectorAll('a[data-toc-for]').forEach(function (a) {
        links[a.dataset.tocFor] = a;
      });

      var visible = {};
      var observer = new IntersectionObserver(
        function (changes) {
          changes.forEach(function (c) {
            visible[c.target.id] = c.isIntersecting;
          });
          var firstId = entries.find(function (e) { return visible[e.id]; });
          if (firstId) {
            Object.keys(links).forEach(function (id) {
              links[id].classList.toggle('is-active', id === firstId.id);
            });
          }
        },
        { rootMargin: '-80px 0px -65% 0px', threshold: [0, 1] }
      );

      entries.forEach(function (e) { observer.observe(e.el); });
    }

    // Run on initial load AND after every Astro view transition.
    // `astro:page-load` covers both — DOMContentLoaded doesn't fire after
    // client-side navigations driven by <ClientRouter />.
    document.addEventListener('astro:page-load', init);
  })();
</script>

<script is:inline>
  (function () {
    function initSidebarToggle() {
      var sidebar = document.querySelector('[data-docs-sidebar]');
      var toggle = document.querySelector('[data-docs-sidebar-toggle]');
      if (!sidebar || !toggle) return;

      // Reset state on (re)init — start collapsed on mobile.
      sidebar.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');

      toggle.addEventListener('click', function () {
        var open = sidebar.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });

      // Collapse after picking an item (mobile only).
      sidebar.querySelectorAll('.docs-nav-link').forEach(function (a) {
        a.addEventListener('click', function () {
          if (window.matchMedia('(max-width: 767px)').matches) {
            sidebar.classList.remove('is-open');
            toggle.setAttribute('aria-expanded', 'false');
          }
        });
      });
    }
    document.addEventListener('astro:page-load', initSidebarToggle);
  })();
</script>

<style is:global>
  /* ── Layout ─────────────────────────────────────────────────── */
  /* Matches .aw-container width (80rem) and gutters so docs page
     chrome lines up with the rest of the site. Content column fills
     all available space between the sidebar and the optional TOC rail. */
  .docs-layout {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .docs-layout {
      padding: 3rem 2.5rem 6rem;
      grid-template-columns: 200px minmax(0, 1fr);
      gap: 3rem;
    }
  }
  @media (min-width: 1200px) {
    .docs-layout {
      grid-template-columns: 220px minmax(0, 1fr) 220px;
      gap: 3rem;
    }
  }

  /* ── Sidebar ────────────────────────────────────────────────── */
  .docs-sidebar { position: relative; }
  @media (min-width: 768px) {
    .docs-sidebar {
      position: sticky;
      top: 5.5rem;
      align-self: start;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      overflow-x: hidden;
      padding-right: 0.5rem;
      margin-right: -0.5rem;
    }
    .docs-sidebar::-webkit-scrollbar { width: 6px; }
    .docs-sidebar::-webkit-scrollbar-thumb {
      background: var(--aw-color-border);
      border-radius: 3px;
    }
  }
  .docs-sidebar-brand {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--aw-color-border);
  }
  .docs-sidebar-kicker {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--aw-color-text-muted);
  }

  /* ── Mobile sidebar toggle ───────────────────────────────── */
  .docs-sidebar-toggle {
    display: none;
    width: 100%;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    border-radius: 8px;
    color: var(--aw-color-text-default);
    cursor: pointer;
    text-align: left;
    transition: border-color 120ms ease, background-color 120ms ease;
  }
  .docs-sidebar-toggle:hover { border-color: var(--aw-color-border-strong); }
  .docs-sidebar-toggle:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--aw-color-bg-page), 0 0 0 4px rgba(82, 153, 97, 0.45);
  }
  .docs-sidebar-toggle-kicker {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aw-color-text-muted);
    padding-right: 0.5rem;
    border-right: 1px solid var(--aw-color-border);
  }
  .docs-sidebar-toggle-current {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex: 1 1 auto;
    min-width: 0;
    font-size: 0.875rem;
  }
  .docs-sidebar-toggle-section {
    color: var(--aw-color-text-muted);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 8rem;
  }
  .docs-sidebar-toggle-current svg {
    flex-shrink: 0;
    color: var(--aw-color-text-muted);
    opacity: 0.6;
  }
  .docs-sidebar-toggle-title {
    color: var(--aw-color-text-heading);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .docs-sidebar-toggle-chevron {
    flex-shrink: 0;
    color: var(--aw-color-text-muted);
    transition: transform 180ms ease;
  }
  .docs-sidebar[data-docs-sidebar].is-open .docs-sidebar-toggle-chevron {
    transform: rotate(180deg);
  }

  /* Mobile: collapse nav by default, hide kicker brand (toggle replaces it). */
  @media (max-width: 767px) {
    .docs-sidebar-brand { display: none; }
    .docs-sidebar-toggle { display: inline-flex; }
    .docs-nav {
      display: none;
      margin-top: 0.75rem;
      padding: 0.5rem 0.25rem 0.25rem;
      border: 1px solid var(--aw-color-border);
      border-radius: 8px;
      background: var(--aw-color-bg-page);
    }
    .docs-sidebar[data-docs-sidebar].is-open .docs-nav {
      display: flex;
      animation: docs-nav-in 160ms ease-out;
    }
    @keyframes docs-nav-in {
      from { opacity: 0; transform: translateY(-2px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }
  .docs-nav { display: flex; flex-direction: column; gap: 1.5rem; }
  .docs-nav-section {}
  .docs-nav-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--aw-color-text-muted);
    margin-bottom: 0.625rem;
    padding-left: 0.5rem;
  }
  .docs-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .docs-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem 0.375rem 0.5rem;
    border-radius: 6px;
    text-decoration: none !important;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--aw-color-text-default);
    position: relative;
    transition: color 120ms ease, background-color 120ms ease;
  }
  .docs-nav-link:hover {
    color: var(--aw-color-primary, #529961);
    background: rgba(82, 153, 97, 0.04);
  }
  .docs-nav-bar {
    width: 2px;
    height: 14px;
    border-radius: 2px;
    background: transparent;
    transition: background-color 120ms ease;
    flex-shrink: 0;
  }
  .docs-nav-link:hover .docs-nav-bar {
    background: rgba(82, 153, 97, 0.3);
  }
  .docs-nav-link.is-active {
    color: var(--aw-color-primary, #529961);
    background: rgba(82, 153, 97, 0.09);
    font-weight: 600;
  }
  .docs-nav-link.is-active .docs-nav-bar {
    background: var(--aw-color-primary, #529961);
    height: 16px;
  }
  .docs-nav-link:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--aw-color-bg-page), 0 0 0 4px rgba(82, 153, 97, 0.45);
  }

  /* ── Main content area ───────────────────────────────────── */
  .docs-main { min-width: 0; }
  .docs-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .docs-breadcrumb a {
    color: var(--aw-color-text-muted) !important;
    text-decoration: none !important;
    transition: color 120ms ease;
  }
  .docs-breadcrumb a:hover { color: var(--aw-color-primary, #529961) !important; }
  .docs-breadcrumb svg { color: var(--aw-color-text-muted); opacity: 0.6; }
  .docs-breadcrumb-section { color: var(--aw-color-text-muted); }
  .docs-breadcrumb-current { color: var(--aw-color-text-heading); font-weight: 500; }

  /* ── Typography (within .docs-content) ───────────────────── */
  .docs-content {
    /* All content elements inherit this max-width; no need to set on each. */
    max-width: 100%;
  }
  .docs-content h1 {
    font-size: clamp(2rem, 3.6vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.028em;
    line-height: 1.12;
    color: var(--aw-color-text-heading);
    margin: 0 0 1.125rem;
    text-wrap: balance;
  }
  .docs-content > .lead {
    font-size: 1.0625rem;
    color: var(--aw-color-text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    text-wrap: pretty;
  }
  .docs-content h2 {
    font-size: 1.4375rem;
    font-weight: 700;
    letter-spacing: -0.022em;
    line-height: 1.3;
    color: var(--aw-color-text-heading);
    margin: 2.75rem 0 0.875rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--aw-color-border);
    position: relative;
    scroll-margin-top: 5rem;
  }
  .docs-content h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--aw-color-text-heading);
    margin: 1.75rem 0 0.5rem;
    position: relative;
    scroll-margin-top: 5rem;
  }
  .docs-content h4 {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    margin: 1.25rem 0 0.5rem;
  }
  .docs-content p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--aw-color-text-default);
    margin: 0 0 1rem;
  }
  .docs-content ul, .docs-content ol {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--aw-color-text-default);
    margin: 0 0 1rem;
    padding-left: 1.25rem;
  }
  .docs-content ul { list-style: disc; }
  .docs-content ol { list-style: decimal; }
  .docs-content li { margin-bottom: 0.375rem; }
  .docs-content li::marker { color: var(--aw-color-text-muted); }
  .docs-content strong {
    color: var(--aw-color-text-heading);
    font-weight: 600;
  }
  .docs-content em { font-style: italic; }
  .docs-content hr {
    border: 0;
    border-top: 1px solid var(--aw-color-border);
    margin: 2rem 0;
  }

  /* ── Heading anchor (# on hover) ─────────────────────────── */
  .docs-content h2 .heading-anchor,
  .docs-content h3 .heading-anchor {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: 0.5rem;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 4px;
    color: var(--aw-color-text-muted);
    text-decoration: none !important;
