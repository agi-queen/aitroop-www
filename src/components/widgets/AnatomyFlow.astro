---
/*
  AnatomyFlow — three-step pipeline: AppInput → Stage → Artifact.
  Typography-led: a large number, a step title, a description, a quiet
  footnote. No inline UI mockups — the hero demo already carries that
  weight. Cards are borderless on desktop, separated by hairlines, so
  the section reads like editorial copy rather than a feature grid.
*/

export interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  steps: {
    title: string;
    desc: string;
    foot: string;
  }[];
}

const {
  eyebrow = 'Anatomy',
  title,
  lede,
  steps,
} = Astro.props;
---

<header class="aw-section-head anatomy-head">
  {eyebrow && <p class="aw-eyebrow">{eyebrow}</p>}
  <h2 class="aw-h2 anatomy-title">{title}</h2>
  {lede && <p class="aw-lede anatomy-lede">{lede}</p>}
</header>

<ol class="anatomy-flow">
  {steps.map((step, i) => (
    <li class="flow-step">
      <article class="step-card">
        <span class="step-num">{String(i + 1).padStart(2, '0')}</span>
        <h3 class="step-title">{step.title}</h3>
        <p class="step-desc">{step.desc}</p>
        <p class="step-foot">{step.foot}</p>
      </article>
    </li>
  ))}
</ol>

<style>
  .anatomy-head { max-width: 56rem; }
  .anatomy-title { max-width: 22ch; }
  .anatomy-lede { max-width: 52ch; margin: 0; }

  /* ── Flow container ───────────────────────────────────────────── */
  .anatomy-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 1024px) {
    .anatomy-flow {
      grid-template-columns: repeat(3, 1fr);
      column-gap: 3.5rem;
    }
  }

  .flow-step {
    display: block;
  }

  /* ── Step — borderless column separated by hairlines ──────────── */
  .step-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 0;
    border-top: 1px solid var(--aw-color-border);
  }
  .flow-step:last-child .step-card {
    border-bottom: 1px solid var(--aw-color-border);
  }
  @media (min-width: 1024px) {
    .step-card {
      padding: 2.25rem 0 0;
      border-top: 1px solid var(--aw-color-border);
    }
    .flow-step:last-child .step-card {
      border-bottom: none;
    }
  }

  .step-num {
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    letter-spacing: 0.18em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .step-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.018em;
    line-height: 1.15;
  }
  @media (min-width: 1024px) {
    .step-title { font-size: 1.625rem; }
  }

  .step-desc {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
    max-width: 38ch;
  }

  .step-foot {
    margin: 0.25rem 0 0;
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: var(--aw-color-text-muted);
    text-transform: uppercase;
  }
</style>
