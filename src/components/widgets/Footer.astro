---
import { Icon } from 'astro-icon/components';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links?: Array<Links>;
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { links = [], socialLinks = [], footNote = '' } = Astro.props;

// Flatten all footer links into a single list for the compact bar
const allLinks = links.flatMap(({ links }) => links);
---

<footer class="border-t border-[var(--aw-color-border)] bg-page not-prose">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-12 flex items-center justify-between gap-4">
    <!-- Left: copyright -->
    <div class="text-xs text-[var(--aw-color-text-muted)] shrink-0">
      <Fragment set:html={footNote} />
    </div>

    <!-- Right: links + social -->
    <div class="flex items-center gap-4">
      {allLinks.map(({ text, href }) => (
        <a
          href={href}
          class="text-xs text-[var(--aw-color-text-muted)] hover:text-[var(--aw-color-text-default)] transition-colors duration-150 whitespace-nowrap"
        >
          <Fragment set:html={text} />
        </a>
      ))}
      {socialLinks.map(({ ariaLabel, href, icon }) => (
        <a
          href={href}
          aria-label={ariaLabel}
          class="text-[var(--aw-color-text-muted)] hover:text-[var(--aw-color-text-default)] transition-colors duration-150"
        >
          {icon && <Icon name={icon} class="w-3.5 h-3.5" />}
        </a>
      ))}
    </div>
  </div>
</footer>
