---
import { Icon } from 'astro-icon/components';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links?: Array<Links>;
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { links = [], secondaryLinks = [], socialLinks = [], footNote = '' } = Astro.props;

const navLinks = links.flatMap(({ links }) => links);
const policyLinks = secondaryLinks;
---

<footer class="aw-footer border-t border-[var(--aw-color-border)] bg-page not-prose">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-5 sm:py-0 sm:min-h-[3.25rem] flex flex-col-reverse sm:flex-row sm:items-center justify-between gap-3 sm:gap-6">

    <!-- Copyright -->
    <div class="aw-footnote text-xs text-[var(--aw-color-text-muted)] leading-relaxed shrink-0">
      <Fragment set:html={footNote} />
    </div>

    <!-- Links & social -->
    <div class="flex flex-wrap items-center gap-x-0.5 gap-y-1.5">

      {navLinks.map(({ text, href }, i) => (
        <Fragment>
          {i > 0 && <span class="aw-footer-sep select-none" aria-hidden="true">·</span>}
          <a href={href} class="aw-footer-link">
            <Fragment set:html={text} />
          </a>
        </Fragment>
      ))}

      {navLinks.length > 0 && policyLinks.length > 0 && (
        <span class="aw-footer-divider hidden sm:block" aria-hidden="true" />
      )}

      {policyLinks.map(({ text, href }, i) => (
        <Fragment>
          {i > 0 && <span class="aw-footer-sep select-none" aria-hidden="true">·</span>}
          <a href={href} class="aw-footer-link">
            <Fragment set:html={text} />
          </a>
        </Fragment>
      ))}

      {socialLinks.length > 0 && (
        <span class="aw-footer-divider hidden sm:block" aria-hidden="true" />
      )}
      {socialLinks.map(({ ariaLabel, href, icon }) => (
        <a href={href} aria-label={ariaLabel} class="aw-footer-social ml-0.5">
          {icon && <Icon name={icon} class="w-[14px] h-[14px]" />}
        </a>
      ))}

    </div>
  </div>
</footer>

<style>
  .aw-footnote :global(a) {
    color: var(--aw-color-text-muted);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .aw-footnote :global(a:hover) { color: var(--aw-color-text-heading); }

  .aw-footer-link {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    padding: 0.25rem 0.4rem;
    border-radius: 4px;
    transition: color 160ms ease, background-color 160ms ease;
    text-decoration: none;
  }
  .aw-footer-link:hover {
    color: var(--aw-color-text-heading);
    background-color: var(--aw-color-bg-subtle);
  }

  .aw-footer-sep {
    color: var(--aw-color-border);
    font-size: 0.75rem;
    line-height: 1;
    padding: 0 0.05rem;
  }

  .aw-footer-divider {
    width: 1px;
    height: 12px;
    background-color: var(--aw-color-border);
    margin: 0 0.4rem;
  }

  .aw-footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 6px;
    color: var(--aw-color-text-muted);
    transition: color 160ms ease, background-color 160ms ease;
  }
  .aw-footer-social:hover {
    color: var(--aw-color-text-heading);
    background-color: var(--aw-color-bg-subtle);
  }
</style>
