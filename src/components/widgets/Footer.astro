---
import { Icon } from 'astro-icon/components';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links?: Array<Links>;
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
  brand?: string;
  tagline?: string;
  theme?: string;
}

const {
  links = [],
  secondaryLinks = [],
  socialLinks = [],
  footNote = '',
  brand = 'AITROOP',
  tagline = 'Save chats as Apps. Run them like agents.',
} = Astro.props;

const legalGroup = secondaryLinks.length > 0
  ? [{ title: 'Legal', links: secondaryLinks }]
  : [];
const columns = [...links, ...legalGroup];
---

<footer class="aw-footer not-prose">
  <div class="aw-container-wide footer-shell">

    <!-- Top: brand + link columns ─────────────────────────── -->
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="brand-mark" aria-label={brand}>
          <span class="brand-dot" aria-hidden="true"></span>
          <span class="brand-name">{brand}</span>
        </a>
        {tagline && <p class="brand-tagline">{tagline}</p>}
      </div>

      {columns.length > 0 && (
        <div class="footer-cols">
          {columns.map((group) => (
            <div class="footer-col">
              {group.title && <h4 class="col-title">{group.title}</h4>}
              <ul class="col-list" role="list">
                {group.links.map(({ text, href }) => (
                  <li>
                    <a href={href} class="col-link">
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Bottom: footnote + social ─────────────────────────── -->
    <div class="footer-meta">
      <div class="footer-note">
        <Fragment set:html={footNote} />
      </div>
      {socialLinks.length > 0 && (
        <div class="footer-socials">
          {socialLinks.map(({ ariaLabel, href, icon }) => (
            <a href={href} aria-label={ariaLabel} class="social-link">
              {icon && <Icon name={icon} class="w-[15px] h-[15px]" />}
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Big watermark ─────────────────────────────────────── -->
    <div class="footer-watermark" aria-hidden="true">
      <span class="watermark-text">{brand}</span>
    </div>
  </div>
</footer>

<style>
  .aw-footer {
    position: relative;
    border-top: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    overflow: hidden;
  }
  .footer-shell {
    position: relative;
    padding-top: 4rem;
    padding-bottom: 0;
  }
  @media (min-width: 768px) {
    .footer-shell { padding-top: 5rem; }
  }

  /* ── Top: brand + columns ───────────────────────────────── */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
  }
  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 1.1fr 1.4fr;
      gap: 3rem;
      padding-bottom: 3rem;
    }
  }
  @media (min-width: 1024px) {
    .footer-top {
      grid-template-columns: 1.2fr 1.6fr;
      gap: 4rem;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    max-width: 32ch;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--aw-color-text-heading);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-size: 0.9375rem;
  }
  .brand-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--aw-color-primary);
    box-shadow: 0 0 0 3px rgba(82, 153, 97, 0.18);
  }
  .brand-name { font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace); }
  .brand-tagline {
    margin: 0;
    color: var(--aw-color-text-muted);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem 1.25rem;
  }
  @media (min-width: 640px) {
    .footer-cols { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .footer-col { min-width: 0; }
  .col-title {
    margin: 0 0 0.875rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
  }
  .col-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .col-link {
    color: var(--aw-color-text-default);
    text-decoration: none;
    font-size: 0.875rem;
    line-height: 1.4;
    transition: color 160ms ease;
  }
  .col-link:hover { color: var(--aw-color-primary); }

  /* ── Meta row ───────────────────────────────────────────── */
  .footer-meta {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column-reverse;
    gap: 1rem;
    padding: 1.25rem 0 2rem;
    border-top: 1px solid var(--aw-color-border);
  }
  @media (min-width: 640px) {
    .footer-meta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 0 2.5rem;
    }
  }
  .footer-note {
    color: var(--aw-color-text-muted);
    font-size: 0.75rem;
    line-height: 1.55;
  }
  .footer-note :global(a) {
    color: var(--aw-color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--aw-color-border);
    transition: color 160ms ease, border-color 160ms ease;
  }
  .footer-note :global(a:hover) {
    color: var(--aw-color-text-heading);
    border-bottom-color: var(--aw-color-primary);
  }

  .footer-socials {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    color: var(--aw-color-text-muted);
    transition: color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }
  .social-link:hover {
    color: var(--aw-color-primary);
    background-color: rgba(82, 153, 97, 0.10);
    transform: translateY(-1px);
  }

  /* ── Big watermark ──────────────────────────────────────── */
  .footer-watermark {
    position: relative;
    z-index: 1;
    margin-top: -1rem;
    pointer-events: none;
    user-select: none;
    line-height: 0.78;
  }
  .watermark-text {
    display: block;
    width: 100%;
    text-align: center;
    font-family: var(--aw-font-heading, var(--aw-font-sans, system-ui), sans-serif);
    font-weight: 800;
    font-size: clamp(5rem, 19vw, 17rem);
    letter-spacing: -0.04em;
    line-height: 0.78;
    color: transparent;
    background:
      linear-gradient(
        180deg,
        rgba(82, 153, 97, 0.22) 0%,
        rgba(82, 153, 97, 0.10) 45%,
        rgba(82, 153, 97, 0.02) 80%,
        transparent 100%
      );
    -webkit-background-clip: text;
            background-clip: text;
    transform: translateY(0.18em);
  }

  @media (prefers-reduced-motion: reduce) {
    .social-link { transition: color 160ms ease, background-color 160ms ease; }
  }
</style>
