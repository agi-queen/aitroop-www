---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '解決方案',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="解決方案"
    title="無論你在增長旅程的哪個階段，Aitroop 都有答案"
    subtitle="獲客難、跟進累、留客靠感情——這些問題不是規模的問題，而是方法的問題。Aitroop 把 AI 的力量帶到每一個增長場景，讓你用更少的精力，做出更可預測的成果。"
    image={{
      src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Aitroop 解決方案',
    }}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="場景一"
    title="從零開始找到第一批精準客戶"
    items={[
      {
        title: '不再大海撈針，直接找「對的人」',
        description:
          'AI 分析你的目標客群特徵，自動在資料庫中篩選匹配的潛在客戶，並補全有效的聯繫方式。你只需要決定「找哪類人」，剩下的交給系統。',
        icon: 'tabler:crosshair',
      },
      {
        title: '90 秒了解一個陌生客戶',
        description:
          'AI Research Agent 自動調研目標對象的業務背景、近期動態和潛在痛點，生成結構化的客戶摘要。你在開口說話之前，就已經比對方更了解他自己的需求。',
        icon: 'tabler:clock',
      },
      {
        title: '第一封信就讓對方感覺「這是為我寫的」',
        description:
          'AI 根據真實的客戶背景——近期新聞、業務方向、公開言論——生成有具體切入點的個性化開場白。不是模板，是真實的連結感。',
        icon: 'tabler:mail-heart',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: '精準獲客',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">精準，是獲客效率的乘數</h3>
      找到一百個普通線索，不如找到十個真正有需求的人。Aitroop 讓你把精力放在值得溝通的對象上。
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="場景二"
    title="規模化觸達，不犧牲個性化品質"
    items={[
      {
        title: '一個人，做出整個外聯團隊的產出',
        description:
          '批量生成個性化觸達內容，每一封都有真實的切入點。逐條預覽確認，一鍵發送。原本需要一天才能做完的工作，現在一小時搞定。',
        icon: 'tabler:users',
      },
      {
        title: '設定一次，系統持續跟進',
        description:
          '設定跟進節奏和觸達渠道，系統自動在對的時間送出對的內容。你不需要每天盯著哪些人該跟進了——有回覆的時候，系統會通知你。',
        icon: 'tabler:repeat',
      },
      {
        title: '郵件確實進主收件箱',
        description:
          '寫了絕妙的開場白，結果進了垃圾箱，一切白費。Aitroop 的送達率基礎設施——域名預熱、信譽監控、智能輪轉——確保你的心血真的被看見。',
        icon: 'tabler:mail-check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1533750349088-cd871a92f312?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: '規模化個性化觸達',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">個性化 × 規模化，魚與熊掌都要</h3>
      這個矛盾在 AI 時代已經可以化解。你不需要在品質和數量之間做取捨。
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    tagline="場景三"
    title="把隱形的興趣轉化成可行動的機會"
    items={[
      {
        title: '97% 的訪客不留資料就離開',
        description:
          'Aitroop 的訪客識別技術，讓你看見那些悄悄瀏覽你官網、研究你產品的潛在客戶。IP 反查匹配公司資訊，結合訪問頁面和停留時長，識別真正有興趣的對象。',
        icon: 'tabler:eye',
      },
      {
        title: '三維意圖信號，不靠猜測',
        description:
          '官網行為、第三方意圖數據、產品使用信號——三個維度的興趣信號融合成統一的意圖評分。高意圖對象自動推送到跟進隊列，讓你在最佳時機出現。',
        icon: 'tabler:radar',
      },
      {
        title: '搶在競爭對手之前',
        description:
          '當一個潛在客戶正在研究解決方案的時候，誰先出現誰就有優勢。Aitroop 讓你做到這件事，而不需要一直守著官網分析後台。',
        icon: 'tabler:bolt',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1543286386-713bdd548da4?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: '意圖識別與轉化',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">主動出擊，而不是等人上門</h3>
      增長不靠等待，靠的是在對的時機找到對的人。意圖雷達讓這件事變得系統化。
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="場景四"
    title="守住客戶，比獲得新客戶更划算"
    items={[
      {
        title: '在客戶開始冷淡之前就察覺',
        description:
          'Aitroop 持續追蹤客戶的使用狀況和互動頻率，自動計算健康度評分。當信號開始下滑，系統在第一時間通知你，讓你有足夠的時間採取行動。',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: '個性化的留存和增購觸達',
        description:
          '根據每個客戶的使用深度和旅程階段，自動觸發有針對性的培育內容或升級建議。不是群發通知，而是基於真實行為的個性化互動。',
        icon: 'tabler:arrow-up-circle',
      },
      {
        title: '把每一個滿意的客戶變成推薦來源',
        description:
          '客戶最滿意的時候，是推薦你的最好時機。Aitroop 幫你識別這個時機，並自動啟動推薦邀請，讓你的獲客成本持續下降。',
        icon: 'tabler:users-group',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1573497491765-dccce02b29df?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: '客戶留存與增長',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">留住客戶，是複利最強的增長引擎</h3>
      獲客是開始，守住客戶、讓客戶帶來更多客戶，才是可持續增長的真正源頭。
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features3 Widget ************** -->

  <Features3
    tagline="核心技能模組"
    title="掌握這六項 AI 複合能力，讓你在增長上無可取代"
    columns={3}
    items={[
      {
        title: '數據洞察力',
        description: '讀懂客戶數據、識別意圖信號、量化渠道效果，讓每個決策都有依據。',
        icon: 'tabler:chart-bar',
      },
      {
        title: '精準觸達力',
        description: '找到對的人、說對的話、在對的時機出現，提升每一次溝通的命中率。',
        icon: 'tabler:target',
      },
      {
        title: '個性化創作力',
        description: '用 AI 大規模生成有真實切入點的個性化內容，品質不輸手寫，速度快 50 倍。',
        icon: 'tabler:pencil',
      },
      {
        title: '自動化執行力',
        description: '把重複性工作系統化，設定一次規則持續運轉，把精力留給需要判斷力的事。',
        icon: 'tabler:settings-automation',
      },
      {
        title: '客戶洞察力',
        description: '理解客戶的健康狀態、需求變化和流失風險，在最關鍵的時刻主動出現。',
        icon: 'tabler:eye',
      },
      {
        title: '增長預測力',
        description: '把直覺變成數據，用可信的預測支撐增長決策，不再靠感覺行事。',
        icon: 'tabler:trending-up',
      },
    ]}
    isBeforeContent={true}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: '觸達效率提升', amount: '10x' },
      { title: '意圖識別準確率', amount: '60%+' },
      { title: '平均留存率提升', amount: '25%' },
      { title: '流失預警提前', amount: '30天' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '找我們聊聊你的增長挑戰',
        href: '/contact',
        icon: 'tabler:messages',
      },
    ]}
    title="你面對的增長挑戰，Aitroop 大概率有答案"
    subtitle="每個人的場景不同。告訴我們你現在卡在哪裡，我們來展示最有針對性的解決方式。"
  />
</Layout>
