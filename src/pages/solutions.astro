---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Solutions',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Solutions"
    title="Whatever Stage of Growth You Are At, Aitroop Has an Answer"
    subtitle="Hard to acquire customers, exhausting follow-ups, retention built on personal relationships — these are not problems of scale. They are problems of method. Aitroop brings the power of AI to every growth scenario, so you achieve more predictable results with less effort."
    image={{
      src: '/illustrations/global-team_8jok.svg', width: 1024, height: 768,
      alt: 'Aitroop Solutions',
    }}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="Scenario 1"
    title="Find Your First High-Quality Customers From Scratch"
    items={[
      {
        title: 'Stop Searching Blindly — Go Straight to the Right People',
        description:
          'AI analyzes the attributes of your target audience, automatically filters matching prospects from the database, and fills in verified contact information. You decide who to look for — the system handles the rest.',
        icon: 'tabler:crosshair',
      },
      {
        title: 'Know a Stranger in 90 Seconds',
        description:
          "The AI Research Agent automatically investigates a prospect's business background, recent developments, and likely pain points, producing a structured summary. By the time you open your mouth, you already understand their needs better than they expect.",
        icon: 'tabler:clock',
      },
      {
        title: 'Make the First Message Feel Like It Was Written Just for Them',
        description:
          "AI generates a personalized opening line grounded in real context — recent news, business direction, public statements. Not a template. A genuine point of connection.",
        icon: 'tabler:mail-heart',
      },
    ]}
    image={{
      src: '/illustrations/data-analysis_b7cp.svg', width: 1024, height: 768,
      alt: 'Precision Prospecting',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Precision Is the Multiplier of Acquisition Efficiency</h3>
      Finding a hundred average leads is worth less than finding ten people with a genuine need. Aitroop lets you put your energy where it counts.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="Scenario 2"
    title="Scale Your Outreach Without Sacrificing Personalization Quality"
    items={[
      {
        title: 'One Person Producing the Output of an Entire Outreach Team',
        description:
          'Generate personalized outreach content in bulk — every message with a real, specific hook. Preview each one, then send with a single click. Work that used to take a full day now takes one hour.',
        icon: 'tabler:users',
      },
      {
        title: 'Set It Once, Let the System Follow Up Forever',
        description:
          'Configure your follow-up cadence and outreach channels, and the system automatically delivers the right content at the right time. You do not need to track who needs a follow-up today — the system notifies you when someone replies.',
        icon: 'tabler:repeat',
      },
      {
        title: 'Emails That Actually Land in the Primary Inbox',
        description:
          "You write the perfect opener, then it ends up in spam — all that effort wasted. Aitroop's deliverability infrastructure — domain warmup, reputation monitoring, intelligent rotation — makes sure your work actually gets seen.",
        icon: 'tabler:mail-check',
      },
    ]}
    image={{
      src: '/illustrations/business-decisions_7vkl.svg', width: 1024, height: 768,
      alt: 'Scaled Personalized Outreach',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Personalization × Scale — You Can Have Both</h3>
      This trade-off is solvable in the AI era. You do not have to choose between quality and volume.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    tagline="Scenario 3"
    title="Turn Hidden Interest Into Actionable Opportunities"
    items={[
      {
        title: '97% of Visitors Leave Without Leaving a Trace',
        description:
          "Aitroop's visitor identification technology lets you see the prospects quietly browsing your website and researching your product. IP reverse lookup matches company information, combined with page views and time-on-site, to surface the visitors who are genuinely interested.",
        icon: 'tabler:eye',
      },
      {
        title: 'Three-Dimensional Intent Signals — No Guesswork',
        description:
          "Website behavior, third-party intent data, and product usage signals — three dimensions of interest fused into a single intent score. High-intent prospects are automatically pushed to the follow-up queue so you show up at the best possible moment.",
        icon: 'tabler:radar',
      },
      {
        title: 'Get There Before the Competition',
        description:
          "When a prospect is actively researching solutions, whoever shows up first has the advantage. Aitroop makes that happen for you — without requiring someone to sit and watch your analytics dashboard all day.",
        icon: 'tabler:bolt',
      },
    ]}
    image={{
      src: '/illustrations/predictive-analytics_6gsu.svg', width: 1024, height: 768,
      alt: 'Intent Identification and Conversion',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Proactive, Not Reactive</h3>
      Growth does not come from waiting. It comes from finding the right person at the right moment. The Intent Radar makes that systematic.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="Scenario 4"
    title="Retaining Customers Is More Cost-Effective Than Acquiring New Ones"
    items={[
      {
        title: 'Detect Cooling Before the Customer Goes Cold',
        description:
          "Aitroop continuously monitors each customer's usage patterns and engagement frequency, automatically calculating a health score. When signals start to slip, the system notifies you immediately — giving you enough time to act.",
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Personalized Retention and Upsell Outreach',
        description:
          "Based on each customer's usage depth and journey stage, the system automatically triggers targeted nurture content or upgrade suggestions. Not a broadcast notification — a personalized interaction grounded in real behavior.",
        icon: 'tabler:arrow-up-circle',
      },
      {
        title: 'Turn Every Satisfied Customer Into a Referral Source',
        description:
          "The moment a customer is most satisfied is the best time to ask for a referral. Aitroop identifies that moment and automatically initiates the referral invitation, steadily lowering your cost of acquisition over time.",
        icon: 'tabler:users-group',
      },
    ]}
    image={{
      src: '/illustrations/remote-worker_0l91.svg', width: 1024, height: 768,
      alt: 'Customer Retention and Growth',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Retention Is the Strongest Compounding Growth Engine</h3>
      Acquisition is only the beginning. Keeping customers, and having them bring in more customers, is the real source of sustainable growth.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    tagline="Scenario 5"
    title="Get the Right Content in Front of the Right Person at the Right Time"
    items={[
      {
        title: 'One Topic, Five Formats, Done in 90 Seconds',
        description:
          "AI generates a long-form blog post, LinkedIn post, outreach email sequence, and newsletter article simultaneously — all matched to your brand voice. Content output increases 5x, marketing-sourced pipeline grows 25–35%, with no increase in headcount.",
        icon: 'tabler:pencil',
      },
      {
        title: 'Strike Within the 24-Hour Golden Window',
        description:
          "A prospect just closed a funding round, just brought in a new executive, just posted a job opening — the 24–72 hours after these events are the optimal outreach window. Aitroop fires an alert within 5–30 minutes, with a recommended angle included, so you are the first to show up.",
        icon: 'tabler:bell',
      },
      {
        title: 'Show Every Visitor the Most Relevant Version of Your Website',
        description:
          "Dynamically adjust your site's headlines, case studies, and calls-to-action based on the visitor's company, industry, and acquisition channel. Demo request rates from target segments increase 20–40%. No additional development required. Marketing response time drops from two weeks to one day.",
        icon: 'tabler:layout-dashboard',
      },
    ]}
    image={{
      src: '/illustrations/teamwork_zplp.svg', width: 1024, height: 768,
      alt: 'Content, Timing, and Personalization',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Content × Timing × Personalization — All Three at Once</h3>
      Most teams can only nail one of the three. Aitroop makes all three happen simultaneously, without adding more people.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features3 Widget ************** -->

  <Features3
    tagline="Core Skill Modules"
    title="Master These Six AI Capabilities — and Become Irreplaceable in Growth"
    columns={3}
    items={[
      {
        title: 'Data Intelligence',
        description: 'Read customer data, identify intent signals, and quantify channel performance — so every decision is evidence-based.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Precision Outreach',
        description: 'Find the right person, say the right thing, and show up at the right moment — improving the hit rate of every conversation.',
        icon: 'tabler:target',
      },
      {
        title: 'Personalized Content Creation',
        description: 'Use AI to generate personalized content with genuine hooks at scale — quality that rivals handwritten copy, 50x faster.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Automated Execution',
        description: 'Systematize repetitive work, set rules once and let them run continuously — reserving your energy for decisions that require judgment.',
        icon: 'tabler:settings-automation',
      },
      {
        title: 'Customer Intelligence',
        description: "Understand each customer's health status, evolving needs, and churn risk — and show up proactively at the moments that matter most.",
        icon: 'tabler:eye',
      },
      {
        title: 'Growth Prediction',
        description: 'Turn intuition into data, and back growth decisions with credible forecasts — no more acting on gut feel alone.',
        icon: 'tabler:trending-up',
      },
    ]}
    isBeforeContent={true}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Increase in Daily Outreach', amount: '6x' },
      { title: 'Personalized Email Reply Rate', amount: '8-15%' },
      { title: 'Churn Warning Lead Time', amount: '90 days' },
      { title: 'Revenue Forecast Error', amount: '<15%' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Talk to Us About Your Growth Challenge',
        href: '/contact',
        icon: 'tabler:messages',
      },
    ]}
    title="Whatever Growth Challenge You Are Facing, Aitroop Very Likely Has an Answer"
    subtitle="Every business situation is different. Tell us where you are stuck, and we will show you the most targeted solution for your context."
  />
</Layout>
