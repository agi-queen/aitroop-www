---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI Agent Platform',
  ignoreTitleTemplate: true,
};

const features = [
  { icon: 'tabler:message-circle',   title: 'Chat',     desc: 'Interactive Claude sessions in isolated sandboxes. Explore, experiment, and iterate with full tool access.' },
  { icon: 'tabler:stack-2',          title: 'Apps',     desc: 'Package any Claude workflow into a reusable one-click tool. Fill a form, get results — no code needed.' },
  { icon: 'tabler:puzzle',           title: 'Skills',   desc: '150+ built-in capabilities — lead gen, CRM sync, web scraping, SEO analysis, content generation, and more.' },
  { icon: 'tabler:plug-connected',   title: 'Connect',  desc: 'OAuth integrations with Salesforce, HubSpot, GitHub, Google Drive, Notion, and 20+ more platforms.' },
  { icon: 'tabler:calendar-clock',   title: 'Schedule', desc: 'Automate any App on a cron schedule. Run daily, weekly, or hourly — results delivered automatically.' },
];

const steps = [
  { n: '01', title: 'Chat & explore',     desc: 'Start a session with Claude. Use built-in skills and connected tools to find exactly what works.' },
  { n: '02', title: 'Package as an App',  desc: 'Save your workflow as a parameterized App in minutes. Define inputs, stages, and expected outputs.' },
  { n: '03', title: 'Run & automate',     desc: 'Run on-demand or schedule it. Every execution is tracked with full artifact history.' },
];

const gtmApps = [
  { icon: 'tabler:radar-2',      title: 'Prospecting', desc: 'Find high-fit leads using company signals, hiring activity, tech stack, and intent data.' },
  { icon: 'tabler:mail-forward', title: 'Outreach',    desc: 'Generate and send personalized cold emails and LinkedIn messages at scale.' },
  { icon: 'tabler:shield-check', title: 'Retention',   desc: 'Monitor health scores and flag at-risk accounts before churn materializes.' },
  { icon: 'tabler:chart-line',   title: 'Insights',    desc: 'Synthesize pipeline data into clear recommendations — know where to focus next.' },
];
---

<Layout metadata={metadata}>

  <!-- HERO -->
  <section class="relative px-6 md:px-10 lg:px-16 pt-10 pb-10 md:pt-12 md:pb-14 overflow-hidden">
    <div class="absolute top-0 left-0 w-[520px] h-[420px] pointer-events-none -z-10"
      style="background:radial-gradient(ellipse at 20% 30%,rgba(82,153,97,0.10) 0%,transparent 65%);"
      aria-hidden="true"></div>

    <div class="mx-auto max-w-6xl">
      <div class="max-w-[680px]">

        <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] mb-3 font-normal tracking-wide">
          AI Agent Platform
        </p>

        <h1 class="text-[2rem] sm:text-[2.375rem] md:text-[2.75rem] lg:text-[3rem] font-black tracking-[-0.03em] leading-[1.1] text-[var(--aw-color-text-heading)] mb-4">
          Build AI agents<br/>for any workflow.
        </h1>

        <p class="text-[1rem] md:text-[1.075rem] leading-[1.75] text-[var(--aw-color-text-muted)] mb-6 max-w-[540px]">
          Turn Claude conversations into reusable Apps — with 150+ built-in skills,
          native integrations, and automated scheduling.
          <span class="text-primary font-medium">Any workflow. No code.</span>
        </p>

        <div class="flex flex-wrap items-center gap-3">
          <a href="https://app.aitroop.net"
            class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
            Start building
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#how-it-works"
            class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
            See how it works
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="py-16 md:py-24 px-4 border-t border-[var(--aw-color-border)]">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="section-title">Everything you need to ship AI agents.</h2>
        <p class="section-sub">Five core capabilities that work together out of the box.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {features.map((f) => (
          <div class="p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] hover:border-primary/25 hover:shadow-[0_8px_30px_rgba(82,153,97,0.09)] hover:-translate-y-1 transition-all duration-200">
            <div class="mb-4 w-10 h-10 rounded-xl bg-primary/[0.08] flex items-center justify-center text-primary">
              <Icon name={f.icon} class="w-5 h-5" />
            </div>
            <h3 class="text-[0.9375rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{f.title}</h3>
            <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="py-16 md:py-24 px-4 bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)]">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <p class="section-label">Simple by design</p>
        <h2 class="section-title">From chat to automated workflow in minutes.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <div class="hidden md:block absolute top-[1.375rem] left-[calc(16.67%+1.375rem)] right-[calc(16.67%+1.375rem)] h-px bg-[var(--aw-color-border)]" aria-hidden="true"></div>

        {steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <div class="relative mb-5 w-11 h-11 rounded-full border-2 border-primary/20 bg-[var(--aw-color-bg-page)] flex items-center justify-center z-10">
              <span class="text-[0.6875rem] font-bold text-primary tracking-wider">{step.n}</span>
            </div>
            <h3 class="text-[0.9375rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{step.title}</h3>
            <p class="text-[0.8125rem] text-[var(--aw-color-text-muted)] leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FIRST USE CASE: GTM -->
  <section class="py-16 md:py-24 px-4">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <p class="section-label">First use case</p>
        <h2 class="section-title">Built for B2B Growth first.</h2>
        <p class="section-sub">Our GTM suite comes pre-loaded with prospecting, outreach, retention, and insights apps — ready to run on day one.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {gtmApps.map((app) => (
          <div class="p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)]">
            <div class="mb-3 w-9 h-9 rounded-lg bg-primary/[0.08] flex items-center justify-center text-primary">
              <Icon name={app.icon} class="w-4 h-4" />
            </div>
            <h3 class="text-[0.875rem] font-semibold text-[var(--aw-color-text-heading)] mb-1.5">{app.title}</h3>
            <p class="text-[0.8125rem] text-[var(--aw-color-text-muted)] leading-relaxed">{app.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CallToAction
    id="cta-section"
    title="Start building your first agent."
    subtitle="Connect your tools, pick a skill, and ship your first App in minutes."
    actions={[
      { text: 'Get started free', href: 'https://app.aitroop.net', variant: 'primary' },
      { text: 'Talk to us', href: '/contact', variant: 'secondary' },
    ]}
  />

</Layout>

<style>
  .section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.5rem;
    opacity: 0.85;
  }
  .section-title {
    font-size: clamp(1.625rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--aw-color-text-heading);
    margin-bottom: 0.75rem;
  }
  .section-sub {
    font-size: 0.9375rem;
    color: var(--aw-color-text-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.75;
  }
</style>
