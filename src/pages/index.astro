---
import Layout from '~/layouts/PageLayout.astro';
import ChatToAppDemo from '~/components/widgets/ChatToAppDemo.astro';

const metadata = {
  title: 'Aitroop — Save AI agent conversations as apps',
  ignoreTitleTemplate: true,
};

const anatomy = [
  { n: '01', title: 'AppInput',  desc: 'A schema-driven form.' },
  { n: '02', title: 'Stage',     desc: 'An agent session with a goal.' },
  { n: '03', title: 'Artifact',  desc: 'The deliverable, ready to chain.' },
];

const stats = [
  { value: '150+', label: 'Skills' },
  { value: '20+',  label: 'Connects' },
  { value: 'cron', label: 'Schedules' },
  { value: '7',    label: 'Artifact formats' },
];

const cases = [
  { slug: '/use-cases/gtm',     title: 'GTM',     desc: 'Prospecting, outreach, pipeline.' },
  { slug: '/use-cases/finance', title: 'Finance', desc: 'Close, audit, variance, reporting.' },
];
---

<Layout metadata={metadata}>

  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">AI Agent Platform</p>
          <h1 class="display">
            Save agent conversations <span class="text-primary">as apps.</span>
          </h1>
          <p class="lede">
            Find what works in a chat. Save it as a one-click App with a form, a goal, and a schedule.
          </p>
          <div class="actions">
            <a href="https://app.aitroop.net" class="btn btn-primary">Start free</a>
            <a href="/use-cases" class="btn btn-ghost">See use cases</a>
          </div>
        </div>
        <div class="hero-demo">
          <ChatToAppDemo />
        </div>
      </div>
    </div>
  </section>

  <!-- ANATOMY ──────────────────────────────────────────────────────── -->
  <section class="block">
    <div class="container">
      <header class="block-head">
        <p class="eyebrow">Anatomy</p>
        <h2 class="h2">An App, in three pieces.</h2>
      </header>

      <div class="anatomy">
        {anatomy.map((a) => (
          <article class="piece">
            <span class="piece-num">{a.n}</span>
            <h3 class="piece-title">{a.title}</h3>
            <p class="piece-desc">{a.desc}</p>
          </article>
        ))}
      </div>

      <div class="stats" role="list">
        {stats.map((s) => (
          <div class="stat" role="listitem">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USE CASES ────────────────────────────────────────────────────── -->
  <section class="block">
    <div class="container">
      <header class="block-head">
        <p class="eyebrow">Use cases</p>
        <h2 class="h2">Built for what you actually do.</h2>
      </header>

      <ul class="cases">
        {cases.map((c) => (
          <li>
            <a href={c.slug}>
              <span class="case-title">{c.title}</span>
              <span class="case-desc">{c.desc}</span>
              <span class="case-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="cta">
    <div class="container container-narrow">
      <h2 class="cta-h2">Ship your first App before lunch.</h2>
      <p class="lede">Open a chat. Click <code>Save as App</code>. That's the loop.</p>
      <div class="actions actions-center">
        <a href="https://app.aitroop.net" class="btn btn-primary">Start free</a>
        <a href="/contact" class="btn btn-ghost">Talk to us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════════════════════════════════════════════════════════════════
     LAYOUT PRIMITIVES — predictable rhythm, no decoration
     ════════════════════════════════════════════════════════════════ */
  .container {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 768px) {
    .container { padding: 0 2.5rem; }
  }
  .container-narrow {
    max-width: 36rem;
    text-align: center;
  }
  .block {
    padding: 6rem 0;
    border-top: 1px solid var(--aw-color-border);
  }
  @media (min-width: 768px) {
    .block { padding: 8rem 0; }
  }
  .block-head {
    margin-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .block-head { margin-bottom: 5rem; }
  }

  /* ════════════════════════════════════════════════════════════════
     TYPOGRAPHY
     ════════════════════════════════════════════════════════════════ */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--aw-color-primary);
    margin: 0 0 1.125rem;
    line-height: 1;
  }
  .eyebrow::before {
    content: '';
    width: 1.25rem;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }

  .display {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--aw-color-text-heading);
    margin: 0 0 1.5rem;
    text-wrap: balance;
    max-width: 14ch;
  }
  .h2 {
    font-size: clamp(1.875rem, 3.4vw, 2.375rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--aw-color-text-heading);
    margin: 0;
    text-wrap: balance;
    max-width: 28ch;
  }
  .lede {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    max-width: 40ch;
    margin: 0 0 2rem;
    text-wrap: pretty;
  }
  .container-narrow .lede { margin: 0 auto 2rem; }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875em;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    background: var(--aw-color-bg-subtle);
    color: var(--aw-color-text-default);
  }

  /* ════════════════════════════════════════════════════════════════
     BUTTONS — real buttons, two variants, restrained
     ════════════════════════════════════════════════════════════════ */
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .actions-center { justify-content: center; }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    padding: 0 1.375rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    line-height: 1;
    white-space: nowrap;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease;
  }
  .btn:focus-visible {
    outline: 2px solid var(--aw-color-primary);
    outline-offset: 2px;
  }
  .btn-primary {
    background: var(--aw-color-primary);
    color: #fff;
    box-shadow:
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 1px 2px rgba(15, 30, 18, 0.06);
  }
  .btn-primary:hover { background: rgb(67, 138, 84); }
  .btn-primary:active {
    box-shadow:
      inset 0 1px 1px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(0, 0, 0, 0.04);
  }
  .btn-ghost {
    color: var(--aw-color-text-default);
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
  }
  .btn-ghost:hover {
    border-color: rgba(0, 0, 0, 0.25);
    background: rgba(0, 0, 0, 0.02);
  }

  /* ════════════════════════════════════════════════════════════════
     HERO
     ════════════════════════════════════════════════════════════════ */
  .hero {
    padding: 6rem 0 5rem;
  }
  @media (min-width: 768px) {
    .hero { padding: 8rem 0 7rem; }
  }
  .hero-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 4rem;
    }
  }

  /* ════════════════════════════════════════════════════════════════
     ANATOMY — three pieces with hairline top border each
     ════════════════════════════════════════════════════════════════ */
  .anatomy {
    display: grid;
    gap: 2rem;
    margin-bottom: 4.5rem;
  }
  @media (min-width: 768px) {
    .anatomy {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
      margin-bottom: 6rem;
    }
  }
  .piece {
    border-top: 1px solid var(--aw-color-text-heading);
    padding-top: 1.25rem;
  }
  .piece-num {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    letter-spacing: 0.06em;
    margin-bottom: 0.875rem;
    font-variant-numeric: tabular-nums;
  }
  .piece-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.375rem;
    letter-spacing: -0.005em;
  }
  .piece-desc {
    margin: 0;
    color: var(--aw-color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  /* ════════════════════════════════════════════════════════════════
     STATS — table-like row with hairline dividers
     ════════════════════════════════════════════════════════════════ */
  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--aw-color-border);
    border: 1px solid var(--aw-color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .stats { grid-template-columns: repeat(4, 1fr); }
  }
  .stat {
    background: var(--aw-color-bg-page);
    padding: 1.125rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .stat-value {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 1rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  /* ════════════════════════════════════════════════════════════════
     USE CASES — editorial row list
     ════════════════════════════════════════════════════════════════ */
  .cases {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cases li { border-top: 1px solid var(--aw-color-border); }
  .cases li:last-child { border-bottom: 1px solid var(--aw-color-border); }
  .cases a {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "title arrow"
      "desc  arrow";
    column-gap: 1rem;
    row-gap: 0.5rem;
    padding: 1.75rem 0;
    align-items: center;
  }
  @media (min-width: 768px) {
    .cases a {
      grid-template-columns: 12rem 1fr auto;
      grid-template-areas: "title desc arrow";
      column-gap: 2.5rem;
      padding: 2.25rem 0;
    }
  }
  .case-title {
    grid-area: title;
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1.1;
    transition: color 200ms ease;
  }
  .case-desc {
    grid-area: desc;
    color: var(--aw-color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .case-arrow {
    grid-area: arrow;
    color: var(--aw-color-text-muted);
    font-size: 1.125rem;
    line-height: 1;
    transition: transform 200ms ease, color 200ms ease;
  }
  .cases a:hover .case-title { color: var(--aw-color-primary); }
  .cases a:hover .case-arrow {
    color: var(--aw-color-primary);
    transform: translateX(4px);
  }

  /* ════════════════════════════════════════════════════════════════
     CTA
     ════════════════════════════════════════════════════════════════ */
  .cta {
    padding: 6rem 0;
    border-top: 1px solid var(--aw-color-border);
  }
  @media (min-width: 768px) {
    .cta { padding: 8rem 0; }
  }
  .cta-h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--aw-color-text-heading);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
</style>
