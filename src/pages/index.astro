---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Aitroop — Save AI agent conversations as apps',
  ignoreTitleTemplate: true,
};

// Built-in pieces — concrete, not generic
const pieces = [
  {
    icon: 'tabler:puzzle',
    label: '150+ skills',
    title: 'Skills',
    desc: 'Reusable capability modules — lead-gen, web-scrape, SEO audit, github-mcp, calendar-mcp, and more. Install with one click.',
    items: ['github-mcp', 'lead-finder', 'web-scrape', 'seo-audit', 'gmail-search', '+ many more'],
  },
  {
    icon: 'tabler:plug-connected',
    label: '20+ connects',
    title: 'Connects',
    desc: 'OAuth integrations to the systems you already use. Agents read and write through your authorized accounts.',
    items: ['google-drive', 'gmail', 'github', 'salesforce', 'hubspot', 'notion'],
  },
  {
    icon: 'tabler:calendar-clock',
    label: 'cron-driven',
    title: 'Schedules',
    desc: 'Run any App on a cron. Daily summaries, hourly polling, weekly digests — results delivered automatically.',
    items: ['daily', 'hourly', 'weekly', 'custom cron', 'on-event', 'manual'],
  },
  {
    icon: 'tabler:files',
    label: '7 formats',
    title: 'Artifacts',
    desc: 'First-class outputs that you can preview, edit, download, and chain into the next stage of the workflow.',
    items: ['markdown', 'code', 'html', 'json', 'csv', 'image', 'file'],
  },
];

const anatomy = [
  { n: '01', title: 'AppInput',  desc: 'A schema-driven form. text, daterange, select, file, connect_file — pick what you need, render automatically.' },
  { n: '02', title: 'Stage',     desc: 'A self-contained AI agent session with a goal. Most Apps need one. Multi-stage Apps chain artifacts forward.' },
  { n: '03', title: 'Artifact',  desc: 'The deliverable. Rendered, previewed, exported. Re-edit in Chat or chain into the next Stage.' },
];

const cases = [
  {
    slug: '/use-cases/gtm',
    eyebrow: 'B2B Growth',
    title: 'GTM',
    desc: 'Prospecting, outreach, retention, and pipeline insights — agent-driven from day one.',
    examples: ['Lead enrichment', 'Cold outreach drafts', 'Account health monitor', 'Pipeline insights'],
  },
  {
    slug: '/use-cases/finance',
    eyebrow: 'Finance teams',
    title: 'Finance',
    desc: 'Month-end close, AR/AP analysis, expense compliance, budget vs actual — for finance teams and CFOs.',
    examples: ['Month-end checklist', 'AR aging report', 'Expense audit', 'Variance analysis'],
  },
];
---

<Layout metadata={metadata}>

  <!-- ── HERO ───────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden">
    <!-- subtle grid background -->
    <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-[0.4]"
         style="background-image:linear-gradient(rgba(0,0,0,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,0.04) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 80% 60% at 50% 0%,#000 30%,transparent 80%);-webkit-mask-image:radial-gradient(ellipse 80% 60% at 50% 0%,#000 30%,transparent 80%);"></div>

    <div class="mx-auto max-w-6xl px-6 md:px-10 pt-16 md:pt-24 pb-12 md:pb-16">
      <!-- eyebrow chip -->
      <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] mb-6">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full rounded-full bg-primary opacity-60 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
        </span>
        <span class="text-[0.6875rem] tracking-[0.18em] uppercase font-mono text-[var(--aw-color-text-muted)]">AI Agent Platform</span>
      </div>

      <h1 class="text-[2.25rem] sm:text-[2.75rem] md:text-[3.5rem] lg:text-[4rem] font-black tracking-[-0.035em] leading-[1.02] text-[var(--aw-color-text-heading)] mb-5 max-w-[920px]">
        Save agent conversations<br/>
        <span class="text-primary">as apps.</span>
      </h1>

      <p class="text-[1.0625rem] md:text-[1.125rem] leading-[1.7] text-[var(--aw-color-text-muted)] max-w-[620px] mb-8">
        Find what works in a chat. Save it as a one-click <span class="font-mono text-[var(--aw-color-text-default)]">App</span> with a form, a goal, and scheduled runs. Your team gets repeatable AI workflows — no code, no prompt copy-pasting.
      </p>

      <div class="flex flex-wrap items-center gap-3 mb-10">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          Start free
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/use-cases"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
          See use cases
        </a>
      </div>

      <!-- meta strip -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-[0.75rem] font-mono text-[var(--aw-color-text-muted)] tracking-tight">
        <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>Multi-tenant</span>
        <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>OAuth integrations</span>
        <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>150+ built-in skills</span>
        <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>Isolated E2B sandboxes</span>
      </div>
    </div>
  </section>

  <!-- ── THE IDEA: Chat → App ──────────────────────────────────────── -->
  <section class="relative border-t border-[var(--aw-color-border)] py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-14 max-w-[640px]">
        <p class="section-label">THE IDEA</p>
        <h2 class="section-title">Two modes. One platform.</h2>
        <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.75]">
          Most teams use AI by typing the same long prompt over and over. We turn that around: explore freely in chat,
          then <span class="text-[var(--aw-color-text-default)] font-medium">crystallize</span> the working version into a parameterized App.
        </p>
      </div>

      <div class="grid md:grid-cols-[1fr_auto_1fr] gap-6 md:gap-4 items-stretch">

        <!-- CHAT mode -->
        <div class="group relative rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-[var(--aw-color-border)] bg-[var(--aw-color-bg-subtle)]">
            <div class="flex items-center gap-2">
              <div class="flex gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[rgba(0,0,0,0.08)]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[rgba(0,0,0,0.08)]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[rgba(0,0,0,0.08)]"></span>
              </div>
              <span class="ml-2 text-[0.6875rem] font-mono uppercase tracking-[0.15em] text-[var(--aw-color-text-muted)]">Mode 1 · Chat</span>
            </div>
            <span class="text-[0.6875rem] font-mono text-[var(--aw-color-text-muted)]">explore</span>
          </div>
          <div class="p-5 md:p-6 space-y-3 text-[0.875rem] leading-[1.65]">
            <div class="text-[0.6875rem] font-mono text-[var(--aw-color-text-muted)] uppercase tracking-[0.12em]">You</div>
            <p class="text-[var(--aw-color-text-default)]">
              Pull commits from 2025-05-01 to 05-07 in <span class="font-mono">shop-frontend</span>, summarize as a daily report in Chinese. Group by repo, include PR titles. Skip merges.
            </p>
            <div class="text-[0.6875rem] font-mono text-[var(--aw-color-text-muted)] uppercase tracking-[0.12em] pt-2">Agent</div>
            <div class="space-y-2">
              <div class="h-2 rounded-full bg-[rgba(0,0,0,0.06)] w-full"></div>
              <div class="h-2 rounded-full bg-[rgba(0,0,0,0.06)] w-[88%]"></div>
              <div class="h-2 rounded-full bg-[rgba(0,0,0,0.06)] w-[72%]"></div>
              <div class="h-2 rounded-full bg-[rgba(0,0,0,0.06)] w-[94%]"></div>
            </div>
            <div class="pt-3 mt-3 border-t border-dashed border-[var(--aw-color-border)]">
              <button class="text-[0.75rem] font-mono text-primary inline-flex items-center gap-1.5 hover:underline">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
                Save as App
              </button>
            </div>
          </div>
        </div>

        <!-- arrow -->
        <div class="hidden md:flex flex-col items-center justify-center px-3 self-center">
          <div class="text-[0.625rem] font-mono uppercase tracking-[0.2em] text-[var(--aw-color-text-muted)] mb-2">crystallize</div>
          <svg width="48" height="32" viewBox="0 0 48 32" fill="none" class="text-primary">
            <path d="M2 16 H42 M34 8 l8 8 -8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="flex md:hidden items-center justify-center">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-primary rotate-90">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <!-- APP mode -->
        <div class="group relative rounded-2xl border-2 border-primary/30 bg-[var(--aw-color-bg-page)] overflow-hidden shadow-[0_12px_40px_rgba(82,153,97,0.10)]">
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-primary/20 bg-primary/[0.04]">
            <div class="flex items-center gap-2">
              <div class="w-5 h-5 rounded-md bg-primary/15 flex items-center justify-center text-primary">
                <Icon name="tabler:report" class="w-3 h-3" />
              </div>
              <span class="ml-1 text-[0.8125rem] font-semibold text-[var(--aw-color-text-default)]">Daily Report</span>
              <span class="text-[0.6875rem] font-mono uppercase tracking-[0.15em] text-primary/80">Mode 2 · App</span>
            </div>
            <span class="text-[0.6875rem] font-mono text-[var(--aw-color-text-muted)]">v3 · public</span>
          </div>
          <div class="p-5 md:p-6 space-y-4 text-[0.8125rem]">
            <div>
              <label class="block text-[0.75rem] font-medium text-[var(--aw-color-text-muted)] mb-1.5">Date range</label>
              <div class="flex gap-2">
                <div class="flex-1 h-8 px-3 rounded-md border border-[var(--aw-color-border)] flex items-center font-mono text-[0.75rem] text-[var(--aw-color-text-default)]">2025-05-01</div>
                <div class="flex items-center text-[var(--aw-color-text-muted)]">→</div>
                <div class="flex-1 h-8 px-3 rounded-md border border-[var(--aw-color-border)] flex items-center font-mono text-[0.75rem] text-[var(--aw-color-text-default)]">2025-05-07</div>
              </div>
            </div>
            <div>
              <label class="block text-[0.75rem] font-medium text-[var(--aw-color-text-muted)] mb-1.5">Repository</label>
              <div class="h-8 px-3 rounded-md border border-[var(--aw-color-border)] flex items-center justify-between">
                <span class="font-mono text-[0.75rem] text-[var(--aw-color-text-default)]">shop-frontend</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[var(--aw-color-text-muted)]"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </div>
            <div>
              <label class="block text-[0.75rem] font-medium text-[var(--aw-color-text-muted)] mb-1.5">Output language</label>
              <div class="h-8 px-3 rounded-md border border-[var(--aw-color-border)] flex items-center justify-between">
                <span class="text-[0.75rem] text-[var(--aw-color-text-default)]">中文</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[var(--aw-color-text-muted)]"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </div>
            <button class="w-full h-9 rounded-md bg-primary text-white text-[0.8125rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors inline-flex items-center justify-center gap-1.5">
              <Icon name="tabler:player-play-filled" class="w-3 h-3" />
              Run
            </button>
          </div>
        </div>
      </div>

      <p class="mt-10 text-[0.875rem] md:text-[0.9375rem] text-[var(--aw-color-text-muted)] max-w-[640px] leading-[1.7]">
        After saving, every team member runs it the same way — fill the form, click <span class="font-mono">Run</span>.
        Set it on a cron and the report shows up in your inbox every Monday morning.
      </p>
    </div>
  </section>

  <!-- ── BUILT-IN PIECES ───────────────────────────────────────────── -->
  <section class="bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)] py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-14 max-w-[640px]">
        <p class="section-label">BUILT-IN</p>
        <h2 class="section-title">Everything an agent needs.</h2>
        <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.75]">
          You don't assemble integrations or write glue code. Pick the skills you want, authorize the systems you use, set a schedule. Ship.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        {pieces.map((p) => (
          <div class="group relative p-6 md:p-7 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] hover:border-primary/30 hover:shadow-[0_8px_30px_rgba(82,153,97,0.09)] transition-all duration-200">
            <div class="flex items-start justify-between mb-4">
              <div class="w-9 h-9 rounded-lg bg-primary/[0.08] flex items-center justify-center text-primary">
                <Icon name={p.icon} class="w-4 h-4" />
              </div>
              <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] px-2 py-0.5 rounded-full border border-[var(--aw-color-border)]">{p.label}</span>
            </div>
            <h3 class="text-[1.0625rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{p.title}</h3>
            <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.65] mb-4">{p.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {p.items.map((item) => (
                <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-[var(--aw-color-bg-subtle)] text-[0.6875rem] font-mono text-[var(--aw-color-text-muted)]">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ANATOMY ───────────────────────────────────────────────────── -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-14 max-w-[640px]">
        <p class="section-label">ANATOMY</p>
        <h2 class="section-title">An App, in three pieces.</h2>
        <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.75]">
          The whole platform comes down to three primitives. Simple to reason about, easy to compose.
        </p>
      </div>

      <div class="relative">
        <!-- connector line -->
        <div aria-hidden="true" class="hidden md:block absolute left-[20px] top-[24px] bottom-[24px] w-px bg-[var(--aw-color-border)]"></div>

        <div class="space-y-8 md:space-y-10">
          {anatomy.map((a) => (
            <div class="flex gap-5 md:gap-8 items-start">
              <div class="shrink-0 relative">
                <div class="w-10 h-10 rounded-full border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] flex items-center justify-center font-mono text-[0.75rem] font-semibold text-primary">
                  {a.n}
                </div>
              </div>
              <div class="flex-1 pt-1">
                <h3 class="text-[1.125rem] font-semibold text-[var(--aw-color-text-heading)] mb-1.5 font-mono">{a.title}</h3>
                <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] max-w-[620px]">{a.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- formula -->
      <div class="mt-14 p-5 rounded-xl bg-[var(--aw-color-bg-subtle)] border border-[var(--aw-color-border)] inline-block">
        <code class="text-[0.8125rem] md:text-[0.875rem] font-mono text-[var(--aw-color-text-default)] leading-relaxed">
          <span class="text-primary">App</span> = <span class="text-primary">AppInput</span>[] + <span class="text-primary">Stage</span>[] + <span class="text-primary">Artifact</span>[]
        </code>
      </div>
    </div>
  </section>

  <!-- ── USE CASES ─────────────────────────────────────────────────── -->
  <section class="bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)] py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-14 max-w-[640px]">
        <p class="section-label">USE CASES</p>
        <h2 class="section-title">Built for what you actually do.</h2>
        <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.75]">
          We ship pre-built App packs for common team workflows. Use as-is or fork to fit your process.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {cases.map((c) => (
          <a href={c.slug} class="group relative block p-7 md:p-8 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] hover:border-primary/40 hover:shadow-[0_12px_40px_rgba(82,153,97,0.10)] transition-all duration-200">
            <p class="text-[0.6875rem] font-mono uppercase tracking-[0.18em] text-[var(--aw-color-text-muted)] mb-3">{c.eyebrow}</p>
            <h3 class="text-[1.75rem] md:text-[2rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] mb-2.5 group-hover:text-primary transition-colors">{c.title}</h3>
            <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-6">{c.desc}</p>
            <div class="space-y-1.5 mb-6">
              {c.examples.map((ex) => (
                <div class="flex items-center gap-2 text-[0.8125rem] text-[var(--aw-color-text-default)]">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-primary/70 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="font-mono text-[0.75rem]">{ex}</span>
                </div>
              ))}
            </div>
            <div class="inline-flex items-center gap-1.5 text-[0.8125rem] font-medium text-primary">
              Explore use case
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────── -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-3xl px-6 md:px-10 text-center">
      <h2 class="text-[1.875rem] md:text-[2.5rem] font-bold tracking-[-0.025em] leading-[1.15] text-[var(--aw-color-text-heading)] mb-4">
        Ship your first App<br/>before lunch.
      </h2>
      <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-8 max-w-[480px] mx-auto">
        Open a chat, get something working, click <span class="font-mono">Save as App</span>. That's the whole loop.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          Start free
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/contact"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
          Talk to us
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-label {
    font-size: 0.6875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.875rem;
  }
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--aw-color-text-heading);
    margin-bottom: 1rem;
  }
</style>
