---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI-Powered Customer Acquisition & Retention Platform',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Demo',
        href: '/contact',
        icon: 'tabler:calendar',
      },
      { text: 'Learn more', href: '#features' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=2070&q=80',
      alt: 'Aitroop — Acquisition & Retention Platform',
    }}
  >
    <Fragment slot="title">
      Master <span class="text-accent dark:text-white">Acquisition & Retention</span> with AI
    </Fragment>

    <Fragment slot="subtitle">
      Aitroop unifies data intelligence, personalized outreach, customer nurturing, and growth
      analytics in one platform — so one person can achieve what once required an entire team.
    </Fragment>
  </Hero>

  <!-- Stats -->

  <Stats
    stats={[
      { title: 'Outreach Efficiency', amount: '10x' },
      { title: 'Contact Data Coverage', amount: '80%+' },
      { title: 'Primary Inbox Delivery', amount: '90%+' },
      { title: 'Research Time Saved', amount: '25hr/wk' },
    ]}
  />

  <!-- Features -->

  <Features
    id="features"
    tagline="Platform Capabilities"
    title="AI at every stage — from finding customers to keeping them"
    subtitle="Acquisition and retention are two sides of the same coin. Aitroop covers the full customer lifecycle in one workspace so every action you take is smarter and more efficient."
    items={[
      {
        title: 'Precision Customer Intelligence',
        description:
          "AI automatically researches each prospect's business context, recent activities, and potential pain points — so every outreach has a genuine hook.",
        icon: 'tabler:search',
      },
      {
        title: 'Personalized Outreach at Scale',
        description:
          "AI generates tailored messages based on each prospect's real background. One person can now reach as many people as an entire outbound team.",
        icon: 'tabler:mail',
      },
      {
        title: 'Smart Data Enrichment',
        description:
          'Our Waterfall enrichment engine chains multiple data sources — turn a name and company into verified contact info with 80%+ coverage.',
        icon: 'tabler:database',
      },
      {
        title: 'Multi-channel Automated Follow-up',
        description:
          'Email and LinkedIn sequences that intelligently time each touchpoint. Never lose a deal because you forgot to follow up.',
        icon: 'tabler:route',
      },
      {
        title: 'Intent Radar',
        description:
          'Website visitor identification, behavioral signal tracking, and intent scoring — focus your energy on the people most likely to buy.',
        icon: 'tabler:radar',
      },
      {
        title: 'Customer Health & Retention',
        description:
          'Continuously monitor customer health scores and intervene at the first sign of churn — cut churn rate and raise renewal rates.',
        icon: 'tabler:heart-rate-monitor',
      },
    ]}
  />

  <!-- Steps -->

  <Steps
    title="Three steps to build your AI acquisition engine"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Define your ideal customer profile</span>',
        description:
          'AI analyzes your best existing customers and automatically surfaces your ideal customer profile — then finds more people just like them. Contact info is enriched automatically.',
        icon: 'tabler:upload',
      },
      {
        title: 'Step 2: <span class="font-medium">AI generates personalized outreach</span>',
        description:
          "AI crafts unique messages based on each prospect's real context — recent news, business direction, likely pain points. Preview in bulk, send with one click.",
        icon: 'tabler:wand',
      },
      {
        title: 'Step 3: <span class="font-medium">Automated follow-up & continuous optimization</span>',
        description:
          'Set your follow-up cadence and let the system run. See who replies and who visits your site in real time. AI learns and helps you iterate your playbook continuously.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Compounding growth',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?auto=format&fit=crop&w=2070&q=80',
      alt: 'Three steps to launch your AI acquisition engine',
    }}
  />

  <!-- Content / Differentiators -->

  <Content
    isReversed
    tagline="Why Aitroop"
    title="Not just a tool — your acquisition & retention operating system"
    items={[
      {
        title: 'Built for China, not a translation',
        description:
          'Deep integration with Chinese business databases, WeChat Work, and local channels. RMB billing, VAT invoices, and full PIPL compliance — designed from the ground up for the China market.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'One platform, full workflow',
        description:
          'Data intelligence, personalized outreach, automated follow-up, performance tracking, and customer health — all in one workspace. No more tool-switching.',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Intent Radar: 3D signal fusion',
        description:
          'Website visitor behavior, third-party intent data, and in-product usage tracking — three signal dimensions fused into a single intent score so you reach the right person at the right moment.',
        icon: 'tabler:radar',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=2070&q=80',
      alt: 'Aitroop differentiators',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Blog -->

  <BlogLatestPosts
    title="Insights on Acquisition & Retention"
    information="We regularly share outreach tactics, AI application practices, and customer growth strategies to help you build your competitive edge."
  />

  <!-- CTA -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free 30-min Demo',
        href: '/contact',
        icon: 'tabler:calendar',
      },
      {
        variant: 'secondary',
        text: 'View Pricing',
        href: '/pricing',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to let AI become<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"
        > your unfair advantage?</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      People who master AI-driven acquisition are achieving team-level results on their own.<br
        class="hidden md:inline"
      /> Your next move starts here.
    </Fragment>
  </CallToAction>
</Layout>
