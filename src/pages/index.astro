---
import Layout from '~/layouts/PageLayout.astro';
import ChatToAppDemo from '~/components/widgets/ChatToAppDemo.astro';

const metadata = {
  title: 'Aitroop — Save AI agent conversations as apps',
  ignoreTitleTemplate: true,
};

const anatomy = [
  { n: '01', title: 'AppInput',  desc: 'A schema-driven form — text, select, daterange, file. Declare once; renders itself.' },
  { n: '02', title: 'Stage',     desc: 'An agent session with a goal. Most Apps need one; chain them when work spans steps.' },
  { n: '03', title: 'Artifact',  desc: 'The deliverable, ready to preview, export, or feed into the next stage.' },
];

const stats = [
  { value: '150+', label: 'Skills' },
  { value: '20+',  label: 'Connects' },
  { value: 'cron', label: 'Schedules' },
  { value: '7',    label: 'Artifact formats' },
];

const cases = [
  { slug: '/use-cases/gtm',     title: 'GTM',     desc: 'Prospecting, outreach, retention, pipeline insights.' },
  { slug: '/use-cases/finance', title: 'Finance', desc: 'Close, audit, variance, reporting — for CFO teams.' },
];
---

<Layout metadata={metadata}>

  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <section class="aw-hero relative isolate overflow-hidden">
    <div aria-hidden="true" class="hero-glow"></div>
    <div class="aw-container-wide">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="aw-eyebrow">AI Agent Platform</p>
          <h1 class="aw-display hero-display">
            Save agent conversations <span class="text-primary">as apps.</span>
          </h1>
          <p class="aw-lede hero-lede">
            Find what works in a chat. Save it as a one-click App with a form, a goal, and a schedule. Your team uses it forever.
          </p>
          <div class="aw-actions">
            <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Start free</a>
            <a href="/use-cases" class="aw-btn aw-btn-ghost">See use cases</a>
          </div>
        </div>
        <div class="hero-demo">
          <ChatToAppDemo />
        </div>
      </div>
    </div>
  </section>

  <!-- ANATOMY ──────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">Anatomy</p>
        <h2 class="aw-h2">An App, in three pieces.</h2>
      </header>

      <div class="anatomy">
        {anatomy.map((a) => (
          <article class="aw-piece">
            <span class="aw-piece-num">{a.n}</span>
            <h3 class="aw-piece-title">{a.title}</h3>
            <p class="aw-piece-desc">{a.desc}</p>
          </article>
        ))}
      </div>

      <div class="stats" role="list">
        {stats.map((s) => (
          <div class="stat" role="listitem">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USE CASES ────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">Use cases</p>
        <h2 class="aw-h2">Built for what you actually do.</h2>
      </header>

      <ul class="cases">
        {cases.map((c) => (
          <li>
            <a href={c.slug}>
              <span class="case-title">{c.title}</span>
              <span class="case-desc">{c.desc}</span>
              <span class="case-arrow aw-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2 cta-h2">Ship your first App before lunch.</h2>
      <p class="aw-lede">Open a chat. Click <code class="aw-code">Save as App</code>. That's the loop.</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Start free</a>
        <a href="/contact" class="aw-btn aw-btn-ghost">Talk to us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero — extra rhythm + soft glow ───────────────────────────── */
  .hero-glow {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 120%;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 50% at 22% 18%, rgba(82, 153, 97, 0.10), transparent 65%),
      radial-gradient(ellipse 50% 50% at 80% 30%, rgba(82, 153, 97, 0.06), transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 80%);
            mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 80%);
  }

  .hero-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 4.5rem;
    }
  }
  .hero-display {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.05;
    margin: 0 0 1.5rem;
    max-width: 14ch;
  }
  .hero-lede {
    max-width: 42ch;
  }

  /* ── Anatomy grid ──────────────────────────────────────────────── */
  .anatomy {
    display: grid;
    gap: 2rem;
    margin-bottom: 4.5rem;
  }
  @media (min-width: 768px) {
    .anatomy {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
      margin-bottom: 5.5rem;
    }
  }

  /* ── Stats ─ table-like row ────────────────────────────────────── */
  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--aw-color-border);
    border: 1px solid var(--aw-color-border);
    border-radius: 10px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .stats { grid-template-columns: repeat(4, 1fr); }
  }
  .stat {
    background: var(--aw-color-bg-page);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: background-color 200ms ease;
  }
  .stat:hover { background: var(--aw-color-bg-subtle); }
  .stat-value {
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.01em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  /* ── Use-case row list ─────────────────────────────────────────── */
  .cases {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cases li { border-top: 1px solid var(--aw-color-border); }
  .cases li:last-child { border-bottom: 1px solid var(--aw-color-border); }
  .cases a {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "title arrow"
      "desc  arrow";
    column-gap: 1rem;
    row-gap: 0.5rem;
    padding: 1.75rem 0;
    align-items: center;
    transition: padding-left 220ms ease;
  }
  @media (min-width: 768px) {
    .cases a {
      grid-template-columns: 12rem 1fr auto;
      grid-template-areas: "title desc arrow";
      column-gap: 2.5rem;
      padding: 2.25rem 0;
    }
  }
  .cases a:hover { padding-left: 0.25rem; }

  .case-title {
    grid-area: title;
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1.1;
    transition: color 200ms ease;
  }
  .case-desc {
    grid-area: desc;
    color: var(--aw-color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .case-arrow {
    grid-area: arrow;
    color: var(--aw-color-text-muted);
    font-size: 1.125rem;
    line-height: 1;
    transition: color 200ms ease, transform 220ms ease;
  }
  .cases a:hover .case-title { color: var(--aw-color-primary); }
  .cases a:hover .case-arrow { color: var(--aw-color-primary); }

  /* ── CTA tightening ────────────────────────────────────────────── */
  .cta-h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin: 0 auto 1rem;
    max-width: 18ch;
  }
</style>
