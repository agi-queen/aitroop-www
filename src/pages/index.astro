---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI-Powered Growth Platform',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════ -->
  <main id="hero-section" class="relative min-h-[calc(100vh-56px)] flex flex-col items-center justify-center px-4 overflow-hidden">

    <!-- Fine dot grid — deepest layer -->
    <div
      class="absolute inset-0 -z-20"
      style="background-image:radial-gradient(circle,rgba(0,0,0,0.045) 1px,transparent 1px);background-size:28px 28px;"
      aria-hidden="true"
    ></div>

    <!-- Aurora SVG blobs (feGaussianBlur — higher quality than CSS filter) -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none -z-10"
      aria-hidden="true"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <filter id="f-aurora" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="65" result="blur"/>
          <feColorMatrix in="blur" type="saturate" values="1.8"/>
        </filter>
        <filter id="f-aurora-sm" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="40"/>
        </filter>
      </defs>
      <!-- blob A — top-left -->
      <ellipse class="aurora-a" cx="18%" cy="32%" rx="340" ry="270"
        fill="rgba(82,153,97,0.22)" filter="url(#f-aurora)"/>
      <!-- blob B — bottom-right -->
      <ellipse class="aurora-b" cx="83%" cy="68%" rx="300" ry="240"
        fill="rgba(55,115,72,0.18)" filter="url(#f-aurora)"/>
      <!-- blob C — center accent -->
      <ellipse class="aurora-c" cx="52%" cy="48%" rx="220" ry="170"
        fill="rgba(110,190,130,0.12)" filter="url(#f-aurora-sm)"/>
    </svg>

    <!-- Perspective grid floor — Vercel-style infinite approaching grid -->
    <div class="pgrid-wrap absolute inset-x-[-20%] bottom-0 h-[58%] pointer-events-none -z-10 overflow-hidden" aria-hidden="true">
      <div class="pgrid-inner w-full h-full"></div>
    </div>

    <!-- Mouse-follow spotlight -->
    <div id="hero-spot" class="absolute inset-0 pointer-events-none" style="z-index:1;" aria-hidden="true"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-[640px] mx-auto flex flex-col items-center gap-4 text-center">

      <!-- Live badge -->
      <div class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-[rgba(82,153,97,0.08)] border border-[rgba(82,153,97,0.22)] px-3 py-1.5 rounded-full">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
        </span>
        AI Agent Platform for Growth
      </div>

      <!-- Headline -->
      <h1 class="text-[2rem] md:text-[2.75rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] leading-[1.15] -mt-1">
        Acquire smarter. Convert faster.<br><span class="hero-shimmer">Retain longer.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] max-w-[480px] leading-[1.8] -mt-1">
        An army of AI agents — prospect, engage, convert, retain — each with a precise mission across your growth pipeline. One platform, one operator, an entire team's output.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-1">
        <a
          href="https://app.aitroop.net"
          class="inline-flex items-center gap-2 h-10 px-5 rounded-[7px] bg-primary text-white text-sm font-semibold shadow-[0_1px_3px_rgba(82,153,97,0.45),0_0_0_1px_rgba(82,153,97,0.22)] hover:bg-[rgb(61,133,79)] hover:shadow-[0_2px_8px_rgba(82,153,97,0.5)] transition-all duration-150"
        >
          Log in to Aitroop
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="/blog"
          class="inline-flex items-center h-10 px-5 rounded-[7px] text-sm font-medium text-[var(--aw-color-text-muted)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.2)] hover:text-[var(--aw-color-text-default)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150"
        >
          Read the blog
        </a>
      </div>

      <!-- Mini stats grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px mt-3 w-full max-w-[440px] rounded-xl border border-[var(--aw-color-border)] overflow-hidden bg-[var(--aw-color-border)]">
        {[
          ['6×', 'Outreach Capacity'],
          ['90d', 'Churn Warning'],
          ['80%+', 'Data Coverage'],
          ['15%', 'Reply Rate'],
        ].map(([metric, label]) => (
          <div class="flex flex-col items-center gap-0.5 py-3 bg-[var(--aw-color-bg-page)]">
            <span class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] tabular-nums">{metric}</span>
            <span class="text-[0.65rem] text-[var(--aw-color-text-muted)] leading-tight px-1">{label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom fade -->
    <div
      class="absolute bottom-0 inset-x-0 h-28 pointer-events-none -z-10"
      style="background:linear-gradient(to top,rgba(255,255,255,1) 0%,transparent 100%);"
      aria-hidden="true"
    ></div>
  </main>

  <!-- ═══════════════════════════════════════════════════════
       SOCIAL PROOF TICKER
  ═══════════════════════════════════════════════════════ -->
  <div class="border-y border-[var(--aw-color-border)] py-5 overflow-hidden" style="background:rgba(82,153,97,0.018);">
    <p class="text-center text-[0.6rem] uppercase tracking-[0.18em] text-[var(--aw-color-text-muted)] mb-4 font-semibold opacity-60">
      Powering growth teams across industries
    </p>
    <div class="relative flex overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_8%,black_92%,transparent)]">
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0">
        {['B2B SaaS', 'E-commerce', 'Fintech', 'MarTech', 'Sales Teams', 'Growth Agencies', 'D2C Brands', 'Enterprise GTM', 'PLG Companies', 'Startups'].map(name => (
          <li class="text-[0.8125rem] font-medium text-[var(--aw-color-text-muted)] opacity-45 hover:opacity-80 transition-opacity cursor-default select-none whitespace-nowrap">{name}</li>
        ))}
      </ul>
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0" aria-hidden="true">
        {['B2B SaaS', 'E-commerce', 'Fintech', 'MarTech', 'Sales Teams', 'Growth Agencies', 'D2C Brands', 'Enterprise GTM', 'PLG Companies', 'Startups'].map(name => (
          <li class="text-[0.8125rem] font-medium text-[var(--aw-color-text-muted)] opacity-45 whitespace-nowrap select-none">{name}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       AI AGENTS — 3D TILT CARD GRID
  ═══════════════════════════════════════════════════════ -->
  <Features2
    id="agents"
    tagline="The AI Growth Squad"
    title="Six specialists. One unified platform."
    subtitle="Each agent is purpose-built for a specific stage of your growth pipeline — working 24/7 so your team can focus on what only humans can do."
    columns={3}
    items={[
      {
        title: 'Prospect Agent',
        description: 'Scans millions of signals to surface high-fit leads — company stage, hiring activity, tech stack, and intent data combined into a precision target list.',
        icon: 'tabler:radar',
      },
      {
        title: 'Outreach Agent',
        description: 'Writes and sends hyper-personalized cold emails and LinkedIn messages. No templates — every message is contextually crafted for each recipient.',
        icon: 'tabler:mail-forward',
      },
      {
        title: 'Engage Agent',
        description: "Follows up intelligently across channels, adjusting tone and timing based on each prospect's engagement signals and conversation history.",
        icon: 'tabler:messages',
      },
      {
        title: 'Convert Agent',
        description: 'Surfaces deal-winning insights for your reps at the right moment — objection handling, social proof, competitive intel, and next best actions.',
        icon: 'tabler:target',
      },
      {
        title: 'Retain Agent',
        description: "Monitors usage patterns and health scores continuously. Flags at-risk accounts 90 days before churn materializes so you can act while there's still time.",
        icon: 'tabler:shield-check',
      },
      {
        title: 'Insights Agent',
        description: 'Synthesizes your entire pipeline into clear, actionable recommendations. Know exactly where to focus next — and why — without digging through dashboards.',
        icon: 'tabler:chart-line',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       HOW IT WORKS
  ═══════════════════════════════════════════════════════ -->
  <Steps
    id="how-it-works"
    tagline="Simple by design"
    title="Up and running in minutes."
    subtitle="No six-month onboarding. No army of consultants. Aitroop is built to deploy fast and compound results over time."
    items={[
      { title: 'Connect your stack',    description: 'Link your CRM, email provider, and LinkedIn in under 10 minutes. Native integrations with HubSpot, Salesforce, Apollo, Outreach, and more.', icon: 'tabler:plug-connected' },
      { title: 'Deploy your agents',    description: 'Select which agents match your growth priorities and configure their parameters. No code required — the setup wizard handles the rest.', icon: 'tabler:robot' },
      { title: 'Agents go to work',     description: 'Automated prospecting, personalized outreach, and intelligent follow-ups run continuously — nights, weekends, time zones, always on.', icon: 'tabler:rocket' },
      { title: 'Measure and scale',     description: "The Insights Agent surfaces what's working and what's not. Amplify winning campaigns and cut what isn't — with a single click.", icon: 'tabler:trending-up' },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       STATS — scramble-to-value counter
  ═══════════════════════════════════════════════════════ -->
  <section id="stats-section" class="relative border-y border-[var(--aw-color-border)] overflow-hidden">
    <!-- Subtle gradient bg -->
    <div class="absolute inset-0 -z-10"
      style="background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(82,153,97,0.05) 0%,transparent 70%);"
      aria-hidden="true"></div>

    <div class="relative mx-auto max-w-5xl px-4 md:px-6 py-14 md:py-20 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="text-center mb-12">
        <p class="text-[0.65rem] uppercase tracking-[0.18em] font-semibold text-primary mb-2 opacity-80">Real results</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--aw-color-text-heading)]">Numbers that move the needle.</h2>
        <p class="text-[var(--aw-color-text-muted)] mt-3 max-w-md mx-auto text-sm md:text-[0.9375rem]">
          Aggregated across growth teams running Aitroop agents in production.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
        {[
          { target: 6,  suffix: '×',   label: 'Outreach capacity' },
          { target: 90, suffix: 'd',   label: 'Churn early warning' },
          { target: 80, suffix: '%+',  label: 'Contact data coverage' },
          { target: 15, suffix: '%',   label: 'Average reply rate' },
        ].map(({ target, suffix, label }, i) => (
          <div
            class="stat-card text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.3)] hover:shadow-[0_6px_28px_rgba(82,153,97,0.1)] hover:-translate-y-1.5"
            style={`--i:${i};`}
          >
            <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1 leading-none">
              <span class="stat-num" data-target={target} data-suffix={suffix}>0</span><span class="stat-suffix">{suffix}</span>
            </div>
            <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-2">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TESTIMONIALS
  ═══════════════════════════════════════════════════════ -->
  <Testimonials
    id="testimonials"
    tagline="What teams are saying"
    title="Growth teams love Aitroop."
    subtitle="From SDR-heavy outbound to lean PLG motions — Aitroop adapts to how you grow."
    testimonials={[
      {
        testimonial: 'We scaled from 200 to 1,400 outreach sequences per month without adding headcount. The Outreach Agent writes better cold emails than most SDRs, honestly.',
        name: 'Lena Torres',
        job: 'Head of Growth · Patrly',
      },
      {
        testimonial: 'The 90-day churn alert is genuinely impressive. We saved three enterprise accounts last quarter because Aitroop flagged them first — before they reached out to cancel.',
        name: 'David Kwan',
        job: 'VP of Sales · Clearflo',
      },
      {
        testimonial: "We used to stitch together five different tools for this workflow. Now it's one platform. Our GTM velocity doubled in 60 days and our ops overhead actually went down.",
        name: 'Priya Nair',
        job: 'CMO · Storyvault',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════════════════ -->
  <CallToAction
    id="cta-section"
    title="Your growth team is ready."
    subtitle="Deploy your first AI agent in minutes. See the pipeline move."
    actions={[
      { text: 'Get started', href: 'https://app.aitroop.net', variant: 'primary' },
      { text: 'Talk to us', href: '/contact', variant: 'secondary' },
    ]}
  />

</Layout>

<!-- ═══════════════════════════════════════════════════════════════
     STYLES
═══════════════════════════════════════════════════════════════ -->
<style>
  /* ── Marquee ────────────────────────────────────────────── */
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-100%); } }
  .marquee-track { animation: marquee 34s linear infinite; }

  /* ── Aurora blob drift ──────────────────────────────────── */
  .aurora-a {
    animation: aurora-a 18s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  .aurora-b {
    animation: aurora-b 22s ease-in-out infinite reverse;
    transform-box: fill-box;
    transform-origin: center;
  }
  .aurora-c {
    animation: aurora-c 14s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }
  @keyframes aurora-a {
    0%,100% { transform: translate(0,0) scale(1); }
    33%     { transform: translate(4%,-6%) scale(1.12); }
    66%     { transform: translate(-3%, 5%) scale(0.93); }
  }
  @keyframes aurora-b {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(-5%,-8%) scale(1.18); }
  }
  @keyframes aurora-c {
    0%,100% { transform: translate(0,0) scale(1);   opacity:0.8; }
    50%     { transform: translate(3%, 4%) scale(1.25); opacity:1; }
  }

  /* ── Perspective grid ───────────────────────────────────── */
  .pgrid-wrap {
    /* fade out at the top edge */
    mask-image: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 100%);
    -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 100%);
  }
  .pgrid-inner {
    background-image:
      linear-gradient(rgba(82,153,97,0.22) 1px, transparent 1px),
      linear-gradient(90deg, rgba(82,153,97,0.22) 1px, transparent 1px);
    background-size: 64px 64px;
    transform: perspective(460px) rotateX(58deg);
    transform-origin: 50% 0%;
    animation: grid-scroll 7s linear infinite;
  }
  @keyframes grid-scroll {
    from { background-position: 0 0; }
    to   { background-position: 0 64px; }
  }

  /* ── Hero headline shimmer ──────────────────────────────── */
  @keyframes text-shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
  }
  .hero-shimmer {
    background: linear-gradient(90deg, #3a7d4a 0%, #529961 28%, #8de0a0 52%, #529961 72%, #3a7d4a 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: text-shimmer 4.5s linear infinite;
  }

  /* ── Feature cards — tilt & shimmer ────────────────────── */
  #agents .rounded-lg {
    position: relative;
    overflow: hidden;
    will-change: transform;
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
  }
  /* traveling light shimmer on hover */
  #agents .rounded-lg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(108deg, transparent 18%, rgba(255,255,255,0.11) 50%, transparent 82%);
    transform: translateX(-160%);
    pointer-events: none;
  }
  #agents .rounded-lg:hover::after {
    animation: card-shine 0.55s ease forwards;
  }
  #agents .rounded-lg:hover {
    box-shadow: 0 16px 48px rgba(82,153,97,0.14), 0 3px 10px rgba(82,153,97,0.07);
    border-color: rgba(82,153,97,0.25) !important;
  }
  @keyframes card-shine { to { transform: translateX(160%); } }

  /* ── Stats card entrance ────────────────────────────────── */
  .stat-card {
    opacity: 0;
    filter: blur(6px);
    transform: translateY(12px) scale(0.97);
    transition: opacity 0.55s ease, filter 0.55s ease, transform 0.55s ease;
  }
  .stat-card.visible {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0) scale(1);
  }

  /* ── CTA glow breathing ─────────────────────────────────── */
  #cta-section .rounded-md {
    animation: cta-breathe 3.5s ease-in-out infinite;
  }
  @keyframes cta-breathe {
    0%,100% { box-shadow: 0 0 0 1px rgba(82,153,97,0.18), 0 8px 32px rgba(82,153,97,0.07); }
    50%     { box-shadow: 0 0 0 1px rgba(82,153,97,0.45), 0 0 56px rgba(82,153,97,0.16), 0 8px 32px rgba(82,153,97,0.1); }
  }

  /* ── Testimonial stagger ────────────────────────────────── */
  #testimonials .grid > div:nth-child(1) { animation-delay:   0ms !important; }
  #testimonials .grid > div:nth-child(2) { animation-delay: 130ms !important; }
  #testimonials .grid > div:nth-child(3) { animation-delay: 260ms !important; }

  /* ── Reduced-motion ─────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track, .aurora-a, .aurora-b, .aurora-c,
    .pgrid-inner, .hero-shimmer, #cta-section .rounded-md { animation: none !important; }
    .hero-shimmer { -webkit-text-fill-color: #529961; color: #529961; }
    .stat-card { opacity: 1; filter: none; transform: none; }
  }
</style>

<!-- ═══════════════════════════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════════════════════════ -->
<script>
  /* ── Mouse-follow spotlight in hero ──────────────────────── */
  const spot = document.getElementById('hero-spot');
  const heroSection = document.getElementById('hero-section');
  if (spot && heroSection) {
    heroSection.addEventListener('mousemove', (e: MouseEvent) => {
      const r = heroSection.getBoundingClientRect();
      spot.style.background =
        `radial-gradient(680px circle at ${e.clientX - r.left}px ${e.clientY - r.top}px,` +
        `rgba(82,153,97,0.065),transparent 48%)`;
    });
    heroSection.addEventListener('mouseleave', () => {
      spot.style.background = '';
    });
  }

  /* ── 3-D magnetic tilt on agent cards ───────────────────── */
  document.querySelectorAll<HTMLElement>('#agents .rounded-lg').forEach((card) => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      card.style.transition = 'box-shadow 0.25s ease, border-color 0.25s ease'; // no transform transition during move
      const r = card.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width;
      const y = (e.clientY - r.top)  / r.height;
      const rx = (0.5 - y) * 16;   // tilt up to ±16 deg
      const ry = (x - 0.5) * 16;
      card.style.transform =
        `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(10px)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform 0.5s cubic-bezier(.03,.98,.52,.99), box-shadow 0.25s ease, border-color 0.25s ease';
      card.style.transform = '';
    });
  });

  /* ── Stats: staggered blur-reveal + scramble counter ────── */
  const statsSection = document.getElementById('stats-section');
  if (statsSection) {
    const io = new IntersectionObserver((entries) => {
      if (!entries[0].isIntersecting) return;
      io.disconnect();

      statsSection.querySelectorAll<HTMLElement>('.stat-card').forEach((card, i) => {
        const delay = i * 110;
        setTimeout(() => card.classList.add('visible'), delay);

        const numEl = card.querySelector<HTMLElement>('.stat-num');
        if (!numEl) return;
        const target = parseInt(numEl.dataset.target ?? '0', 10);
        const DIGITS = '0123456789';
        const scrambleDur = 700;
        const countDur = 700;
        let start: number | null = null;

        const tick = (ts: number) => {
          if (!start) start = ts;
          const elapsed = ts - start;

          if (elapsed < scrambleDur) {
            // Phase 1: random scramble
            numEl.textContent = DIGITS[Math.floor(Math.random() * 10)];
            requestAnimationFrame(tick);
          } else if (elapsed < scrambleDur + countDur) {
            // Phase 2: count up with ease-out
            const t = (elapsed - scrambleDur) / countDur;
            const eased = 1 - Math.pow(1 - t, 3);
            numEl.textContent = String(Math.round(eased * target));
            requestAnimationFrame(tick);
          } else {
            numEl.textContent = String(target);
          }
        };
        setTimeout(() => requestAnimationFrame(tick), delay + 200);
      });
    }, { threshold: 0.35 });
    io.observe(statsSection);
  }
</script>
