---
import Layout from '~/layouts/PageLayout.astro';
import AnatomyFlow from '~/components/widgets/AnatomyFlow.astro';
import WorkflowLifecycle from '~/components/widgets/WorkflowLifecycle.astro';
import CircleHighlight from '~/components/ui/CircleHighlight.astro';
import GridBackground from '~/components/ui/GridBackground.astro';
import BentoGrid from '~/components/ui/BentoGrid.astro';
import type { BentoItem } from '~/components/ui/BentoGrid.astro';
import Marquee from '~/components/ui/Marquee.astro';
import OrbitingCircles from '~/components/ui/OrbitingCircles.astro';
import { brandIcons } from '~/data/brandIcons';

const metadata = {
  title: 'Aitroop - Save AI agent conversations as apps',
  ignoreTitleTemplate: true,
};

const orbitRings = [
  {
    radius: 92,
    duration: 26,
    reverse: false,
    items: [brandIcons.claude, brandIcons.openai, brandIcons.gmail, brandIcons.github],
  },
  {
    radius: 200,
    duration: 42,
    reverse: true,
    items: [
      brandIcons.slack,
      brandIcons.notion,
      brandIcons.figma,
      brandIcons.discord,
      brandIcons.linear,
      brandIcons.stripe,
    ],
  },
];

const anatomySteps = [
  {
    title: 'AppInput',
    desc: 'A schema-driven form. Text, select, daterange, file. Declared once, rendered for you.',
    foot: '4 input types · validated',
  },
  {
    title: 'Stage',
    desc: 'An agent session with one goal, wired to your skills and connects. Chain stages when work spans steps.',
    foot: '150+ skills · 20+ connects',
  },
  {
    title: 'Artifact',
    desc: 'The deliverable. Preview, export, or feed it into the next stage.',
    foot: '7 formats · preview + export',
  },
];

const skills = [
  'GitHub', 'Gmail', 'Slack', 'Notion', 'Drive', 'Linear',
  'Stripe', 'HubSpot', 'Salesforce', 'Figma', 'Jira', 'Asana',
  'Webhook', 'Web search', 'Code exec', 'PDF', 'CSV', 'Postgres',
  'Discord', 'Twitter', 'YouTube', 'Calendar', 'Sheets', 'Airtable',
];

const testimonials = [
  {
    quote: 'We replaced a 4-person ops loop with three Apps. They run on a cron and nobody touches them.',
    name: 'Marta R.',
    title: 'Head of RevOps',
    company: 'Northbound',
    featured: true,
  },
  {
    quote: 'Save as App turned my chaotic prompt notebook into something the rest of the team can actually run.',
    name: 'Diego K.',
    title: 'Solutions Architect',
    company: 'Plate',
  },
  {
    quote: 'The sandbox is the killer feature. Real file access, real tools, real outputs — no toy demos.',
    name: 'Priya S.',
    title: 'Director of AI',
    company: 'Vector Labs',
  },
];

const features: BentoItem[] = [
  {
    title: 'Save chats as Apps',
    desc: 'One click freezes the working flow into a typed, runnable workflow with named inputs.',
    icon: 'M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z',
    span: 'wide',
  },
  {
    title: 'Multi-stage pipelines',
    desc: 'Chain stages when a single agent run is not enough. Each stage owns its own model, skills and prompt.',
    icon: 'M4 6h16M4 12h16M4 18h10',
  },
  {
    title: '150+ skills, 20+ connects',
    desc: 'GitHub, Gmail, Slack, Drive, Notion, web search, code execution — wired in with one toggle.',
    icon: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z',
  },
  {
    title: 'Real sandboxes',
    desc: 'Every run lands in an isolated environment with file access, network and the right toolchain.',
    icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
  },
  {
    title: 'Schedules & webhooks',
    desc: 'Run on a cron, on demand, or off a webhook. Hands-free after one setup, with full run history.',
    icon: 'M12 6v6l4 2M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z',
  },
  {
    title: 'Share with your team',
    desc: 'Each App is a permissioned object. Hand it off, embed it, or expose it as an internal API.',
    icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  },
];

const cases = [
  { slug: '/use-cases/engineering', title: 'Engineering',   tagline: 'PR review, release notes, on-call digest.' },
  { slug: '/use-cases/marketing',   title: 'Marketing',     tagline: 'Briefs, social pack, weekly digest.' },
  { slug: '/use-cases/support',     title: 'Customer support', tagline: 'Triage, reply drafts, KB sync.' },
  { slug: '/use-cases/research',    title: 'Research',      tagline: 'Competitor scans, synthesis, briefings.' },
  { slug: '/use-cases/operations',  title: 'Operations',    tagline: 'SOPs, vendor risk, redlines.' },
  { slug: '/use-cases/gtm',         title: 'GTM',           tagline: 'Prospecting, outreach, pipeline.' },
  { slug: '/use-cases/finance',     title: 'Finance',       tagline: 'Close, AR aging, variance.' },
  { slug: '/use-cases/personal',    title: 'Personal',      tagline: 'Inbox, meetings, weekly review.' },
];

const faqs = [
  {
    q: 'Do I have to rebuild my prompts to save an App?',
    a: 'No. Open a chat that already works, click Save as App, and Aitroop captures the skills, connects and prompts as a runnable workflow.',
  },
  {
    q: 'What runs the App after it is saved?',
    a: 'Each run executes in an isolated sandbox with the file system, network and tools the agent needs. You can trigger it manually, on a cron, or from a webhook.',
  },
  {
    q: 'Can I chain steps that need different tools?',
    a: 'Yes. Stages let you wire one agent into the next, each with its own model, skills and prompt. The artifact from one stage feeds the input of the next.',
  },
  {
    q: 'Who can use the App once I publish it?',
    a: 'Apps are permissioned objects. Share with a teammate, an external collaborator, or expose them as an internal API. Run history is visible to admins.',
  },
];
---

<Layout metadata={metadata}>

  <!-- HERO — single backdrop (grid only) ─────────────────────────── -->
  <section class="aw-hero hero relative isolate overflow-hidden">
    <GridBackground variant="grid" tone="brand" />
    <div class="aw-container-wide">
      <div class="hero-grid">
        <div class="hero-copy">
          <a href="/use-cases" class="hero-pill">
            <span class="pill-tag">NEW</span>
            <span class="pill-text">150+ skills · 20+ connects</span>
            <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <h1 class="aw-display hero-display">
            Powerful agents.<br />
            Endless skills.<br />
            <span class="hero-finale">
              One-click <CircleHighlight text="Apps" class="hero-apps-circle" delay={520} />.
            </span>
          </h1>
          <p class="aw-lede hero-lede">
            One click freezes the agent flow that just worked into an App your team can run forever. No re-prompting. No glue code.
          </p>
          <div class="aw-actions hero-actions">
            <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Start free</a>
            <a href="/use-cases" class="aw-btn aw-btn-ghost">See use cases</a>
          </div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <OrbitingCircles
            size={480}
            iconSize={58}
            centerSize={92}
            centerSrc="/favicon.svg"
            centerAlt="Aitroop"
            rings={orbitRings}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS — single lede (replaces stats strip) + dual marquee ── -->
  <section class="skills-section">
    <div class="aw-container-wide">
      <p class="skills-lede">
        Already wired with <strong>150+ skills</strong> and <strong>20+ connects</strong> —
        from GitHub &amp; Gmail to Slack, Notion, Drive, Linear and the long tail your team already lives in.
      </p>
    </div>
    <Marquee speed={45} class="skills-marquee">
      {skills.map((s) => (
        <span class="skill-chip">
          <span class="skill-dot" aria-hidden="true"></span>
          {s}
        </span>
      ))}
    </Marquee>
    <Marquee speed={55} direction="right" class="skills-marquee skills-marquee--second">
      {skills.slice().reverse().map((s) => (
        <span class="skill-chip skill-chip--ghost">
          <span class="skill-dot" aria-hidden="true"></span>
          {s}
        </span>
      ))}
    </Marquee>
  </section>

  <!-- LIFECYCLE — the loop, end to end ───────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head lifecycle-head">
        <h2 class="aw-h2">From chat to scheduled App, in one loop.</h2>
        <p class="aw-lede lifecycle-lede">A conversation becomes a form. The form runs a stage. The stage ships an artifact. The artifact triggers the next run.</p>
      </header>
      <WorkflowLifecycle loopHint="and it repeats — on a cron, on demand, on a webhook" />
    </div>
  </section>

  <!-- ANATOMY ──────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section anatomy-borderless">
    <div class="aw-container-wide">
      <AnatomyFlow
        eyebrow=""
        title="Three pieces. One pipeline."
        lede="Inputs feed the stage. The stage produces the artifact. The artifact ships, or feeds the next stage."
        steps={anatomySteps}
      />
    </div>
  </section>

  <!-- FEATURES — bento grid (first tile is wide for asymmetry) ──── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head">
        <h2 class="aw-h2">Everything you need to make an agent stick.</h2>
      </header>
      <BentoGrid items={features} />
    </div>
  </section>

  <!-- USE CASES — function tile grid, generic-agent framing ──────── -->
  <section class="aw-section-flush home-section">
    <div class="aw-container-wide">
      <header class="aw-section-head cases-head">
        <h2 class="aw-h2">Any repeated work can be an App.</h2>
        <p class="aw-lede cases-lede">Aitroop is a generic agent — it does not assume your job. Below are starting points across eight functions. Open one, install it, or fork it into your own shape.</p>
      </header>

      <ul class="cases-tiles" role="list">
        {cases.map((c) => (
          <li>
            <a href={c.slug} class="case-tile">
              <span class="case-tile-title">{c.title}</span>
              <span class="case-tile-tagline">{c.tagline}</span>
              <span class="case-tile-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>

      <div class="cases-cta">
        <a href="/use-cases" class="cases-cta-link">
          See all use cases
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS — first one featured, others quieter ──────────── -->
  <section class="aw-section-flush home-section home-section--soft testimonials-section">
    <div class="aw-container-wide">
      <header class="aw-section-head">
        <h2 class="aw-h2">Operators who already shipped the loop.</h2>
      </header>

      <ul class="testimonials" role="list">
        {testimonials.map((t) => (
          <li class:list={['testimonial', t.featured && 'testimonial--featured']}>
            <svg class="testimonial__quote" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7.17 6A5.17 5.17 0 0 0 2 11.17V18h7v-6.83H5.5c0-1.93 1.57-3.5 3.5-3.5V6h-1.83zm10 0a5.17 5.17 0 0 0-5.17 5.17V18h7v-6.83h-3.5c0-1.93 1.57-3.5 3.5-3.5V6h-1.83z"/>
            </svg>
            <p class="testimonial__quote-text">{t.quote}</p>
            <div class="testimonial__author">
              <span class="testimonial__avatar" aria-hidden="true">{t.name.charAt(0)}</span>
              <div>
                <div class="testimonial__name">{t.name}</div>
                <div class="testimonial__title">{t.title} · {t.company}</div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ ──────────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head faq-head">
        <h2 class="aw-h2">Questions, answered.</h2>
      </header>
      <ul class="faq-list" role="list">
        {faqs.map((item) => (
          <li class="faq-item">
            <h3 class="faq-q">{item.q}</h3>
            <p class="faq-a">{item.a}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA — drenched brand green, no decoration ──────────────────── -->
  <section class="aw-section-flush home-section cta-section">
    <div class="aw-container-wide">
      <div class="cta-drench">
        <h2 class="cta-h2">Ship your first App before lunch.</h2>
        <p class="cta-lede">Open a chat. Click <code class="cta-code">Save as App</code>. That's the loop.</p>
        <div class="aw-actions aw-actions-center cta-actions">
          <a href="https://app.aitroop.net" class="aw-btn cta-btn-primary">Open the app</a>
          <a href="/contact" class="aw-btn cta-btn-ghost">Talk to us</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ══════════════════════════════════════════════════════════════════
     HERO — centered single column, restrained backdrop
     ══════════════════════════════════════════════════════════════════ */
  .hero {
    padding-top: clamp(3.5rem, 7vw, 5.5rem);
    padding-bottom: clamp(4rem, 7vw, 6rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
  }

  .hero-copy {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto;
  }

  .hero-visual {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap: clamp(2rem, 4vw, 4rem);
    }
    .hero-copy {
      text-align: left;
      max-width: 36rem;
      margin: 0;
    }
    .hero-visual {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 480px;
    }
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3125rem 0.875rem 0.3125rem 0.4375rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: border-color 200ms ease, color 200ms ease;
  }
  .hero-pill:hover {
    border-color: rgba(82, 153, 97, 0.35);
    color: var(--aw-color-text-default);
  }
  .pill-tag {
    padding: 1px 7px;
    border-radius: 9999px;
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  .pill-arrow {
    width: 12px;
    height: 12px;
    color: var(--aw-color-text-muted);
    transition: transform 200ms ease;
  }
  .hero-pill:hover .pill-arrow { transform: translateX(2px); }

  .hero-display {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.04;
    margin: 0 auto 1.5rem;
    max-width: 22ch;
  }
  .hero-finale {
    display: inline-block;
    color: var(--aw-color-primary);
    white-space: nowrap;
  }
  .hero-lede {
    margin: 0 auto 2rem;
    max-width: 40rem;
    font-size: clamp(1.0625rem, 1.25vw, 1.1875rem);
  }
  .hero-actions {
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-display {
      margin: 0 0 1.5rem;
      max-width: none;
    }
    .hero-lede {
      margin: 0 0 2rem;
      max-width: 34rem;
    }
    .hero-actions {
      justify-content: flex-start;
    }
  }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
  .hero-pill,
  .hero-display,
  .hero-lede,
  .hero-actions {
    animation: hero-rise 700ms cubic-bezier(0.25, 1, 0.5, 1) both;
  }
  .hero-pill    { animation-delay: 0ms; }
  .hero-display { animation-delay: 80ms; }
  .hero-lede    { animation-delay: 160ms; }
  .hero-actions { animation-delay: 240ms; }


  /* ══════════════════════════════════════════════════════════════════
     SKILLS MARQUEE — replaces the hero-metric stats strip
     ══════════════════════════════════════════════════════════════════ */
  .skills-section {
    padding: 0.5rem 0 3rem;
  }
  @media (min-width: 768px) {
    .skills-section { padding: 1rem 0 4rem; }
  }
  .skills-lede {
    text-align: center;
    max-width: 56ch;
    margin: 0 auto 2rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
  }
  .skills-lede strong {
    color: var(--aw-color-text-heading);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .skills-marquee { padding: 0.5rem 0; }
  .skills-marquee--second {
    margin-top: 0.5rem;
    opacity: 0.85;
  }
  .skill-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.95rem;
    border: 1px solid var(--aw-color-border);
    border-radius: 9999px;
    background: var(--aw-color-bg-page);
    font-size: 0.8125rem;
    color: var(--aw-color-text-default);
    white-space: nowrap;
    transition: border-color 200ms ease, color 200ms ease;
  }
  .skill-chip:hover {
    border-color: rgba(82, 153, 97, 0.4);
    color: var(--aw-color-primary);
  }
  .skill-chip--ghost {
    background: transparent;
    color: var(--aw-color-text-muted);
  }
  .skill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--aw-color-primary);
  }

  /* ══════════════════════════════════════════════════════════════════
     Home section rhythm — soft tinted bands replace section borders
     ══════════════════════════════════════════════════════════════════ */
  .home-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .home-section { padding-top: 5.5rem; padding-bottom: 5.5rem; }
  }
  .home-section--soft {
    background: rgba(82, 153, 97, 0.04);
  }

  /* Anatomy: drop hairline borders inside the component */
  :global(.anatomy-borderless .step-card) {
    border-top: none !important;
    border-bottom: none !important;
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  @media (min-width: 1024px) {
    :global(.anatomy-borderless .step-card) {
      padding-top: 0 !important;
    }
  }

  .lifecycle-head { max-width: 56rem; margin-bottom: 2.5rem; }
  .lifecycle-lede { max-width: 52ch; margin: 0; }

  /* ══════════════════════════════════════════════════════════════════
     USE CASES — function tile grid (8 starting points)
     ══════════════════════════════════════════════════════════════════ */
  .cases-head { max-width: 60rem; margin-bottom: 2.5rem; }
  .cases-lede { max-width: 56ch; margin: 0.75rem 0 0; }

  .cases-tiles {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--aw-color-border-strong);
  }
  @media (min-width: 640px) {
    .cases-tiles { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .cases-tiles { grid-template-columns: repeat(4, 1fr); }
  }
  .case-tile {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.125rem;
    border-bottom: 1px solid var(--aw-color-border);
    border-right: 1px solid var(--aw-color-border);
    color: inherit;
    text-decoration: none;
    background: transparent;
    transition: background 180ms ease, color 180ms ease;
  }
  @media (min-width: 640px) {
    .case-tile:nth-child(2n) { border-right: 1px solid var(--aw-color-border); }
  }
  /* trim trailing right borders at the row's end */
  .cases-tiles li:nth-child(2n) .case-tile { border-right: 0; }
  @media (min-width: 1024px) {
    .cases-tiles li:nth-child(2n) .case-tile { border-right: 1px solid var(--aw-color-border); }
    .cases-tiles li:nth-child(4n) .case-tile { border-right: 0; }
  }
  .case-tile-title {
    grid-row: 1;
    grid-column: 1;
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.015em;
    line-height: 1.2;
  }
  .case-tile-tagline {
    grid-row: 2;
    grid-column: 1 / -1;
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    line-height: 1.5;
    margin-top: 0.25rem;
  }
  .case-tile-arrow {
    grid-row: 1;
    grid-column: 2;
    color: var(--aw-color-text-muted);
    font-size: 0.95rem;
    transition: transform 180ms ease, color 180ms ease;
  }
  .case-tile:hover {
    background: rgba(82, 153, 97, 0.05);
  }
  .case-tile:hover .case-tile-arrow {
    color: var(--aw-color-primary);
    transform: translateX(3px);
  }
  .case-tile:hover .case-tile-title {
    color: var(--aw-color-primary);
  }

  .cases-cta {
    margin-top: 2rem;
    display: flex;
    justify-content: flex-start;
  }
  .cases-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
