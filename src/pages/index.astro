---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import ChatToAppDemo from '~/components/widgets/ChatToAppDemo.astro';
import WorkflowLifecycle from '~/components/widgets/WorkflowLifecycle.astro';

const metadata = {
  title: 'Aitroop — Save AI agent conversations as apps',
  ignoreTitleTemplate: true,
};

// Built-in pieces — concrete, not generic
const pieces = [
  {
    icon: 'tabler:puzzle',
    label: '150+ skills',
    title: 'Skills',
    desc: 'Reusable capability modules — lead-gen, web-scrape, SEO audit, github-mcp, calendar-mcp, and more. Install with one click.',
    items: ['github-mcp', 'lead-finder', 'web-scrape', 'seo-audit', 'gmail-search', '+ many more'],
  },
  {
    icon: 'tabler:plug-connected',
    label: '20+ connects',
    title: 'Connects',
    desc: 'OAuth integrations to the systems you already use. Agents read and write through your authorized accounts.',
    items: ['google-drive', 'gmail', 'github', 'salesforce', 'hubspot', 'notion'],
  },
  {
    icon: 'tabler:calendar-clock',
    label: 'cron-driven',
    title: 'Schedules',
    desc: 'Run any App on a cron. Daily summaries, hourly polling, weekly digests — results delivered automatically.',
    items: ['daily', 'hourly', 'weekly', 'custom cron', 'on-event', 'manual'],
  },
  {
    icon: 'tabler:files',
    label: '7 formats',
    title: 'Artifacts',
    desc: 'First-class outputs that you can preview, edit, download, and chain into the next stage of the workflow.',
    items: ['markdown', 'code', 'html', 'json', 'csv', 'image', 'file'],
  },
];

const anatomy = [
  { n: '01', title: 'AppInput',  desc: 'A schema-driven form. text, daterange, select, file, connect_file — pick what you need, render automatically.' },
  { n: '02', title: 'Stage',     desc: 'A self-contained AI agent session with a goal. Most Apps need one. Multi-stage Apps chain artifacts forward.' },
  { n: '03', title: 'Artifact',  desc: 'The deliverable. Rendered, previewed, exported. Re-edit in Chat or chain into the next Stage.' },
];

const cases = [
  {
    slug: '/use-cases/gtm',
    eyebrow: 'B2B Growth',
    title: 'GTM',
    desc: 'Prospecting, outreach, retention, and pipeline insights — agent-driven from day one.',
    examples: ['Lead enrichment', 'Cold outreach drafts', 'Account health monitor', 'Pipeline insights'],
  },
  {
    slug: '/use-cases/finance',
    eyebrow: 'Finance teams',
    title: 'Finance',
    desc: 'Month-end close, AR/AP analysis, expense compliance, budget vs actual — for finance teams and CFOs.',
    examples: ['Month-end checklist', 'AR aging report', 'Expense audit', 'Variance analysis'],
  },
];
---

<Layout metadata={metadata}>

  <!-- ══════════════════════════════════════════════════════════════════
       HERO — two columns + aurora background + live product demo
       ══════════════════════════════════════════════════════════════════ -->
  <section class="relative isolate overflow-hidden">
    <!-- Aurora: two soft drifting radial gradients, brand-tinted -->
    <div aria-hidden="true" class="aurora">
      <div class="aurora-a"></div>
      <div class="aurora-b"></div>
    </div>
    <!-- Tight dot grid with radial mask -->
    <div aria-hidden="true" class="grid-bg"></div>

    <div class="mx-auto max-w-6xl px-6 md:px-10 pt-20 md:pt-28 lg:pt-32 pb-24 md:pb-32">
      <div class="grid lg:grid-cols-[1.05fr_1fr] gap-12 lg:gap-14 items-center">

        <!-- ── Copy ── -->
        <div class="hero-copy">
          <div class="hero-eyebrow">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full rounded-full bg-primary opacity-60 animate-ping"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
            </span>
            <span>AI Agent Platform</span>
          </div>

          <h1 class="hero-h1">
            Save agent<br/>
            <span class="strike-pop">conversations</span><br/>
            <span class="text-primary">as apps.</span>
          </h1>

          <p class="hero-sub">
            Find what works in a chat. Save it as a one-click <span class="font-mono text-[var(--aw-color-text-default)]">App</span> with a form, a goal, and scheduled runs. Your team gets repeatable AI workflows — no code, no prompt copy-pasting.
          </p>

          <div class="hero-cta">
            <a href="https://app.aitroop.net" class="btn-pill btn-pill-primary">
              Start free
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/use-cases" class="btn-pill btn-pill-ghost">
              See use cases
            </a>
          </div>

          <ul class="trust-strip">
            <li>Multi-tenant</li>
            <li>OAuth integrations</li>
            <li>150+ built-in skills</li>
            <li>Isolated E2B sandboxes</li>
          </ul>
        </div>

        <!-- ── Live demo ── -->
        <div class="hero-demo">
          <ChatToAppDemo />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════
       WORKFLOW — full lifecycle strip, animates once on scroll-in
       ══════════════════════════════════════════════════════════════════ -->
  <section class="band-subtle border-t border-[var(--aw-color-border)]">
    <div class="mx-auto max-w-6xl px-6 md:px-10 py-16 md:py-24">
      <div class="text-center mb-12 md:mb-14 mx-auto max-w-[640px]">
        <p class="section-label inline-block">THE LOOP</p>
        <h2 class="section-title section-title--mid">One chat. Then a thousand runs.</h2>
      </div>
      <WorkflowLifecycle />
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════
       BUILT-IN PIECES
       ══════════════════════════════════════════════════════════════════ -->
  <section class="border-y border-[var(--aw-color-border)] py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <header class="section-intro">
        <p class="section-label">BUILT-IN</p>
        <h2 class="section-title">Everything an agent needs.</h2>
        <p class="section-lede">
          You don't assemble integrations or write glue code. Pick the skills you want, authorize the systems you use, set a schedule. Ship.
        </p>
      </header>

      <div class="grid sm:grid-cols-2 gap-5">
        {pieces.map((p, i) => (
          <div class="piece-card intersect intersect-once motion-safe:opacity-0 motion-safe:translate-y-3 motion-safe:[&:not([no-intersect])]:opacity-100 motion-safe:[&:not([no-intersect])]:translate-y-0 motion-safe:transition-all motion-safe:duration-700" style={`transition-delay:${i * 90}ms`}>
            <div class="flex items-start justify-between mb-5">
              <div class="piece-icon">
                <Icon name={p.icon} class="w-[18px] h-[18px]" />
              </div>
              <span class="piece-badge">{p.label}</span>
            </div>
            <h3 class="piece-title">{p.title}</h3>
            <p class="piece-desc">{p.desc}</p>
            <div class="piece-tags">
              {p.items.map((item) => (
                <span class="piece-tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════
       ANATOMY — 3-column on desktop with connecting rail
       ══════════════════════════════════════════════════════════════════ -->
  <section class="band-subtle py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <header class="section-intro">
        <p class="section-label">ANATOMY</p>
        <h2 class="section-title">An App, in three pieces.</h2>
        <p class="section-lede">
          The whole platform comes down to three primitives. Simple to reason about, easy to compose.
        </p>
      </header>

      <div class="anatomy">
        <!-- horizontal rail on desktop, aligned to circle centers -->
        <div aria-hidden="true" class="anatomy-rail"></div>
        <div class="grid md:grid-cols-3 gap-6 md:gap-8 relative">
          {anatomy.map((a, i) => (
            <div class="anatomy-card intersect intersect-once motion-safe:opacity-0 motion-safe:translate-y-3 motion-safe:[&:not([no-intersect])]:opacity-100 motion-safe:[&:not([no-intersect])]:translate-y-0 motion-safe:transition-all motion-safe:duration-700" style={`transition-delay:${i * 110}ms`}>
              <div class="anatomy-num">{a.n}</div>
              <h3 class="anatomy-title">{a.title}</h3>
              <p class="anatomy-desc">{a.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="anatomy-formula-wrap">
        <div class="anatomy-formula">
          <code>
            <span class="text-primary">App</span> = <span class="text-primary">AppInput</span>[] + <span class="text-primary">Stage</span>[] + <span class="text-primary">Artifact</span>[]
          </code>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════
       USE CASES
       ══════════════════════════════════════════════════════════════════ -->
  <section class="border-y border-[var(--aw-color-border)] py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <header class="section-intro">
        <p class="section-label">USE CASES</p>
        <h2 class="section-title">Built for what you actually do.</h2>
        <p class="section-lede">
          We ship pre-built App packs for common team workflows. Use as-is or fork to fit your process.
        </p>
      </header>

      <div class="grid md:grid-cols-2 gap-5">
        {cases.map((c, i) => (
          <a href={c.slug} class="case-card group intersect intersect-once motion-safe:opacity-0 motion-safe:translate-y-3 motion-safe:[&:not([no-intersect])]:opacity-100 motion-safe:[&:not([no-intersect])]:translate-y-0 motion-safe:transition-all motion-safe:duration-700" style={`transition-delay:${i * 120}ms`}>
            <p class="case-eyebrow">{c.eyebrow}</p>
            <h3 class="case-title">{c.title}</h3>
            <p class="case-desc">{c.desc}</p>
            <ul class="case-list">
              {c.examples.map((ex) => (
                <li>
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
            <span class="case-cta">
              Explore use case
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════
       CTA
       ══════════════════════════════════════════════════════════════════ -->
  <section class="cta-section relative isolate overflow-hidden">
    <div aria-hidden="true" class="cta-glow"></div>
    <div class="mx-auto max-w-3xl px-6 md:px-10 text-center relative">
      <h2 class="cta-h2">
        Ship your first App<br/>before lunch.
      </h2>
      <p class="cta-lede">
        Open a chat, get something working, click <span class="font-mono">Save as App</span>. That's the whole loop.
      </p>
      <div class="cta-actions">
        <a href="https://app.aitroop.net" class="btn-pill btn-pill-primary">
          Start free
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/contact" class="btn-pill btn-pill-ghost">
          Talk to us
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════════════════════════════════════════════════════════════════
     DESIGN TOKENS (local to homepage)
     Built on the global --aw-color-* CSS variables. All measurements
     snap to a 4/8 px rhythm and the global 14px base.
     ════════════════════════════════════════════════════════════════ */
  :where(.hero-eyebrow, .section-intro, .piece-card, .case-card, .anatomy-card) {
    --p-rgb: 82, 153, 97;            /* primary, decomposed for rgba() */
  }

  /* ── Surface bands ── */
  .band-subtle {
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.012), rgba(0, 0, 0, 0.022) 50%, rgba(0, 0, 0, 0.012));
  }

  /* ── Shared section intro block ── */
  .section-intro {
    max-width: 640px;
    margin-bottom: 3rem;          /* 48px */
  }
  @media (min-width: 768px) {
    .section-intro { margin-bottom: 4rem; }   /* 64px */
  }
  .section-label {
    display: inline-block;
    font-size: 0.6875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--aw-color-primary);
    margin-bottom: 0.875rem;       /* 14px */
    line-height: 1;
  }
  .section-title {
    font-size: clamp(1.875rem, 3.6vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.032em;
    line-height: 1.08;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.875rem;
    text-wrap: balance;
  }
  .section-title--mid {
    font-size: clamp(1.625rem, 3vw, 2rem);
    letter-spacing: -0.028em;
    margin-bottom: 0;
  }
  .section-lede {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
    text-wrap: pretty;
    margin: 0;
  }
  @media (min-width: 768px) {
    .section-lede { font-size: 1.0625rem; }
  }

  /* ════════════════════════════════════════════════════════════════
     HERO
     ════════════════════════════════════════════════════════════════ */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3125rem 0.6875rem;   /* 5px 11px */
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(8px);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.6) inset;
    margin-bottom: 1.5rem;
  }
  .hero-eyebrow > span:last-child {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--aw-color-text-muted);
    line-height: 1;
  }

  .hero-h1 {
    font-size: clamp(2.5rem, 5.2vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    color: var(--aw-color-text-heading);
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }
  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
    max-width: 520px;
    margin: 0 0 2rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .hero-sub { font-size: 1.125rem; }
  }

  /* Stroke highlight on "conversations" */
  .strike-pop {
    position: relative;
    display: inline-block;
  }
  .strike-pop::after {
    content: '';
    position: absolute;
    left: -2px;
    right: -2px;
    bottom: 0.08em;
    height: 0.34em;
    background: rgba(82, 153, 97, 0.16);
    border-radius: 3px;
    z-index: -1;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .trust-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem 1.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .trust-strip li {
    position: relative;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    line-height: 1.3;
    letter-spacing: -0.01em;
    padding-left: 0.75rem;
  }
  .trust-strip li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: rgba(82, 153, 97, 0.55);
  }

  /* ── Aurora background ── */
  .aurora {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 120%;
    z-index: -2;
    pointer-events: none;
  }
  .aurora-a, .aurora-b {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.9;
  }
  .aurora-a {
    top: -10%; left: 5%;
    width: 55%; height: 70%;
    background: radial-gradient(circle, rgba(82, 153, 97, 0.22), transparent 65%);
  }
  .aurora-b {
    top: 10%; right: -10%;
    width: 50%; height: 60%;
    background: radial-gradient(circle, rgba(82, 153, 97, 0.14), transparent 65%);
  }
  @media (prefers-reduced-motion: no-preference) {
    .aurora-a { animation: aurora-drift-a 28s ease-in-out infinite; }
    .aurora-b { animation: aurora-drift-b 36s ease-in-out infinite; }
  }
  @keyframes aurora-drift-a {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(2%, 3%, 0) scale(1.08); }
  }
  @keyframes aurora-drift-b {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(-2%, -2%, 0) scale(1.06); }
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.32;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.045) 1px, transparent 1px);
    background-size: 48px 48px;
    -webkit-mask-image: radial-gradient(ellipse 72% 56% at 50% 0%, #000 30%, transparent 78%);
            mask-image: radial-gradient(ellipse 72% 56% at 50% 0%, #000 30%, transparent 78%);
  }

  /* ════════════════════════════════════════════════════════════════
     BUTTONS — pill, two variants, layered shadow
     ════════════════════════════════════════════════════════════════ */
  .btn-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: 2.75rem;             /* 44px — accessible tap target */
    padding: 0 1.375rem;          /* 22px */
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    line-height: 1;
    white-space: nowrap;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      box-shadow 200ms ease,
      transform 160ms ease;
    will-change: transform;
  }
  .btn-pill:focus-visible {
    outline: none;
    box-shadow:
      0 0 0 2px var(--aw-color-bg-page),
      0 0 0 4px rgba(82, 153, 97, 0.55);
  }

  .btn-pill-primary {
    background: var(--aw-color-primary);
    color: #fff;
    border: 1px solid rgba(0, 0, 0, 0.04);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 1px 2px rgba(45, 110, 63, 0.25),
      0 8px 20px -8px rgba(82, 153, 97, 0.55);
  }
  .btn-pill-primary:hover {
    background: rgb(61, 133, 79);
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 2px 4px rgba(45, 110, 63, 0.28),
      0 14px 28px -10px rgba(82, 153, 97, 0.6);
  }
  .btn-pill-primary:active {
    transform: translateY(0);
    box-shadow:
      inset 0 1px 1px rgba(0, 0, 0, 0.08),
      0 1px 2px rgba(45, 110, 63, 0.25);
  }

  .btn-pill-ghost {
    background: rgba(255, 255, 255, 0.6);
    color: var(--aw-color-text-default);
    border: 1px solid var(--aw-color-border);
    backdrop-filter: blur(6px);
  }
  .btn-pill-ghost:hover {
    border-color: rgba(0, 0, 0, 0.22);
    background: rgba(0, 0, 0, 0.03);
    transform: translateY(-1px);
  }
  .btn-pill-ghost:active { transform: translateY(0); }

  /* ════════════════════════════════════════════════════════════════
     BUILT-IN piece cards
     ════════════════════════════════════════════════════════════════ */
  .piece-card {
    position: relative;
    padding: 1.625rem;            /* 26px uniform */
    border-radius: 14px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 1px 0 rgba(0, 0, 0, 0.015);
    transition:
      border-color 200ms ease,
      box-shadow 250ms ease,
      transform 200ms ease;
  }
  .piece-card:hover {
    border-color: rgba(82, 153, 97, 0.35);
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 12px 32px -16px rgba(82, 153, 97, 0.28),
      0 4px 12px -6px rgba(0, 0, 0, 0.06);
  }
  .piece-card:hover .piece-icon {
    background: rgba(82, 153, 97, 0.16);
    transform: scale(1.05);
  }
  .piece-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(82, 153, 97, 0.08);
    color: var(--aw-color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 200ms ease, transform 200ms ease;
  }
  .piece-badge {
    display: inline-flex;
    align-items: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    line-height: 1;
    height: 22px;
  }
  .piece-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.5rem;
  }
  .piece-desc {
    font-size: 0.9375rem;
