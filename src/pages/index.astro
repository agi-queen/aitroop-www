---
import Layout from '~/layouts/PageLayout.astro';
import AnatomyFlow from '~/components/widgets/AnatomyFlow.astro';
import WorkflowLifecycle from '~/components/widgets/WorkflowLifecycle.astro';
import PopText from '~/components/ui/PopText.astro';

const metadata = {
  title: 'Aitroop - Save AI agent conversations as apps',
  ignoreTitleTemplate: true,
};

const anatomySteps = [
  {
    title: 'AppInput',
    desc: 'A schema-driven form. Text, select, daterange, file. Declared once, rendered for you.',
    foot: '4 input types · validated',
  },
  {
    title: 'Stage',
    desc: 'An agent session with one goal, wired to your skills and connects. Chain stages when work spans steps.',
    foot: '150+ skills · 20+ connects',
  },
  {
    title: 'Artifact',
    desc: 'The deliverable. Preview, export, or feed it into the next stage.',
    foot: '7 formats · preview + export',
  },
];

const stats = [
  { value: '150+', label: 'Skills' },
  { value: '20+',  label: 'Connects' },
  { value: '7',    label: 'Artifact formats' },
  { value: 'cron', label: 'Schedules' },
];

const features = [
  {
    title: 'Save chats as Apps',
    desc: 'One click freezes the working flow into a typed, runnable workflow with named inputs.',
    icon: 'M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z',
  },
  {
    title: 'Multi-stage pipelines',
    desc: 'Chain stages when a single agent run is not enough. Each stage owns its own model, skills and prompt.',
    icon: 'M4 6h16M4 12h16M4 18h10',
  },
  {
    title: '150+ skills, 20+ connects',
    desc: 'GitHub, Gmail, Slack, Drive, Notion, web search, code execution — wired in with one toggle.',
    icon: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z',
  },
  {
    title: 'Real sandboxes',
    desc: 'Every run lands in an isolated environment with file access, network and the right toolchain.',
    icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
  },
  {
    title: 'Schedules & webhooks',
    desc: 'Run on a cron, on demand, or off a webhook. Hands-free after one setup, with full run history.',
    icon: 'M12 6v6l4 2M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z',
  },
  {
    title: 'Share with your team',
    desc: 'Each App is a permissioned object. Hand it off, embed it, or expose it as an internal API.',
    icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  },
];

const cases = [
  {
    slug: '/use-cases/gtm',
    title: 'GTM',
    desc: 'Prospecting, outreach, retention, pipeline insights.',
    points: ['ICP research at scale', 'Personalised sequences', 'Pipeline & retention reports'],
  },
  {
    slug: '/use-cases/finance',
    title: 'Finance',
    desc: 'Close, audit, variance, reporting. Built for CFO teams.',
    points: ['Close-pack assembly', 'Variance & flux analysis', 'Auditor-ready exports'],
  },
];

const faqs = [
  {
    q: 'Do I have to rebuild my prompts to save an App?',
    a: 'No. Open a chat that already works, click Save as App, and Aitroop captures the skills, connects and prompts as a runnable workflow.',
  },
  {
    q: 'What runs the App after it is saved?',
    a: 'Each run executes in an isolated sandbox with the file system, network and tools the agent needs. You can trigger it manually, on a cron, or from a webhook.',
  },
  {
    q: 'Can I chain steps that need different tools?',
    a: 'Yes. Stages let you wire one agent into the next, each with its own model, skills and prompt. The artifact from one stage feeds the input of the next.',
  },
  {
    q: 'Who can use the App once I publish it?',
    a: 'Apps are permissioned objects. Share with a teammate, an external collaborator, or expose them as an internal API. Run history is visible to admins.',
  },
];
---

<Layout metadata={metadata}>

  <!-- HERO — split layout: copy left, feature stack right ─────────── -->
  <section class="aw-hero hero relative isolate overflow-hidden">
    <div aria-hidden="true" class="hero-dots"></div>
    <div aria-hidden="true" class="hero-glow"></div>
    <div class="aw-container-wide">
      <div class="hero-grid">
        <div class="hero-copy">
          <a href="/use-cases" class="hero-pill">
            <span class="pill-tag">NEW</span>
            <span class="pill-text">150+ skills · 20+ connects</span>
            <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <h1 class="aw-display hero-display">
            Powerful agents.<br />
            Endless skills.<br />
            <PopText
              text="One-click Apps."
              stagger={32}
              delay={260}
              duration={310}
              class="text-primary hero-pop"
            />
          </h1>
          <p class="aw-lede hero-lede">
            One click freezes the agent flow that just worked into an App your team can run forever. No re-prompting. No glue code.
          </p>
          <div class="aw-actions hero-actions">
            <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Start free</a>
            <a href="/use-cases" class="aw-btn aw-btn-ghost">See use cases</a>
          </div>
        </div>

        <ul class="hero-features" role="list">
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">Save chats as Apps</p>
              <p class="feature-desc">Click once. The conversation becomes a typed, runnable workflow your team can re-run.</p>
            </div>
          </li>
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">150+ skills · 20+ connects</p>
              <p class="feature-desc">Deep integrations: GitHub, Gmail, Slack, Drive, web search, code execution.</p>
            </div>
          </li>
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">Real sandboxes</p>
              <p class="feature-desc">Each run executes in an isolated environment with file access, network and the right tools.</p>
            </div>
          </li>
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">Schedules &amp; webhooks</p>
              <p class="feature-desc">Run daily at 9 AM, or trigger from your stack via API. Hands-free after one setup.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- STATS — quiet strip just below the fold ────────────────────── -->
  <section class="stats-section">
    <div class="aw-container-wide">
      <ul class="stats" role="list">
        {stats.map((s) => (
          <li class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- LIFECYCLE — the loop, end to end ───────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head lifecycle-head">
        <h2 class="aw-h2">From chat to scheduled App, in one loop.</h2>
        <p class="aw-lede lifecycle-lede">A conversation becomes a form. The form runs a stage. The stage ships an artifact. The artifact triggers the next run.</p>
      </header>
      <WorkflowLifecycle loopHint="and it repeats — on a cron, on demand, on a webhook" />
    </div>
  </section>

  <!-- ANATOMY ──────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section anatomy-borderless">
    <div class="aw-container-wide">
      <AnatomyFlow
        eyebrow=""
        title="Three pieces. One pipeline."
        lede="Inputs feed the stage. The stage produces the artifact. The artifact ships, or feeds the next stage."
        steps={anatomySteps}
      />
    </div>
  </section>

  <!-- FEATURES — six concrete capabilities ─────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head">
        <p class="aw-eyebrow">Why teams pick Aitroop</p>
        <h2 class="aw-h2">Everything you need to make an agent stick.</h2>
      </header>
      <ul class="features-grid" role="list">
        {features.map((f) => (
          <li class="feature-tile">
            <span class="tile-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon} />
              </svg>
            </span>
            <h3 class="tile-title">{f.title}</h3>
            <p class="tile-desc">{f.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- USE CASES ────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section">
    <div class="aw-container-wide">
      <header class="aw-section-head">
        <p class="aw-eyebrow">Use cases</p>
        <h2 class="aw-h2">Built for what you actually do.</h2>
      </header>

      <ul class="cases-grid" role="list">
        {cases.map((c) => (
          <li class="case-card">
            <a href={c.slug} class="case-link">
              <div class="case-head">
                <span class="case-title">{c.title}</span>
                <span class="case-arrow aw-arrow" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
              <p class="case-desc">{c.desc}</p>
              <ul class="case-points" role="list">
                {c.points.map((p) => (
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ ──────────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head faq-head">
        <p class="aw-eyebrow">FAQ</p>
        <h2 class="aw-h2">Questions, answered.</h2>
      </header>
      <ul class="faq-list" role="list">
        {faqs.map((item) => (
          <li class="faq-item">
            <h3 class="faq-q">{item.q}</h3>
            <p class="faq-a">{item.a}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section cta-section">
    <div class="aw-container-wide">
      <div class="cta-card">
        <h2 class="aw-h2 cta-h2">Ship your first App before lunch.</h2>
        <p class="aw-lede cta-lede">Open a chat. Click <code class="aw-code">Save as App</code>. That's the loop.</p>
        <div class="aw-actions aw-actions-center">
          <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Open the app</a>
          <a href="/contact" class="aw-btn aw-btn-ghost">Talk to us</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ══════════════════════════════════════════════════════════════════
     HERO — split layout
     ══════════════════════════════════════════════════════════════════ */
  .hero {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero-dots {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, rgba(10, 10, 10, 0.06) 1px, transparent 0);
    background-size: 22px 22px;
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 22%, #000 25%, transparent 82%);
            mask-image: radial-gradient(ellipse 70% 50% at 50% 22%, #000 25%, transparent 82%);
  }
  .hero-glow {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 80%;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 45% at 50% 10%, rgba(82, 153, 97, 0.08), transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 75% 60% at 50% 0%, #000 25%, transparent 85%);
            mask-image: radial-gradient(ellipse 75% 60% at 50% 0%, #000 25%, transparent 85%);
    animation: hero-breathe 14s ease-in-out infinite;
  }
  @keyframes hero-breathe {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
    }
  }

  .hero-copy {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .hero-copy {
      text-align: left;
      max-width: none;
      margin: 0;
    }
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3125rem 0.875rem 0.3125rem 0.4375rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: border-color 200ms ease, color 200ms ease, transform 200ms ease;
  }
  .hero-pill:hover {
    border-color: rgba(82, 153, 97, 0.35);
    color: var(--aw-color-text-default);
  }
  .pill-tag {
    padding: 1px 7px;
    border-radius: 9999px;
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  .pill-arrow {
    width: 12px;
    height: 12px;
    color: var(--aw-color-text-muted);
    transition: transform 200ms ease;
  }
  .hero-pill:hover .pill-arrow { transform: translateX(2px); }

  .hero-display {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.04;
    margin: 0 auto 1.5rem;
    max-width: 22ch;
  }
  :global(.hero-pop) {
    display: inline-flex;
    flex-wrap: nowrap;
    white-space: nowrap;
  }
  .hero-lede {
    margin: 0 auto 2rem;
    max-width: 40rem;
    font-size: clamp(1.0625rem, 1.25vw, 1.1875rem);
  }
  .hero-actions {
    justify-content: center;
  }
  @media (min-width: 1024px) {
    .hero-display { margin-left: 0; margin-right: 0; }
    .hero-lede    { margin-left: 0; margin-right: 0; }
    .hero-actions { justify-content: flex-start; }
  }

  .hero-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    border: 1px solid var(--aw-color-border);
    border-radius: 12px;
    background: var(--aw-color-bg-page);
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .feature-card:hover {
    border-color: rgba(82, 153, 97, 0.35);
    transform: translateY(-1px);
    box-shadow: 0 10px 28px -16px rgba(10, 10, 10, 0.10);
  }
  .feature-icon {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: rgba(82, 153, 97, 0.10);
    color: var(--aw-color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .feature-icon svg { width: 18px; height: 18px; }
  .feature-body { min-width: 0; }
  .feature-title {
    font-weight: 600;
    color: var(--aw-color-text-heading);
    font-size: 0.95rem;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }
  .feature-desc {
    font-size: 0.85rem;
    color: var(--aw-color-text-muted);
    line-height: 1.55;
    margin: 0;
  }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
  .hero-pill,
  .hero-display,
  .hero-lede,
  .hero-actions,
  .hero-features {
    animation: hero-rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .hero-pill      { animation-delay: 0ms; }
  .hero-display   { animation-delay: 80ms; }
  .hero-lede      { animation-delay: 160ms; }
  .hero-actions   { animation-delay: 240ms; }
  .hero-features  { animation-delay: 320ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow,
    .hero-pill,
    .hero-display,
    .hero-lede,
    .hero-actions,
    .hero-features {
      animation: none;
    }
  }

  /* ── Stats ─ minimal strip, no borders, lots of air ──────────── */
  .stats-section {
    padding: 2rem 0 3rem;
  }
  @media (min-width: 768px) {
    .stats-section { padding: 2.75rem 0 3.5rem; }
  }
  .stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem 1rem;
  }
  @media (min-width: 768px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .stat-value {
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  /* ── Home sections — divider-free rhythm via soft tints ──────── */
  .home-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .home-section { padding-top: 5.5rem; padding-bottom: 5.5rem; }
  }
  .home-section--soft {
    background: rgba(82, 153, 97, 0.025);
  }

  /* Anatomy: remove the hairline borders inside the component */
  :global(.anatomy-borderless .step-card) {
    border-top: none !important;
    border-bottom: none !important;
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  @media (min-width: 1024px) {
    :global(.anatomy-borderless .step-card) {
      padding-top: 0 !important;
    }
  }

  /* Lifecycle section heading uses a tighter rhythm */
  .lifecycle-head { max-width: 56rem; margin-bottom: 2.5rem; }
  .lifecycle-lede { max-width: 52ch; margin: 0; }

  /* ── Features grid — 6 tiles, borderless, soft hover ─────────── */
  .features-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 960px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  }
  .feature-tile {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.5rem 1.5rem 1.625rem;
    border-radius: 14px;
    background: var(--aw-color-bg-page);
    border: 1px solid transparent;
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .feature-tile:hover {
    border-color: rgba(82, 153, 97, 0.25);
    transform: translateY(-1px);
    box-shadow: 0 12px 30px -20px rgba(10, 10, 10, 0.12);
  }
  .tile-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(82, 153, 97, 0.10);
    color: var(--aw-color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
  }
  .tile-icon svg { width: 20px; height: 20px; }
  .tile-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .tile-desc {
