---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Aitroop — AI-Powered Growth Platform',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <main class="relative min-h-[calc(100vh-56px)] flex flex-col items-center justify-center px-4 overflow-hidden">

    <!-- Dot grid background -->
    <div
      class="absolute inset-0 -z-10"
      style="background-image: radial-gradient(circle, rgba(0,0,0,0.055) 1px, transparent 1px); background-size: 24px 24px;"
      aria-hidden="true"
    ></div>

    <!-- Soft green glow behind headline -->
    <div
      class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full"
      style="background: radial-gradient(ellipse at center, rgba(82,153,97,0.10) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <div class="max-w-2xl mx-auto flex flex-col items-center gap-6 text-center">

      <!-- Badge -->
      <div class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-[rgba(82,153,97,0.08)] border border-[rgba(82,153,97,0.22)] px-3 py-1.5 rounded-full shadow-sm">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
        </span>
        AI-Powered Growth Platform
      </div>

      <!-- Headline -->
      <h1 class="text-[3.25rem] md:text-[4.25rem] font-bold tracking-[-0.03em] text-[var(--aw-color-text-heading)] leading-[1.05] mt-2">
        Acquire more.<br />
        <span class="text-primary">Retain longer.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-[1rem] md:text-[1.0625rem] text-[var(--aw-color-text-muted)] max-w-[420px] leading-[1.7] -mt-1">
        AI-native tools for precision outreach, customer intelligence, and retention — so one person can do what once took an entire team.
      </p>

      <!-- Actions -->
      <div class="flex items-center gap-3 mt-2">
        <a
          href="https://app.aitroop.net"
          class="inline-flex items-center gap-2 h-10 px-5 rounded-[7px] bg-primary text-white text-sm font-semibold shadow-[0_1px_3px_rgba(82,153,97,0.4),0_0_0_1px_rgba(82,153,97,0.2)] hover:bg-[rgb(61,133,79)] hover:shadow-[0_2px_6px_rgba(82,153,97,0.45)] transition-all duration-150"
        >
          Log in to Aitroop
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="/blog"
          class="inline-flex items-center h-10 px-5 rounded-[7px] text-sm font-medium text-[var(--aw-color-text-muted)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.2)] hover:text-[var(--aw-color-text-default)] hover:bg-[rgba(0,0,0,0.02)] transition-all duration-150"
        >
          Read the blog
        </a>
      </div>

      <!-- Feature pills -->
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 mt-3 text-xs text-[var(--aw-color-text-muted)]">
        {[
          ['🔍', 'Prospect Intelligence'],
          ['✉️', 'Personalized Outreach'],
          ['📡', 'Intent Signals'],
          ['💚', 'Customer Retention'],
        ].map(([icon, label]) => (
          <span class="inline-flex items-center gap-1.5">
            <span class="text-[11px]">{icon}</span>
            {label}
          </span>
        ))}
      </div>

    </div>

    <!-- Bottom fade to blend with footer -->
    <div
      class="absolute bottom-0 left-0 right-0 h-24 -z-10"
      style="background: linear-gradient(to top, rgba(255,255,255,1) 0%, transparent 100%);"
      aria-hidden="true"
    ></div>

  </main>
</Layout>
