---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI-Powered Growth Platform',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════ -->
  <main class="relative min-h-[calc(100vh-56px)] flex flex-col items-center justify-center px-4 overflow-hidden">

    <!-- Dot grid background -->
    <div
      class="absolute inset-0 -z-10"
      style="background-image: radial-gradient(circle, rgba(0,0,0,0.05) 1px, transparent 1px); background-size: 24px 24px;"
      aria-hidden="true"
    ></div>

    <!-- Breathing green glow -->
    <div
      class="absolute -z-10 hero-glow"
      style="width:700px;height:500px;top:50%;left:50%;margin-left:-350px;margin-top:-250px;border-radius:50%;background:radial-gradient(ellipse at center,rgba(82,153,97,0.11) 0%,transparent 65%);"
      aria-hidden="true"
    ></div>

    <!-- Decorative ring — slow spin -->
    <div
      class="absolute -z-10 hero-ring"
      style="width:460px;height:460px;top:50%;left:50%;margin-left:-230px;margin-top:-230px;border-radius:50%;border:1px solid rgba(82,153,97,0.08);"
      aria-hidden="true"
    ></div>

    <!-- Decorative ring — counter spin -->
    <div
      class="absolute -z-10 hero-ring-rev"
      style="width:640px;height:640px;top:50%;left:50%;margin-left:-320px;margin-top:-320px;border-radius:50%;border:1px solid rgba(82,153,97,0.05);"
      aria-hidden="true"
    ></div>

    <!-- Network SVG: nodes + connecting lines -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none"
      style="z-index:-5;"
      aria-hidden="true"
      preserveAspectRatio="none"
    >
      <line x1="10%" y1="22%" x2="89%" y2="18%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-1" />
      <line x1="89%" y1="18%" x2="86%" y2="79%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-2" />
      <line x1="86%" y1="79%" x2="11%" y2="76%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-3" />
      <line x1="11%" y1="76%" x2="10%" y2="22%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-4" />
      <circle cx="10%" cy="22%" r="3"   fill="rgba(82,153,97,0.5)" class="net-node" style="animation-delay:0s" />
      <circle cx="89%" cy="18%" r="4"   fill="rgba(82,153,97,0.4)" class="net-node" style="animation-delay:0.6s" />
      <circle cx="86%" cy="79%" r="3"   fill="rgba(82,153,97,0.45)" class="net-node" style="animation-delay:1.2s" />
      <circle cx="11%" cy="76%" r="3.5" fill="rgba(82,153,97,0.4)" class="net-node" style="animation-delay:1.8s" />
    </svg>

    <!-- Horizontal scan beam -->
    <div class="hero-scan absolute inset-x-0 pointer-events-none" style="z-index:-5;height:1px;" aria-hidden="true"></div>

    <div class="max-w-[640px] mx-auto flex flex-col items-center gap-4 text-center">

      <!-- Badge -->
      <div class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-[rgba(82,153,97,0.08)] border border-[rgba(82,153,97,0.20)] px-3 py-1.5 rounded-full">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
        </span>
        AI Agent Platform for Growth
      </div>

      <!-- Headline -->
      <h1 class="text-[2rem] md:text-[2.625rem] font-bold tracking-[-0.02em] text-[var(--aw-color-text-heading)] leading-[1.2] -mt-1">
        Acquire smarter. Convert faster. <span class="hero-shimmer">Retain longer.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] max-w-[480px] leading-[1.8] -mt-1">
        An army of AI agents — prospect, engage, convert, retain — each with a precise mission across your growth pipeline. One platform, one operator, an entire team's output.
      </p>

      <!-- Actions -->
      <div class="flex flex-wrap items-center justify-center gap-3 mt-1">
        <a
          href="https://app.aitroop.net"
          class="inline-flex items-center gap-2 h-10 px-5 rounded-[7px] bg-primary text-white text-sm font-semibold shadow-[0_1px_3px_rgba(82,153,97,0.4),0_0_0_1px_rgba(82,153,97,0.2)] hover:bg-[rgb(61,133,79)] hover:shadow-[0_2px_6px_rgba(82,153,97,0.45)] transition-all duration-150"
        >
          Log in to Aitroop
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="/blog"
          class="inline-flex items-center h-10 px-5 rounded-[7px] text-sm font-medium text-[var(--aw-color-text-muted)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.2)] hover:text-[var(--aw-color-text-default)] hover:bg-[rgba(0,0,0,0.02)] transition-all duration-150"
        >
          Read the blog
        </a>
      </div>

      <!-- Stats mini grid -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px mt-3 w-full max-w-[440px] rounded-xl border border-[var(--aw-color-border)] overflow-hidden bg-[var(--aw-color-border)]">
        {[
          ['6×', 'Outreach Capacity'],
          ['90d', 'Churn Warning'],
          ['80%+', 'Data Coverage'],
          ['15%', 'Reply Rate'],
        ].map(([metric, label]) => (
          <div class="flex flex-col items-center gap-0.5 py-3 bg-[var(--aw-color-bg-page)]">
            <span class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] tabular-nums">{metric}</span>
            <span class="text-[0.65rem] text-[var(--aw-color-text-muted)] leading-tight px-1">{label}</span>
          </div>
        ))}
      </div>

    </div>

    <!-- Bottom fade -->
    <div
      class="absolute bottom-0 left-0 right-0 h-24 -z-10"
      style="background: linear-gradient(to top, rgba(255,255,255,1) 0%, transparent 100%);"
      aria-hidden="true"
    ></div>
  </main>

  <!-- ═══════════════════════════════════════════════════════
       SOCIAL PROOF TICKER
  ═══════════════════════════════════════════════════════ -->
  <div class="border-y border-[var(--aw-color-border)] py-5 overflow-hidden" style="background:rgba(82,153,97,0.02);">
    <p class="text-center text-[0.65rem] uppercase tracking-[0.15em] text-[var(--aw-color-text-muted)] mb-4 font-medium">
      Powering growth teams across industries
    </p>
    <div class="relative flex overflow-hidden">
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0">
        {['B2B SaaS', 'E-commerce', 'Fintech', 'MarTech', 'Sales Teams', 'Growth Agencies', 'D2C Brands', 'Enterprise GTM', 'PLG Companies', 'Startups'].map(name => (
          <li class="text-sm font-medium text-[var(--aw-color-text-muted)] opacity-50 hover:opacity-90 transition-opacity cursor-default select-none whitespace-nowrap">{name}</li>
        ))}
      </ul>
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0" aria-hidden="true">
        {['B2B SaaS', 'E-commerce', 'Fintech', 'MarTech', 'Sales Teams', 'Growth Agencies', 'D2C Brands', 'Enterprise GTM', 'PLG Companies', 'Startups'].map(name => (
          <li class="text-sm font-medium text-[var(--aw-color-text-muted)] opacity-50 whitespace-nowrap select-none">{name}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       AI AGENTS — FEATURE GRID
  ═══════════════════════════════════════════════════════ -->
  <Features2
    id="agents"
    tagline="The AI Growth Squad"
    title="Six specialists. One unified platform."
    subtitle="Each agent is purpose-built for a specific stage of your growth pipeline — working 24/7 so your team can focus on what only humans can do."
    columns={3}
    items={[
      {
        title: 'Prospect Agent',
        description:
          'Scans millions of signals to surface high-fit leads — company stage, hiring activity, tech stack, and intent data combined into a precision target list.',
        icon: 'tabler:radar',
      },
      {
        title: 'Outreach Agent',
        description:
          'Writes and sends hyper-personalized cold emails and LinkedIn messages. No templates — every message is contextually crafted for each recipient.',
        icon: 'tabler:mail-forward',
      },
      {
        title: 'Engage Agent',
        description:
          "Follows up intelligently across channels, adjusting tone and timing based on each prospect's engagement signals and conversation history.",
        icon: 'tabler:messages',
      },
      {
        title: 'Convert Agent',
        description:
          'Surfaces deal-winning insights for your reps at the right moment — objection handling, social proof, competitive intel, and next best actions.',
        icon: 'tabler:target',
      },
      {
        title: 'Retain Agent',
        description:
          "Monitors usage patterns and health scores continuously. Flags at-risk accounts 90 days before churn materializes so you can act while there's still time.",
        icon: 'tabler:shield-check',
      },
      {
        title: 'Insights Agent',
        description:
          'Synthesizes your entire pipeline into clear, actionable recommendations. Know exactly where to focus next — and why — without digging through dashboards.',
        icon: 'tabler:chart-line',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       HOW IT WORKS
  ═══════════════════════════════════════════════════════ -->
  <Steps
    id="how-it-works"
    tagline="Simple by design"
    title="Up and running in minutes."
    subtitle="No six-month onboarding. No army of consultants. Aitroop is built to deploy fast and compound results over time."
    items={[
      {
        title: 'Connect your stack',
        description:
          'Link your CRM, email provider, and LinkedIn in under 10 minutes. Native integrations with HubSpot, Salesforce, Apollo, Outreach, and more.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Deploy your agents',
        description:
          'Select which agents match your growth priorities and configure their parameters. No code required — the setup wizard handles the rest.',
        icon: 'tabler:robot',
      },
      {
        title: 'Agents go to work',
        description:
          'Automated prospecting, personalized outreach, and intelligent follow-ups run continuously — nights, weekends, time zones, always on.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Measure and scale',
        description:
          "The Insights Agent surfaces what's working and what's not. Amplify winning campaigns and cut what isn't — with a single click.",
        icon: 'tabler:trending-up',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       STATS — animated counters
  ═══════════════════════════════════════════════════════ -->
  <section id="stats-section" class="relative border-y border-[var(--aw-color-border)] overflow-hidden">
    <div
      class="absolute inset-0 -z-10 stats-gradient"
      aria-hidden="true"
    ></div>
    <div class="relative mx-auto max-w-5xl px-4 md:px-6 py-14 md:py-20 text-default intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="text-center mb-10">
        <p class="text-xs uppercase tracking-[0.15em] font-medium text-primary mb-2">Real results</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--aw-color-text-heading)]">Numbers that move the needle.</h2>
        <p class="text-[var(--aw-color-text-muted)] mt-3 max-w-md mx-auto text-sm md:text-base">
          Aggregated across growth teams running Aitroop agents in production.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <div class="stat-card group text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1">
            <span class="stat-num" data-target="6" data-suffix="×">6</span><span>×</span>
          </div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">Outreach capacity increase</p>
        </div>
        <div class="stat-card group text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1">
            <span class="stat-num" data-target="90">90</span><span>d</span>
          </div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">Average churn early warning</p>
        </div>
        <div class="stat-card group text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1">
            <span class="stat-num" data-target="80">80</span><span>%+</span>
          </div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">Contact data coverage</p>
        </div>
        <div class="stat-card group text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1">
            <span class="stat-num" data-target="15">15</span><span>%</span>
          </div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">Average reply rate</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TESTIMONIALS
  ═══════════════════════════════════════════════════════ -->
  <Testimonials
    id="testimonials"
    tagline="What teams are saying"
    title="Growth teams love Aitroop."
    subtitle="From SDR-heavy outbound to lean PLG motions — Aitroop adapts to how you grow."
    testimonials={[
      {
        testimonial:
          'We scaled from 200 to 1,400 outreach sequences per month without adding headcount. The Outreach Agent writes better cold emails than most SDRs, honestly.',
        name: 'Lena Torres',
        job: 'Head of Growth · Patrly',
      },
      {
        testimonial:
          'The 90-day churn alert is genuinely impressive. We saved three enterprise accounts last quarter because Aitroop flagged them first — before they reached out to cancel.',
        name: 'David Kwan',
        job: 'VP of Sales · Clearflo',
      },
      {
        testimonial:
          "We used to stitch together five different tools for this workflow. Now it's one platform. Our GTM velocity doubled in 60 days and our ops overhead actually went down.",
        name: 'Priya Nair',
        job: 'CMO · Storyvault',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════════════════ -->
  <CallToAction
    title="Your growth team is ready."
    subtitle="Deploy your first AI agent in minutes. See the pipeline move."
    actions={[
      { text: 'Get started', href: 'https://app.aitroop.net', variant: 'primary' },
      { text: 'Talk to us', href: '/contact', variant: 'secondary' },
    ]}
  />

</Layout>

<style>
  /* ── Marquee ───────────────────────────────────────────── */
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-100%); }
  }
  .marquee-track { animation: marquee 32s linear infinite; }

  /* ── Hero glow breathe ─────────────────────────────────── */
  @keyframes glow-breathe {
    0%, 100% { opacity: 0.75; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.18); }
  }
  .hero-glow { animation: glow-breathe 7s ease-in-out infinite; transform-origin: center center; }

  /* ── Hero rings ────────────────────────────────────────── */
  @keyframes ring-spin     { to { transform: rotate(360deg); } }
  @keyframes ring-spin-rev { to { transform: rotate(-360deg); } }
  .hero-ring     { animation: ring-spin     28s linear infinite; transform-origin: center center; }
  .hero-ring-rev { animation: ring-spin-rev 40s linear infinite; transform-origin: center center; }

  /* ── Hero scan beam ────────────────────────────────────── */
  @keyframes scan-down {
    0%   { top: 0%;   opacity: 0; }
    5%   { opacity: 0.45; }
    95%  { opacity: 0.35; }
    100% { top: 100%; opacity: 0; }
  }
  .hero-scan {
    background: linear-gradient(to right, transparent 0%, rgba(82,153,97,0.5) 50%, transparent 100%);
    animation: scan-down 5s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  /* ── Network SVG lines draw + pulse ───────────────────── */
  .net-line {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
  }
  .net-line-1 { animation: draw-line 1.2s ease forwards 0.3s, pulse-line 4s ease-in-out 1.5s infinite; }
  .net-line-2 { animation: draw-line 1.2s ease forwards 0.7s, pulse-line 4s ease-in-out 1.9s infinite; }
  .net-line-3 { animation: draw-line 1.2s ease forwards 1.1s, pulse-line 4s ease-in-out 2.3s infinite; }
  .net-line-4 { animation: draw-line 1.2s ease forwards 1.5s, pulse-line 4s ease-in-out 2.7s infinite; }
  @keyframes draw-line  { to { stroke-dashoffset: 0; } }
  @keyframes pulse-line { 0%, 100% { opacity: 0.12; } 50% { opacity: 0.35; } }

  /* ── Network nodes float ───────────────────────────────── */
  .net-node { animation: float-node 4s ease-in-out infinite; }
  @keyframes float-node {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50%       { transform: translateY(-8px); opacity: 0.85; }
  }

  /* ── Hero headline shimmer ─────────────────────────────── */
  @keyframes text-shimmer {
    0%   { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  .hero-shimmer {
    background: linear-gradient(90deg, #3d854f 0%, #529961 30%, #7fcf8f 55%, #529961 70%, #3d854f 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: text-shimmer 4s linear infinite;
  }

  /* ── Agent card hover lift ─────────────────────────────── */
  #agents .rounded-lg {
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }
  #agents .rounded-lg:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 36px rgba(82,153,97,0.13), 0 2px 8px rgba(82,153,97,0.07);
    border-color: rgba(82,153,97,0.28) !important;
  }

  /* ── Stats background gradient animation ──────────────── */
  @keyframes stats-bg-shift {
    0%, 100% { background-position: 0% 50%; }
    50%       { background-position: 100% 50%; }
  }
  .stats-gradient {
    background: linear-gradient(135deg, rgba(82,153,97,0.04) 0%, transparent 40%, rgba(82,153,97,0.04) 100%);
    background-size: 200% 200%;
    animation: stats-bg-shift 8s ease-in-out infinite;
  }

  /* ── Testimonial cards staggered entrance ─────────────── */
  #testimonials .grid > div:nth-child(1) { animation-delay: 0ms !important; }
  #testimonials .grid > div:nth-child(2) { animation-delay: 120ms !important; }
  #testimonials .grid > div:nth-child(3) { animation-delay: 240ms !important; }

  /* ── Respect reduced-motion preference ─────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track, .hero-glow, .hero-ring, .hero-ring-rev,
    .hero-scan, .net-line, .net-node, .hero-shimmer,
    .stats-gradient { animation: none !important; }
    .hero-shimmer { -webkit-text-fill-color: var(--aw-color-primary, #529961); color: #529961; }
  }
</style>

<script>
  /* ── Stats counter animation ───────────────────────────── */
  const statsSection = document.getElementById('stats-section');
  if (statsSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          entry.target.querySelectorAll<HTMLElement>('.stat-num[data-target]').forEach((el) => {
            const target = parseInt(el.dataset.target ?? '0', 10);
            if (isNaN(target)) return;
            const duration = 1600;
            const ease = (t: number) => t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            let startTime: number | null = null;
            const step = (timestamp: number) => {
              if (!startTime) startTime = timestamp;
              const progress = Math.min((timestamp - startTime) / duration, 1);
              el.textContent = String(Math.round(ease(progress) * target));
              if (progress < 1) requestAnimationFrame(step);
              else el.textContent = String(target);
            };
            requestAnimationFrame(step);
          });
        });
      },
      { threshold: 0.4 }
    );
    observer.observe(statsSection);
  }
</script>
