---
import Layout from '~/layouts/PageLayout.astro';
import GridBackground from '~/components/ui/GridBackground.astro';
import Spotlight from '~/components/ui/Spotlight.astro';

const metadata = {
  title: 'Aitroop - Save AI agent conversations as apps',
  ignoreTitleTemplate: true,
};

const loopNodes = [
  { index: '0.2.1', title: 'AppInput',  desc: 'A schema-driven form. 4 input types, declared once.' },
  { index: '0.2.2', title: 'Stage',     desc: 'An agent session with one goal, wired to skills.' },
  { index: '0.2.3', title: 'Artifact',  desc: 'Preview, export, or feed the next stage.' },
];

const skillGroups = [
  { label: 'Build',   items: ['GitHub', 'Linear', 'Jira', 'Asana', 'Figma', 'Notion'] },
  { label: 'Comms',   items: ['Gmail', 'Slack', 'Discord', 'Calendar', 'Twitter', 'Webhook'] },
  { label: 'Data',    items: ['Drive', 'Sheets', 'Airtable', 'Postgres', 'PDF', 'CSV'] },
  { label: 'Run',     items: ['Web search', 'Code exec', 'Stripe', 'HubSpot', 'Salesforce', 'YouTube'] },
];

const testimonials = [
  {
    quote: 'We replaced a 4-person ops loop with three Apps. They run on a cron and nobody touches them.',
    name: 'Marta R.',
    title: 'Head of RevOps',
    company: 'Northbound',
    featured: true,
  },
  {
    quote: 'Save as App turned my chaotic prompt notebook into something the rest of the team can actually run.',
    name: 'Diego K.',
    title: 'Solutions Architect',
    company: 'Plate',
  },
  {
    quote: 'The sandbox is the killer feature. Real file access, real tools, real outputs — no toy demos.',
    name: 'Priya S.',
    title: 'Director of AI',
    company: 'Vector Labs',
  },
];

const cases = [
  {
    slug: '/use-cases/gtm',
    title: 'GTM',
    desc: 'Prospecting, outreach, retention, pipeline insights — handed off as Apps your revenue team runs daily.',
    points: ['ICP research at scale', 'Personalised sequences', 'Pipeline & retention reports'],
  },
  {
    slug: '/use-cases/finance',
    title: 'Finance',
    desc: 'Close, audit, variance, reporting. Built for CFO teams who need traceable, repeatable output.',
    points: ['Close-pack assembly', 'Variance & flux analysis', 'Auditor-ready exports'],
  },
];

const faqs = [
  {
    q: 'Do I have to rebuild my prompts to save an App?',
    a: 'No. Open a chat that already works, click Save as App, and Aitroop captures the skills, connects and prompts as a runnable workflow.',
  },
  {
    q: 'What runs the App after it is saved?',
    a: 'Each run executes in an isolated sandbox with the file system, network and tools the agent needs. You can trigger it manually, on a cron, or from a webhook.',
  },
  {
    q: 'Can I chain steps that need different tools?',
    a: 'Yes. Stages let you wire one agent into the next, each with its own model, skills and prompt. The artifact from one stage feeds the input of the next.',
  },
  {
    q: 'Who can use the App once I publish it?',
    a: 'Apps are permissioned objects. Share with a teammate, an external collaborator, or expose them as an internal API. Run history is visible to admins.',
  },
];
---

<Layout metadata={metadata}>

  <Spotlight />

  <!-- 0.1 · HERO — manifesto + real App specimen ─────────────────── -->
  <section class="home-hero">
    <GridBackground variant="dots" tone="brand" class="home-hero-bg" />
    <div class="aw-container-wide home-hero-copy">
      <p class="ds-eyebrow home-hero-eyebrow">0.1 · The loop</p>
      <h1 class="home-hero-display">
        Save the chat<br />
        that worked.<br />
        <span class="home-hero-display-accent">Run it forever.</span>
      </h1>
      <p class="home-hero-lede">
        Open a chat. <kbd class="ds-kbd">⌘</kbd><kbd class="ds-kbd">S</kbd> turns the agent flow that just worked into a typed App your team runs on a cron, on a webhook, or on demand.
      </p>
      <p class="home-hero-stats">
        <span><strong>150</strong>&nbsp;skills</span>
        <span class="home-hero-stats-sep" aria-hidden="true">·</span>
        <span><strong>20</strong>&nbsp;connects</span>
        <span class="home-hero-stats-sep" aria-hidden="true">·</span>
        <span><strong>4</strong>&nbsp;input types</span>
        <span class="home-hero-stats-sep" aria-hidden="true">·</span>
        <span><strong>7</strong>&nbsp;export formats</span>
      </p>
      <div class="home-hero-actions">
        <a href="https://app.aitroop.net" class="home-hero-btn home-hero-btn--primary">
          <span>Start free</span>
          <kbd class="ds-kbd ds-kbd--on-dark" aria-hidden="true">↵</kbd>
        </a>
        <a href="/use-cases" class="home-hero-btn home-hero-btn--ghost">
          <span>See use cases</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>

    <div class="aw-container-wide">
      <figure class="home-specimen spotlight-card ds-reveal" data-spotlight aria-label="Anatomy of an App — sample run">
        <figcaption class="home-specimen-caption">
          <span class="ds-eyebrow">Specimen · app run</span>
          <span class="home-specimen-caption-note">illustrative — your data, your skills</span>
        </figcaption>
        <div class="home-specimen-chrome">
          <span class="home-specimen-traffic" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
          <span class="home-specimen-filename">apps/icp-research.app</span>
          <span class="home-specimen-status">
            <span class="home-specimen-status-dot" aria-hidden="true"></span>
            running · stage 1 / 3
          </span>
        </div>

        <div class="home-specimen-body">
          <div class="home-specimen-pane">
            <p class="ds-eyebrow home-specimen-pane-eyebrow">0.1 · Input</p>
            <dl class="home-specimen-fields">
              <div><dt>ICP</dt><dd>SaaS &lt; 200 employees</dd></div>
              <div><dt>Region</dt><dd>EU + UK</dd></div>
              <div><dt>Since</dt><dd>2026-04-01</dd></div>
              <div><dt>Brief</dt><dd>signal-led, no cold lists</dd></div>
            </dl>
          </div>

          <div class="home-specimen-pane home-specimen-pane--mid">
            <p class="ds-eyebrow home-specimen-pane-eyebrow">0.2 · Stage</p>
            <p class="home-specimen-stage-model">claude-sonnet-4-6</p>
            <p class="home-specimen-stage-skills">github · web-search · gmail</p>
            <div class="home-specimen-stage-bar" aria-hidden="true">
              <span class="home-specimen-stage-fill"></span>
            </div>
            <p class="home-specimen-stage-foot">
              <span>read · think · act</span>
              <span class="ds-mono">12.4s</span>
            </p>
          </div>

          <div class="home-specimen-pane">
            <p class="ds-eyebrow home-specimen-pane-eyebrow">0.3 · Artifact</p>
            <table class="home-specimen-table">
              <thead><tr><th>Company</th><th>Signal</th><th>Score</th></tr></thead>
              <tbody>
                <tr><td>Northbound</td><td>hiring · 4 RevOps</td><td>0.92</td></tr>
                <tr><td>Plate</td><td>funded · Series A</td><td>0.84</td></tr>
                <tr><td>Vector Labs</td><td>exec move · CRO</td><td>0.79</td></tr>
              </tbody>
            </table>
            <p class="home-specimen-artifact-foot">
              <span class="home-specimen-file">icp-q2-2026.csv</span>
              <span class="home-specimen-file-meta">142 rows · 14 KB</span>
            </p>
          </div>
        </div>
      </figure>
    </div>
  </section>

  <!-- 0.2 · THE LOOP — single dark band, anatomy + lifecycle merged ── -->
  <section class="home-loop">
    <div class="home-loop-ambient" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="aw-container-wide">
      <header class="home-section-head ds-reveal">
        <p class="ds-eyebrow home-section-eyebrow">0.2 · The loop</p>
        <h2 class="home-section-title">
          A chat becomes a form.<br />
          The form ships an artifact.<br />
          The artifact triggers the next run.
        </h2>
      </header>

      <ol class="home-loop-flow ds-reveal-stagger" role="list">
        {loopNodes.map((n, i) => (
          <>
            <li class="home-loop-node">
              <p class="ds-eyebrow home-loop-node-index">{n.index}</p>
              <p class="home-loop-node-title">{n.title}</p>
              <p class="home-loop-node-desc">{n.desc}</p>
            </li>
            {i < loopNodes.length - 1 && (
              <li class="home-loop-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </li>
            )}
          </>
        ))}
      </ol>

      <div class="home-loop-return" aria-hidden="true">
        <svg class="home-loop-return-svg" viewBox="0 0 200 40" preserveAspectRatio="none">
          <path d="M 198 4 C 198 30, 4 30, 2 4" stroke="currentColor" stroke-width="1" stroke-dasharray="4 5" fill="none" />
          <path d="M 2 4 L 8 9 M 2 4 L 8 -1" stroke="currentColor" stroke-width="1.25" fill="none" stroke-linecap="round" />
        </svg>
        <span class="home-loop-return-label">repeats</span>
      </div>

      <p class="home-loop-trigger">
        <span class="ds-eyebrow home-loop-trigger-eyebrow">Triggers</span>
        <span class="home-loop-trigger-chip"><span class="home-loop-trigger-dot" aria-hidden="true"></span>cron</span>
        <span class="home-loop-trigger-chip"><span class="home-loop-trigger-dot" aria-hidden="true"></span>webhook</span>
        <span class="home-loop-trigger-chip"><span class="home-loop-trigger-dot" aria-hidden="true"></span>on demand</span>
      </p>
    </div>
  </section>

  <!-- 0.3 · WHAT SHIPS — three artifact specimens ──────────────────── -->
  <section class="home-ships">
    <div class="aw-container-wide">
      <header class="home-section-head ds-reveal">
        <p class="ds-eyebrow home-section-eyebrow">0.3 · What ships</p>
        <h2 class="home-section-title">Not features. Artifacts.</h2>
        <p class="home-section-lede">What actually lands in your team's inbox after a stage runs.</p>
      </header>

      <div class="home-ships-grid ds-reveal-stagger">
        <article class="home-ship spotlight-card" data-spotlight>
          <header class="home-ship-head">
            <span class="home-ship-ext">csv</span>
            <span class="home-ship-name">q2-close-pack.csv</span>
          </header>
          <table class="home-ship-table">
            <thead><tr><th>Account</th><th>Δ</th><th>Flag</th></tr></thead>
            <tbody>
              <tr><td>4100 · Revenue</td><td>+2.4%</td><td>·</td></tr>
              <tr><td>5200 · COGS</td><td>+11.0%</td><td><span class="home-ship-flag">var</span></td></tr>
              <tr><td>6300 · OpEx</td><td>−0.8%</td><td>·</td></tr>
            </tbody>
          </table>
          <p class="home-ship-foot">142 rows · close-of-month · variance flagged</p>
        </article>

        <article class="home-ship spotlight-card" data-spotlight>
          <header class="home-ship-head">
            <span class="home-ship-ext">md</span>
            <span class="home-ship-name">weekly-status.md</span>
          </header>
          <div class="home-ship-doc">
            <p class="home-ship-doc-title">Week 23 · Ops Status</p>
            <ul class="home-ship-bullets" role="list">
              <li><span class="home-ship-bullet-dot ds-mono">✓</span>Pipeline cleared, queue back at 0</li>
              <li><span class="home-ship-bullet-dot ds-mono">✓</span>Q2 close on track for Friday</li>
              <li><span class="home-ship-bullet-dot ds-mono">!</span>Two HubSpot dupes — escalated</li>
            </ul>
          </div>
          <p class="home-ship-foot">posted to slack #ops · cc CEO</p>
        </article>

        <article class="home-ship spotlight-card" data-spotlight>
          <header class="home-ship-head">
            <span class="home-ship-ext">json</span>
            <span class="home-ship-name">POST /pipeline/intake</span>
          </header>
          <pre class="home-ship-code"><code><span class="hs-p">&#123;</span>
  <span class="hs-k">"lead_id"</span>: <span class="hs-s">"ld_8h2k"</span>,
  <span class="hs-k">"score"</span>: <span class="hs-n">0.92</span>,
  <span class="hs-k">"signals"</span>: [<span class="hs-s">"hiring"</span>],
  <span class="hs-k">"route"</span>: <span class="hs-s">"hubspot"</span>
<span class="hs-p">&#125;</span></code></pre>
          <p class="home-ship-foot">→ hubspot · stripe · stays in sync</p>
        </article>
      </div>
    </div>
  </section>

  <!-- 0.4 · SKILLS & CONNECTS — quiet taxonomy, no marquee ─────────── -->
  <section class="home-skills">
    <div class="aw-container-wide">
      <header class="home-section-head ds-reveal">
        <p class="ds-eyebrow home-section-eyebrow">0.4 · Skills &amp; connects</p>
        <h2 class="home-section-title">150 skills. 20 connects.<br />Already wired.</h2>
        <p class="home-section-lede">A library, not a logo wall. Toggle on what you need; we keep the auth.</p>
      </header>

      <div class="home-skills-grid ds-reveal-stagger">
        {skillGroups.map((g) => (
          <div class="home-skill-col">
            <p class="home-skill-col-head">
              <span class="ds-eyebrow home-skill-col-label">{g.label}</span>
              <span class="ds-mono home-skill-col-count">{String(g.items.length).padStart(2, '0')}</span>
            </p>
            <ul class="home-skill-list" role="list">
              {g.items.map((s) => (
                <li class="home-skill-item">
                  <span class="home-skill-dot" aria-hidden="true"></span>
                  <span>{s}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="home-skills-foot">
        + <strong>126</strong> more in the library, composable in any stage.
      </p>
    </div>
  </section>

  <!-- 0.5 · USE CASES — editorial, kept ────────────────────────────── -->
  <section class="home-section home-cases">
    <div class="aw-container-wide">
      <header class="home-section-head ds-reveal">
        <p class="ds-eyebrow home-section-eyebrow">0.5 · Use cases</p>
        <h2 class="home-section-title">Built for what you actually do.</h2>
      </header>

      <div class="cases-editorial ds-reveal-stagger">
        {cases.map((c, i) => (
          <article class="case">
            <a href={c.slug} class="case-link">
              <p class="ds-eyebrow case-index">{`0.5.${i + 1}`}</p>
              <h3 class="case-title">{c.title}</h3>
              <p class="case-desc">{c.desc}</p>
              <ul class="case-points" role="list">
                {c.points.map((p) => <li>{p}</li>)}
              </ul>
              <span class="case-cta">
                Explore {c.title.toLowerCase()}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 0.6 · OPERATORS — testimonials, kept ─────────────────────────── -->
  <section class="home-section home-operators">
    <div class="aw-container-wide">
      <header class="home-section-head ds-reveal">
        <p class="ds-eyebrow home-section-eyebrow">0.6 · Operators</p>
        <h2 class="home-section-title">Already shipped the loop.</h2>
      </header>

      <ul class="testimonials ds-reveal-stagger" role="list">
        {testimonials.map((t) => (
          <li class:list={['testimonial', t.featured && 'testimonial--featured']}>
            <p class="testimonial__quote-text">{t.quote}</p>
            <div class="testimonial__author">
              <span class="testimonial__avatar" aria-hidden="true">{t.name.charAt(0)}</span>
              <div>
                <div class="testimonial__name">{t.name}</div>
                <div class="testimonial__title ds-mono">{t.title} · {t.company}</div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 0.7 · QUESTIONS — borderless 2-col, kept ─────────────────────── -->
  <section class="home-section home-faq">
    <div class="aw-container-wide">
      <header class="home-section-head ds-reveal">
        <p class="ds-eyebrow home-section-eyebrow">0.7 · Questions</p>
        <h2 class="home-section-title">Answered.</h2>
      </header>
      <ul class="faq-list ds-reveal-stagger" role="list">
        {faqs.map((item, i) => (
          <li class="faq-item">
            <p class="ds-eyebrow faq-index">{`0.7.${i + 1}`}</p>
            <h3 class="faq-q">{item.q}</h3>
            <p class="faq-a">{item.a}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 0.8 · CTA — quiet inline, no drenched box ────────────────────── -->
  <section class="home-cta">
    <div class="aw-container-wide ds-reveal">
      <p class="ds-eyebrow home-section-eyebrow">0.8 · Ship</p>
      <h2 class="home-cta-line">
        Open a chat.<br />
        <kbd class="ds-kbd">⌘</kbd><kbd class="ds-kbd">S</kbd>
        <span class="home-cta-line-accent">Save as App.</span><br />
        That's the loop.
      </h2>
      <div class="home-cta-actions">
        <a href="https://app.aitroop.net" class="home-hero-btn home-hero-btn--primary">
          <span>Open the app</span>
          <kbd class="ds-kbd ds-kbd--on-dark" aria-hidden="true">↵</kbd>
        </a>
        <a href="/contact" class="home-hero-btn home-hero-btn--ghost">
          <span>Talk to us</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <p class="home-cta-meta">
        <span>aitroop · v1</span>
        <span class="home-cta-meta-sep" aria-hidden="true">·</span>
        <span>made for operators</span>
        <span class="home-cta-meta-sep" aria-hidden="true">·</span>
        <span>2026</span>
      </p>
    </div>
  </section>

</Layout>

<style>
  /* ══════════════════════════════════════════════════════════════════
     0.1 · HERO — manifesto + real App specimen
     ══════════════════════════════════════════════════════════════════ */
  .home-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--ds-ground);
    padding-top: clamp(4.5rem, 8vw, 7rem);
    padding-bottom: clamp(3.5rem, 6vw, 5.5rem);
  }
  /* Tame the GridBackground default so it reads as ambient texture only */
  .home-hero :global(.home-hero-bg) {
    z-index: -1;
    opacity: 0.55;
  }
  .home-hero :global(.home-hero-bg .gridbg__layer) {
    -webkit-mask-image: radial-gradient(ellipse 80% 55% at 50% 20%, #000 35%, transparent 85%) !important;
            mask-image: radial-gradient(ellipse 80% 55% at 50% 20%, #000 35%, transparent 85%) !important;
  }
  .home-hero > .aw-container-wide { position: relative; z-index: 1; }
  .home-hero-copy {
    margin: 0 auto 3.5rem;
    max-width: 64rem;
    text-align: left;
  }
  @media (min-width: 768px) {
    .home-hero-copy { margin-bottom: 4.5rem; }
  }
  .home-hero-eyebrow {
    margin: 0 0 1.75rem;
    color: var(--ds-text-quiet);
  }
  .home-hero-display {
    font-family: var(--aw-font-heading);
    font-size: clamp(2.5rem, 6.2vw, 4.75rem);
    font-weight: 580;
    letter-spacing: -0.028em;
    line-height: 1.02;
    color: var(--ds-text);
    margin: 0 0 1.75rem;
    max-width: 18ch;
    text-wrap: balance;
  }
  .home-hero-display-accent { color: var(--ds-accent); }

  .home-hero-lede {
    margin: 0 0 1.25rem;
    max-width: 42rem;
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    line-height: 1.55;
    color: var(--ds-text-body);
    font-weight: 500;
    text-wrap: pretty;
  }
  .home-hero-lede .ds-kbd { vertical-align: 1px; margin: 0 1px; }

  .home-hero-stats {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin: 0 0 2.25rem;
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
    color: var(--ds-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .home-hero-stats strong { color: var(--ds-text); font-weight: 600; }
  .home-hero-stats-sep { color: var(--ds-text-quiet); opacity: 0.7; }

  .home-hero-actions {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .home-hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    height: 44px;
    border-radius: 10px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 150ms var(--ds-ease-out),
                color 150ms var(--ds-ease-out),
                transform 150ms var(--ds-ease-out);
  }
  .home-hero-btn--primary {
    background: var(--ds-text);
    color: var(--ds-surface);
    padding: 0 0.875rem 0 1.125rem;
  }
  .home-hero-btn--primary:hover {
    background: #1f1f1f;
    transform: translateY(-1px);
  }
  .home-hero-btn--ghost {
    background: transparent;
    color: var(--ds-text);
    padding: 0 0.25rem;
  }
  .home-hero-btn--ghost svg {
    transition: transform 200ms var(--ds-ease-out);
  }
  .home-hero-btn--ghost:hover { color: var(--ds-accent); }
  .home-hero-btn--ghost:hover svg { transform: translateX(3px); }

  /* ── App specimen card ────────────────────────────────────────── */
  .home-specimen {
    max-width: 76rem;
    margin: 0 auto;
    background: var(--ds-surface);
    border: 1px solid var(--ds-hairline);
    border-radius: var(--ds-radius-lg);
    box-shadow: var(--ds-shadow-3);
    overflow: hidden;
  }
  .home-specimen-caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1.125rem;
    border-bottom: 1px solid var(--ds-hairline);
    background: var(--ds-surface-2);
  }
  .home-specimen-caption-note {
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    color: var(--ds-text-muted);
  }
  .home-specimen-chrome {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 1.125rem;
    border-bottom: 1px solid var(--ds-hairline);
  }
  .home-specimen-traffic {
    display: inline-flex;
    gap: 0.375rem;
  }
  .home-specimen-traffic span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--ds-hairline-strong);
  }
  .home-specimen-filename {
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
    color: var(--ds-text-muted);
  }
  .home-specimen-status {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    color: var(--ds-accent);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    background: var(--ds-accent-tint);
  }
  .home-specimen-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ds-accent);
    animation: home-specimen-pulse 1.8s var(--ds-ease-out) infinite;
  }
  @keyframes home-specimen-pulse {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  .home-specimen-body {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .home-specimen-body {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr) minmax(0, 1.65fr);
    }
  }
  .home-specimen-pane {
    padding: 1.375rem 1.375rem 1.5rem;
    border-bottom: 1px solid var(--ds-hairline);
  }
  @media (min-width: 900px) {
    .home-specimen-pane {
      border-bottom: 0;
      border-right: 1px solid var(--ds-hairline);
    }
    .home-specimen-pane:last-child { border-right: 0; }
  }
  .home-specimen-pane-eyebrow { margin: 0 0 1rem; }

  .home-specimen-fields {
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.625rem;
    font-size: 0.8125rem;
  }
  .home-specimen-fields > div {
    display: grid;
    grid-template-columns: 4rem 1fr;
    align-items: baseline;
    gap: 0.75rem;
  }
  .home-specimen-fields dt {
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ds-text-quiet);
    margin: 0;
  }
  .home-specimen-fields dd {
    margin: 0;
    color: var(--ds-text);
    font-weight: 500;
  }

  .home-specimen-stage-model {
    font-family: var(--ds-font-mono);
    font-size: 0.875rem;
    color: var(--ds-text);
    margin: 0 0 0.25rem;
  }
  .home-specimen-stage-skills {
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
    color: var(--ds-text-muted);
    margin: 0 0 1rem;
    line-height: 1.45;
  }
  .home-specimen-stage-bar {
    display: block;
    height: 4px;
    border-radius: 99px;
    background: var(--ds-hairline);
    overflow: hidden;
    margin-bottom: 0.625rem;
  }
  .home-specimen-stage-fill {
    display: block;
    width: 28%;
    height: 100%;
    background: var(--ds-accent);
    animation: home-specimen-stage 4.5s var(--ds-ease-out) infinite;
  }
  @keyframes home-specimen-stage {
    0%   { width: 18%; }
    55%  { width: 78%; }
    100% { width: 18%; }
  }
  .home-specimen-stage-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 0;
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: var(--ds-text-muted);
  }

  .home-specimen-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    margin-bottom: 0.875rem;
  }
  .home-specimen-table th {
    text-align: left;
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ds-text-quiet);
    font-weight: 500;
    padding: 0 0.5rem 0.5rem 0;
    border-bottom: 1px solid var(--ds-hairline);
  }
  .home-specimen-table td {
    padding: 0.5rem 0.5rem 0.5rem 0;
    color: var(--ds-text);
    border-bottom: 1px dashed var(--ds-hairline);
  }
  .home-specimen-table th:last-child,
  .home-specimen-table td:last-child {
    font-family: var(--ds-font-mono);
    font-variant-numeric: tabular-nums;
    text-align: right;
    padding-right: 0;
  }
  .home-specimen-table tr:last-child td { border-bottom: 0; }

  .home-specimen-artifact-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 0;
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.03em;
    color: var(--ds-text-muted);
  }
  .home-specimen-file {
    color: var(--ds-text);
    font-weight: 600;
  }

  /* ── Entry animation ──────────────────────────────────────────── */
  @keyframes home-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
  .home-hero-eyebrow,
  .home-hero-display,
  .home-hero-lede,
  .home-hero-stats,
  .home-hero-actions {
    animation: home-rise 600ms var(--ds-ease-out) both;
  }
  .home-hero-eyebrow { animation-delay: 0ms; }
  .home-hero-display { animation-delay: 60ms; }
  .home-hero-lede    { animation-delay: 130ms; }
  .home-hero-stats   { animation-delay: 200ms; }
  .home-hero-actions { animation-delay: 260ms; }
  /* The specimen card uses .ds-reveal (IntersectionObserver) instead of home-rise. */
  @media (prefers-reduced-motion: reduce) {
    .home-hero-eyebrow,
    .home-hero-display,
    .home-hero-lede,
    .home-hero-stats,
    .home-hero-actions { animation: none; }
  }

  /* ══════════════════════════════════════════════════════════════════
     Shared — section head, rhythm
     ══════════════════════════════════════════════════════════════════ */
  .home-section {
    padding-top: clamp(4.5rem, 8vw, 6rem);
    padding-bottom: clamp(4.5rem, 8vw, 6rem);
  }
  .home-section-head {
    max-width: 56rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 768px) {
    .home-section-head { margin-bottom: 3.5rem; }
  }
  .home-section-eyebrow {
    margin: 0 0 1rem;
  }
  .home-section-title {
    font-family: var(--aw-font-heading);
    font-size: clamp(1.75rem, 3.6vw, 2.75rem);
    font-weight: 580;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ds-text);
    margin: 0;
    max-width: 28ch;
    text-wrap: balance;
  }
  .home-section-lede {
    margin: 1rem 0 0;
    font-size: clamp(1rem, 1.2vw, 1.125rem);
    line-height: 1.55;
    color: var(--ds-text-muted);
    max-width: 48ch;
  }

  /* ══════════════════════════════════════════════════════════════════
     0.2 · THE LOOP — single dark band (Anatomy + Lifecycle merged)
     ══════════════════════════════════════════════════════════════════ */
  .home-loop {
    background: var(--ds-dark-ground);
    color: var(--ds-dark-text);
    padding: clamp(5.5rem, 9vw, 7.5rem) 0 clamp(5rem, 8vw, 6.5rem);
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .home-loop::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(82, 153, 97, 0.10), transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .home-loop > * { position: relative; z-index: 1; }

  /* Ambient vertical streaks drifting downward — extremely slow + faint */
  .home-loop-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 70%, transparent 100%);
            mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 70%, transparent 100%);
  }
  .home-loop-ambient span {
    position: absolute;
    top: -40%;
    width: 1px;
    height: 60%;
    background: linear-gradient(180deg, transparent, rgba(82, 153, 97, 0.42), transparent);
    animation: home-loop-streak 18s linear infinite;
    opacity: 0.55;
  }
  .home-loop-ambient span:nth-child(1) { left: 12%; animation-delay:   0s; animation-duration: 17s; }
  .home-loop-ambient span:nth-child(2) { left: 34%; animation-delay:  -4s; animation-duration: 21s; opacity: 0.35; }
  .home-loop-ambient span:nth-child(3) { left: 58%; animation-delay:  -9s; animation-duration: 19s; }
  .home-loop-ambient span:nth-child(4) { left: 76%; animation-delay: -13s; animation-duration: 23s; opacity: 0.35; }
  .home-loop-ambient span:nth-child(5) { left: 91%; animation-delay:  -6s; animation-duration: 25s; opacity: 0.45; }
  @keyframes home-loop-streak {
    0%   { transform: translateY(0);    opacity: 0; }
    15%  { opacity: 0.55; }
    85%  { opacity: 0.55; }
    100% { transform: translateY(220vh); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .home-loop-ambient span { animation: none; opacity: 0.2; }
  }
  .home-loop .home-section-eyebrow { color: rgba(255, 255, 255, 0.45); }
  .home-loop .home-section-title { color: var(--ds-dark-text); max-width: 42ch; }

  .home-loop-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: stretch;
  }
  @media (min-width: 900px) {
    .home-loop-flow {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
  }
  .home-loop-node {
    flex: 1 1 0;
    min-width: 0;
    padding: 1.5rem 1.5rem 1.625rem;
    background: var(--ds-dark-surface);
    border: 1px solid var(--ds-dark-hairline);
    border-radius: var(--ds-radius-lg);
    position: relative;
    transition: border-color 240ms var(--ds-ease-out), transform 240ms var(--ds-ease-out);
  }
  .home-loop-node:hover {
    border-color: rgba(82, 153, 97, 0.5);
    transform: translateY(-2px);
  }
  .home-loop-node::before {
    content: '';
    position: absolute;
    top: -5px;
    left: 1.5rem;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--ds-accent);
    box-shadow: 0 0 0 4px var(--ds-dark-ground);
  }
  .home-loop-node-index {
    margin: 0 0 0.625rem;
    color: rgba(255, 255, 255, 0.45);
  }
  .home-loop-node-title {
    margin: 0 0 0.375rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ds-dark-text);
    letter-spacing: -0.01em;
  }
  .home-loop-node-desc {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--ds-dark-text-muted);
  }
  .home-loop-arrow {
    list-style: none;
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(82, 153, 97, 0.65);
    padding: 0 0.25rem;
  }
  .home-loop-arrow svg { width: 18px; height: 18px; }
  @media (max-width: 899px) {
    .home-loop-arrow { transform: rotate(90deg); padding: 0.25rem 0; }
  }

  .home-loop-return {
    margin: 1.5rem auto 0;
    max-width: 80%;
    position: relative;
    color: rgba(255, 255, 255, 0.25);
    display: none;
  }
  @media (min-width: 900px) {
    .home-loop-return { display: block; }
  }
  .home-loop-return-svg {
    width: 100%;
    height: 36px;
    display: block;
  }
  .home-loop-return-label {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ds-accent);
    background: var(--ds-dark-ground);
    padding: 0 0.5rem;
  }

  .home-loop-trigger {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin: 2.25rem 0 0;
    font-size: 0.8125rem;
    color: var(--ds-dark-text-muted);
  }
  .home-loop-trigger-eyebrow { color: rgba(255, 255, 255, 0.45); margin-right: 0.25rem; }
  .home-loop-trigger-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.625rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--ds-dark-hairline);
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
    color: var(--ds-dark-text);
    letter-spacing: 0.01em;
  }
  .home-loop-trigger-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--ds-accent);
  }

  /* ══════════════════════════════════════════════════════════════════
     0.3 · WHAT SHIPS — three artifact specimens
     ══════════════════════════════════════════════════════════════════ */
  .home-ships {
    background: var(--ds-ground);
    padding: clamp(4.5rem, 8vw, 6rem) 0;
  }
  .home-ships-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 900px) {
    .home-ships-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
  .home-ship {
    background: var(--ds-surface);
    border: 1px solid var(--ds-hairline);
    border-radius: var(--ds-radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 240ms var(--ds-ease-out),
                box-shadow 240ms var(--ds-ease-out),
                transform 240ms var(--ds-ease-out);
  }
  .home-ship:hover {
    border-color: var(--ds-hairline-strong);
    box-shadow: var(--ds-shadow-2);
    transform: translateY(-2px);
  }
  .home-ship-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--ds-hairline);
    background: var(--ds-surface-2);
  }
  .home-ship-ext {
    font-family: var(--ds-font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.18rem 0.4rem;
    border-radius: 4px;
    background: var(--ds-accent-tint);
    color: var(--ds-accent);
  }
  .home-ship-name {
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
    color: var(--ds-text);
  }
  .home-ship-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    margin: 1rem 1rem 0.5rem;
    width: calc(100% - 2rem);
  }
  .home-ship-table th {
    text-align: left;
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ds-text-quiet);
    font-weight: 500;
    padding: 0 0.5rem 0.5rem 0;
    border-bottom: 1px solid var(--ds-hairline);
  }
  .home-ship-table th:nth-child(2),
  .home-ship-table td:nth-child(2) {
    font-family: var(--ds-font-mono);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
  .home-ship-table th:last-child,
  .home-ship-table td:last-child { text-align: right; padding-right: 0; }
  .home-ship-table td {
    padding: 0.5rem 0.5rem 0.5rem 0;
    color: var(--ds-text);
    border-bottom: 1px dashed var(--ds-hairline);
  }
  .home-ship-table tr:last-child td { border-bottom: 0; }
  .home-ship-flag {
    display: inline-block;
    font-family: var(--ds-font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    background: rgba(229, 109, 71, 0.10);
    color: #C65530;
  }

  .home-ship-doc {
    padding: 1rem 1.125rem 0.25rem;
    flex: 1;
  }
  .home-ship-doc-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ds-text);
    margin: 0 0 0.625rem;
  }
  .home-ship-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--ds-text-body);
    line-height: 1.5;
  }
  .home-ship-bullets li {
    display: grid;
    grid-template-columns: 1.25rem 1fr;
    gap: 0.5rem;
    align-items: baseline;
  }
  .home-ship-bullet-dot {
    color: var(--ds-accent);
    font-weight: 700;
    font-size: 0.75rem;
  }
  .home-ship-bullets li:last-child .home-ship-bullet-dot { color: #C65530; }

  .home-ship-code {
    margin: 0;
    padding: 1rem 1.125rem 1.25rem;
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
    line-height: 1.65;
    color: var(--ds-text-body);
    background: transparent;
    overflow-x: auto;
    flex: 1;
  }
  .home-ship-code .hs-k { color: var(--ds-text); }
  .home-ship-code .hs-s { color: var(--ds-accent); }
  .home-ship-code .hs-n { color: #C65530; }
  .home-ship-code .hs-p { color: var(--ds-text-quiet); }

  .home-ship-foot {
    margin: 0;
    padding: 0.625rem 1rem 0.875rem;
    border-top: 1px dashed var(--ds-hairline);
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: var(--ds-text-muted);
  }

  /* ══════════════════════════════════════════════════════════════════
     0.4 · SKILLS & CONNECTS — taxonomy
     ══════════════════════════════════════════════════════════════════ */
  .home-skills {
    background: var(--ds-surface-2);
    padding: clamp(4.5rem, 8vw, 6rem) 0;
  }
  .home-skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 2.5rem;
  }
  @media (min-width: 768px) {
    .home-skills-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .home-skill-col-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 0 0 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--ds-hairline-strong);
  }
  .home-skill-col-count {
    font-size: 0.6875rem;
    color: var(--ds-text-quiet);
  }
  .home-skill-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .home-skill-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--ds-text);
  }
  .home-skill-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ds-accent);
    opacity: 0.55;
    transition: opacity 150ms ease, transform 150ms ease;
  }
  .home-skill-item:hover .home-skill-dot {
    opacity: 1;
    transform: scale(1.2);
  }
  .home-skills-foot {
    margin: 2.5rem 0 0;
    font-size: 0.875rem;
    color: var(--ds-text-muted);
  }
  .home-skills-foot strong {
    color: var(--ds-text);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  /* ══════════════════════════════════════════════════════════════════
     0.5 · USE CASES — editorial, refined to ds tokens
     ══════════════════════════════════════════════════════════════════ */
  .home-cases { background: var(--ds-ground); }
  .cases-editorial {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .cases-editorial {
      grid-template-columns: repeat(2, 1fr);
      gap: 3.5rem 4rem;
    }
  }
  .case {
    border-top: 1px solid var(--ds-hairline-strong);
    padding-top: 1.5rem;
  }
  .case-link {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: inherit;
    text-decoration: none;
  }
  .case-index {
    margin: 0 0 0.25rem;
  }
  .case-title {
    font-family: var(--aw-font-heading);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 580;
    color: var(--ds-text);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0;
  }
  .case-desc {
    color: var(--ds-text-body);
    font-size: 0.9375rem;
