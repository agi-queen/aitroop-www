---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI-Powered Growth Platform',
  ignoreTitleTemplate: true,
};

const agents = [
  { icon: 'tabler:radar-2',       title: 'Prospect Agent',  desc: 'Scans millions of signals to surface high-fit leads — company stage, hiring activity, tech stack, and intent data combined into a precision target list.' },
  { icon: 'tabler:mail-forward',  title: 'Outreach Agent',  desc: 'Writes and sends hyper-personalized cold emails and LinkedIn messages. No templates — every message is contextually crafted for each recipient.' },
  { icon: 'tabler:messages',      title: 'Engage Agent',    desc: "Follows up intelligently across channels, adjusting tone and timing based on each prospect's engagement signals and conversation history." },
  { icon: 'tabler:target',        title: 'Convert Agent',   desc: 'Surfaces deal-winning insights for your reps at the right moment — objection handling, social proof, competitive intel, and next best actions.' },
  { icon: 'tabler:shield-check',  title: 'Retain Agent',    desc: 'Monitors usage patterns and health scores continuously. Flags at-risk accounts 90 days before churn materializes so you can act while there\'s still time.' },
  { icon: 'tabler:chart-line',    title: 'Insights Agent',  desc: 'Synthesizes your entire pipeline into clear, actionable recommendations. Know exactly where to focus next — and why — without digging through dashboards.' },
];

const steps = [
  { n: '01', title: 'Connect your stack',   desc: 'Link your CRM, email provider, and LinkedIn in under 10 minutes. Native integrations with HubSpot, Salesforce, Apollo, Outreach, and more.' },
  { n: '02', title: 'Deploy your agents',   desc: 'Select which agents match your growth priorities and configure their parameters. No code required — the setup wizard handles the rest.' },
  { n: '03', title: 'Agents go to work',    desc: 'Automated prospecting, personalized outreach, and follow-ups run continuously — nights, weekends, across every time zone.' },
  { n: '04', title: 'Measure and scale',    desc: "The Insights Agent surfaces what's working and what's not. Amplify winning campaigns and cut the rest — with a single click." },
];

const faqs = [
  { q: 'How is Aitroop different from other sales automation tools?',
    a: 'Most tools automate one part of the funnel. Aitroop covers the entire growth pipeline — from prospecting and outreach to conversion and churn prevention — using purpose-built AI agents that work together as a coordinated team.' },
  { q: 'Do I need technical skills to set up Aitroop?',
    a: 'No. Aitroop is designed for growth and sales operators, not engineers. The setup wizard guides you through connecting your tools and configuring each agent in minutes.' },
  { q: 'How do agents personalize outreach at scale?',
    a: 'Each prospect is researched individually using live signals — company news, job postings, tech stack, LinkedIn activity. The Outreach Agent combines these inputs to write messages that feel like they came from a human who did their homework.' },
  { q: 'What CRMs and tools does Aitroop integrate with?',
    a: 'Aitroop natively integrates with HubSpot, Salesforce, Apollo, Outreach, LinkedIn Sales Navigator, and most major email providers. Custom integrations are available for enterprise plans.' },
  { q: 'How does churn prediction work?',
    a: 'The Retain Agent monitors product usage patterns, engagement signals, and account health in real time. It flags accounts showing early churn patterns — typically 90+ days before they would otherwise escalate — so your team can intervene proactively.' },
];
---

<Layout metadata={metadata}>

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════ -->
  <section id="hero" class="relative overflow-hidden text-center px-4 pt-20 pb-16 md:pt-28 md:pb-24">
    <!-- Subtle top-center green glow -->
    <div class="absolute inset-0 -z-10 pointer-events-none"
      style="background:radial-gradient(ellipse 75% 50% at 50% -5%,rgba(82,153,97,0.09) 0%,transparent 65%);"
      aria-hidden="true"></div>
    <!-- Fine dot grid, fades away downward -->
    <div class="absolute inset-0 -z-10 pointer-events-none"
      style="background-image:radial-gradient(circle,rgba(0,0,0,0.032) 1px,transparent 1px);background-size:32px 32px;mask-image:radial-gradient(ellipse 80% 55% at 50% 0%,black 25%,transparent 80%);"
      aria-hidden="true"></div>

    <div class="mx-auto max-w-4xl">
      <!-- Live badge -->
      <div class="inline-flex items-center gap-1.5 text-[0.75rem] font-semibold text-primary bg-primary/[0.07] border border-primary/20 px-3.5 py-1.5 rounded-full mb-7">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
        </span>
        AI Agent Platform for Growth Teams
      </div>

      <!-- Headline -->
      <h1 class="text-[2.75rem] sm:text-5xl md:text-[3.75rem] lg:text-[4.25rem] font-bold tracking-[-0.03em] leading-[1.1] text-[var(--aw-color-text-heading)]">
        Acquire smarter.<br>Convert faster.<br>
        <span class="text-primary">Retain longer.</span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-6 text-[1.0625rem] md:text-xl text-[var(--aw-color-text-muted)] max-w-2xl mx-auto leading-relaxed">
        An army of AI agents — prospect, engage, convert, retain — each with a precise mission across your growth pipeline.
        One platform. One operator. An entire team's output.
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.aitroop.net"
          class="inline-flex items-center gap-2 h-11 px-6 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          Start for free
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#how-it-works"
          class="inline-flex items-center gap-2 h-11 px-6 rounded-lg text-sm font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.022)] transition-all duration-150">
          How it works
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </a>
      </div>

      <!-- Social proof row -->
      <div class="mt-9 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[0.8125rem] text-[var(--aw-color-text-muted)]">
        <div class="flex items-center gap-1.5">
          <div class="flex gap-0.5">
            {Array(5).fill(0).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#529961" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <span>Loved by <strong class="text-[var(--aw-color-text-heading)] font-semibold">200+</strong> growth teams</span>
        </div>
        <span class="h-3.5 w-px bg-[var(--aw-color-border)] hidden sm:block" aria-hidden="true"></span>
        <span>No credit card required</span>
        <span class="h-3.5 w-px bg-[var(--aw-color-border)] hidden sm:block" aria-hidden="true"></span>
        <span>Up and running in <strong class="text-[var(--aw-color-text-heading)] font-semibold">10 minutes</strong></span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       SOCIAL PROOF TICKER
  ═══════════════════════════════════════════════════════ -->
  <div class="border-y border-[var(--aw-color-border)] py-5 overflow-hidden">
    <p class="text-center text-[0.6rem] uppercase tracking-[0.18em] text-[var(--aw-color-text-muted)] mb-4 font-semibold opacity-50">
      Powering growth teams across industries
    </p>
    <div class="relative flex overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_8%,black_92%,transparent)]">
      <ul class="flex shrink-0 gap-12 pr-12 marquee-track list-none m-0 p-0">
        {['B2B SaaS','E-commerce','Fintech','MarTech','Sales Teams','Growth Agencies','D2C Brands','Enterprise GTM','PLG Companies','Startups'].map(n => (
          <li class="text-[0.8125rem] font-medium text-[var(--aw-color-text-muted)] opacity-40 hover:opacity-70 transition-opacity cursor-default select-none whitespace-nowrap">{n}</li>
        ))}
      </ul>
      <ul class="flex shrink-0 gap-12 pr-12 marquee-track list-none m-0 p-0" aria-hidden="true">
        {['B2B SaaS','E-commerce','Fintech','MarTech','Sales Teams','Growth Agencies','D2C Brands','Enterprise GTM','PLG Companies','Startups'].map(n => (
          <li class="text-[0.8125rem] font-medium text-[var(--aw-color-text-muted)] opacity-40 whitespace-nowrap select-none">{n}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       AI AGENTS GRID
  ═══════════════════════════════════════════════════════ -->
  <section id="agents" class="py-20 md:py-28 px-4">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="section-label">The AI Growth Squad</p>
        <h2 class="section-title">Six specialists. One platform.</h2>
        <p class="section-sub">Each agent is purpose-built for a specific stage of your growth pipeline — working 24/7 so your team can focus on what only humans can do.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {agents.map((agent) => (
          <div class="agent-card group p-7 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-200 hover:border-primary/25 hover:shadow-[0_8px_30px_rgba(82,153,97,0.09)] hover:-translate-y-1">
            <div class="mb-4 w-10 h-10 rounded-xl bg-primary/[0.08] flex items-center justify-center text-primary">
              <Icon name={agent.icon} class="w-5 h-5" />
            </div>
            <h3 class="text-[0.9375rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{agent.title}</h3>
            <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-relaxed">{agent.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       HOW IT WORKS — numbered steps
  ═══════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="py-20 md:py-28 px-4 bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)]">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="section-label">Simple by design</p>
        <h2 class="section-title">Up and running in minutes.</h2>
        <p class="section-sub">No six-month onboarding. No army of consultants. Aitroop is built to deploy fast and compound results over time.</p>
      </div>

      <!-- Horizontal steps on md+, vertical on mobile -->
      <div class="grid md:grid-cols-4 gap-8 relative">
        <!-- Connector line (desktop only) -->
        <div class="hidden md:block absolute top-[1.375rem] left-[calc(12.5%+1.375rem)] right-[calc(12.5%+1.375rem)] h-px bg-[var(--aw-color-border)]" aria-hidden="true"></div>

        {steps.map((step) => (
          <div class="flex flex-col items-center text-center md:items-center">
            <div class="relative mb-5 w-11 h-11 rounded-full border-2 border-primary/20 bg-[var(--aw-color-bg-page)] flex items-center justify-center z-10">
              <span class="text-[0.6875rem] font-bold text-primary tracking-wider">{step.n}</span>
            </div>
            <h3 class="text-[0.9375rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{step.title}</h3>
            <p class="text-[0.8125rem] text-[var(--aw-color-text-muted)] leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       STATS — scramble counter
  ═══════════════════════════════════════════════════════ -->
  <section id="stats-section" class="py-20 md:py-28 px-4">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="section-label">Real results</p>
        <h2 class="section-title">Numbers that move the needle.</h2>
        <p class="section-sub">Aggregated across growth teams running Aitroop agents in production.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-6">
        {[
          { target: 6,  suffix: '×',   label: 'Outreach capacity' },
          { target: 90, suffix: 'd',   label: 'Churn early warning' },
          { target: 80, suffix: '%+',  label: 'Contact data coverage' },
          { target: 15, suffix: '%',   label: 'Average reply rate' },
        ].map(({ target, suffix, label }, i) => (
          <div class="stat-card text-center" style={`--i:${i};`}>
            <div class="text-[2.75rem] md:text-5xl font-bold text-primary tabular-nums leading-none">
              <span class="stat-num" data-target={target}>0</span>{suffix}
            </div>
            <div class="mt-2 w-8 h-0.5 bg-primary/30 mx-auto rounded-full"></div>
            <p class="mt-3 text-[0.8125rem] text-[var(--aw-color-text-muted)]">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TESTIMONIALS
  ═══════════════════════════════════════════════════════ -->
  <Testimonials
    id="testimonials"
    tagline="What teams are saying"
    title="Growth teams love Aitroop."
    subtitle="From SDR-heavy outbound to lean PLG motions — Aitroop adapts to how you grow."
    testimonials={[
      {
        testimonial: 'We scaled from 200 to 1,400 outreach sequences per month without adding headcount. The Outreach Agent writes better cold emails than most SDRs, honestly.',
        name: 'Lena Torres',
        job: 'Head of Growth · Patrly',
      },
      {
        testimonial: 'The 90-day churn alert is genuinely impressive. We saved three enterprise accounts last quarter because Aitroop flagged them first — before they reached out to cancel.',
        name: 'David Kwan',
        job: 'VP of Sales · Clearflo',
      },
      {
        testimonial: "We used to stitch together five different tools for this workflow. Now it's one platform. Our GTM velocity doubled in 60 days and our ops overhead actually went down.",
        name: 'Priya Nair',
        job: 'CMO · Storyvault',
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════════════════ -->
  <section id="faq" class="py-20 md:py-28 px-4 bg-[rgba(0,0,0,0.015)] border-t border-[var(--aw-color-border)]">
    <div class="mx-auto max-w-2xl">
      <div class="text-center mb-12">
        <p class="section-label">Got questions?</p>
        <h2 class="section-title">Frequently asked.</h2>
      </div>

      <div class="space-y-3" id="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item group rounded-xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer select-none list-none font-medium text-[0.9375rem] text-[var(--aw-color-text-heading)]">
              {faq.q}
              <span class="faq-icon shrink-0 w-5 h-5 rounded-full border border-[var(--aw-color-border)] flex items-center justify-center text-[var(--aw-color-text-muted)] transition-transform duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path class="faq-plus-v" d="M12 5v14"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-5 text-[0.875rem] text-[var(--aw-color-text-muted)] leading-relaxed border-t border-[var(--aw-color-border)] pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       FINAL CTA
  ═══════════════════════════════════════════════════════ -->
  <CallToAction
    id="cta-section"
    title="Your growth team is ready."
    subtitle="Deploy your first AI agent in minutes. See the pipeline move."
    actions={[
      { text: 'Get started', href: 'https://app.aitroop.net', variant: 'primary' },
      { text: 'Talk to us', href: '/contact', variant: 'secondary' },
    ]}
  />

</Layout>

<style>
  /* ── Shared section typography ──────────────────────── */
  .section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.5rem;
    opacity: 0.85;
  }
  .section-title {
    font-size: clamp(1.625rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--aw-color-text-heading);
    margin-bottom: 0.75rem;
  }
  .section-sub {
    font-size: 0.9375rem;
    color: var(--aw-color-text-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.75;
  }

  /* ── Marquee ─────────────────────────────────────────── */
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-100%); } }
  .marquee-track { animation: marquee 34s linear infinite; }

  /* ── FAQ accordion ───────────────────────────────────── */
  details.faq-item[open] summary { color: #529961; }
  details.faq-item[open] .faq-plus-v { display: none; }
  details.faq-item summary::-webkit-details-marker { display: none; }

  /* ── Stats card entrance ─────────────────────────────── */
  .stat-card {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .stat-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Reduced-motion ──────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none !important; }
    .stat-card { opacity: 1; transform: none; }
  }
</style>

<script>
  /* ── Stats: staggered reveal + scramble counter ─────── */
  const statsSection = document.getElementById('stats-section');
  if (statsSection) {
    const io = new IntersectionObserver((entries) => {
      if (!entries[0].isIntersecting) return;
      io.disconnect();

      statsSection.querySelectorAll<HTMLElement>('.stat-card').forEach((card, i) => {
        setTimeout(() => card.classList.add('visible'), i * 120);

        const numEl = card.querySelector<HTMLElement>('.stat-num');
        if (!numEl) return;
        const target = parseInt(numEl.dataset.target ?? '0', 10);
        const DIGITS = '0123456789';
        let start: number | null = null;

        const tick = (ts: number) => {
          if (!start) start = ts;
          const elapsed = ts - start;
          if (elapsed < 600) {
            numEl.textContent = DIGITS[Math.floor(Math.random() * 10)];
            requestAnimationFrame(tick);
          } else if (elapsed < 1200) {
            const t = (elapsed - 600) / 600;
            numEl.textContent = String(Math.round((1 - Math.pow(1 - t, 3)) * target));
            requestAnimationFrame(tick);
          } else {
            numEl.textContent = String(target);
          }
        };
        setTimeout(() => requestAnimationFrame(tick), i * 120 + 150);
      });
    }, { threshold: 0.3 });
    io.observe(statsSection);
  }
</script>
