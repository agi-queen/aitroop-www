---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Book a demo · Aitroop',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline=""
    title="Book a demo and see Aitroop in action."
    subtitle="A 30-minute walkthrough tailored to your team's workflows."
    actions={[
      { variant: 'primary', text: 'Book a demo', href: '/contact', icon: 'tabler:square-rounded-arrow-right' },
      { text: 'Learn more', href: '#' },
    ]}
    image={{
      src: '/illustrations/brainstorming_gny9.svg', width: 1024, height: 768,
      alt: 'Magnet attracting screws. Lead generation landing page demo',
    }}
  />

  <CallToAction
    title="Coming soon"
    subtitle="We are working on the content of these demo pages. You will see them very soon. Stay tuned."
    actions={[
      {
        variant: 'primary',
        text: 'Open the app',
        href: 'https://app.aitroop.net',
        icon: 'tabler:download',
      },
    ]}
  />
</Layout>
