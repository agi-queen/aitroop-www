---
import Layout from '~/layouts/PageLayout.astro';
import GridBackground from '~/components/ui/GridBackground.astro';

const metadata = {
  title: 'Use Cases · Aitroop',
};

const cases = [
  {
    slug: '/use-cases/gtm',
    title: 'GTM',
    tagline: 'Pipeline that runs itself.',
    desc: 'Prospecting, outreach, retention, and pipeline insights. Pre-built Apps for revenue teams who want compounding output without expanding headcount.',
    apps: [
      { tag: 'Top of funnel',    name: 'Prospecting',       brief: 'Find high-fit accounts using company signals, hiring activity, and intent data.' },
      { tag: 'Engagement',       name: 'Outreach',          brief: 'Personalized cold emails and LinkedIn messages that match your voice.' },
      { tag: 'Customer success', name: 'Retention',         brief: 'Flag at-risk customers before churn materializes.' },
      { tag: 'RevOps',           name: 'Pipeline insights', brief: 'Synthesize pipeline data into deal recommendations you can act on.' },
    ],
  },
  {
    slug: '/use-cases/finance',
    title: 'Finance',
    tagline: 'Close the books faster.',
    desc: 'Month-end close, AR/AP analysis, expense compliance, and budget variance. For finance teams who want to spend less time on spreadsheets and more on the analysis.',
    apps: [
      { tag: 'Close cycle', name: 'Month-end checklist', brief: 'GL reconciliation, accruals, intercompany matching, and sign-off, in order.' },
      { tag: 'Receivables', name: 'AR aging report',     brief: 'Bucket by age, flag risk, and draft dunning messages automatically.' },
      { tag: 'Controls',    name: 'Expense audit',       brief: 'Scan reports for policy violations, duplicates, and anomalies.' },
      { tag: 'FP&A',        name: 'Variance analysis',   brief: 'Compare actuals to budget and explain each variance for the board.' },
    ],
  },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head usecases-page-head">
    <GridBackground variant="dots" tone="brand" class="usecases-bg" />
    <div class="aw-container">
      <p class="aw-eyebrow">0.1 · Use cases</p>
      <h1 class="aw-h1" style="max-width: 28ch;">
        Pre-built App packs for the work your team actually does.
      </h1>
      <p class="aw-page-head-desc">
        Each pack is a curated set of Apps, skills, and connects that work together out of the box. Use as-is, or fork to fit your process.
      </p>
    </div>
  </section>

  <!-- PACKS ────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <ul class="packs ds-reveal-stagger">
        {cases.map((c, i) => (
          <li class="pack">
            <div class="pack-head">
              <p class="aw-eyebrow pack-index">{`0.1.${i + 1}`}</p>
              <h2 class="pack-title">
                <a href={c.slug}>{c.title}</a>
              </h2>
              <p class="pack-tagline">{c.tagline}</p>
              <p class="pack-desc">{c.desc}</p>
              <a href={c.slug} class="pack-cta">
                Open use case
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>

            <ul class="pack-apps">
              {c.apps.map((app, j) => (
                <li class="pack-app">
                  <span class="pack-app-idx">{`${i + 1}.${j + 1}`}</span>
                  <span class="pack-app-tag">{app.tag}</span>
                  <span class="pack-app-name">{app.name}</span>
                  <span class="pack-app-brief">{app.brief}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>

      <!-- BYO — inline, no card chrome -->
      <div class="byo">
        <div class="byo-text">
          <p class="aw-eyebrow">0.1.x · Bring your own</p>
          <h3 class="byo-title">Don't see your workflow?</h3>
          <p class="byo-desc">Aitroop crystallizes any AI-assisted workflow into a reusable App. Bring the use case; we'll fit the pack to it.</p>
        </div>
        <a href="/contact" class="aw-btn aw-btn-ghost">Talk to us →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ ambient page-head backdrop ════ */
  .usecases-page-head {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .usecases-page-head :global(.usecases-bg) { z-index: -1; opacity: 0.5; }
  .usecases-page-head :global(.usecases-bg .gridbg__layer) {
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 25% 30%, #000 30%, transparent 80%) !important;
            mask-image: radial-gradient(ellipse 70% 70% at 25% 30%, #000 30%, transparent 80%) !important;
  }
  .usecases-page-head > .aw-container { position: relative; z-index: 1; }

  /* ════ pack list — editorial hairline rows, no card chrome ════ */
  .packs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .pack {
    border-top: 1px solid var(--ds-hairline-strong);
    padding: 2.5rem 0 2.75rem;
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .pack {
      grid-template-columns: 20rem 1fr;
      gap: 4rem;
      padding: 3rem 0 3.25rem;
    }
  }
  .pack-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .pack-index { margin: 0 0 1rem; }
  .pack-title {
    font-family: var(--aw-font-heading);
    font-size: clamp(2rem, 3.6vw, 2.625rem);
    font-weight: 580;
    letter-spacing: -0.026em;
    line-height: 1.04;
    color: var(--ds-text);
    margin: 0 0 0.875rem;
  }
  .pack-title a { color: inherit; text-decoration: none; }
  .pack-title a:hover { color: var(--ds-accent); }
  .pack-tagline {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--ds-text-body);
    margin: 0 0 1rem;
    line-height: 1.4;
  }
  .pack-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ds-text-muted);
    margin: 0 0 1.5rem;
    max-width: 42ch;
    text-wrap: pretty;
  }
  .pack-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ds-accent);
    text-decoration: none;
    transition: gap 200ms var(--ds-ease-out);
  }
  .pack-cta svg {
    width: 14px;
    height: 14px;
    transition: transform 200ms var(--ds-ease-out);
  }
  .pack-cta:hover { gap: 0.7rem; }
  .pack-cta:hover svg { transform: translateX(3px); }

  /* ════ pack apps — mono-indexed rows ════ */
  .pack-apps {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pack-app {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1rem 0;
    border-top: 1px dashed var(--ds-hairline);
    font-size: 0.875rem;
    line-height: 1.55;
  }
  .pack-app:first-child { border-top: 0; padding-top: 0; }
  @media (min-width: 640px) {
    .pack-app {
      grid-template-columns: 3rem 8rem 11rem 1fr;
      gap: 1.25rem;
      align-items: baseline;
      padding: 1rem 0;
    }
  }
  .pack-app-idx {
    font-family: var(--ds-font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.6875rem;
    color: var(--ds-text-quiet);
  }
  .pack-app-tag {
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ds-text-muted);
    line-height: 1.4;
  }
  .pack-app-name {
    font-weight: 600;
    color: var(--ds-text);
    letter-spacing: -0.005em;
  }
  .pack-app-brief {
    color: var(--ds-text-muted);
    text-wrap: pretty;
  }

  /* ════ BYO inline row — no card chrome ════ */
  .byo {
    margin-top: 3rem;
    padding-top: 2.75rem;
    border-top: 1px solid var(--ds-hairline-strong);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .byo {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      margin-top: 4rem;
      padding-top: 3rem;
      gap: 3rem;
    }
  }
  .byo-text { flex: 1; }
  .byo-title {
    font-family: var(--aw-font-heading);
    font-size: 1.375rem;
    font-weight: 580;
    color: var(--ds-text);
    letter-spacing: -0.018em;
    margin: 0.5rem 0 0.5rem;
  }
  .byo-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ds-text-muted);
    margin: 0;
    max-width: 52ch;
  }
</style>
