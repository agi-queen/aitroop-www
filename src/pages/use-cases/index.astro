---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Use Cases · Aitroop',
};

const cases = [
  {
    slug: '/use-cases/engineering',
    title: 'Engineering',
    tagline: 'Ship safely, write less.',
    desc: 'PR review, release notes, on-call digests, postmortems. Apps that sit next to your repo and pager, doing the writing-up nobody loves.',
    apps: [
      { name: 'PR review',        brief: 'Senior-level review that flags real bugs, not nits.' },
      { name: 'Release notes',    brief: 'Roll commits and tickets into a clean changelog.' },
      { name: 'Incident digest',  brief: 'Group overnight alerts into one on-call brief.' },
      { name: 'Postmortem',       brief: 'Timeline, root cause, action items — from logs.' },
    ],
  },
  {
    slug: '/use-cases/marketing',
    title: 'Marketing',
    tagline: 'Ship the campaign without the scramble.',
    desc: 'Briefs, social distribution, weekly newsletters, SEO audits. Each App keeps the marketing engine moving when the calendar runs out of hours.',
    apps: [
      { name: 'Content brief',    brief: 'Keyword to outline, with competitor gaps mapped.' },
      { name: 'Social pack',      brief: 'One source post into platform-native variants.' },
      { name: 'Weekly digest',    brief: 'Sweep your sources into a newsletter.' },
      { name: 'Content audit',    brief: 'Crawl, find thin pages, prioritise the fixes.' },
    ],
  },
  {
    slug: '/use-cases/support',
    title: 'Customer support',
    tagline: 'Triage, draft, resolve.',
    desc: 'Ticket triage, KB-grounded reply drafts, knowledge sync, churn signals. Apps that take the repetitive half off the queue.',
    apps: [
      { name: 'Ticket triage',    brief: 'Classify and route with reasoning attached.' },
      { name: 'Reply drafter',    brief: 'First-response drafts, grounded in your KB.' },
      { name: 'KB sync',          brief: 'Turn solved tickets into KB articles.' },
      { name: 'Churn signal',     brief: 'Escalate at-risk accounts before renewal.' },
    ],
  },
  {
    slug: '/use-cases/research',
    title: 'Research',
    tagline: 'Insight without the slog.',
    desc: 'Competitor scans, interview synthesis, market sizing, weekly briefings. Apps for the half of research that is just reading a lot of things carefully.',
    apps: [
      { name: 'Competitor scan',  brief: 'Diff competitor sites weekly with a take.' },
      { name: 'Interview synthesis', brief: 'Cluster transcripts into themes with quotes.' },
      { name: 'Market sizing',    brief: 'Top-down + bottom-up with auditable sources.' },
      { name: 'Weekly briefing',  brief: 'Rank what is worth your read time.' },
    ],
  },
  {
    slug: '/use-cases/operations',
    title: 'Operations',
    tagline: 'Process without the busywork.',
    desc: 'SOP drafts, vendor risk reviews, contract redlines, controls scans. The unglamorous back-office work, captured as Apps the team can run.',
    apps: [
      { name: 'SOP draft',        brief: 'Chat to structured procedure, with owners.' },
      { name: 'Vendor risk',      brief: 'Read SOC2 PDFs and flag what to discuss.' },
      { name: 'Contract redline', brief: 'Mark deviations against your playbook.' },
      { name: 'Controls scan',    brief: 'Walk SOC2/ISO/GDPR gaps with evidence.' },
    ],
  },
  {
    slug: '/use-cases/gtm',
    title: 'GTM',
    tagline: 'Pipeline that runs itself.',
    desc: 'Prospecting, outreach, retention, pipeline insights. Apps for revenue teams that want compounding output without expanding headcount.',
    apps: [
      { name: 'Prospecting',      brief: 'Find ICP-fit accounts from company signals.' },
      { name: 'Outreach',         brief: 'Personalised emails and LinkedIn messages.' },
      { name: 'Retention',        brief: 'Flag at-risk customers before churn.' },
      { name: 'Pipeline insights', brief: 'Deal recommendations from pipeline data.' },
    ],
  },
  {
    slug: '/use-cases/finance',
    title: 'Finance',
    tagline: 'Close the books faster.',
    desc: 'Month-end close, AR/AP analysis, expense compliance, budget variance. Less spreadsheet wrangling, more time on the analysis.',
    apps: [
      { name: 'Month-end checklist', brief: 'GL reconcile, accruals, intercompany.' },
      { name: 'AR aging report',     brief: 'Bucket by age, flag risk, draft dunning.' },
      { name: 'Expense audit',       brief: 'Find policy violations and anomalies.' },
      { name: 'Variance analysis',   brief: 'Actuals vs budget with a narrative.' },
    ],
  },
  {
    slug: '/use-cases/personal',
    title: 'Personal productivity',
    tagline: 'Reclaim your inbox.',
    desc: 'Inbox triage, meeting prep, weekly reviews, decision logs. Apps that quietly run in the background of your week.',
    apps: [
      { name: 'Inbox triage',     brief: 'Label, summarise, draft fast replies.' },
      { name: 'Meeting prep',     brief: 'Pre-read that lands before every call.' },
      { name: 'Weekly review',    brief: 'Sweep your week into a digest.' },
      { name: 'Decision log',     brief: 'Capture decisions with their rationale.' },
    ],
  },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head">
    <div class="aw-container">
      <h1 class="aw-h2">
        Any repeated work can be an App.
      </h1>
      <p class="aw-page-head-desc">
        Aitroop is a generic agent — it does not assume your job. Below are starting points across eight functions. Open one, install it, or fork it into your own shape.
      </p>
    </div>
  </section>

  <!-- PACKS ────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <ul class="packs">
        {cases.map((c) => (
          <li class="pack">
            <div class="pack-head">
              <h2 class="pack-title">
                <a href={c.slug}>{c.title}</a>
              </h2>
              <p class="pack-tagline">{c.tagline}</p>
              <p class="pack-desc">{c.desc}</p>
              <a href={c.slug} class="pack-cta">
                Open use case
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>

            <ul class="pack-apps">
              {c.apps.map((app) => (
                <li class="pack-app">
                  <span class="pack-app-name">{app.name}</span>
                  <span class="pack-app-brief">{app.brief}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>

      <!-- BYO use case -->
      <div class="byo">
        <div class="byo-text">
          <h3 class="byo-title">Don't see your workflow?</h3>
          <p class="byo-desc">The eight packs above are starting points, not the product. Aitroop crystallises any AI-assisted workflow into a reusable App — including the one your team has not named yet.</p>
        </div>
        <a href="/contact" class="aw-btn aw-btn-ghost">Talk to us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ pack list — editorial hairline rows, no card chrome ════ */
  .packs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .pack {
    border-top: 1px solid var(--aw-color-border-strong);
    padding: 2.25rem 0 2.5rem;
    display: grid;
    gap: 1.75rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .pack {
      grid-template-columns: 18rem 1fr;
      gap: 3.5rem;
      padding: 2.75rem 0 3rem;
    }
  }
  .pack-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .pack-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.06;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.5rem;
  }
  .pack-title a {
    color: inherit;
    text-decoration: none;
  }
  .pack-title a:hover { text-decoration: underline; }
  .pack-tagline {
    font-size: 1rem;
    font-weight: 500;
    color: var(--aw-color-text-default);
    margin: 0 0 0.875rem;
    line-height: 1.4;
  }
  .pack-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 0 0 1.125rem;
    max-width: 42ch;
    text-wrap: pretty;
  }
  .pack-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    text-decoration: none;
    transition: gap 200ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .pack-cta svg {
    width: 16px;
    height: 16px;
    transition: transform 200ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .pack-cta:hover { gap: 0.625rem; }
  .pack-cta:hover svg { transform: translateX(2px); }

  /* ════ pack apps — compact preview rows ════ */
  .pack-apps {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pack-app {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 0.875rem 0;
    border-top: 1px solid var(--aw-color-border);
    font-size: 0.875rem;
    line-height: 1.55;
  }
  .pack-app:first-child {
    border-top: 0;
    padding-top: 0;
  }
  @media (min-width: 640px) {
    .pack-app {
      grid-template-columns: 12rem 1fr;
      gap: 1.5rem;
      align-items: baseline;
    }
  }
  .pack-app-name {
    font-weight: 600;
    color: var(--aw-color-text-default);
    letter-spacing: -0.005em;
  }
  .pack-app-brief {
    color: var(--aw-color-text-muted);
    text-wrap: pretty;
  }

  /* ════ BYO row ════ */
  .byo {
    margin-top: 3rem;
    padding: 2.5rem 0 0;
    border-top: 1px solid var(--aw-color-border-strong);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .byo {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      margin-top: 4rem;
      padding-top: 3rem;
      gap: 3rem;
    }
  }
  .byo-text { flex: 1; }
  .byo-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
  }
  .byo-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    margin: 0;
    max-width: 56ch;
  }
</style>
