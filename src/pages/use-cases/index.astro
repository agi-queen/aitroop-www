---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Use Cases · Aitroop',
};

const cases = [
  {
    slug: '/use-cases/gtm',
    title: 'GTM',
    tagline: 'Pipeline that runs itself.',
    desc: 'Prospecting, outreach, retention, and pipeline insights. Pre-built Apps for revenue teams who want compounding output without expanding headcount.',
    apps: ['Prospecting', 'Outreach', 'Retention', 'Pipeline insights'],
  },
  {
    slug: '/use-cases/finance',
    title: 'Finance',
    tagline: 'Close the books faster.',
    desc: 'Month-end close, AR/AP analysis, expense compliance, and budget variance. For finance teams who want to spend less time on spreadsheets and more on the analysis.',
    apps: ['Month-end checklist', 'AR aging report', 'Expense audit', 'Variance analysis'],
  },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <p class="aw-eyebrow">Use cases</p>
      <h1 class="aw-display" style="max-width: 22ch;">
        Pre-built App packs for the work your team actually does.
      </h1>
      <p class="aw-lede" style="max-width: 56ch;">
        Each pack is a curated set of Apps, skills, and connects that work together out of the box. Use as-is, or fork to fit your process.
      </p>
    </div>
  </section>

  <!-- PACKS ────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <ul class="packs">
        {cases.map((c) => (
          <li>
            <a href={c.slug} class="group">
              <div class="pack-head">
                <h2 class="pack-title">{c.title}</h2>
                <p class="pack-tagline">{c.tagline}</p>
              </div>
              <div class="pack-body">
                <p class="pack-desc">{c.desc}</p>
                <ul class="pack-apps">
                  {c.apps.map((app) => <li class="aw-tag">{app}</li>)}
                </ul>
                <span class="pack-cta">
                  Open use case
                  <span class="aw-arrow" aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <!-- BYO use case -->
      <div class="byo">
        <div class="byo-text">
          <h3 class="byo-title">Don't see your workflow?</h3>
          <p class="byo-desc">Aitroop is a platform for crystallizing any AI-assisted workflow into a reusable App.</p>
        </div>
        <a href="/contact" class="aw-btn aw-btn-ghost">Talk to us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ pack list — hairline editorial ════ */
  .packs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .packs > li { border-top: 1px solid var(--aw-color-border-strong); }
  .packs > li:last-child { border-bottom: 1px solid var(--aw-color-border); }
  .packs a {
    display: grid;
    gap: 1.5rem;
    padding: 2rem 0 2.5rem;
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 768px) {
    .packs a {
      grid-template-columns: 16rem 1fr;
      gap: 3.5rem;
      padding: 2.5rem 0 3rem;
    }
  }
  .pack-title {
    font-size: clamp(1.875rem, 3.4vw, 2.375rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.5rem;
  }
  .pack-tagline {
    font-size: 1rem;
    font-weight: 500;
    color: var(--aw-color-text-default);
    margin: 0;
    line-height: 1.4;
  }
  .pack-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 0 0 1.25rem;
    text-wrap: pretty;
  }
  .pack-apps {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pack-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--aw-color-primary);
  }

  /* ════ BYO row ════ */
  .byo {
    margin-top: 3rem;
    padding: 2.5rem 0 0;
    border-top: 1px solid var(--aw-color-border);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .byo {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      margin-top: 4rem;
      padding-top: 3rem;
      gap: 3rem;
    }
  }
  .byo-text { flex: 1; }
  .byo-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
  }
  .byo-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    margin: 0;
    max-width: 50ch;
  }
</style>
