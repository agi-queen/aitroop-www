---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Finance — Use Cases — Aitroop',
};

const stats = [
  { value: '↓ 60%', label: 'Close cycle time' },
  { value: '100%',  label: 'Audit trail coverage' },
  { value: '7',     label: 'Artifact formats' },
  { value: '∞',     label: 'Reruns, same shape' },
];

const apps = [
  {
    n: '01',
    name: 'Month-end checklist',
    description: 'Run the entire close in order: GL reconciliation, accrual entries, intercompany matching, and sign-off. Each step produces an audit trail.',
    inputs: ['Closing period', 'Entity scope', 'Owner assignments'],
    outputs: ['Close checklist (Markdown)', 'Reconciliation report (CSV)'],
    skills: ['gl-reconcile', 'accrual-calc', 'intercompany-match'],
    connects: ['quickbooks', 'xero', 'netsuite'],
  },
  {
    n: '02',
    name: 'AR aging report',
    description: 'Bucket receivables by age, flag at-risk balances, and draft customized dunning messages to overdue customers — automatically.',
    inputs: ['As-of date', 'Aging buckets', 'Risk threshold'],
    outputs: ['Aging report (CSV)', 'Dunning email drafts (Markdown)'],
    skills: ['ar-bucket', 'risk-score', 'email-writer'],
    connects: ['quickbooks', 'stripe', 'gmail'],
  },
  {
    n: '03',
    name: 'Expense audit',
    description: 'Scan expense reports for policy violations, duplicate submissions, and anomalies. Surfaces exceptions for human review with reasoning.',
    inputs: ['Reporting period', 'Policy document', 'Threshold rules'],
    outputs: ['Exception list (CSV)', 'Audit summary (Markdown)'],
    skills: ['expense-classify', 'policy-match', 'anomaly-detect'],
    connects: ['expensify', 'concur', 'google-drive'],
  },
  {
    n: '04',
    name: 'Variance analysis',
    description: 'Compare actuals to budget, identify the top drivers behind each variance, and generate a narrative explanation suitable for board decks.',
    inputs: ['Period', 'Department filter', 'Variance threshold'],
    outputs: ['Variance breakdown (CSV)', 'Executive narrative (Markdown)'],
    skills: ['variance-calc', 'driver-attribute', 'narrative-writer'],
    connects: ['netsuite', 'quickbooks', 'sheets'],
  },
];

const why = [
  { title: 'Auditable by default', desc: 'Every App run produces structured artifacts with full execution logs. Reproducible, comparable, defensible.' },
  { title: 'Your data stays yours', desc: 'Each user runs in an isolated sandbox. OAuth scopes limit what agents see. No model training on your numbers.' },
  { title: 'Same shape every cycle', desc: 'An App produces the same structured output every time. Predictable for downstream consumers, auditable for your board.' },
];
---

<Layout metadata={metadata}>

  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <nav class="crumbs">
        <a href="/use-cases">Use cases</a>
        <span aria-hidden="true">/</span>
        <span>Finance</span>
      </nav>
      <p class="eyebrow">Finance teams · CFO</p>
      <h1 class="display">Close the books faster.</h1>
      <p class="lede">
        Four pre-built Apps cover the month-end and operational finance workflows your team runs every cycle. Less spreadsheet wrangling — more time on the analysis.
      </p>
      <div class="actions">
        <a href="https://app.aitroop.net" class="btn btn-primary">Install Finance pack</a>
        <a href="/contact" class="btn btn-ghost">Talk to a consultant</a>
      </div>
    </div>
  </section>

  <!-- METRICS — hairline grid ──────────────────────────────────────── -->
  <section class="metrics-section">
    <div class="container">
      <div class="metrics" role="list">
        {stats.map((s) => (
          <div class="metric" role="listitem">
            <span class="metric-value">{s.value}</span>
            <span class="metric-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="block">
    <div class="container">
      <header class="block-head">
        <p class="eyebrow">Included apps</p>
        <h2 class="h2">Four Apps for the finance cycle.</h2>
      </header>

      <div class="apps">
        {apps.map((app) => (
          <article class="app">
            <div class="app-head">
              <span class="app-num">{app.n}</span>
              <h3 class="app-title">{app.name}</h3>
            </div>
            <p class="app-desc">{app.description}</p>
            <dl class="app-meta">
              <div>
                <dt>Inputs</dt>
                <dd>{app.inputs.join(' · ')}</dd>
              </div>
              <div>
                <dt>Outputs</dt>
                <dd>{app.outputs.join(' · ')}</dd>
              </div>
              <div>
                <dt>Skills</dt>
                <dd class="mono">{app.skills.join(' · ')}</dd>
              </div>
              <div>
                <dt>Connects</dt>
                <dd class="mono accent">{app.connects.join(' · ')}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ──────────────────────────────────────────────────────────── -->
  <section class="block">
    <div class="container">
      <header class="block-head">
        <p class="eyebrow">Why finance leaders pick Aitroop</p>
        <h2 class="h2">Built for auditable, repeatable work.</h2>
      </header>
      <div class="why">
        {why.map((w, i) => (
          <article class="why-item">
            <span class="why-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="why-title">{w.title}</h3>
            <p class="why-desc">{w.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="cta">
    <div class="container container-narrow">
      <h2 class="cta-h2">Start with the Finance pack.</h2>
      <p class="lede">Free to install. Connect your accounting system and run the first close-cycle App in a single session.</p>
      <div class="actions actions-center">
        <a href="https://app.aitroop.net" class="btn btn-primary">Install Finance pack</a>
        <a href="/use-cases/gtm" class="btn btn-ghost">See GTM pack</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ layout primitives ════ */
  .container {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 768px) {
    .container { padding: 0 2.5rem; }
  }
  .container-narrow {
    max-width: 36rem;
    text-align: center;
  }
  .block {
    padding: 6rem 0;
    border-top: 1px solid var(--aw-color-border);
  }
  @media (min-width: 768px) {
    .block { padding: 8rem 0; }
  }
  .block-head { margin-bottom: 4rem; }
  @media (min-width: 768px) {
    .block-head { margin-bottom: 5rem; }
  }

  /* ════ shared type ════ */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--aw-color-primary);
    margin: 0 0 1.125rem;
    line-height: 1;
  }
  .eyebrow::before {
    content: '';
    width: 1.25rem;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }
  .display {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--aw-color-text-heading);
    margin: 0 0 1.5rem;
    text-wrap: balance;
    max-width: 18ch;
  }
  .h2 {
    font-size: clamp(1.875rem, 3.4vw, 2.375rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--aw-color-text-heading);
    margin: 0;
    text-wrap: balance;
    max-width: 28ch;
  }
  .lede {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    max-width: 48ch;
    margin: 0 0 2rem;
    text-wrap: pretty;
  }
  .container-narrow .lede { margin: 0 auto 2rem; }
  .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
  .accent { color: var(--aw-color-primary); }

  /* ════ crumbs ════ */
  .crumbs {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    margin: 0 0 2rem;
  }
  .crumbs a {
    color: var(--aw-color-text-muted);
    text-decoration: underline;
    text-decoration-color: var(--aw-color-border);
    text-underline-offset: 3px;
    transition: color 160ms ease;
  }
  .crumbs a:hover { color: var(--aw-color-primary); }
  .crumbs span[aria-hidden] { opacity: 0.5; }

  /* ════ actions ════ */
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .actions-center { justify-content: center; }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    padding: 0 1.375rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    line-height: 1;
    white-space: nowrap;
    transition: background-color 160ms ease, border-color 160ms ease, color 160ms ease;
  }
  .btn-primary {
    background: var(--aw-color-primary);
    color: #fff;
    box-shadow:
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 1px 2px rgba(15, 30, 18, 0.06);
  }
  .btn-primary:hover { background: rgb(67, 138, 84); }
  .btn-ghost {
    color: var(--aw-color-text-default);
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
  }
  .btn-ghost:hover {
    border-color: rgba(0, 0, 0, 0.25);
    background: rgba(0, 0, 0, 0.02);
  }

  /* ════ hero ════ */
  .hero {
    padding: 6rem 0 5rem;
  }
  @media (min-width: 768px) {
    .hero { padding: 8rem 0 6rem; }
  }

  /* ════ metrics — hairline grid ════ */
  .metrics-section {
    padding: 0 0 6rem;
  }
  @media (min-width: 768px) {
    .metrics-section { padding: 0 0 8rem; }
  }
  .metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--aw-color-border);
    border: 1px solid var(--aw-color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .metrics { grid-template-columns: repeat(4, 1fr); }
  }
  .metric {
    background: var(--aw-color-bg-page);
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .metric-value {
    font-size: clamp(1.625rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--aw-color-text-heading);
  }
  .metric-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--aw-color-text-muted);
    line-height: 1.3;
  }

  /* ════ apps list ════ */
  .apps {
    display: grid;
    gap: 0;
  }
  .app {
    border-top: 1px solid var(--aw-color-text-heading);
    padding: 2rem 0 2.5rem;
  }
  .app:last-child {
    border-bottom: 1px solid var(--aw-color-border);
  }
  @media (min-width: 768px) {
    .app {
      display: grid;
      grid-template-columns: 18rem 1fr;
      gap: 3rem;
      padding: 2.5rem 0 3rem;
    }
  }
  .app-head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .app-num {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }
  .app-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    margin: 1rem 0 1.5rem;
  }
  @media (min-width: 768px) {
    .app-desc { margin: 0 0 1.5rem; }
  }
  .app-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }
  @media (min-width: 640px) {
    .app-meta { grid-template-columns: repeat(2, 1fr); gap: 1rem 2rem; }
  }
  .app-meta dt {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--aw-color-text-muted);
    margin: 0 0 0.25rem;
    line-height: 1;
  }
  .app-meta dd {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--aw-color-text-default);
  }

  /* ════ why grid ════ */
  .why {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .why { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }
  .why-item {
    border-top: 1px solid var(--aw-color-text-heading);
    padding-top: 1.25rem;
  }
  .why-num {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    letter-spacing: 0.06em;
    margin-bottom: 0.875rem;
    font-variant-numeric: tabular-nums;
  }
  .why-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.5rem;
    letter-spacing: -0.005em;
  }
  .why-desc {
    margin: 0;
    color: var(--aw-color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* ════ cta ════ */
  .cta {
    padding: 6rem 0;
    border-top: 1px solid var(--aw-color-border);
  }
  @media (min-width: 768px) {
    .cta { padding: 8rem 0; }
  }
  .cta-h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--aw-color-text-heading);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
</style>
