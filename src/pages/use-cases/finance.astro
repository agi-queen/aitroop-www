---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Finance — Use Cases — Aitroop',
};

const apps = [
  {
    icon: 'tabler:calendar-check',
    name: 'Month-end checklist',
    description: 'Run the entire close in order: GL reconciliation, accrual entries, intercompany matching, and sign-off. Each step produces an audit trail.',
    inputs: ['Closing period', 'Entity scope', 'Owner assignments'],
    outputs: ['Close checklist (markdown)', 'Reconciliation report (csv)'],
    skills: ['gl-reconcile', 'accrual-calc', 'intercompany-match'],
    connects: ['quickbooks', 'xero', 'netsuite'],
  },
  {
    icon: 'tabler:receipt-tax',
    name: 'AR aging report',
    description: 'Bucket receivables by age, flag at-risk balances, and draft customized dunning messages to overdue customers — automatically.',
    inputs: ['As-of date', 'Aging buckets', 'Risk threshold'],
    outputs: ['Aging report (csv)', 'Dunning email drafts (markdown)'],
    skills: ['ar-bucket', 'risk-score', 'email-writer'],
    connects: ['quickbooks', 'stripe', 'gmail'],
  },
  {
    icon: 'tabler:scan-eye',
    name: 'Expense audit',
    description: 'Scan expense reports for policy violations, duplicate submissions, and anomalies. Surfaces exceptions for human review with reasoning.',
    inputs: ['Reporting period', 'Policy document', 'Threshold rules'],
    outputs: ['Exception list (csv)', 'Audit summary (markdown)'],
    skills: ['expense-classify', 'policy-match', 'anomaly-detect'],
    connects: ['expensify', 'concur', 'google-drive'],
  },
  {
    icon: 'tabler:chart-arcs',
    name: 'Variance analysis',
    description: 'Compare actuals to budget, identify the top drivers behind each variance, and generate a narrative explanation suitable for board decks.',
    inputs: ['Period', 'Department filter', 'Variance threshold'],
    outputs: ['Variance breakdown (csv)', 'Executive narrative (markdown)'],
    skills: ['variance-calc', 'driver-attribute', 'narrative-writer'],
    connects: ['netsuite', 'quickbooks', 'sheets'],
  },
];
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="border-b border-[var(--aw-color-border)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <nav class="text-[0.75rem] font-mono text-[var(--aw-color-text-muted)] mb-6">
        <a href="/use-cases" class="hover:text-[var(--aw-color-text-default)] transition-colors">Use Cases</a>
        <span class="mx-2 opacity-50">/</span>
        <span class="text-[var(--aw-color-text-default)]">Finance</span>
      </nav>

      <p class="section-label">FINANCE TEAMS · CFO</p>
      <h1 class="text-[2.25rem] md:text-[3.25rem] font-black tracking-[-0.03em] leading-[1.05] text-[var(--aw-color-text-heading)] mb-5 max-w-[820px]">
        Close the books<br/>faster than ever.
      </h1>
      <p class="text-[1rem] md:text-[1.0625rem] text-[var(--aw-color-text-muted)] leading-[1.7] max-w-[640px] mb-8">
        Four pre-built Apps cover the month-end and operational finance workflows your team runs every cycle.
        Spend less time on spreadsheets — more time on the analysis that drives decisions.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          Install Finance pack
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/contact"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
          Talk to a consultant
        </a>
      </div>
    </div>
  </section>

  <!-- KEY METRICS -->
  <section class="border-b border-[var(--aw-color-border)] py-12 md:py-14">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10">
        <div>
          <p class="text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] mb-1">↓ 60%</p>
          <p class="text-[0.75rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)]">Close cycle time</p>
        </div>
        <div>
          <p class="text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] mb-1">100%</p>
          <p class="text-[0.75rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)]">Audit trail coverage</p>
        </div>
        <div>
          <p class="text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] mb-1">7</p>
          <p class="text-[0.75rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)]">Artifact formats</p>
        </div>
        <div>
          <p class="text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] mb-1">∞</p>
          <p class="text-[0.75rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)]">Reruns, same shape</p>
        </div>
      </div>
    </div>
  </section>

  <!-- APPS -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-12">
        <p class="section-label">INCLUDED APPS</p>
        <h2 class="text-[1.75rem] md:text-[2rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)]">Four Apps for the finance cycle.</h2>
      </div>

      <div class="space-y-4">
        {apps.map((app) => (
          <div class="group p-6 md:p-8 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] hover:border-primary/25 transition-colors">
            <div class="grid md:grid-cols-[1fr_320px] gap-6 md:gap-10">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/[0.08] flex items-center justify-center text-primary">
                    <Icon name={app.icon} class="w-5 h-5" />
                  </div>
                  <h3 class="text-[1.25rem] font-semibold text-[var(--aw-color-text-heading)]">{app.name}</h3>
                </div>
                <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-5">{app.description}</p>

                <div class="flex flex-wrap gap-x-6 gap-y-3 text-[0.8125rem]">
                  <div>
                    <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-1">Skills</span>
                    <div class="flex flex-wrap gap-1.5">
                      {app.skills.map((s) => (
                        <span class="font-mono text-[0.6875rem] px-2 py-0.5 rounded-md bg-[var(--aw-color-bg-subtle)] text-[var(--aw-color-text-default)]">{s}</span>
                      ))}
                    </div>
                  </div>
                  <div>
                    <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-1">Connects</span>
                    <div class="flex flex-wrap gap-1.5">
                      {app.connects.map((c) => (
                        <span class="font-mono text-[0.6875rem] px-2 py-0.5 rounded-md bg-primary/[0.08] text-primary">{c}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <div class="md:border-l md:border-[var(--aw-color-border)] md:pl-8">
                <div class="mb-4">
                  <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-2">Inputs</span>
                  <ul class="space-y-1">
                    {app.inputs.map((i) => (
                      <li class="text-[0.8125rem] text-[var(--aw-color-text-default)] flex items-center gap-2">
                        <span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>
                        {i}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-2">Outputs</span>
                  <ul class="space-y-1">
                    {app.outputs.map((o) => (
                      <li class="text-[0.8125rem] text-[var(--aw-color-text-default)] flex items-center gap-2">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-primary/70 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                        {o}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY FINANCE -->
  <section class="bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)] py-16 md:py-24">
    <div class="mx-auto max-w-5xl px-6 md:px-10">
      <p class="section-label">WHY FINANCE LEADERS PICK AITROOP</p>
      <div class="grid md:grid-cols-3 gap-8 mt-6">
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">Auditable by default</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">Every App run produces structured artifacts with full execution logs. Reproducible, comparable, defensible — even six months later.</p>
        </div>
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">Your data stays yours</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">Each user runs in an isolated sandbox. OAuth scopes limit what agents see. No model training on your numbers.</p>
        </div>
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">Same shape, every cycle</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">An App produces the same structured output every time. Predictable for downstream consumers, auditable for your board.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-3xl px-6 md:px-10 text-center">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold tracking-[-0.025em] leading-[1.15] text-[var(--aw-color-text-heading)] mb-4">
        Start with the Finance pack.
      </h2>
      <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-7">
        Free to install. Connect your accounting system and run the first close-cycle App in a single session.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          Install Finance pack
        </a>
        <a href="/use-cases/gtm"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] transition-all">
          See GTM pack →
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-label {
    font-size: 0.6875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.875rem;
  }
</style>
