---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Finance · Use Cases · Aitroop',
};

const apps = [
  {
    tag: 'Close cycle',
    name: 'Month-end checklist',
    description: 'Run the entire close in order: GL reconciliation, accrual entries, intercompany matching, and sign-off. Each step produces an audit trail.',
    inputs: ['Closing period', 'Entity scope', 'Owner assignments'],
    outputs: ['Close checklist (Markdown)', 'Reconciliation report (CSV)'],
    skills: ['gl-reconcile', 'accrual-calc', 'intercompany-match'],
    connects: ['quickbooks', 'xero', 'netsuite'],
  },
  {
    tag: 'Receivables',
    name: 'AR aging report',
    description: 'Bucket receivables by age, flag at-risk balances, and draft customized dunning messages to overdue customers automatically.',
    inputs: ['As-of date', 'Aging buckets', 'Risk threshold'],
    outputs: ['Aging report (CSV)', 'Dunning email drafts (Markdown)'],
    skills: ['ar-bucket', 'risk-score', 'email-writer'],
    connects: ['quickbooks', 'stripe', 'gmail'],
  },
  {
    tag: 'Controls',
    name: 'Expense audit',
    description: 'Scan expense reports for policy violations, duplicate submissions, and anomalies. Surfaces exceptions for human review with reasoning.',
    inputs: ['Reporting period', 'Policy document', 'Threshold rules'],
    outputs: ['Exception list (CSV)', 'Audit summary (Markdown)'],
    skills: ['expense-classify', 'policy-match', 'anomaly-detect'],
    connects: ['expensify', 'concur', 'google-drive'],
  },
  {
    tag: 'FP&A',
    name: 'Variance analysis',
    description: 'Compare actuals to budget, identify the top drivers behind each variance, and generate a narrative explanation suitable for board decks.',
    inputs: ['Period', 'Department filter', 'Variance threshold'],
    outputs: ['Variance breakdown (CSV)', 'Executive narrative (Markdown)'],
    skills: ['variance-calc', 'driver-attribute', 'narrative-writer'],
    connects: ['netsuite', 'quickbooks', 'sheets'],
  },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head aw-page-head-banner">
    <div class="aw-container">
      <nav class="aw-crumbs">
        <a href="/use-cases">Use cases</a>
        <span aria-hidden="true">/</span>
        <span>Finance</span>
      </nav>
      <h1 class="aw-h2">Close the books faster.</h1>
      <p class="aw-page-head-desc">
        Four pre-built Apps cover the month-end and operational finance workflows your team runs every cycle. Less spreadsheet wrangling, more time on the analysis.
      </p>
      <div class="aw-actions">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Install Finance pack</a>
        <a href="/contact" class="aw-btn aw-btn-ghost">Talk to a consultant</a>
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <h2 class="aw-h2">Four Apps for the finance cycle.</h2>
      </header>

      <div class="apps">
        {apps.map((app) => (
          <article class="app">
            <div class="app-head">
              <span class="app-tag">{app.tag}</span>
              <h3 class="app-title">{app.name}</h3>
            </div>
            <div class="app-body">
              <p class="app-desc">{app.description}</p>
              <dl class="app-meta">
                <div>
                  <dt>Inputs</dt>
                  <dd>{app.inputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Outputs</dt>
                  <dd>{app.outputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Skills</dt>
                  <dd class="mono">{app.skills.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Connects</dt>
                  <dd class="mono accent">{app.connects.join(' · ')}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>

      <a href="/use-cases/gtm" class="next-pack">
        <span class="next-pack-label">Next pack</span>
        <span class="next-pack-body">
          <span class="next-pack-name">GTM</span>
          <span class="next-pack-tagline">Pipeline that runs itself.</span>
        </span>
        <span class="aw-arrow next-pack-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

</Layout>

<style>
  /* ════ apps — hairline separated rows ════ */
  .apps {
    display: grid;
    gap: 0;
  }
  .app {
    border-top: 1px solid var(--aw-color-border-strong);
    padding: 2rem 0 2.5rem;
  }
  @media (min-width: 768px) {
    .app {
      display: grid;
      grid-template-columns: 16rem 1fr;
      gap: 3rem;
      padding: 2.25rem 0 2.75rem;
    }
  }
  .app-head {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .app-tag {
    align-self: flex-start;
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1;
  }
  .app-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 1rem 0 1.5rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .app-desc { margin: 0 0 1.5rem; }
  }
  .app-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .app-meta { grid-template-columns: repeat(2, 1fr); gap: 1.125rem 2rem; }
  }
  .app-meta dt {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
    margin: 0 0 0.3125rem;
    line-height: 1;
    font-weight: 600;
  }
  .app-meta dd {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
  }
  .mono { font-family: var(--aw-font-mono, ui-monospace, monospace); }
  .accent { color: var(--aw-color-primary); }

  /* ════ next pack — single hairline row, replaces bottom CTA ════ */
  .next-pack {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
    padding: 2rem 0;
    border-top: 1px solid var(--aw-color-border-strong);
    border-bottom: 1px solid var(--aw-color-border);
    color: var(--aw-color-text-heading);
    text-decoration: none;
  }
  @media (min-width: 768px) {
    .next-pack {
      grid-template-columns: 16rem 1fr auto;
      gap: 3rem;
      padding: 2.25rem 0;
    }
  }
  .next-pack-label {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--aw-color-text-muted);
    line-height: 1;
  }
  .next-pack-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .next-pack-name {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--aw-color-text-heading);
    line-height: 1.1;
  }
  .next-pack-tagline {
    font-size: 0.875rem;
    color: var(--aw-color-text-muted);
    line-height: 1.4;
  }
  .next-pack-arrow {
    color: var(--aw-color-primary);
    font-size: 1.125rem;
    transition: transform 0.18s ease;
  }
  .next-pack:hover .next-pack-arrow { transform: translateX(4px); }
  .next-pack:hover .next-pack-name { text-decoration: underline; }
</style>
