---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Finance · Use Cases · Aitroop',
};

const stats = [
  { value: '4',   label: 'Apps in the pack' },
  { value: '100%', label: 'Audit trail coverage' },
  { value: '7',    label: 'Artifact formats' },
  { value: 'cron', label: 'Reruns, same shape' },
];

const apps = [
  {
    tag: 'Close cycle',
    name: 'Month-end checklist',
    description: 'Run the entire close in order: GL reconciliation, accrual entries, intercompany matching, and sign-off. Each step produces an audit trail.',
    inputs: ['Closing period', 'Entity scope', 'Owner assignments'],
    outputs: ['Close checklist (Markdown)', 'Reconciliation report (CSV)'],
    skills: ['gl-reconcile', 'accrual-calc', 'intercompany-match'],
    connects: ['quickbooks', 'xero', 'netsuite'],
  },
  {
    tag: 'Receivables',
    name: 'AR aging report',
    description: 'Bucket receivables by age, flag at-risk balances, and draft customized dunning messages to overdue customers automatically.',
    inputs: ['As-of date', 'Aging buckets', 'Risk threshold'],
    outputs: ['Aging report (CSV)', 'Dunning email drafts (Markdown)'],
    skills: ['ar-bucket', 'risk-score', 'email-writer'],
    connects: ['quickbooks', 'stripe', 'gmail'],
  },
  {
    tag: 'Controls',
    name: 'Expense audit',
    description: 'Scan expense reports for policy violations, duplicate submissions, and anomalies. Surfaces exceptions for human review with reasoning.',
    inputs: ['Reporting period', 'Policy document', 'Threshold rules'],
    outputs: ['Exception list (CSV)', 'Audit summary (Markdown)'],
    skills: ['expense-classify', 'policy-match', 'anomaly-detect'],
    connects: ['expensify', 'concur', 'google-drive'],
  },
  {
    tag: 'FP&A',
    name: 'Variance analysis',
    description: 'Compare actuals to budget, identify the top drivers behind each variance, and generate a narrative explanation suitable for board decks.',
    inputs: ['Period', 'Department filter', 'Variance threshold'],
    outputs: ['Variance breakdown (CSV)', 'Executive narrative (Markdown)'],
    skills: ['variance-calc', 'driver-attribute', 'narrative-writer'],
    connects: ['netsuite', 'quickbooks', 'sheets'],
  },
];

const why = [
  { title: 'Auditable by default', desc: 'Every App run produces structured artifacts with full execution logs. Reproducible, comparable, defensible.' },
  { title: 'Your data stays yours', desc: 'Each user runs in an isolated sandbox. OAuth scopes limit what agents see. No model training on your numbers.' },
  { title: 'Same shape every cycle', desc: 'An App produces the same structured output every time. Predictable for downstream consumers, auditable for your board.' },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <nav class="aw-crumbs">
        <a href="/use-cases">Use cases</a>
        <span aria-hidden="true">/</span>
        <span>Finance</span>
      </nav>
      <p class="aw-eyebrow">Finance teams · CFO</p>
      <h1 class="aw-display" style="max-width: 18ch;">Close the books faster.</h1>
      <p class="aw-lede" style="max-width: 52ch;">
        Four pre-built Apps cover the month-end and operational finance workflows your team runs every cycle. Less spreadsheet wrangling, more time on the analysis.
      </p>
      <div class="aw-actions">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Install Finance pack</a>
        <a href="/contact" class="aw-btn aw-btn-ghost">Talk to a consultant</a>
      </div>
    </div>
  </section>

  <!-- METRICS — hairline grid ──────────────────────────────────────── -->
  <section class="metrics-section">
    <div class="aw-container">
      <div class="metrics" role="list">
        {stats.map((s) => (
          <div class="metric" role="listitem">
            <span class="metric-value">{s.value}</span>
            <span class="metric-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">Included apps</p>
        <h2 class="aw-h2">Four Apps for the finance cycle.</h2>
      </header>

      <div class="apps">
        {apps.map((app) => (
          <article class="app">
            <div class="app-head">
              <span class="app-tag">{app.tag}</span>
              <h3 class="app-title">{app.name}</h3>
            </div>
            <div class="app-body">
              <p class="app-desc">{app.description}</p>
              <dl class="app-meta">
                <div>
                  <dt>Inputs</dt>
                  <dd>{app.inputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Outputs</dt>
                  <dd>{app.outputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Skills</dt>
                  <dd class="mono">{app.skills.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Connects</dt>
                  <dd class="mono accent">{app.connects.join(' · ')}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <h2 class="aw-h2">Built for auditable, repeatable work.</h2>
      </header>
      <div class="why">
        {why.map((w) => (
          <article class="aw-piece">
            <h3 class="aw-piece-title">{w.title}</h3>
            <p class="aw-piece-desc">{w.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2" style="max-width: 18ch; margin: 0 auto 1rem;">Start with the Finance pack.</h2>
      <p class="aw-lede">Free to install. Connect your accounting system and run the first close-cycle App in a single session.</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Open the app</a>
        <a href="/use-cases/gtm" class="aw-btn aw-btn-ghost">See GTM pack</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ metrics — first content after hero, no top border ════ */
  .metrics-section {
    padding: 0 0 5rem;
  }
  @media (min-width: 768px) {
    .metrics-section { padding: 0 0 7rem; }
  }
  .metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--aw-color-border);
    border: 1px solid var(--aw-color-border);
    border-radius: 10px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .metrics { grid-template-columns: repeat(4, 1fr); }
  }
  .metric {
    background: var(--aw-color-bg-page);
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .metric-value {
    font-size: clamp(1.625rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--aw-color-text-heading);
    font-variant-numeric: tabular-nums;
  }
  .metric-label {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--aw-color-text-muted);
    line-height: 1.3;
  }

  /* ════ apps — hairline separated rows ════ */
  .apps {
    display: grid;
    gap: 0;
  }
  .app {
    border-top: 1px solid var(--aw-color-border-strong);
    padding: 2rem 0 2.5rem;
  }
  .app:last-child { border-bottom: 1px solid var(--aw-color-border); }
  @media (min-width: 768px) {
    .app {
      display: grid;
      grid-template-columns: 16rem 1fr;
      gap: 3rem;
      padding: 2.25rem 0 2.75rem;
    }
  }
  .app-head {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .app-tag {
    align-self: flex-start;
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1;
  }
  .app-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 1rem 0 1.5rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .app-desc { margin: 0 0 1.5rem; }
  }
  .app-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .app-meta { grid-template-columns: repeat(2, 1fr); gap: 1.125rem 2rem; }
  }
  .app-meta dt {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
    margin: 0 0 0.3125rem;
    line-height: 1;
    font-weight: 600;
  }
  .app-meta dd {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
  }
  .mono { font-family: var(--aw-font-mono, ui-monospace, monospace); }
  .accent { color: var(--aw-color-primary); }

  /* ════ why grid ════ */
  .why {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .why { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }
</style>
