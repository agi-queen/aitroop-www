---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'GTM — Use Cases — Aitroop',
};

const apps = [
  {
    n: '01',
    name: 'Prospecting',
    description: 'Find high-fit accounts using company signals, hiring activity, tech stack, and intent data — scored against your ICP.',
    inputs: ['ICP description', 'Industry filter', 'Company size', 'Tech keywords'],
    outputs: ['Enriched lead list (CSV)', 'ICP scoring rationale (Markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    n: '02',
    name: 'Outreach',
    description: 'Generate personalized cold emails and LinkedIn messages. Combines firmographic context, recent triggers, and your voice.',
    inputs: ['Target list', 'Email template', 'Sender persona', 'Tone'],
    outputs: ['Email drafts (Markdown)', 'A/B variants (JSON)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    n: '03',
    name: 'Retention',
    description: 'Monitor account health scores. Flag at-risk customers before churn materializes — usage drop-offs, support patterns, exec changes.',
    inputs: ['Account list', 'Risk threshold', 'Lookback window'],
    outputs: ['Risk report (Markdown)', 'Account scores (CSV)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    n: '04',
    name: 'Pipeline insights',
    description: 'Synthesize pipeline data into clear recommendations. Know which deals to push, which to deprioritize, and where to invest your time.',
    inputs: ['Sales stage filter', 'Time window', 'Owner filter'],
    outputs: ['Pipeline narrative (Markdown)', 'Deal scoring (CSV)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];

const why = [
  { title: 'Compounding output', desc: 'Every chat that worked becomes a reusable App. Team know-how compounds week over week.' },
  { title: 'Native CRM integration', desc: 'Read and write Salesforce, HubSpot, your data warehouse — through OAuth, not Zapier.' },
  { title: 'Schedule it once', desc: 'Daily pipeline summaries, weekly outreach lists, monthly retention reports. Set the cron and forget it.' },
];
---

<Layout metadata={metadata}>

  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <section class="aw-hero">
    <div class="aw-container">
      <nav class="aw-crumbs">
        <a href="/use-cases">Use cases</a>
        <span aria-hidden="true">/</span>
        <span>GTM</span>
      </nav>
      <p class="aw-eyebrow">B2B Growth</p>
      <h1 class="aw-display" style="max-width: 18ch;">Pipeline that runs itself.</h1>
      <p class="aw-lede" style="max-width: 52ch;">
        Four pre-built Apps cover the GTM motion end-to-end — from finding leads through retaining customers. Each ships with the skills and integrations it needs.
      </p>
      <div class="aw-actions">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Install GTM pack</a>
        <a href="/contact" class="aw-btn aw-btn-ghost">Book demo</a>
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">Included apps</p>
        <h2 class="aw-h2">Four Apps. One revenue motion.</h2>
      </header>

      <div class="apps">
        {apps.map((app) => (
          <article class="app">
            <div class="app-head">
              <span class="app-num">{app.n}</span>
              <h3 class="app-title">{app.name}</h3>
            </div>
            <div class="app-body">
              <p class="app-desc">{app.description}</p>
              <dl class="app-meta">
                <div>
                  <dt>Inputs</dt>
                  <dd>{app.inputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Outputs</dt>
                  <dd>{app.outputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Skills</dt>
                  <dd class="mono">{app.skills.join(' · ')}</dd>
                </div>
                <div>
                  <dt>Connects</dt>
                  <dd class="mono accent">{app.connects.join(' · ')}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">Why GTM teams pick Aitroop</p>
        <h2 class="aw-h2">Built for compounding pipeline work.</h2>
      </header>
      <div class="why">
        {why.map((w, i) => (
          <article class="aw-piece">
            <span class="aw-piece-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="aw-piece-title">{w.title}</h3>
            <p class="aw-piece-desc">{w.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2" style="max-width: 18ch; margin: 0 auto 1rem;">Start with the GTM pack today.</h2>
      <p class="aw-lede">Free to install. Connect your CRM and run the first App in under 10 minutes.</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Install GTM pack</a>
        <a href="/use-cases/finance" class="aw-btn aw-btn-ghost">See Finance pack</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ apps — hairline separated rows ════ */
  .apps {
    display: grid;
    gap: 0;
  }
  .app {
    border-top: 1px solid var(--aw-color-border-strong);
    padding: 2rem 0 2.5rem;
  }
  .app:last-child { border-bottom: 1px solid var(--aw-color-border); }
  @media (min-width: 768px) {
    .app {
      display: grid;
      grid-template-columns: 16rem 1fr;
      gap: 3rem;
      padding: 2.25rem 0 2.75rem;
    }
  }
  .app-head {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .app-num {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .app-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 1rem 0 1.5rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .app-desc { margin: 0 0 1.5rem; }
  }
  .app-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .app-meta { grid-template-columns: repeat(2, 1fr); gap: 1.125rem 2rem; }
  }
  .app-meta dt {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
    margin: 0 0 0.3125rem;
    line-height: 1;
    font-weight: 600;
  }
  .app-meta dd {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
  }
  .mono { font-family: var(--aw-font-mono, ui-monospace, monospace); }
  .accent { color: var(--aw-color-primary); }

  /* ════ why grid ════ */
  .why {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .why { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }
</style>
