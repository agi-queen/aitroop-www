---
import Layout from '~/layouts/PageLayout.astro';
import UseCasePack from '~/components/widgets/UseCasePack.astro';

const metadata = { title: 'GTM · Use Cases · Aitroop' };

const apps = [
  {
    tag: 'Top of funnel',
    name: 'Prospecting',
    description: 'Find high-fit accounts using company signals, hiring activity, tech stack, and intent data, scored against your ICP.',
    inputs: ['ICP description', 'Industry filter', 'Company size', 'Tech keywords'],
    outputs: ['Enriched lead list (CSV)', 'ICP scoring rationale (Markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    tag: 'Engagement',
    name: 'Outreach',
    description: 'Generate personalized cold emails and LinkedIn messages. Combines firmographic context, recent triggers, and your voice.',
    inputs: ['Target list', 'Email template', 'Sender persona', 'Tone'],
    outputs: ['Email drafts (Markdown)', 'A/B variants (JSON)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    tag: 'Customer success',
    name: 'Retention',
    description: 'Monitor account health scores. Flag at-risk customers before churn materializes: usage drop-offs, support patterns, exec changes.',
    inputs: ['Account list', 'Risk threshold', 'Lookback window'],
    outputs: ['Risk report (Markdown)', 'Account scores (CSV)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    tag: 'RevOps',
    name: 'Pipeline insights',
    description: 'Synthesize pipeline data into clear recommendations. Know which deals to push, which to deprioritize, and where to invest your time.',
    inputs: ['Sales stage filter', 'Time window', 'Owner filter'],
    outputs: ['Pipeline narrative (Markdown)', 'Deal scoring (CSV)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];
---

<Layout metadata={metadata}>
  <UseCasePack
    crumb="GTM"
    h1="Pipeline that runs itself."
    lede="Four pre-built Apps cover the GTM motion end-to-end, from finding leads through retaining customers. Each ships with the skills and integrations it needs."
    primaryCta={{ label: 'Install GTM pack', href: 'https://app.aitroop.net' }}
    secondaryCta={{ label: 'Book demo', href: '/contact' }}
    apps={apps}
    next={{ href: '/use-cases/finance', name: 'Finance', tagline: 'Close the books faster.' }}
    labels={{ appsHeading: 'Four Apps. One revenue motion.' }}
  />
</Layout>
