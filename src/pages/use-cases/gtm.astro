---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'GTM — Use Cases — Aitroop',
};

const apps = [
  {
    icon: 'tabler:radar-2',
    name: 'Prospecting',
    description: 'Find high-fit accounts using company signals, hiring activity, tech stack, and intent data — scored against your ICP.',
    inputs: ['ICP description', 'Industry filter', 'Company size', 'Tech keywords'],
    outputs: ['Enriched lead list (CSV)', 'ICP scoring rationale (markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    icon: 'tabler:mail-forward',
    name: 'Outreach',
    description: 'Generate personalized cold emails and LinkedIn messages. Combines firmographic context, recent triggers, and your voice.',
    inputs: ['Target list', 'Email template', 'Sender persona', 'Tone'],
    outputs: ['Email drafts (markdown)', 'A/B variants (json)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    icon: 'tabler:shield-check',
    name: 'Retention',
    description: 'Monitor account health scores. Flag at-risk customers before churn materializes — usage drop-offs, support patterns, exec changes.',
    inputs: ['Account list', 'Risk threshold', 'Lookback window'],
    outputs: ['Risk report (markdown)', 'Account scores (csv)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    icon: 'tabler:chart-line',
    name: 'Pipeline insights',
    description: 'Synthesize pipeline data into clear recommendations. Know which deals to push, which to deprioritize, and where to invest your time.',
    inputs: ['Sales stage filter', 'Time window', 'Owner filter'],
    outputs: ['Pipeline narrative (markdown)', 'Deal scoring (csv)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];
---

<Layout metadata={metadata}>
  <!-- HERO -->
  <section class="border-b border-[var(--aw-color-border)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <nav class="text-[0.75rem] font-mono text-[var(--aw-color-text-muted)] mb-6">
        <a href="/use-cases" class="hover:text-[var(--aw-color-text-default)] transition-colors">Use Cases</a>
        <span class="mx-2 opacity-50">/</span>
        <span class="text-[var(--aw-color-text-default)]">GTM</span>
      </nav>

      <p class="section-label">B2B GROWTH</p>
      <h1 class="text-[2.25rem] md:text-[3.25rem] font-black tracking-[-0.03em] leading-[1.05] text-[var(--aw-color-text-heading)] mb-5 max-w-[820px]">
        Pipeline that runs itself.
      </h1>
      <p class="text-[1rem] md:text-[1.0625rem] text-[var(--aw-color-text-muted)] leading-[1.7] max-w-[640px] mb-8">
        Four pre-built Apps cover the GTM motion end-to-end — from finding leads through retaining customers.
        Each one ships with the skills and integrations it needs, ready to run on day one.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          Install GTM pack
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/contact"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
          Book demo
        </a>
      </div>
    </div>
  </section>

  <!-- APPS -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-12">
        <p class="section-label">INCLUDED APPS</p>
        <h2 class="text-[1.75rem] md:text-[2rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)]">Four Apps. One revenue motion.</h2>
      </div>

      <div class="space-y-4">
        {apps.map((app) => (
          <div class="group p-6 md:p-8 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] hover:border-primary/25 transition-colors">
            <div class="grid md:grid-cols-[1fr_320px] gap-6 md:gap-10">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/[0.08] flex items-center justify-center text-primary">
                    <Icon name={app.icon} class="w-5 h-5" />
                  </div>
                  <h3 class="text-[1.25rem] font-semibold text-[var(--aw-color-text-heading)]">{app.name}</h3>
                </div>
                <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-5">{app.description}</p>

                <div class="flex flex-wrap gap-x-6 gap-y-3 text-[0.8125rem]">
                  <div>
                    <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-1">Skills</span>
                    <div class="flex flex-wrap gap-1.5">
                      {app.skills.map((s) => (
                        <span class="font-mono text-[0.6875rem] px-2 py-0.5 rounded-md bg-[var(--aw-color-bg-subtle)] text-[var(--aw-color-text-default)]">{s}</span>
                      ))}
                    </div>
                  </div>
                  <div>
                    <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-1">Connects</span>
                    <div class="flex flex-wrap gap-1.5">
                      {app.connects.map((c) => (
                        <span class="font-mono text-[0.6875rem] px-2 py-0.5 rounded-md bg-primary/[0.08] text-primary">{c}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <div class="md:border-l md:border-[var(--aw-color-border)] md:pl-8">
                <div class="mb-4">
                  <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-2">Inputs</span>
                  <ul class="space-y-1">
                    {app.inputs.map((i) => (
                      <li class="text-[0.8125rem] text-[var(--aw-color-text-default)] flex items-center gap-2">
                        <span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>
                        {i}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-2">Outputs</span>
                  <ul class="space-y-1">
                    {app.outputs.map((o) => (
                      <li class="text-[0.8125rem] text-[var(--aw-color-text-default)] flex items-center gap-2">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-primary/70 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                        {o}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)] py-16 md:py-24">
    <div class="mx-auto max-w-5xl px-6 md:px-10">
      <p class="section-label">WHY GTM TEAMS PICK AITROOP</p>
      <div class="grid md:grid-cols-3 gap-8 mt-6">
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">Compounding output</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">Every chat that worked becomes a reusable App. The team's collective know-how compounds week over week.</p>
        </div>
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">Native CRM integration</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">Read and write Salesforce, HubSpot, and your data warehouse through OAuth — no Zapier, no custom scripts.</p>
        </div>
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">Schedule it once</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">Daily pipeline summaries, weekly outreach lists, monthly retention reports — set the cron and forget it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-3xl px-6 md:px-10 text-center">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold tracking-[-0.025em] leading-[1.15] text-[var(--aw-color-text-heading)] mb-4">
        Start with the GTM pack today.
      </h2>
      <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-7">
        Free to install. Connect your CRM and run the first App in under 10 minutes.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          Install GTM pack
        </a>
        <a href="/use-cases/finance"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] transition-all">
          See finance pack →
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-label {
    font-size: 0.6875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.875rem;
  }
</style>
