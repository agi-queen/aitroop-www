---
import Layout from '~/layouts/PageLayout.astro';
import GridBackground from '~/components/ui/GridBackground.astro';
import Spotlight from '~/components/ui/Spotlight.astro';

const metadata = {
  title: 'GTM · Use Cases · Aitroop',
};

const apps = [
  {
    tag: 'Top of funnel',
    name: 'Prospecting',
    description: 'Find high-fit accounts using company signals, hiring activity, tech stack, and intent data, scored against your ICP.',
    inputs: ['ICP description', 'Industry filter', 'Company size', 'Tech keywords'],
    outputs: ['Enriched lead list (CSV)', 'ICP scoring rationale (Markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    tag: 'Engagement',
    name: 'Outreach',
    description: 'Generate personalized cold emails and LinkedIn messages. Combines firmographic context, recent triggers, and your voice.',
    inputs: ['Target list', 'Email template', 'Sender persona', 'Tone'],
    outputs: ['Email drafts (Markdown)', 'A/B variants (JSON)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    tag: 'Customer success',
    name: 'Retention',
    description: 'Monitor account health scores. Flag at-risk customers before churn materializes: usage drop-offs, support patterns, exec changes.',
    inputs: ['Account list', 'Risk threshold', 'Lookback window'],
    outputs: ['Risk report (Markdown)', 'Account scores (CSV)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    tag: 'RevOps',
    name: 'Pipeline insights',
    description: 'Synthesize pipeline data into clear recommendations. Know which deals to push, which to deprioritize, and where to invest your time.',
    inputs: ['Sales stage filter', 'Time window', 'Owner filter'],
    outputs: ['Pipeline narrative (Markdown)', 'Deal scoring (CSV)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];
---

<Layout metadata={metadata}>

  <Spotlight />

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head usecases-page-head">
    <GridBackground variant="dots" tone="brand" class="usecases-bg" />
    <div class="aw-container">
      <nav class="aw-crumbs">
        <a href="/use-cases">Use cases</a>
        <span aria-hidden="true">/</span>
        <span>GTM</span>
      </nav>
      <p class="aw-eyebrow">0.1.1 · GTM pack</p>
      <h1 class="aw-h1" style="max-width: 22ch;">Pipeline that runs itself.</h1>
      <p class="aw-page-head-desc">
        Four pre-built Apps cover the GTM motion end-to-end, from finding leads through retaining customers. Each ships with the skills and integrations it needs.
      </p>
      <div class="aw-actions">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">Install GTM pack</a>
        <a href="/contact" class="aw-btn aw-btn-ghost">Book demo →</a>
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">0.1.1.* · Apps in this pack</p>
        <h2 class="aw-h2">Four Apps. One revenue motion.</h2>
      </header>

      <div class="apps ds-reveal-stagger">
        {apps.map((app, i) => (
          <article class="app-spec spotlight-card" data-spotlight>
            <header class="app-spec-chrome">
              <span class="app-spec-idx">{`0.1.1.${i + 1}`}</span>
              <span class="app-spec-tag">{app.tag}</span>
              <span class="app-spec-name">apps/{app.name.toLowerCase().replace(/\s+/g, '-')}.app</span>
            </header>

            <div class="app-spec-headline">
              <h3 class="app-spec-title">{app.name}</h3>
              <p class="app-spec-desc">{app.description}</p>
            </div>

            <div class="app-spec-body">
              <div class="app-spec-pane">
                <p class="aw-eyebrow app-spec-pane-eyebrow">Input</p>
                <ul class="app-spec-list" role="list">
                  {app.inputs.map((it) => (
                    <li><span class="app-spec-dot" aria-hidden="true"></span>{it}</li>
                  ))}
                </ul>
              </div>

              <div class="app-spec-pane">
                <p class="aw-eyebrow app-spec-pane-eyebrow">Stage · skills</p>
                <ul class="app-spec-list app-spec-list--mono" role="list">
                  {app.skills.map((s) => (
                    <li><span class="app-spec-dot app-spec-dot--accent" aria-hidden="true"></span>{s}</li>
                  ))}
                </ul>
                <p class="app-spec-connects">
                  <span class="app-spec-connects-label">connects</span>
                  <span class="app-spec-connects-list">{app.connects.join(' · ')}</span>
                </p>
              </div>

              <div class="app-spec-pane">
                <p class="aw-eyebrow app-spec-pane-eyebrow">Artifact</p>
                <ul class="app-spec-list" role="list">
                  {app.outputs.map((o) => (
                    <li><span class="app-spec-dot" aria-hidden="true"></span>{o}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>

      <a href="/use-cases/finance" class="next-pack">
        <span class="next-pack-label">Next pack · 0.1.2</span>
        <span class="next-pack-body">
          <span class="next-pack-name">Finance</span>
          <span class="next-pack-tagline">Close the books faster.</span>
        </span>
        <svg class="next-pack-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

</Layout>

<style>
  /* ════ ambient page-head backdrop ════ */
  .usecases-page-head {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .usecases-page-head :global(.usecases-bg) { z-index: -1; opacity: 0.5; }
  .usecases-page-head :global(.usecases-bg .gridbg__layer) {
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 25% 30%, #000 30%, transparent 80%) !important;
            mask-image: radial-gradient(ellipse 70% 70% at 25% 30%, #000 30%, transparent 80%) !important;
  }
  .usecases-page-head > .aw-container { position: relative; z-index: 1; }

  /* ════ apps — specimen-style cards ════ */
  .apps {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .app-spec {
    background: var(--ds-surface);
    border: 1px solid var(--ds-hairline);
    border-radius: var(--ds-radius-lg);
    overflow: hidden;
    transition: border-color 240ms var(--ds-ease-out),
                box-shadow 260ms var(--ds-ease-out);
  }
  .app-spec:hover {
    border-color: var(--ds-hairline-strong);
    box-shadow: var(--ds-shadow-2);
  }
  .app-spec-chrome {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--ds-hairline);
    background: var(--ds-surface-2);
  }
  .app-spec-idx {
    font-family: var(--ds-font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--ds-text-quiet);
  }
  .app-spec-tag {
    font-family: var(--ds-font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.18rem 0.45rem;
    border-radius: 4px;
    background: var(--ds-accent-tint);
    color: var(--ds-accent);
  }
  .app-spec-name {
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
    color: var(--ds-text-muted);
    margin-left: auto;
  }
  .app-spec-headline {
    padding: 1.25rem 1.25rem 0.5rem;
  }
  .app-spec-title {
    font-family: var(--aw-font-heading);
    font-size: 1.25rem;
    font-weight: 580;
    color: var(--ds-text);
    letter-spacing: -0.018em;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }
  .app-spec-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--ds-text-muted);
    margin: 0;
    max-width: 62ch;
    text-wrap: pretty;
  }

  .app-spec-body {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .app-spec-body { grid-template-columns: repeat(3, 1fr); }
  }
  .app-spec-pane {
    padding: 1.25rem 1.25rem 1.375rem;
    border-top: 1px solid var(--ds-hairline);
  }
  @media (min-width: 900px) {
    .app-spec-pane {
      border-top: 1px solid var(--ds-hairline);
      border-right: 1px solid var(--ds-hairline);
    }
    .app-spec-pane:last-child { border-right: 0; }
  }
  .app-spec-pane-eyebrow {
    margin: 0 0 0.875rem;
  }
  .app-spec-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--ds-text);
  }
  .app-spec-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .app-spec-list--mono { font-family: var(--ds-font-mono); }
  .app-spec-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ds-text-quiet);
    opacity: 0.6;
  }
  .app-spec-dot--accent {
    background: var(--ds-accent);
    opacity: 0.7;
  }
  .app-spec-connects {
    margin: 1rem 0 0;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--ds-hairline);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-family: var(--ds-font-mono);
    font-size: 0.75rem;
  }
  .app-spec-connects-label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ds-text-quiet);
  }
  .app-spec-connects-list { color: var(--ds-accent); }

  /* ════ next pack — hairline row ════ */
  .next-pack {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 2rem 0;
    margin-top: 1rem;
    border-top: 1px solid var(--ds-hairline-strong);
    color: var(--ds-text);
    text-decoration: none;
    transition: color 200ms var(--ds-ease-out);
  }
  @media (min-width: 768px) {
    .next-pack {
      grid-template-columns: 16rem 1fr auto;
      gap: 3rem;
      padding: 2.5rem 0;
    }
  }
  .next-pack-label {
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ds-text-quiet);
    line-height: 1;
  }
  .next-pack-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .next-pack-name {
    font-family: var(--aw-font-heading);
    font-size: 1.375rem;
    font-weight: 580;
    letter-spacing: -0.02em;
    color: var(--ds-text);
    line-height: 1.1;
  }
  .next-pack-tagline {
    font-size: 0.875rem;
    color: var(--ds-text-muted);
    line-height: 1.4;
  }
  .next-pack-arrow {
    color: var(--ds-accent);
    transition: transform 200ms var(--ds-ease-out);
  }
  .next-pack:hover .next-pack-arrow { transform: translateX(4px); }
  .next-pack:hover .next-pack-name { color: var(--ds-accent); }
</style>
