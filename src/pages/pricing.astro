---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Pricing"
    title="Transparent Pricing, Pay for What You Use"
    subtitle="Data enrichment is billed by Credit. AI generation and email sending volume are included in each plan. Annual billing saves 15%, and all plans include a 14-day free trial."
  />

  <!-- Pricing Widget ******************* -->

  <Prices
    title="Choose the Plan That Fits Your Team"
    subtitle="Prices shown are per user per month (annual billing). Monthly billing adds 20%."
    prices={[
      {
        title: 'Starter',
        subtitle: 'Ideal for small SDR or marketing teams of 1–3 people',
        price: 99,
        period: 'per user / per month (annual)',
        items: [
          { description: '500 data enrichment Credits per month (email verification)' },
          { description: '50 phone number lookup Credits per month' },
          { description: '3,000 AI-personalized emails generated per month' },
          { description: 'Up to 10,000 emails sent per month' },
          { description: 'Up to 3 active outreach sequences' },
          { description: 'LinkedIn sequences (200 messages per month)' },
          { description: '1 CRM two-way sync' },
          { description: 'Basic lead scoring' },
          { description: 'Email deliverability monitoring' },
        ],
        callToAction: {
          text: 'Start Free 14-Day Trial',
          href: '/contact',
        },
      },
      {
        title: 'Growth',
        subtitle: 'Built for fast-scaling GTM teams',
        price: 249,
        period: 'per user / per month (annual)',
        items: [
          { description: '2,000 data enrichment Credits per month (email verification)' },
          { description: '300 phone number lookup Credits per month' },
          { description: '20,000 AI-personalized emails generated per month' },
          { description: 'Up to 100,000 emails sent per month' },
          { description: 'Unlimited active outreach sequences' },
          { description: 'LinkedIn sequences (1,000 messages per month)' },
          { description: 'Unlimited CRM two-way sync' },
          { description: 'AI account research assistant (batch, 500 accounts per month)' },
          { description: 'Advanced lead scoring + intent detection' },
          { description: 'Website visitor identification (IP reverse lookup, 1,000 per month)' },
          { description: 'Pipeline health monitoring' },
          { description: 'Multi-touch attribution analysis' },
        ],
        callToAction: {
          text: 'Start Free 14-Day Trial',
          href: '/contact',
        },
        hasRibbon: true,
        ribbonTitle: 'Most Popular',
      },
      {
        title: 'Enterprise',
        subtitle: 'For large sales and marketing organizations',
        price: 499,
        period: 'per user / per month starting (annual)',
        items: [
          { description: 'Custom data enrichment Credit volume (negotiable, no cap)' },
          { description: 'Custom phone lookup Credit volume' },
          { description: 'Custom AI generation quota (including blog posts and proposals)' },
          { description: 'Custom monthly sending volume' },
          { description: 'AI assistants: meeting summaries, CRM auto-fill, Text-to-SQL' },
          { description: 'Customer health scoring + churn early warning' },
          { description: 'AI revenue forecasting model (error < 15%)' },
          { description: 'Custom ICP modeling and ABM account management' },
          { description: 'Private cloud / on-premises deployment (optional)' },
          { description: 'Dedicated customer success manager' },
          { description: 'Service Level Agreement (SLA) guarantee' },
        ],
        callToAction: {
          text: 'Talk to Sales',
          href: '/contact',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="About Credits: Full Transparency"
    subtitle="We use Credits to measure data enrichment consumption because every lookup requires connecting to external data sources, which has a real cost."
    columns={2}
    items={[
      {
        title: '1 Credit = 1 Email Lookup',
        description: 'Querying a data provider for a valid email address consumes 1 Credit. If the query returns no result, no Credit is deducted.',
        icon: 'tabler:mail',
      },
      {
        title: 'Phone Lookups Are Billed Separately',
        description: 'Phone number data costs significantly more than email data, so it has its own quota. Starter includes 50 per month; Growth includes 300 per month.',
        icon: 'tabler:phone',
      },
      {
        title: 'Credits Expire Monthly and Do Not Roll Over',
        description: 'Unused Credits do not carry over to the next month. Annual plan subscribers may draw up to 20% of the following quarter\'s quota in advance. Additional Credits can be purchased as needed.',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'AI Generation Quota Explained',
        description: 'Each AI-personalized email counts as 1 generation. The AI account research agent counts each company research task as 1 Credit, separate from the email generation quota.',
        icon: 'tabler:robot',
      },
      {
        title: 'Monthly Sending Volume Cap',
        description: 'The monthly sending volume refers to emails actually sent through the Aitroop platform. Emails sent through your own SMTP server do not count toward this limit.',
        icon: 'tabler:send',
      },
      {
        title: 'Top-Up Add-Ons',
        description: 'All quotas can be topped up individually — no forced plan upgrades. Email Credit add-on: 100 Credits / $8. Phone Credits: 10 lookups / $12.',
        icon: 'tabler:plus',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="From Trial to Active Use in as Little as 30 Minutes"
    tagline="Quick Start"
    isReversed={true}
    items={[
      {
        title: 'Choose a plan and start your 14-day free trial',
        icon: 'tabler:number-1',
      },
      {
        title: 'Connect your CRM and email account',
        icon: 'tabler:number-2',
      },
      {
        title: 'Import your first batch of target prospects',
        icon: 'tabler:number-3',
      },
      {
        title: 'AI automatically enriches data and generates personalized emails',
        icon: 'tabler:number-4',
      },
      {
        title: 'Launch your first email + LinkedIn outreach sequence',
        icon: 'tabler:number-5',
      },
      {
        title: 'Review open rates and reply rates, then keep optimizing',
        icon: 'tabler:number-6',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'Quick Start Process',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Pricing FAQs"
    subtitle="Questions about our pricing or how usage is calculated? Find the most complete answers here."
    columns={1}
    items={[
      {
        title: "What happens when I run out of Credits? Can I still use the platform?",
        description:
          "When Credits run out, the data enrichment feature pauses. However, outreach sequences using existing data and AI generation features continue to work (they do not consume Credits). You can purchase an add-on pack at any time to resume enrichment, or wait for your quota to reset at the start of the next month.",
      },
      {
        title: "How significant is the difference between monthly and annual billing?",
        description:
          "Monthly billing is 20% more than annual billing. For the Growth plan, that means $299 per user on monthly billing versus $249 per user on annual billing — a saving of $600 per user over a full year. Annual plan subscribers also have the flexibility to draw ahead from the next quarter's Credits quota.",
      },
      {
        title: "Does the 14-day trial include full feature access? How many Credits are included?",
        description:
          "During the trial you can experience all features of the corresponding plan. Trial Credit allowances are: 100 email lookups, 10 phone lookups, 500 AI-generated emails, and a sending volume of 2,000 emails. No credit card is required, and your data can be exported when the trial ends.",
      },
      {
        title: "How is billing handled for teams? Are Credits shared or individual?",
        description:
          "Credits are shared across all users under the same account. For example, a team of 3 users on the Growth plan shares 6,000 email Credits per month (3 x 2,000). If you need individual usage caps for different team members, you can configure personal limits in the admin dashboard.",
      },
      {
        title: "Can I upgrade or downgrade my plan mid-cycle?",
        description:
          "You can upgrade at any time and the prorated difference will be charged immediately. Downgrades take effect at the end of the current billing cycle. Downgrading an annual plan requires contacting customer support.",
      },
      {
        title: "What are the main differences between the Enterprise and Growth plans?",
        description:
          "Beyond higher usage quotas, the Enterprise plan includes features not available in Growth: customer health scoring and churn early warning, an AI revenue forecasting model, automated meeting summaries with CRM auto-fill, ABM account management, a private cloud deployment option, and a dedicated customer success manager.",
      },
      {
        title: "What payment methods are supported?",
        description:
          "We accept major credit cards (Visa, Mastercard), Alipay, WeChat Pay, and corporate bank transfers (with VAT invoice). Annual enterprise customers may apply for quarterly or semi-annual payment schedules.",
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Not Sure Which Plan Is Right for You?"
    subtitle="Tell us your team size and use case and we will help you find the most cost-effective combination."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Consultant Call',
        href: '/contact',
        icon: 'tabler:messages',
      },
      {
        variant: 'secondary',
        text: 'Start Your Free Trial',
        href: '/contact',
      },
    ]}
  />
</Layout>
