---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '定價方案',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="定價方案"
    title="透明定價，按用量付費"
    subtitle="資料富化按 Credit 計費，AI 生成和發信量根據方案各有額度。年付享 85 折，所有方案提供 14 天免費試用。"
  />

  <!-- Pricing Widget ******************* -->

  <Prices
    title="選擇適合你團隊的方案"
    subtitle="以下價格為每用戶每月（年付），月付另加 20%"
    prices={[
      {
        title: '入門版',
        subtitle: '適合 1-3 人的小型 SDR 或行銷團隊',
        price: 99,
        period: '每用戶 / 每月（年付）',
        items: [
          { description: '每月 500 筆資料富化 Credits（郵箱驗證）' },
          { description: '每月 50 筆電話號碼查詢 Credits' },
          { description: '每月 3,000 封 AI 個性化郵件生成' },
          { description: '每月最多發送 10,000 封郵件' },
          { description: '最多 3 條活躍外聯序列' },
          { description: 'LinkedIn 序列（每月 200 則訊息）' },
          { description: '1 個 CRM 雙向同步' },
          { description: '基礎線索評分' },
          { description: '郵件送達率監控' },
        ],
        callToAction: {
          text: '免費試用 14 天',
          href: '/contact',
        },
      },
      {
        title: '成長版',
        subtitle: '適合快速擴張的 GTM 團隊',
        price: 249,
        period: '每用戶 / 每月（年付）',
        items: [
          { description: '每月 2,000 筆資料富化 Credits（郵箱驗證）' },
          { description: '每月 300 筆電話號碼查詢 Credits' },
          { description: '每月 20,000 封 AI 個性化郵件生成' },
          { description: '每月最多發送 100,000 封郵件' },
          { description: '無限活躍外聯序列' },
          { description: 'LinkedIn 序列（每月 1,000 則訊息）' },
          { description: '無限 CRM 雙向同步' },
          { description: 'AI 客戶研究助手（批量，每月 500 筆）' },
          { description: '進階線索評分 + 意圖識別' },
          { description: '官網訪客識別（IP 反查，每月 1,000 筆）' },
          { description: 'Pipeline 健康度監控' },
          { description: '多觸點歸因分析' },
        ],
        callToAction: {
          text: '免費試用 14 天',
          href: '/contact',
        },
        hasRibbon: true,
        ribbonTitle: '最受歡迎',
      },
      {
        title: '企業版',
        subtitle: '適合大型銷售與行銷組織',
        price: 499,
        period: '每用戶 / 每月起（年付）',
        items: [
          { description: '自訂資料富化 Credits 額度（可談無上限）' },
          { description: '自訂電話查詢 Credits 額度' },
          { description: '自訂 AI 生成額度（含部落格、提案）' },
          { description: '自訂每月發信量' },
          { description: 'AI 助手：會議摘要、CRM 自動回填、Text-to-SQL' },
          { description: '客戶健康度評分 + 流失預警' },
          { description: 'AI 收入預測模型（誤差 < 15%）' },
          { description: '自訂 ICP 建模與 ABM 帳戶管理' },
          { description: '私有雲 / 本地化部署（可選）' },
          { description: '專屬客戶成功經理' },
          { description: '服務等級協議（SLA）保障' },
        ],
        callToAction: {
          text: '聯繫銷售顧問',
          href: '/contact',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="關於 Credits：透明說清楚"
    subtitle="我們用 Credit 計算資料富化的用量，因為每一筆查詢都需要對接外部資料源，有真實的成本。"
    columns={2}
    items={[
      {
        title: '1 Credit = 1 筆郵箱查詢',
        description: '向資料供應商查詢一個有效郵箱地址消耗 1 Credit。查詢失敗（無命中）不扣 Credit。',
        icon: 'tabler:mail',
      },
      {
        title: '電話查詢獨立計費',
        description: '電話號碼的資料成本遠高於郵箱，因此單獨設額度。入門版每月 50 筆，成長版 300 筆。',
        icon: 'tabler:phone',
      },
      {
        title: 'Credits 當月有效，不累積',
        description: '未使用的 Credits 不跨月累積（年付方案可預支下季 20% 額度）。超出後可按需購買加購包。',
        icon: 'tabler:calendar-time',
      },
      {
        title: 'AI 生成額度說明',
        description: '每封 AI 個性化郵件計為 1 次生成。AI 客戶研究（Research Agent）每筆公司調研計為 1 Credit，獨立於郵件生成額度。',
        icon: 'tabler:robot',
      },
      {
        title: '發信量上限',
        description: '每月發信量是指從 Aitroop 平台實際發出的郵件封數。通過你自己的 SMTP 服務器發送的郵件不計入此限制。',
        icon: 'tabler:send',
      },
      {
        title: '超額加購',
        description: '所有額度超出後均可單獨加購，不強迫升級方案。郵箱 Credits 加購包：100 Credits / $8，電話 Credits：10 筆 / $12。',
        icon: 'tabler:plus',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="從試用到正式使用，最快 30 分鐘"
    tagline="快速啟動"
    isReversed={true}
    items={[
      {
        title: '選擇方案，開始 14 天免費試用',
        icon: 'tabler:number-1',
      },
      {
        title: '連接你的 CRM 和郵件帳戶',
        icon: 'tabler:number-2',
      },
      {
        title: '導入第一批目標客戶名單',
        icon: 'tabler:number-3',
      },
      {
        title: 'AI 自動富化資料 + 生成個性化信件',
        icon: 'tabler:number-4',
      },
      {
        title: '啟動第一個郵件 + LinkedIn 外聯序列',
        icon: 'tabler:number-5',
      },
      {
        title: '查看開信率、回覆率，持續優化',
        icon: 'tabler:number-6',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: '快速啟動流程',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="定價常見問題"
    subtitle="對我們的定價或用量計算有疑問？這裡有最完整的解答。"
    columns={1}
    items={[
      {
        title: 'Credits 用完了怎麼辦？還能繼續用嗎？',
        description:
          'Credits 用完後，資料富化功能會暫停，但已有資料的外聯序列和 AI 生成功能可繼續使用（不消耗 Credits）。你可以隨時購買加購包繼續使用，或等下個月重置。',
      },
      {
        title: '月付和年付的差距有多大？',
        description:
          '月付費用在年付基礎上加 20%。以成長版為例，月付 $299/用戶，年付 $249/用戶，一年下來每位用戶節省 $600。年付方案同時享有提前預支下季 Credits 額度的彈性。',
      },
      {
        title: '14 天試用包含完整功能嗎？Credits 有多少？',
        description:
          '試用期間可體驗對應方案的全部功能。Credits 試用額度：郵箱 100 筆、電話 10 筆、AI 郵件生成 500 封、發信量 2,000 封。無需信用卡，試用結束後資料可匯出。',
      },
      {
        title: '多人團隊怎麼計費？Credits 是共享還是各自獨立？',
        description:
          'Credits 在同一帳戶下所有用戶共享。例如，3 個用戶訂閱成長版，每月共享 6,000 筆郵箱 Credits（3 × 2,000）。如需讓不同成員有獨立的額度控制，可在管理後台設置個人用量上限。',
      },
      {
        title: '可以中途升級或降級方案嗎？',
        description:
          '可以隨時升級，差額按比例即時結算。降級在當前計費週期結束後生效。年付方案降級需聯繫客服處理。',
      },
      {
        title: '企業版和成長版的主要差異是什麼？',
        description:
          '除了更高的用量額度，企業版還包括成長版沒有的功能：客戶健康度評分與流失預警、AI 收入預測模型、會議自動摘要與 CRM 回填、ABM 帳戶管理，以及私有雲部署選項和專屬客戶成功經理。',
      },
      {
        title: '支援哪些支付方式？',
        description:
          '支援主流信用卡（Visa、Mastercard）、支付寶、微信支付，以及企業對公轉帳（開增值稅發票）。年付企業客戶可申請季付或半年付。',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="還不確定哪個方案適合你？"
    subtitle="告訴我們你的團隊規模和使用場景，我們會幫你算出最划算的組合。"
    actions={[
      {
        variant: 'primary',
        text: '預約顧問諮詢',
        href: '/contact',
        icon: 'tabler:messages',
      },
      {
        variant: 'secondary',
        text: '免費開始試用',
        href: '/contact',
      },
    ]}
  />
</Layout>
