---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact us — Aitroop',
};

const fields = [
  { name: 'name',    label: 'Your name',    type: 'text',  placeholder: 'Jane Smith' },
  { name: 'email',   label: 'Work email',   type: 'email', placeholder: 'name@company.com' },
  { name: 'company', label: 'Company name', type: 'text',  placeholder: 'Your company' },
  { name: 'role',    label: 'Your role',    type: 'text',  placeholder: 'VP of Sales, Head of Marketing, RevOps…' },
] as const;

const offers = [
  { n: '01', title: 'Product demo',          desc: 'Tailored to your context — SDR outreach, marketing attribution, RevOps, customer success. Not a generic deck.' },
  { n: '02', title: 'Enterprise plan',       desc: 'Teams of 20+, private deployment, custom integrations. Our sales team designs a dedicated solution and pricing.' },
  { n: '03', title: 'Integration support',   desc: 'Connect Aitroop to your existing CRM, data systems, or internal tools. Solutions engineers assess feasibility.' },
  { n: '04', title: 'Partnerships',          desc: 'Data providers, CRM vendors, systems integrators. We actively seek ecosystem partners.' },
];
---

<Layout metadata={metadata}>

  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Contact us</p>
      <h1 class="display">Let's talk about your GTM challenges.</h1>
      <p class="lede">
        Book a product demo, explore an enterprise plan, or just learn more. Our consultants are happy to connect.
      </p>
    </div>
  </section>

  <!-- FORM + DIRECT ─────────────────────────────────────────────────── -->
  <section class="block">
    <div class="container">
      <div class="form-grid">
        <div class="form-intro">
          <p class="eyebrow">Form</p>
          <h2 class="h2">Book a demo or consultation.</h2>
          <p class="lede">
            We respond within one business day. For urgent inquiries, email <a href="mailto:hello@aitroop.net">hello@aitroop.net</a>.
          </p>
        </div>

        <form class="form" id="form">
          {fields.map((f) => (
            <div class="field">
              <label for={f.name}>{f.label}</label>
              <input
                type={f.type}
                name={f.name}
                id={f.name}
                placeholder={f.placeholder}
                autocomplete="on"
              />
            </div>
          ))}
          <div class="field">
            <label for="message">What's the biggest problem you want to solve?</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="A brief description of your situation helps us prepare the most relevant demo content."
            ></textarea>
          </div>
          <label class="disclaimer">
            <input type="checkbox" id="disclaimer" name="disclaimer" />
            <span>By submitting, you agree we may use your contact info per our Privacy Policy to respond to your inquiry. We will not share it with third parties.</span>
          </label>
          <button type="submit" class="btn btn-primary">Send message</button>
        </form>
      </div>
    </div>
  </section>

  <!-- WHAT WE OFFER ────────────────────────────────────────────────── -->
  <section class="block">
    <div class="container">
      <header class="block-head">
        <p class="eyebrow">What we offer</p>
        <h2 class="h2">Four ways to work with us.</h2>
      </header>
      <div class="offers">
        {offers.map((o) => (
          <article class="offer">
            <span class="offer-num">{o.n}</span>
            <h3 class="offer-title">{o.title}</h3>
            <p class="offer-desc">{o.desc}</p>
          </article>
        ))}
      </div>

      <div class="direct">
        <div class="direct-row">
          <span class="direct-label">Email</span>
          <a href="mailto:hello@aitroop.net" class="direct-value">hello@aitroop.net</a>
        </div>
        <div class="direct-row">
          <span class="direct-label">WeChat</span>
          <span class="direct-value">Search “Aitroop” to follow for B2B sales and GTM insights.</span>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ layout primitives ════ */
  .container {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (min-width: 768px) {
    .container { padding: 0 2.5rem; }
  }
  .block {
    padding: 6rem 0;
    border-top: 1px solid var(--aw-color-border);
  }
  @media (min-width: 768px) {
    .block { padding: 8rem 0; }
  }
  .block-head { margin-bottom: 4rem; }
  @media (min-width: 768px) {
    .block-head { margin-bottom: 5rem; }
  }

  /* ════ shared type ════ */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--aw-color-primary);
    margin: 0 0 1.125rem;
    line-height: 1;
  }
  .eyebrow::before {
    content: '';
    width: 1.25rem;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }
  .display {
    font-size: clamp(2.25rem, 4.6vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--aw-color-text-heading);
    margin: 0 0 1.25rem;
    text-wrap: balance;
    max-width: 22ch;
  }
  .h2 {
    font-size: clamp(1.75rem, 3vw, 2.125rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--aw-color-text-heading);
    margin: 0 0 1rem;
    text-wrap: balance;
    max-width: 28ch;
  }
  .lede {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--aw-color-text-muted);
    max-width: 48ch;
    margin: 0;
    text-wrap: pretty;
  }
  .lede a {
    color: var(--aw-color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ════ hero ════ */
  .hero {
    padding: 6rem 0 4rem;
  }
  @media (min-width: 768px) {
    .hero { padding: 8rem 0 6rem; }
  }

  /* ════ form layout ════ */
  .form-grid {
    display: grid;
    gap: 3rem;
  }
  @media (min-width: 900px) {
    .form-grid {
      grid-template-columns: 18rem 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  /* ════ form ════ */
  .form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 32rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.005em;
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--aw-color-border);
    border-radius: 0.5rem;
    background: var(--aw-color-bg-page);
    color: var(--aw-color-text-default);
    font-family: inherit;
    font-size: 0.9375rem;
    line-height: 1.4;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }
  .field textarea {
    resize: vertical;
    min-height: 6rem;
    line-height: 1.55;
  }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--aw-color-text-muted); }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--aw-color-primary);
    box-shadow: 0 0 0 3px rgba(82, 153, 97, 0.15);
  }
  .disclaimer {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    line-height: 1.55;
    cursor: pointer;
  }
  .disclaimer input {
    margin-top: 0.2rem;
    accent-color: var(--aw-color-primary);
  }

  /* ════ buttons ════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    padding: 0 1.375rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    border: none;
    cursor: pointer;
    transition: background-color 160ms ease, border-color 160ms ease;
  }
  .btn-primary {
    background: var(--aw-color-primary);
    color: #fff;
    box-shadow:
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 1px 2px rgba(15, 30, 18, 0.06);
    align-self: flex-start;
  }
  .btn-primary:hover { background: rgb(67, 138, 84); }

  /* ════ offers ════ */
  .offers {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .offers { grid-template-columns: repeat(2, 1fr); gap: 2.5rem 3rem; }
  }
  .offer {
    border-top: 1px solid var(--aw-color-text-heading);
    padding-top: 1.25rem;
  }
  .offer-num {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    letter-spacing: 0.06em;
    margin-bottom: 0.875rem;
    font-variant-numeric: tabular-nums;
  }
  .offer-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.5rem;
    letter-spacing: -0.005em;
  }
  .offer-desc {
    margin: 0;
    color: var(--aw-color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* ════ direct contact rows ════ */
  .direct {
    margin-top: 4rem;
    border-top: 1px solid var(--aw-color-border);
  }
  .direct-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--aw-color-border);
  }
  @media (min-width: 640px) {
    .direct-row {
      grid-template-columns: 8rem 1fr;
      gap: 2rem;
      align-items: center;
    }
  }
  .direct-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--aw-color-text-muted);
  }
  .direct-value {
    font-size: 0.9375rem;
    color: var(--aw-color-text-default);
    line-height: 1.5;
  }
  a.direct-value {
    color: var(--aw-color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--aw-color-border);
  }
  a.direct-value:hover { text-decoration-color: var(--aw-color-primary); }
</style>
