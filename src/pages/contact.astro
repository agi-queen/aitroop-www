---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: '聯絡我們',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="聯絡我們"
    title="讓我們聊聊你的 GTM 挑戰"
    subtitle="無論你是想預約產品示範、探討企業方案，還是只是想了解更多，我們的顧問都很樂意與你交流。"
  />

  <ContactUs
    id="form"
    title="預約產品示範或諮詢"
    subtitle="填寫以下表單，我們的顧問將在 1 個工作日內與你聯繫，安排最適合的時間進行 30 分鐘一對一示範。"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: '你的姓名',
        placeholder: '王小明',
      },
      {
        type: 'email',
        name: 'email',
        label: '工作郵箱',
        placeholder: 'name@company.com',
      },
      {
        type: 'text',
        name: 'company',
        label: '公司名稱',
        placeholder: '你的公司名稱',
      },
      {
        type: 'text',
        name: 'role',
        label: '你的職位',
        placeholder: '例如：銷售總監、市場負責人、RevOps',
      },
    ]}
    textarea={{
      label: '你最想解決的問題是什麼？',
      placeholder: '例如：SDR 外聯效率低、收入預測不準、客戶資料品質差……簡單描述你的場景，有助於我們為你準備最相關的示範內容。',
    }}
    disclaimer={{
      label:
        '提交此表單，即表示你同意我們根據隱私政策收集和使用你的聯繫資訊，用於回應你的諮詢。我們不會將你的資訊分享給第三方。',
    }}
    description="通常在 1 個工作日內回覆。如需緊急聯繫，請直接發送郵件至 hello@aitroop.net。"
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="我們能為你提供什麼"
    items={[
      {
        title: '一對一產品示範',
        description:
          '我們的顧問會根據你的業務場景（SDR 外聯、市場歸因、RevOps、客戶成功），準備最有針對性的示範內容，不是通用的 PPT 演示。',
        icon: 'tabler:presentation',
      },
      {
        title: '企業方案諮詢',
        description:
          '如果你的團隊超過 20 人，或有私有化部署、定制整合等需求，我們的企業銷售團隊可以為你設計專屬解決方案和定價。',
        icon: 'tabler:building',
      },
      {
        title: '技術整合支援',
        description:
          '需要將 Aitroop 連接到你現有的 CRM、數據系統或內部工具？我們的解決方案工程師可以評估整合可行性並提供技術方案。',
        icon: 'tabler:plug',
      },
      {
        title: '合作夥伴洽談',
        description:
          '數據供應商、CRM 廠商、系統整合商——我們積極尋求可以共同為 B2B 客戶創造更大價值的生態合作夥伴。',
        icon: 'tabler:handshake',
        icon: 'tabler:handshake',
      },
      {
        title: '郵件直接聯繫',
        description: 'hello@aitroop.net',
        icon: 'tabler:mail',
      },
      {
        title: '微信公眾號',
        description: '搜索「Aitroop」關注我們，獲取最新 B2B 銷售和 GTM 洞察內容。',
        icon: 'tabler:brand-wechat',
      },
    ]}
  />
</Layout>
