---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact us · Aitroop',
};

const fields = [
  { name: 'name',    label: 'Your name',    type: 'text',  placeholder: 'Full name' },
  { name: 'email',   label: 'Work email',   type: 'email', placeholder: 'name@company.com' },
  { name: 'company', label: 'Company name', type: 'text',  placeholder: 'Your company' },
  { name: 'role',    label: 'Your role',    type: 'text',  placeholder: 'e.g. VP of Sales, RevOps' },
] as const;

const offers = [
  { tag: 'Demo',          title: 'Product demo',        desc: 'Tailored to your context: SDR outreach, marketing attribution, RevOps, customer success. Not a generic deck.' },
  { tag: 'Enterprise',    title: 'Enterprise plan',     desc: 'Teams of 20+, private deployment, custom integrations. Our sales team designs a dedicated solution and pricing.' },
  { tag: 'Engineering',   title: 'Integration support', desc: 'Connect Aitroop to your existing CRM, data systems, or internal tools. Solutions engineers assess feasibility.' },
  { tag: 'Partner',       title: 'Partnerships',        desc: 'Data providers, CRM vendors, systems integrators. We actively seek ecosystem partners.' },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head">
    <div class="aw-container">
      <p class="aw-eyebrow">0.2 · Talk to us</p>
      <h1 class="aw-h1" style="max-width: 22ch;">Let's talk about your GTM challenges.</h1>
      <p class="aw-page-head-desc">
        Book a product demo, explore an enterprise plan, or just learn more. Our consultants are happy to connect.
      </p>
    </div>
  </section>

  <!-- FORM ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <div class="contact-split">
        <header class="contact-form-head">
          <p class="aw-eyebrow">0.2.1 · Book</p>
          <h2 class="aw-h2" style="max-width: 18ch; margin-bottom: 1rem;">Book a demo or consultation.</h2>
          <p class="aw-lede" style="max-width: 36ch;">
            We respond within one business day. For urgent inquiries, email <a href="mailto:hello@aitroop.net">hello@aitroop.net</a>.
          </p>
          <p class="contact-form-meta ds-mono">
            <span>response · &lt; 1 business day</span>
          </p>
        </header>

        <form class="contact-form" id="form">
          {fields.map((f) => (
            <div class="aw-field">
              <label class="aw-field-label" for={f.name}>{f.label}</label>
              <input
                class="aw-input"
                type={f.type}
                name={f.name}
                id={f.name}
                placeholder={f.placeholder}
                autocomplete="on"
              />
            </div>
          ))}
          <div class="aw-field">
            <label class="aw-field-label" for="message">What's the biggest problem you want to solve?</label>
            <textarea
              class="aw-textarea"
              id="message"
              name="message"
              rows="4"
              placeholder="A brief description of your situation helps us prepare the most relevant demo content."
            ></textarea>
          </div>
          <label class="disclaimer">
            <input type="checkbox" id="disclaimer" name="disclaimer" />
            <span>By submitting, you agree we may use your contact info per our Privacy Policy to respond to your inquiry. We will not share it with third parties.</span>
          </label>
          <button type="submit" class="aw-btn aw-btn-primary contact-submit">
            Send message
            <kbd class="ds-kbd ds-kbd--on-dark" aria-hidden="true">↵</kbd>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- OFFERS ────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">0.2.2 · Ways to work with us</p>
        <h2 class="aw-h2">Four lanes.</h2>
      </header>
      <div class="offers">
        {offers.map((o, i) => (
          <article class="aw-piece">
            <p class="aw-piece-num">{`0.2.2.${i + 1}`}</p>
            <span class="aw-piece-tag">{o.tag}</span>
            <h3 class="aw-piece-title">{o.title}</h3>
            <p class="aw-piece-desc">{o.desc}</p>
          </article>
        ))}
      </div>

      <div class="direct">
        <p class="aw-eyebrow direct-eyebrow">0.2.3 · Or just</p>
        <div class="direct-row">
          <span class="direct-label">Email</span>
          <a href="mailto:hello@aitroop.net" class="direct-value direct-link">hello@aitroop.net</a>
        </div>
        <div class="direct-row">
          <span class="direct-label">WeChat</span>
          <span class="direct-value">Search "Aitroop" on WeChat.</span>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ════ editorial split — sticky head on desktop ════ */
  .contact-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .contact-split {
      grid-template-columns: 22rem 1fr;
      gap: 5rem;
      align-items: start;
    }
  }
  .contact-form-head {
    position: relative;
  }
  @media (min-width: 900px) {
    .contact-form-head {
      position: sticky;
      top: 5rem;
    }
  }
  .contact-form-meta {
    margin: 1.5rem 0 0;
    padding-top: 1rem;
    border-top: 1px dashed var(--ds-hairline);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--ds-text-quiet);
  }

  /* ════ form ════ */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    max-width: 34rem;
  }
  .contact-submit { align-self: flex-start; margin-top: 0.5rem; }

  /* ════ disclaimer ════ */
  .disclaimer {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
    font-size: 0.8125rem;
    color: var(--ds-text-muted);
    line-height: 1.55;
    cursor: pointer;
  }
  .disclaimer input {
    margin-top: 0.2rem;
    accent-color: var(--ds-accent);
  }

  /* ════ offers ════ */
  .offers {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .offers { grid-template-columns: repeat(2, 1fr); gap: 3rem 4rem; }
  }

  /* ════ direct contact rows ════ */
  .direct {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--ds-hairline-strong);
  }
  .direct-eyebrow { display: block; margin-bottom: 1.25rem; }
  .direct-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
    padding: 1rem 0;
  }
  .direct-row + .direct-row {
    border-top: 1px dashed var(--ds-hairline);
  }
  @media (min-width: 640px) {
    .direct-row {
      grid-template-columns: 8rem 1fr;
      gap: 2rem;
      align-items: center;
    }
  }
  .direct-label {
    font-family: var(--ds-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ds-text-quiet);
    font-weight: 500;
  }
  .direct-value {
    font-size: 0.9375rem;
    color: var(--ds-text);
    line-height: 1.5;
  }
  .direct-link {
    color: var(--ds-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--ds-accent-tint-2);
    transition: border-color 160ms ease;
  }
  .direct-link:hover { border-bottom-color: var(--ds-accent); }
</style>
