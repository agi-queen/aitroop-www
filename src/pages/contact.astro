---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Us',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Contact Us"
    title="Let's Talk About Your GTM Challenges"
    subtitle="Whether you want to book a product demo, explore an enterprise plan, or simply learn more, our consultants are happy to connect with you."
  />

  <ContactUs
    id="form"
    title="Book a Product Demo or Consultation"
    subtitle="Fill out the form below and our consultant will reach out within one business day to schedule a 30-minute one-on-one demo at a time that works for you."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Your Name',
        placeholder: 'Jane Smith',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Work Email',
        placeholder: 'name@company.com',
      },
      {
        type: 'text',
        name: 'company',
        label: 'Company Name',
        placeholder: 'Your company name',
      },
      {
        type: 'text',
        name: 'role',
        label: 'Your Role',
        placeholder: 'e.g. VP of Sales, Head of Marketing, RevOps',
      },
    ]}
    textarea={{
      label: 'What is the biggest problem you want to solve?',
      placeholder: "e.g. SDR outreach efficiency is low, revenue forecasts are unreliable, prospect data quality is poor... A brief description of your situation helps us prepare the most relevant demo content.",
    }}
    disclaimer={{
      label:
        "By submitting this form, you agree that we may collect and use your contact information in accordance with our Privacy Policy to respond to your inquiry. We will not share your information with third parties.",
    }}
    description="We typically respond within one business day. For urgent inquiries, please email us directly at hello@aitroop.net."
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="What We Can Do for You"
    items={[
      {
        title: 'One-on-One Product Demo',
        description:
          "Our consultants tailor each demo to your specific business context — whether that's SDR outreach, marketing attribution, RevOps, or customer success. Expect a focused walkthrough, not a generic slide deck.",
        icon: 'tabler:presentation',
      },
      {
        title: 'Enterprise Plan Consulting',
        description:
          "If your team is larger than 20 people, or if you have requirements around private deployment or custom integrations, our enterprise sales team can design a dedicated solution and pricing structure for you.",
        icon: 'tabler:building',
      },
      {
        title: 'Technical Integration Support',
        description:
          "Need to connect Aitroop to your existing CRM, data systems, or internal tools? Our solutions engineers can assess integration feasibility and provide a technical plan.",
        icon: 'tabler:plug',
      },
      {
        title: 'Partnership Discussions',
        description:
          "Data providers, CRM vendors, systems integrators — we actively seek ecosystem partners who can help create greater value for B2B customers together.",
        icon: 'tabler:users',
      },
      {
        title: 'Email Us Directly',
        description: 'hello@aitroop.net',
        icon: 'tabler:mail',
      },
      {
        title: 'WeChat Official Account',
        description: 'Search "Aitroop" on WeChat to follow us for the latest B2B sales and GTM insights.',
        icon: 'tabler:brand-wechat',
      },
    ]}
  />
</Layout>
