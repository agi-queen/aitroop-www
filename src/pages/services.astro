---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '功能特色',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="功能特色"
    title="你需要的每一個 GTM 超能力，全在這裡"
    subtitle="Aitroop 將資料富化、AI 研究、個性化外聯、多渠道自動化、CRM 同步和收入運營整合為一個平台，讓你的銷售與行銷團隊真正做到：少花時間在工具上，多花時間在客戶上。"
    actions={[{ variant: 'primary', text: '預約產品示範', href: '/contact' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Aitroop 功能特色',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="全方位覆蓋 GTM 工作流"
    subtitle="從找到對的客戶，到促成交易、守住客戶——Aitroop 的每個功能模組都為一個核心目的而設計：讓你的每一份努力產生更大的業績回報。"
    columns={3}
    items={[
      {
        title: '客戶資料富化',
        description:
          '上傳名單後自動補全有效郵箱、手機號、LinkedIn 主頁、融資資訊、員工規模、技術棧。Waterfall 智能富化邏輯，有效聯繫人覆蓋率 80% 以上。',
        icon: 'tabler:database-search',
      },
      {
        title: 'AI 客戶研究助手',
        description:
          '輸入公司域名，AI 自動瀏覽官網、新聞、LinkedIn，在 90 秒內回答你預設的問題：他們的主要客群是誰？最近有哪些切入點？結果結構化填入外聯模板。',
        icon: 'tabler:robot',
      },
      {
        title: '個性化外聯流水線',
        description:
          '資料富化 → AI 生成個性化信件 → 推送外聯序列，全流程在一個界面內完成。基於融資事件、招聘動態、CEO 文章的個性化首句，回覆率提升 3 倍以上。',
        icon: 'tabler:send',
      },
      {
        title: '郵件送達率基礎設施',
        description:
          '域名預熱、信譽監控、多域名智能輪轉——確保你的冷郵件進主收件箱而不是垃圾箱。主收件箱到達率穩定維持在 90% 以上。',
        icon: 'tabler:mail-check',
      },
      {
        title: '多渠道自動化序列',
        description:
          '郵件 + LinkedIn 混合序列，自動化跟進節奏。設定一次規則，系統持續運轉。Email + LinkedIn 混合外聯比純郵件回覆率高 30-50%。',
        icon: 'tabler:list-check',
      },
      {
        title: 'CRM 雙向同步',
        description:
          '深度整合 Salesforce、HubSpot、纷享销客、销售易。線索、聯繫人、商機雙向即時同步，銷售不再需要在兩個系統間手動複製資料。',
        icon: 'tabler:refresh',
      },
      {
        title: '線索評分與意圖識別',
        description:
          '官網訪客 IP 反查，即時識別是哪家公司在研究你。AI 評估購買意圖（0-100 分），高意圖客戶自動推送銷售優先跟進。',
        icon: 'tabler:target',
      },
      {
        title: '競品與市場情報監控',
        description:
          '設定關鍵字，系統自動監控目標公司的融資事件、高管變動、產品發布、競品動向。第一時間掌握最佳切入時機。',
        icon: 'tabler:radar',
      },
      {
        title: 'AI 內容批量生成',
        description:
          '輸入話題和目標客群，AI 在 30 秒內生成部落格、LinkedIn 貼文、郵件序列草稿，支援批量生成最多 20 篇，配合統一內容日曆管理發布節奏。',
        icon: 'tabler:pencil',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: '找到最值得跟進的線索',
        description:
          'AI 自動對每條線索進行評分，綜合公司規模、行業匹配度、意圖信號和互動歷史，讓銷售每天的優先清單一目了然。',
        icon: 'tabler:star',
      },
      {
        title: '收入預測誤差 < 15%',
        description:
          'AI 分析商機健康度、歷史成交規律、Pipeline 流速，給出可信的季度收入預測。告別「靠感覺報數字」，讓管理層做決策有依據。',
        icon: 'tabler:chart-arrows',
      },
      {
        title: 'Pipeline 停滯預警',
        description:
          '自動識別哪些商機已超過正常推進週期、哪些客戶出現冷淡信號，提前介入，避免到季末才發現 Pipeline 有缺口。',
        icon: 'tabler:alert-triangle',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=870&q=80',
      alt: '收入運營功能',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">收入運營：讓預測變成現實</h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: '客戶健康度即時評分',
        description:
          '持續追蹤產品使用頻率、功能採用深度、支援工單趨勢，自動計算每個客戶帳號的健康分數。',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: '流失預警：比客戶先知道',
        description:
          '健康分數持續下滑或關鍵行為消失時，系統立即推送預警，讓客戶成功團隊在流失發生前 30 天介入，成本僅是事後挽回的 1/5。',
        icon: 'tabler:bell-ringing',
      },
      {
        title: '自動化續費與增購序列',
        description:
          '基於客戶旅程設計個性化的續費提醒和增購推薦，自動觸發、自動跟進，不再靠人工逐個盯客戶。',
        icon: 'tabler:arrow-up-circle',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1573497491765-dccce02b29df?ixlib=rb-4.0.3&auto=format&fit=crop&w=870&q=80',
      alt: '客戶成功功能',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">客戶成功：把流失扼殺在搖籃裡</h3>
    </Fragment>
  </Content>

  <!-- Features3 Widget ************** -->

  <Features3
    title="整合你現有的每一個工具"
    subtitle="Aitroop 不是要替換你的工具，而是把它們連接起來，消除協作摩擦。"
    columns={2}
    items={[
      {
        title: 'CRM 整合',
        description: 'Salesforce、HubSpot、纷享销客、销售易——雙向即時同步，資料永遠一致。',
        icon: 'tabler:plug',
      },
      {
        title: '數據供應商',
        description: '探迹、企查查、Apollo、Crunchbase——一站式搜尋全球 B2B 聯繫人資料。',
        icon: 'tabler:database',
      },
      {
        title: '溝通工具',
        description: '郵件客戶端、企業微信、Slack——通知和工作流直達你的日常協作工具。',
        icon: 'tabler:message',
      },
      {
        title: '行銷平台',
        description: '廣告歸因、UTM 管理、官網追蹤——從流量到成交，全路徑數據打通。',
        icon: 'tabler:chart-pie',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="他們用 Aitroop 改變了業績軌跡"
    testimonials={[
      {
        testimonial: `以前每天花兩三個小時調研客戶、寫個性化郵件，用了 Aitroop 之後，我只需要審核 AI 生成的內容，每天外聯量從 20 人增加到 100 人以上，預約率提升了將近一倍。`,
        name: '陳建宏',
        job: '企業軟體公司 SDR',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=930&q=80',
          alt: '陳建宏',
        },
      },
      {
        testimonial: `最讓我驚訝的是歸因功能。以前老闆問「這筆預算帶來了多少收入」我只能說大概，現在每個渠道的 ROI 清清楚楚，預算申請容易多了，行銷和銷售的摩擦也少了。`,
        name: '林雅婷',
        job: 'SaaS 公司行銷運營負責人',
        image: {
          src: 'https://images.unsplash.com/photo-1494790108755-2616b612b786?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80',
          alt: '林雅婷',
        },
      },
      {
        testimonial: `收入預測這件事做了五年，誤差從沒低於 25%。Aitroop 上線三個季度後，我們的預測誤差穩定在 12% 以內。這對我們做人員規劃和預算分配意義重大。`,
        name: '王志強',
        job: '製造業數位化公司 RevOps 總監',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&auto=format&fit=crop&w=824&q=80',
          alt: '王志強',
        },
      },
    ]}
    callToAction={{
      text: '查看更多用戶故事',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '預約 30 分鐘產品示範',
        href: '/contact',
      },
    ]}
    title="親眼看看 Aitroop 如何改變你的 GTM 效率"
    subtitle="讓我們的顧問根據你的業務場景，展示最適合你的工作流方案。"
  />
</Layout>
