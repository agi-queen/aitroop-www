---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Features',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Features"
    title="Find, Engage, Convert, Retain — AI at Every Stage of the Customer Journey"
    subtitle="Aitroop covers the complete growth lifecycle. From identifying your ideal prospects to retaining every existing customer, four core pillars work in concert — so one person can accomplish what used to take an entire team."
    actions={[{ variant: 'primary', text: 'Book a Product Demo', href: '/contact' }]}
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1740&q=80',
      alt: 'Aitroop Features',
    }}
  />

  <!-- PILLAR 1: FIND **************** -->

  <Features2
    tagline="Step 1: Find"
    title="Precision Targeting — Find the People Worth Talking To"
    subtitle="Before you say a word, make sure you have found the right person. Aitroop turns target identification from guesswork into science."
    columns={3}
    items={[
      {
        title: 'ICP Modeling & Audience Analysis',
        description:
          'AI analyzes your existing high-value customers and extracts quantifiable ideal customer profile attributes — industry, company size, tech stack, and growth stage. ICP-matched leads close at 25–40% higher rates and move through sales cycles 30% faster.',
        icon: 'tabler:crosshair',
      },
      {
        title: 'Waterfall Intelligent Data Enrichment',
        description:
          'Upload a list and automatically fill in verified emails, phone numbers, LinkedIn profiles, and funding history. The Waterfall engine cascades across multiple data sources in priority order, lifting contact coverage from 40% to 80%+ and cutting bounce rates from 15% to under 3%.',
        icon: 'tabler:database-search',
      },
      {
        title: 'AI Prospect Research Agent',
        description:
          'Enter a domain and the AI browses the company website, recent news, and LinkedIn in 90 seconds — answering your preset questions about their main customers, recent triggers, and likely pain points. Results flow directly into your outreach templates.',
        icon: 'tabler:robot',
      },
      {
        title: 'Anonymous Visitor Identification',
        description:
          '97% of website visitors leave without filling out a form. Aitroop uses IP reverse lookup to identify the companies behind anonymous visits, tracks which pages they viewed and how long they stayed, and turns each month\'s invisible visitors into actionable leads.',
        icon: 'tabler:eye',
      },
      {
        title: 'Buyer Intent Signal Monitoring',
        description:
          'Website behavior, third-party intent data, and product usage records — three dimensions of purchase signals fused into a single unified score. High-intent prospects are automatically pushed to the priority follow-up queue so you show up at exactly the right moment.',
        icon: 'tabler:radar',
      },
      {
        title: 'Real-Time Company Event Alerts',
        description:
          'Funding rounds, executive changes, hiring expansions, and competitor moves — the system fires alerts within 5–30 minutes, 24–48 hours faster than traditional tools. Signal-triggered outreach generates 5–10x the reply rate of cold outreach.',
        icon: 'tabler:bell',
      },
    ]}
  />

  <!-- PILLAR 2: ENGAGE ************** -->

  <Features2
    tagline="Step 2: Engage"
    title="Personalization × Scale — No Longer a Trade-Off"
    subtitle="One person producing the output of an entire outreach team, with every message feeling like it was written exclusively for the recipient."
    columns={3}
    items={[
      {
        title: 'Personalized Outreach Pipeline',
        description:
          'List upload → auto-enrich → AI-generated personalized opener (based on funding events, hiring signals, and CEO articles) → one-click sequence launch. Work that used to take a full day now takes one hour. Reply rates increase 3–5x.',
        icon: 'tabler:send',
      },
      {
        title: 'Multi-Channel Automated Sequences',
        description:
          'Email + LinkedIn blended sequences — set your follow-up cadence once, and the system runs continuously, pausing automatically when a reply arrives. Multi-channel outreach outperforms email-only by 37%, more than doubling monthly meetings booked per rep.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Email Deliverability Infrastructure',
        description:
          'Domain warmup, reputation monitoring, and intelligent multi-domain rotation — ensuring the emails you craft carefully land in the primary inbox, not spam. Primary inbox delivery rate held consistently above 90%.',
        icon: 'tabler:mail-check',
      },
      {
        title: 'AI Bulk Content Generation',
        description:
          'Enter a topic and target audience, and receive a blog post, LinkedIn post, and email sequence simultaneously in 90 seconds. Monthly content output increases 5x, and marketing-sourced pipeline grows 25–35%.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Website Personalization',
        description:
          "Dynamically adjust homepage copy and case studies based on the visitor's company, industry, and acquisition channel — so every visitor sees the most relevant content. No engineering required. Demo request rates increase 20–40%.",
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Marketing Automation Workflows',
        description:
          'Visual journey builder with behavior- and attribute-based triggers for email, SMS, and in-app messages. Dynamic audiences refresh every 15 minutes. MQL-to-SQL conversion rates reach 25–30%.',
        icon: 'tabler:settings-automation',
      },
    ]}
  />

  <!-- PILLAR 3: CONVERT ************* -->

  <Features2
    tagline="Step 3: Convert"
    title="Turn Every Interest Signal Into a Predictable Closed Deal"
    subtitle="From lead to contract, AI helps you identify priorities, accelerate pace, and increase win rates at every stage."
    columns={3}
    items={[
      {
        title: 'Lead Scoring & Prioritization',
        description:
          'AI scores leads in real time using behavioral, intent, and firmographic data — with explainable scoring reasons included. Each day\'s priority list is immediately clear. SQL close rates increase 2.7x. No more time wasted on low-quality leads.',
        icon: 'tabler:target',
      },
      {
        title: 'AI Proposal Generation',
        description:
          'The AE enters the client name, and AI Research combined with CRM data auto-generates a 12–15 page personalized proposal — company background, tailored solution, relevant case studies, and pricing framework. Draft ready in 5 minutes, sent the same day, 3 days faster than competitors.',
        icon: 'tabler:file-description',
      },
      {
        title: 'Pipeline Management & Health Alerts',
        description:
          'Real-time CRM sync, automatic flagging of deals that have stalled beyond normal cycle time, and AI-suggested next actions. Win rate increases 10–15%, sales cycle shortens 20%, and the weekly management review shrinks from 4 hours to 1.5 hours.',
        icon: 'tabler:chart-arrows',
      },
      {
        title: 'Revenue Forecasting',
        description:
          'AI analyzes pipeline velocity, historical close patterns, and rep biases to generate optimistic, base, and pessimistic scenario forecasts. Forecast error narrows from ±30% to ±10–15%, giving every resource allocation decision a credible foundation.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'PQL Identification',
        description:
          'Precisely identify trial users who are hitting their Aha moment — feature activation, usage approaching limits, inviting teammates. AI triggers immediate follow-up. Free-to-paid conversion rates increase 2.3x.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Sales Call Analysis & Coaching',
        description:
          'AI automatically transcribes and scores every sales call, extracts the conversation patterns of top performers, and generates personalized coaching recommendations. New rep ramp time drops from 6 months to 3 months. Overall team call quality improves 15%.',
        icon: 'tabler:microphone',
      },
    ]}
  />

  <!-- PILLAR 4: RETAIN ************** -->

  <Features2
    tagline="Step 4: Retain"
    title="Retaining Customers Is the Highest-ROI, Lowest-Cost Growth Strategy"
    subtitle="Acquiring a customer is just the beginning. Serving existing customers well is the true engine of compounding growth. Aitroop lets you act before problems occur."
    columns={3}
    items={[
      {
        title: 'Real-Time Customer Health Scoring',
        description:
          'Continuously tracks product usage depth, feature adoption, support ticket trends, and engagement frequency to automatically calculate a health score. CSMs save 4–6 hours of manual review per week. NRR improves an average of 8–15 percentage points.',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Churn Warning: Know Before Your Customer Does',
        description:
          'When health scores trend downward, the system sends an alert 90 days before churn occurs and automatically generates a personalized save strategy. Proactive intervention succeeds 3–4x more often than reactive recovery and costs 80% less.',
        icon: 'tabler:bell-ringing',
      },
      {
        title: 'Renewal & Upsell Automation',
        description:
          "Based on each customer's journey stage and usage data, the system automatically triggers personalized upgrade recommendations and renewal reminders at the optimal moment — so CSMs can focus on accounts that genuinely need human attention.",
        icon: 'tabler:arrow-up-circle',
      },
      {
        title: 'Champion Job Change Tracking',
        description:
          "A key contact leaving is one of the strongest early warning signals for customer churn. Aitroop automatically monitors job changes among key stakeholders within each account, notifying you immediately and suggesting relationship maintenance actions.",
        icon: 'tabler:user-search',
      },
      {
        title: 'Referral Program Automation',
        description:
          "Automatically trigger referral invitations at the peak of a customer's NPS satisfaction, track the referral chain, and turn your happiest customers into your lowest-cost acquisition channel.",
        icon: 'tabler:share',
      },
      {
        title: 'Bi-Directional CRM Sync',
        description:
          'Deep integration with all major CRM platforms — leads, contacts, deals, and health scores sync bi-directionally in real time. CRM fill rate rises from 40% to 85%. Data stays consistent across every system with no manual copy-pasting.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- AI Assistant Content ********** -->

  <Content
    isReversed
    items={[
      {
        title: 'Automatic Meeting Transcription + CRM Auto-Fill',
        description:
          'Five minutes after a call ends, AI auto-generates a structured summary, BANT information, and action items — synced directly to the CRM. The follow-up email goes out within the golden first hour. No relying on memory. No relying on willpower.',
        icon: 'tabler:notes',
      },
      {
        title: 'Natural Language Data Queries',
        description:
          'Just ask in plain English: "Which industry had the highest conversion rate last month?" or "How large is our pipeline gap this quarter?" No waiting for an analyst, no writing SQL — an answer in 30 seconds.',
        icon: 'tabler:message-question',
      },
      {
        title: 'Real-Time AI Talk Track Assistance',
        description:
          'During a live call, AI instantly surfaces relevant case studies, objection-handling suggestions, and competitive comparison responses — so every rep performs at the level of your best rep, not just that one top performer.',
        icon: 'tabler:message-chatbot',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=870&q=80',
      alt: 'AI Assistant',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">AI Assistant: Turn the 72% of Admin Work Back Into Selling Time</h3>
      The gap between top performers and average reps is rarely about skill. It is about how much time they actually spend selling.
    </Fragment>
  </Content>

  <!-- Features3: Why Aitroop ******** -->

  <Features3
    tagline="Why Aitroop"
    title="Six Things That Make Aitroop Different"
    subtitle="We are not building another growth tool that is good enough. We are redefining the ceiling of what one person or one team can accomplish with AI."
    columns={2}
    items={[
      {
        title: 'China-Native, Not a Localized Port',
        description:
          'From data sources to compliance design, Aitroop is built natively for the China market. Supports local commercial database integrations, WeCom outreach, RMB billing, and is designed in accordance with PIPL requirements.',
        icon: 'tabler:flag',
      },
      {
        title: 'Intent Radar: Three-Dimensional Signal Fusion',
        description:
          'Website visit behavior + third-party intent data + product usage records — three dimensions fused into a single unified score. You appear in front of a prospect before your competitors have even noticed the opportunity.',
        icon: 'tabler:radar',
      },
      {
        title: 'Waterfall Intelligent Enrichment Engine',
        description:
          'Cascades across multiple data sources in priority order, stopping the moment a match is found. Valid email coverage holds above 80% and bounce rates stay below 3% — results no single data source can deliver alone.',
        icon: 'tabler:filter-bolt',
      },
      {
        title: 'Full-Funnel, Zero Tool Switching',
        description:
          'From finding target prospects to closing deals and securing renewals, every step is completed on one platform. What you save is not just the cost of separate tools — it is the focus lost every time you switch, search, and copy-paste.',
        icon: 'tabler:arrows-join',
      },
      {
        title: 'AI Assistant Fluent in Business Context',
        description:
          'AI-generated outreach emails, meeting summaries, and proposals understand the conventions and communication style of B2B business — not a stiff translation of a Western template. More natural in practice, more effective in results.',
        icon: 'tabler:message-chatbot',
      },
      {
        title: 'A Predictable Growth Engine',
        description:
          'More than an outreach tool — a growth operations platform. AI revenue forecast error under 15%, churn warnings 90 days in advance, pipeline health visible in real time. Growth shifts from gut feel to grounded evidence.',
        icon: 'tabler:trending-up',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Features3: Integrations ******* -->

  <Features3
    title="Integrates with Every Tool You Already Use"
    subtitle="Aitroop is not here to replace your stack — it connects everything together and eliminates the friction between tools."
    columns={2}
    items={[
      {
        title: 'CRM Integrations',
        description: 'Full support for all major CRM platforms — bi-directional real-time sync keeps data consistent whether you are on a domestic or international platform.',
        icon: 'tabler:plug',
      },
      {
        title: 'Data Vendors',
        description: 'Deep integration with multiple commercial databases globally — the Waterfall strategy automatically selects the best data source, providing one-stop coverage for contact data worldwide.',
        icon: 'tabler:database',
      },
      {
        title: 'Communication Tools',
        description: 'Email clients, WeCom, Slack — notifications and workflow triggers delivered directly to the collaboration tools you use every day.',
        icon: 'tabler:message',
      },
      {
        title: 'Marketing Platforms',
        description: 'Ad attribution, UTM management, website tracking — full-path data connected from traffic source all the way through to closed revenue.',
        icon: 'tabler:chart-pie',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="They Changed Their Revenue Trajectory with Aitroop"
    testimonials={[
      {
        testimonial: `I used to spend two or three hours every day researching prospects and writing personalized emails. With Aitroop, I just review what the AI generates. My daily outreach volume went from 20 people to over 100, and my meeting booking rate nearly doubled.`,
        name: 'Chen Jianhong',
        job: 'Business Development, Enterprise Software',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=930&q=80',
          alt: 'Chen Jianhong',
        },
      },
      {
        testimonial: `What surprised me most was the attribution. Before, when leadership asked "how much revenue did this budget generate," I could only give a rough estimate. Now every channel's ROI is crystal clear. Budget approvals are much easier, and the friction between marketing and sales has dropped significantly.`,
        name: 'Lin Yating',
        job: 'Growth Marketing Lead, SaaS Company',
        image: {
          src: 'https://images.unsplash.com/photo-1494790108755-2616b612b786?auto=format&fit=crop&w=774&q=80',
          alt: 'Lin Yating',
        },
      },
      {
        testimonial: `We had been doing revenue forecasting for five years and the error never dropped below 25%. Three quarters after deploying Aitroop, our forecast error has held steady below 12%. That makes a real difference for headcount planning and budget allocation.`,
        name: 'Wang Zhiqiang',
        job: 'Growth Lead, Manufacturing Digitalization Company',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=824&q=80',
          alt: 'Wang Zhiqiang',
        },
      },
    ]}
    callToAction={{
      text: 'Read More Customer Stories',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a 30-min Product Demo',
        href: '/contact',
      },
    ]}
    title="See How Aitroop Transforms Your Growth Efficiency"
    subtitle="Let our team walk through the workflows most relevant to your business scenario."
  />
</Layout>
