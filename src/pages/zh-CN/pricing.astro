---
import Layout from '~/layouts/PageLayout.astro';
import Pricing from '~/components/widgets/Pricing.astro';

const metadata = {
  title: '定价 · Aitroop',
};
---

<Layout metadata={metadata}>
  <Pricing
    title="简单透明的定价"
    subtitle="所有套餐均包含完整平台功能，Token 额度每个计费周期自动补充。"
    tagline="定价"
    prices={[
      {
        title: '月租',
        subtitle: '按月灵活付费',
        price: 20,
        period: '每月',
        items: [
          { description: '每月 $18 AI Token 额度' },
          { description: '完整平台功能权限' },
          { description: '所有应用与自动化工作流' },
          { description: '随时取消' },
        ],
        callToAction: {
          text: '立即开始',
          href: 'https://app.aitroop.net',
        },
      },
      {
        title: '季租',
        subtitle: '按季付费更划算',
        price: 55,
        period: '每季度',
        items: [
          { description: '每季度 $50 AI Token 额度' },
          { description: '完整平台功能权限' },
          { description: '所有应用与自动化工作流' },
          { description: '相比月租节省约 8%' },
        ],
        callToAction: {
          text: '立即开始',
          href: 'https://app.aitroop.net',
        },
      },
      {
        title: '年租',
        subtitle: '年付最超值',
        price: 200,
        period: '每年',
        hasRibbon: true,
        ribbonTitle: '最超值',
        items: [
          { description: '每年 $180 AI Token 额度' },
          { description: '完整平台功能权限' },
          { description: '所有应用与自动化工作流' },
          { description: '相比月租节省约 17%' },
        ],
        callToAction: {
          text: '立即开始',
          href: 'https://app.aitroop.net',
        },
      },
    ]}
  />
</Layout>
