---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI 驱动的增长平台',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <main id="hero-section" class="relative min-h-[calc(100vh-56px)] flex flex-col items-center justify-center px-4 overflow-hidden">

    <div class="absolute inset-0 -z-20" style="background-image:radial-gradient(circle,rgba(0,0,0,0.045) 1px,transparent 1px);background-size:28px 28px;" aria-hidden="true"></div>

    <svg class="absolute inset-0 w-full h-full pointer-events-none -z-10" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
      <defs>
        <filter id="f-aurora" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="65"/>
        </filter>
        <filter id="f-aurora-sm" x="-60%" y="-60%" width="220%" height="220%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="40"/>
        </filter>
      </defs>
      <ellipse class="aurora-a" cx="18%" cy="32%" rx="340" ry="270" fill="rgba(82,153,97,0.11)" filter="url(#f-aurora)"/>
      <ellipse class="aurora-b" cx="83%" cy="68%" rx="300" ry="240" fill="rgba(55,115,72,0.08)" filter="url(#f-aurora)"/>
      <ellipse class="aurora-c" cx="52%" cy="48%" rx="220" ry="170" fill="rgba(110,190,130,0.06)" filter="url(#f-aurora-sm)"/>
    </svg>

    <div class="pgrid-wrap absolute inset-x-[-20%] bottom-0 h-[58%] pointer-events-none -z-10 overflow-hidden" aria-hidden="true">
      <div class="pgrid-inner w-full h-full"></div>
    </div>

    <div id="hero-spot" class="absolute inset-0 pointer-events-none" style="z-index:1;" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[640px] mx-auto flex flex-col items-center gap-4 text-center">

      <div class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-[rgba(82,153,97,0.08)] border border-[rgba(82,153,97,0.22)] px-3 py-1.5 rounded-full">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
        </span>
        AI 智能体增长平台
      </div>

      <h1 class="text-[2rem] md:text-[2.75rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] leading-[1.15] -mt-1">
        精准获客。快速转化。<span class="hero-shimmer">持续留存。</span>
      </h1>

      <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] max-w-[420px] leading-[1.8] -mt-1">
        一支 AI 智能体军团，各司其职，覆盖完整增长链路。情报、触达、转化、留存，一个平台全搞定。一个操盘手，整支团队的战斗力。
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mt-1">
        <a href="https://app.aitroop.net" class="inline-flex items-center gap-2 h-10 px-5 rounded-[7px] bg-primary text-white text-sm font-semibold shadow-[0_1px_3px_rgba(82,153,97,0.45),0_0_0_1px_rgba(82,153,97,0.22)] hover:bg-[rgb(61,133,79)] hover:shadow-[0_2px_8px_rgba(82,153,97,0.5)] transition-all duration-150">
          登录 Aitroop
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/zh-CN/blog" class="inline-flex items-center h-10 px-5 rounded-[7px] text-sm font-medium text-[var(--aw-color-text-muted)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.2)] hover:text-[var(--aw-color-text-default)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
          阅读博客
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px mt-3 w-full max-w-[440px] rounded-xl border border-[var(--aw-color-border)] overflow-hidden bg-[var(--aw-color-border)]">
        {[
          ['6×', '外发量提升'],
          ['90天', '流失预警'],
          ['80%+', '数据覆盖'],
          ['15%', '回复率'],
        ].map(([metric, label]) => (
          <div class="flex flex-col items-center gap-0.5 py-3 bg-[var(--aw-color-bg-page)]">
            <span class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] tabular-nums">{metric}</span>
            <span class="text-[0.65rem] text-[var(--aw-color-text-muted)] leading-tight px-1">{label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="absolute bottom-0 inset-x-0 h-28 pointer-events-none -z-10" style="background:linear-gradient(to top,rgba(255,255,255,1) 0%,transparent 100%);" aria-hidden="true"></div>
  </main>

  <!-- 行业滚动标签 -->
  <div class="border-y border-[var(--aw-color-border)] py-5 overflow-hidden" style="background:rgba(82,153,97,0.018);">
    <p class="text-center text-[0.6rem] uppercase tracking-[0.18em] text-[var(--aw-color-text-muted)] mb-4 font-semibold opacity-60">服务各行业增长团队</p>
    <div class="relative flex overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_8%,black_92%,transparent)]">
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0">
        {['B2B SaaS', '电商', '金融科技', '营销技术', '销售团队', '增长代理', 'D2C 品牌', '企业 GTM', 'PLG 产品', '初创公司'].map(n => (
          <li class="text-[0.8125rem] font-medium text-[var(--aw-color-text-muted)] opacity-45 hover:opacity-80 transition-opacity cursor-default select-none whitespace-nowrap">{n}</li>
        ))}
      </ul>
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0" aria-hidden="true">
        {['B2B SaaS', '电商', '金融科技', '营销技术', '销售团队', '增长代理', 'D2C 品牌', '企业 GTM', 'PLG 产品', '初创公司'].map(n => (
          <li class="text-[0.8125rem] font-medium text-[var(--aw-color-text-muted)] opacity-45 whitespace-nowrap select-none">{n}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- 六大智能体 -->
  <Features2
    id="agents"
    tagline="AI 增长军团"
    title="六位专家，一个统一平台。"
    subtitle="每个智能体专为增长链路中的特定阶段打造，全天候运转，让你的团队专注于只有人类才能做的事。"
    columns={3}
    items={[
      { title: '探查智能体', description: '扫描海量信号，精准浮现高匹配度线索——融合公司阶段、招聘动态、技术栈与意图数据，构建精准目标名单。', icon: 'tabler:radar' },
      { title: '触达智能体', description: '撰写并发送高度个性化的冷邮件和 LinkedIn 消息。无模板——每条消息都针对每位收件人量身定制。', icon: 'tabler:mail-forward' },
      { title: '跟进智能体', description: '跨渠道智能跟进，根据每位潜客的互动信号和对话历史动态调整语气与时机。', icon: 'tabler:messages' },
      { title: '转化智能体', description: '在最关键的时刻为销售代表提供成交洞察——异议处理、社会证明、竞品情报和下一步行动建议。', icon: 'tabler:target' },
      { title: '留存智能体', description: '持续监控使用模式和健康分，提前 90 天预警流失风险账户，让你在还来得及时采取行动。', icon: 'tabler:shield-check' },
      { title: '洞察智能体', description: '将整条销售管道提炼为清晰可执行的建议。明确告诉你下一步应聚焦在哪里，以及为什么——无需翻遍仪表盘。', icon: 'tabler:chart-line' },
    ]}
  />

  <!-- 如何使用 -->
  <Steps
    id="how-it-works"
    tagline="极简设计"
    title="几分钟内启动运转。"
    subtitle="无需半年漫长部署，无需外部咨询团队。Aitroop 追求快速落地，随时间持续复利增长。"
    items={[
      { title: '接入你的工具栈', description: '10 分钟内完成 CRM、邮件服务和 LinkedIn 的连接。原生支持 HubSpot、Salesforce、Apollo、Outreach 等主流工具。', icon: 'tabler:plug-connected' },
      { title: '部署你的智能体', description: '根据增长优先级选择对应的智能体，配置好参数即可。无需编写任何代码，安装向导自动完成剩余操作。', icon: 'tabler:robot' },
      { title: '智能体开始工作', description: '自动化的线索挖掘、个性化触达和智能跟进持续运转——夜间、周末、跨时区，永不停歇。', icon: 'tabler:rocket' },
      { title: '度量与规模化', description: '洞察智能体呈现哪些在奏效、哪些不行。一键放大效果好的营销活动，砍掉无效投入。', icon: 'tabler:trending-up' },
    ]}
  />

  <!-- 数据指标 -->
  <section id="stats-section" class="relative border-y border-[var(--aw-color-border)] overflow-hidden">
    <div class="absolute inset-0 -z-10" style="background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(82,153,97,0.05) 0%,transparent 70%);" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 md:px-6 py-14 md:py-20 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="text-center mb-12">
        <p class="text-[0.65rem] uppercase tracking-[0.18em] font-semibold text-primary mb-2 opacity-80">真实成果</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--aw-color-text-heading)]">驱动增长的数字。</h2>
        <p class="text-[var(--aw-color-text-muted)] mt-3 max-w-md mx-auto text-sm md:text-[0.9375rem]">来自在生产环境中运行 Aitroop 智能体的增长团队的汇总数据。</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
        {[
          { target: 6,  suffix: '×',   label: '外发容量提升' },
          { target: 90, suffix: '天',  label: '平均流失预警周期' },
          { target: 80, suffix: '%+',  label: '联系人数据覆盖率' },
          { target: 15, suffix: '%',   label: '平均回复率' },
        ].map(({ target, suffix, label }, i) => (
          <div class="stat-card text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.3)] hover:shadow-[0_6px_28px_rgba(82,153,97,0.1)] hover:-translate-y-1.5" style={`--i:${i};`}>
            <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1 leading-none">
              <span class="stat-num" data-target={target}>0</span><span class="stat-suffix">{suffix}</span>
            </div>
            <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-2">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 用户评价 -->
  <Testimonials
    id="testimonials"
    tagline="团队的声音"
    title="增长团队都爱用 Aitroop。"
    subtitle="无论是重度 SDR 外呼团队，还是精简 PLG 模型——Aitroop 适配你的增长方式。"
    testimonials={[
      { testimonial: '我们的外发序列从每月 200 条扩展到 1400 条，人员没有增加。触达智能体写的冷邮件，说实话，比我们大多数 SDR 写得还好。', name: '林晓晴', job: '增长负责人 · Patrly' },
      { testimonial: '90 天流失预警真的很厉害。上个季度我们靠 Aitroop 的预警保住了三个企业大客户——比他们主动提出取消还早。', name: '陈志远', job: '销售副总裁 · Clearflo' },
      { testimonial: '以前我们要把五个工具拼在一起完成这个流程。现在一个平台搞定。60 天内 GTM 速度翻倍，运营开销反而下降了。', name: '王嘉怡', job: '首席营销官 · Storyvault' },
    ]}
  />

  <!-- 行动召唤 -->
  <CallToAction
    id="cta-section"
    title="你的增长团队，已准备就绪。"
    subtitle="几分钟内部署你的第一个 AI 智能体，看着销售管道动起来。"
    actions={[
      { text: '立即开始', href: 'https://app.aitroop.net', variant: 'primary' },
      { text: '联系我们', href: '/zh-CN/contact', variant: 'secondary' },
    ]}
  />

</Layout>

<style>
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-100%); } }
  .marquee-track { animation: marquee 34s linear infinite; }

  .aurora-a { animation: aurora-a 18s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }
  .aurora-b { animation: aurora-b 22s ease-in-out infinite reverse; transform-box: fill-box; transform-origin: center; }
  .aurora-c { animation: aurora-c 14s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }
  @keyframes aurora-a { 0%,100%{transform:translate(0,0) scale(1);} 33%{transform:translate(4%,-6%) scale(1.12);} 66%{transform:translate(-3%,5%) scale(0.93);} }
  @keyframes aurora-b { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(-5%,-8%) scale(1.18);} }
  @keyframes aurora-c { 0%,100%{transform:translate(0,0) scale(1);opacity:.8;} 50%{transform:translate(3%,4%) scale(1.25);opacity:1;} }

  .pgrid-wrap { mask-image:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 100%); -webkit-mask-image:linear-gradient(to top,rgba(0,0,0,0.55) 0%,transparent 100%); }
  .pgrid-inner { background-image:linear-gradient(rgba(82,153,97,0.10) 1px,transparent 1px),linear-gradient(90deg,rgba(82,153,97,0.10) 1px,transparent 1px); background-size:64px 64px; transform:perspective(460px) rotateX(58deg); transform-origin:50% 0%; animation:grid-scroll 7s linear infinite; }
  @keyframes grid-scroll { from{background-position:0 0;} to{background-position:0 64px;} }

  @keyframes text-shimmer { 0%{background-position:-200% center;} 100%{background-position:200% center;} }
  .hero-shimmer { background:linear-gradient(90deg,#3a7d4a 0%,#529961 28%,#8de0a0 52%,#529961 72%,#3a7d4a 100%); background-size:200% auto; -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; animation:text-shimmer 4.5s linear infinite; }

  #agents .rounded-lg { position:relative; overflow:hidden; will-change:transform; transition:box-shadow .25s ease,border-color .25s ease; }
  #agents .rounded-lg::after { content:''; position:absolute; inset:0; background:linear-gradient(108deg,transparent 18%,rgba(255,255,255,0.11) 50%,transparent 82%); transform:translateX(-160%); pointer-events:none; }
  #agents .rounded-lg:hover::after { animation:card-shine .55s ease forwards; }
  #agents .rounded-lg:hover { box-shadow:0 16px 48px rgba(82,153,97,0.14),0 3px 10px rgba(82,153,97,0.07); border-color:rgba(82,153,97,0.25) !important; }
  @keyframes card-shine { to{transform:translateX(160%);} }

  .stat-card { opacity:0; filter:blur(6px); transform:translateY(12px) scale(0.97); transition:opacity .55s ease,filter .55s ease,transform .55s ease; }
  .stat-card.visible { opacity:1; filter:blur(0); transform:translateY(0) scale(1); }

  #cta-section .rounded-md { animation:cta-breathe 3.5s ease-in-out infinite; }
  @keyframes cta-breathe { 0%,100%{box-shadow:0 0 0 1px rgba(82,153,97,0.18),0 8px 32px rgba(82,153,97,0.07);} 50%{box-shadow:0 0 0 1px rgba(82,153,97,0.45),0 0 56px rgba(82,153,97,0.16),0 8px 32px rgba(82,153,97,0.1);} }

  #testimonials .grid>div:nth-child(1){animation-delay:0ms !important;}
  #testimonials .grid>div:nth-child(2){animation-delay:130ms !important;}
  #testimonials .grid>div:nth-child(3){animation-delay:260ms !important;}

  @media (prefers-reduced-motion:reduce) {
    .marquee-track,.aurora-a,.aurora-b,.aurora-c,.pgrid-inner,.hero-shimmer,#cta-section .rounded-md{animation:none !important;}
    .hero-shimmer{-webkit-text-fill-color:#529961;color:#529961;}
    .stat-card{opacity:1;filter:none;transform:none;}
  }
</style>

<script>
  const spot = document.getElementById('hero-spot');
  const heroSection = document.getElementById('hero-section');
  if (spot && heroSection) {
    heroSection.addEventListener('mousemove', (e: MouseEvent) => {
      const r = heroSection.getBoundingClientRect();
      spot.style.background = `radial-gradient(680px circle at ${e.clientX-r.left}px ${e.clientY-r.top}px,rgba(82,153,97,0.065),transparent 48%)`;
    });
    heroSection.addEventListener('mouseleave', () => { spot.style.background = ''; });
  }

  document.querySelectorAll<HTMLElement>('#agents .rounded-lg').forEach((card) => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      card.style.transition = 'box-shadow .25s ease,border-color .25s ease';
      const r = card.getBoundingClientRect();
      const rx = (0.5 - (e.clientY-r.top)/r.height) * 16;
      const ry = ((e.clientX-r.left)/r.width - 0.5) * 16;
      card.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(10px)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform .5s cubic-bezier(.03,.98,.52,.99),box-shadow .25s ease,border-color .25s ease';
      card.style.transform = '';
    });
  });

  const statsSection = document.getElementById('stats-section');
  if (statsSection) {
    const io = new IntersectionObserver((entries) => {
      if (!entries[0].isIntersecting) return;
      io.disconnect();
      statsSection.querySelectorAll<HTMLElement>('.stat-card').forEach((card, i) => {
        const delay = i * 110;
        setTimeout(() => card.classList.add('visible'), delay);
        const numEl = card.querySelector<HTMLElement>('.stat-num');
        if (!numEl) return;
        const target = parseInt(numEl.dataset.target ?? '0', 10);
        const DIGITS = '0123456789';
        let start: number | null = null;
        const tick = (ts: number) => {
          if (!start) start = ts;
          const e = ts - start;
          if (e < 700) { numEl.textContent = DIGITS[Math.floor(Math.random()*10)]; requestAnimationFrame(tick); }
          else if (e < 1400) { const t = (e-700)/700; numEl.textContent = String(Math.round((1-Math.pow(1-t,3))*target)); requestAnimationFrame(tick); }
          else numEl.textContent = String(target);
        };
        setTimeout(() => requestAnimationFrame(tick), delay+200);
      });
    }, { threshold: 0.35 });
    io.observe(statsSection);
  }
</script>
