---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import ChatToAppDemo from '~/components/widgets/ChatToAppDemo.astro';
import WorkflowLifecycle from '~/components/widgets/WorkflowLifecycle.astro';

const metadata = {
  title: 'Aitroop — 把 AI Agent 对话固化成 App',
  ignoreTitleTemplate: true,
};

const pieces = [
  {
    icon: 'tabler:puzzle',
    label: '150+ 技能',
    title: '技能 Skills',
    desc: '可复用的能力模块：线索挖掘、网页抓取、SEO 审计、github-mcp、calendar-mcp 等。一键安装。',
    items: ['github-mcp', 'lead-finder', 'web-scrape', 'seo-audit', 'gmail-search', '更多'],
  },
  {
    icon: 'tabler:plug-connected',
    label: '20+ 集成',
    title: '集成 Connects',
    desc: 'OAuth 连接你已在使用的系统。Agent 通过你授权的账户读写数据。',
    items: ['google-drive', 'gmail', 'github', 'salesforce', 'hubspot', 'notion'],
  },
  {
    icon: 'tabler:calendar-clock',
    label: 'cron 驱动',
    title: '调度 Schedules',
    desc: '将任意 App 设为定时任务。日报、小时轮询、周度汇总——结果自动送达。',
    items: ['daily', 'hourly', 'weekly', '自定义 cron', '事件触发', '手动'],
  },
  {
    icon: 'tabler:files',
    label: '7 种格式',
    title: '产物 Artifacts',
    desc: '一等公民的产出物，可预览、编辑、下载，并作为下一阶段的输入继续流转。',
    items: ['markdown', 'code', 'html', 'json', 'csv', 'image', 'file'],
  },
];

const anatomy = [
  { n: '01', title: 'AppInput',  desc: '基于 Schema 的表单：text、daterange、select、file、connect_file——按需声明，自动渲染。' },
  { n: '02', title: 'Stage',     desc: '一次独立的 AI Agent 会话，带明确目标。大多数 App 仅需一个；多 Stage 时产物自动向后流转。' },
  { n: '03', title: 'Artifact',  desc: '最终交付物。可渲染预览、导出，也能回到 Chat 继续编辑或喂给下一个 Stage。' },
];

const cases = [
  {
    slug: '/zh-CN/use-cases/gtm',
    eyebrow: 'B2B 增长',
    title: 'GTM',
    desc: '线索挖掘、外部触达、客户留存、管道洞察——Agent 驱动的增长能力套件。',
    examples: ['线索富化', '冷邮件草稿', '账户健康监控', '管道洞察'],
  },
  {
    slug: '/zh-CN/use-cases/finance',
    eyebrow: '财务团队',
    title: '财务 Finance',
    desc: '月结、应收账款、费用合规、预算差异分析——面向财务团队与 CFO。',
    examples: ['月结清单', '应收账龄报告', '费用稽核', '差异分析叙事'],
  },
];

const demoStrings = {
  modeChatLabel: '模式 1 · Chat',
  modeAppLabel: '模式 2 · App',
  liveLabel: '实时演示 · 循环播放',
  youLabel: '你',
  agentLabel: 'Agent',
  promptParts: [
    '拉取 2025-05-01 至 05-07 的提交',
    '按仓库分组、忽略 merge 提交，',
    '整理成中文工作日报。',
  ] as [string, string, string],
  promptCode: 'shop-frontend',
  saveAsAppLabel: '存为 App',
  appTitle: '工作日报',
  appVersion: 'v3 · public',
  dateRangeLabel: '日期范围',
  repoLabel: '代码仓库',
  langLabel: '输出语言',
  langValue: '中文',
  runLabel: '运行',
  artifactLabel: 'daily-report.md',
  artifactRows: [
    '## 周一 · 4 个仓库共 12 个 PR',
    '- feat(api): /v2/orders 加分页',
    '- fix(ui): 购物车合计四舍五入',
  ],
};

const lifecycleSteps = [
  { icon: 'tabler:messages', label: '对话' },
  { icon: 'tabler:device-floppy', label: '保存' },
  { icon: 'tabler:forms', label: '表单' },
  { icon: 'tabler:player-play', label: '运行' },
  { icon: 'tabler:file-text', label: '产物' },
  { icon: 'tabler:repeat', label: '调度' },
];
---

<Layout metadata={metadata}>

  <!-- ══════════════════════════ HERO ══════════════════════════ -->
  <section class="relative isolate overflow-hidden">
    <div aria-hidden="true" class="aurora">
      <div class="aurora-a"></div>
      <div class="aurora-b"></div>
    </div>
    <div aria-hidden="true" class="grid-bg"></div>

    <div class="mx-auto max-w-6xl px-6 md:px-10 pt-16 md:pt-24 lg:pt-28 pb-20 md:pb-28">
      <div class="grid lg:grid-cols-[1.05fr_1fr] gap-10 lg:gap-16 items-center">

        <div class="hero-copy">
          <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)]/80 backdrop-blur-sm mb-6 shadow-[0_1px_0_rgba(255,255,255,0.6)_inset]">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full rounded-full bg-primary opacity-60 animate-ping"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
            </span>
            <span class="text-[0.6875rem] tracking-[0.18em] uppercase font-mono text-[var(--aw-color-text-muted)]">AI Agent 平台</span>
          </div>

          <h1 class="hero-h1">
            把 Agent <span class="strike-pop">对话</span><br/>
            <span class="text-primary">固化成 App。</span>
          </h1>

          <p class="hero-sub">
            在 Chat 里探索出有效方法后，保存为带表单与定时任务的 <span class="font-mono text-[var(--aw-color-text-default)]">App</span>。
            团队拿到的是可复用的 AI 工作流——无需编码，也无需复制粘贴长 Prompt。
          </p>

          <div class="flex flex-wrap items-center gap-3 mb-8">
            <a href="https://app.aitroop.net"
               class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-[0_6px_20px_-6px_rgba(82,153,97,0.5)]">
              免费开始
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/zh-CN/use-cases"
               class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
              查看案例
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-[0.75rem] font-mono text-[var(--aw-color-text-muted)] tracking-tight">
            <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>多租户</span>
            <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>OAuth 集成</span>
            <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>150+ 内置技能</span>
            <span class="inline-flex items-center gap-1.5"><span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>E2B 沙箱隔离</span>
          </div>
        </div>

        <div class="hero-demo">
          <ChatToAppDemo {...demoStrings} />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ WORKFLOW ══════════════════════ -->
  <section class="relative border-t border-[var(--aw-color-border)] bg-[rgba(0,0,0,0.015)]">
    <div class="mx-auto max-w-5xl px-6 md:px-10 py-14 md:py-20">
      <div class="text-center mb-10 md:mb-12">
        <p class="section-label inline-block">完整闭环</p>
        <h2 class="text-[1.5rem] md:text-[1.875rem] font-bold tracking-[-0.02em] text-[var(--aw-color-text-heading)]">
          一次对话，跑上一千遍。
        </h2>
      </div>
      <WorkflowLifecycle steps={lifecycleSteps} loopHint="并且会自动循环——定时、按需、Webhook 触发" />
    </div>
  </section>

  <!-- ══════════════════════════ BUILT-IN ══════════════════════ -->
  <section class="border-y border-[var(--aw-color-border)] py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-14 md:mb-16 max-w-[640px]">
        <p class="section-label">开箱即用</p>
        <h2 class="section-title">Agent 需要的一切，都在这里。</h2>
        <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.75]">
          不需要组装集成，也不需要写胶水代码。挑选技能、授权系统、设置调度——发布上线。
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        {pieces.map((p) => (
          <div class="piece-card intersect intersect-once motion-safe:opacity-0 motion-safe:translate-y-3 motion-safe:[&:not([no-intersect])]:opacity-100 motion-safe:[&:not([no-intersect])]:translate-y-0 motion-safe:transition-all motion-safe:duration-700">
            <div class="flex items-start justify-between mb-4">
              <div class="piece-icon">
                <Icon name={p.icon} class="w-4 h-4" />
              </div>
              <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] px-2 py-0.5 rounded-full border border-[var(--aw-color-border)]">{p.label}</span>
            </div>
            <h3 class="text-[1.0625rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{p.title}</h3>
            <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.65] mb-4">{p.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {p.items.map((item) => (
                <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-[var(--aw-color-bg-subtle)] text-[0.6875rem] font-mono text-[var(--aw-color-text-muted)]">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ ANATOMY ══════════════════════ -->
  <section class="py-24 md:py-32 bg-[rgba(0,0,0,0.015)]">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-14 md:mb-16 max-w-[640px]">
        <p class="section-label">App 的解剖</p>
        <h2 class="section-title">一个 App，三块拼图。</h2>
        <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.75]">
          整个平台的核心只有三个原语。简单可推理，灵活可组合。
        </p>
      </div>

      <div class="anatomy">
        <div aria-hidden="true" class="anatomy-rail"></div>
        <div class="grid md:grid-cols-3 gap-6 md:gap-8 relative">
          {anatomy.map((a) => (
            <div class="anatomy-card intersect intersect-once motion-safe:opacity-0 motion-safe:translate-y-3 motion-safe:[&:not([no-intersect])]:opacity-100 motion-safe:[&:not([no-intersect])]:translate-y-0 motion-safe:transition-all motion-safe:duration-700">
              <div class="anatomy-num">{a.n}</div>
              <h3 class="anatomy-title">{a.title}</h3>
              <p class="anatomy-desc">{a.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-14 md:mt-16 p-5 rounded-xl bg-[var(--aw-color-bg-page)] border border-[var(--aw-color-border)] inline-block shadow-[0_1px_0_rgba(255,255,255,0.6)_inset]">
        <code class="text-[0.8125rem] md:text-[0.875rem] font-mono text-[var(--aw-color-text-default)] leading-relaxed">
          <span class="text-primary">App</span> = <span class="text-primary">AppInput</span>[] + <span class="text-primary">Stage</span>[] + <span class="text-primary">Artifact</span>[]
        </code>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ USE CASES ════════════════════ -->
  <section class="border-y border-[var(--aw-color-border)] py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-14 md:mb-16 max-w-[640px]">
        <p class="section-label">案例</p>
        <h2 class="section-title">为团队真实要做的事而设计。</h2>
        <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.75]">
          我们提供预置 App 包，覆盖各团队的常见工作流。开箱即用，或 fork 后改造为你自己的流程。
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {cases.map((c) => (
          <a href={c.slug} class="case-card intersect intersect-once motion-safe:opacity-0 motion-safe:translate-y-3 motion-safe:[&:not([no-intersect])]:opacity-100 motion-safe:[&:not([no-intersect])]:translate-y-0 motion-safe:transition-all motion-safe:duration-700">
            <p class="text-[0.6875rem] font-mono uppercase tracking-[0.18em] text-[var(--aw-color-text-muted)] mb-3">{c.eyebrow}</p>
            <h3 class="text-[1.75rem] md:text-[2rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)] mb-2.5 group-hover:text-primary transition-colors">{c.title}</h3>
            <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-6">{c.desc}</p>
            <div class="space-y-1.5 mb-6">
              {c.examples.map((ex) => (
                <div class="flex items-center gap-2 text-[0.8125rem] text-[var(--aw-color-text-default)]">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-primary/70 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  <span class="font-mono text-[0.75rem]">{ex}</span>
                </div>
              ))}
            </div>
            <div class="inline-flex items-center gap-1.5 text-[0.8125rem] font-medium text-primary">
              查看案例详情
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ CTA ══════════════════════════ -->
  <section class="relative isolate overflow-hidden py-24 md:py-32">
    <div aria-hidden="true" class="cta-glow"></div>
    <div class="mx-auto max-w-3xl px-6 md:px-10 text-center relative">
      <h2 class="text-[1.875rem] md:text-[2.5rem] font-bold tracking-[-0.025em] leading-[1.15] text-[var(--aw-color-text-heading)] mb-4">
        午饭前发布你的<br/>第一个 App。
      </h2>
      <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-8 max-w-[480px] mx-auto">
        打开对话，跑通一次，点击<span class="font-mono"> 存为 App </span>——就是整个流程。
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-[0_6px_20px_-6px_rgba(82,153,97,0.5)]">
          免费开始
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/zh-CN/contact"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
          联系我们
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-label {
    font-size: 0.6875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.875rem;
  }
  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--aw-color-text-heading);
    margin-bottom: 1rem;
  }
  .hero-h1 {
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--aw-color-text-heading);
    margin-bottom: 1.4rem;
  }
  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--aw-color-text-muted);
    max-width: 540px;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) { .hero-sub { font-size: 1.125rem; } }

  .strike-pop { position: relative; display: inline-block; }
  .strike-pop::after {
    content: '';
    position: absolute;
    left: -4px; right: -4px;
    bottom: 0.06em;
    height: 0.36em;
    background: rgba(82, 153, 97, 0.18);
    border-radius: 3px;
    z-index: -1;
  }

  .aurora {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 120%;
    z-index: -2;
    pointer-events: none;
  }
  .aurora-a, .aurora-b {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.9;
  }
  .aurora-a {
    top: -10%; left: 5%;
    width: 55%; height: 70%;
    background: radial-gradient(circle, rgba(82, 153, 97, 0.22), transparent 65%);
  }
  .aurora-b {
    top: 10%; right: -10%;
    width: 50%; height: 60%;
    background: radial-gradient(circle, rgba(82, 153, 97, 0.14), transparent 65%);
  }
  @media (prefers-reduced-motion: no-preference) {
    .aurora-a { animation: aurora-drift-a 28s ease-in-out infinite; }
    .aurora-b { animation: aurora-drift-b 36s ease-in-out infinite; }
  }
  @keyframes aurora-drift-a {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(2%, 3%, 0) scale(1.08); }
  }
  @keyframes aurora-drift-b {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(-2%, -2%, 0) scale(1.06); }
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.35;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.045) 1px, transparent 1px);
    background-size: 44px 44px;
    -webkit-mask-image: radial-gradient(ellipse 75% 55% at 50% 0%, #000 30%, transparent 78%);
    mask-image: radial-gradient(ellipse 75% 55% at 50% 0%, #000 30%, transparent 78%);
  }

  .piece-card {
    position: relative;
    padding: 1.5rem 1.75rem;
    border-radius: 16px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    transition: border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
  }
  .piece-card:hover {
    border-color: rgba(82, 153, 97, 0.35);
    box-shadow: 0 8px 30px rgba(82, 153, 97, 0.09);
    transform: translateY(-1px);
  }
  .piece-card:hover .piece-icon {
    background: rgba(82, 153, 97, 0.16);
    transform: scale(1.04);
  }
  .piece-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: rgba(82, 153, 97, 0.08);
    color: var(--aw-color-primary);
    display: flex; align-items: center; justify-content: center;
    transition: background 200ms ease, transform 200ms ease;
  }

  .anatomy { position: relative; }
  .anatomy-rail {
    display: none;
    position: absolute;
    top: 28px; left: 8%; right: 8%;
    height: 1px;
    background: linear-gradient(to right,
      transparent,
      var(--aw-color-border) 10%,
      var(--aw-color-border) 90%,
      transparent
    );
    z-index: 0;
  }
  @media (min-width: 768px) { .anatomy-rail { display: block; } }
  .anatomy-card {
    position: relative;
    padding: 1.5rem 1.75rem 1.75rem;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    border-radius: 16px;
    z-index: 1;
  }
  .anatomy-num {
    width: 56px; height: 56px;
    margin: -2.25rem 0 1.25rem;
    border-radius: 9999px;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    display: flex; align-items: center; justify-content: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.875rem; font-weight: 700;
    color: var(--aw-color-primary);
    box-shadow: 0 4px 14px -6px rgba(82, 153, 97, 0.25);
