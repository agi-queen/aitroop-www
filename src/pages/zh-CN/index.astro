---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Aitroop — AI 驱动的 B2B 增长平台',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <main class="min-h-[calc(100vh-56px)] flex flex-col items-center justify-center px-4 text-center">
    <div class="max-w-2xl mx-auto flex flex-col items-center gap-8">

      <span class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-[rgba(82,153,97,0.08)] border border-[rgba(82,153,97,0.2)] px-3 py-1 rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span>
        AI 驱动的 B2B 增长
      </span>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tighter text-[var(--aw-color-text-heading)] leading-[1.08]">
        精准获客。<br />持续留存。
      </h1>

      <p class="text-lg text-[var(--aw-color-text-muted)] max-w-md leading-relaxed">
        AI军团为你的团队提供 AI 原生的精准触达、客户洞察和留存工具——让一个人创造整个团队的成果。
      </p>

      <div class="flex items-center gap-3">
        <a
          href="https://app.aitroop.net"
          class="inline-flex items-center gap-2 h-10 px-5 rounded-[6px] bg-primary text-white text-sm font-semibold hover:bg-[rgb(61_133_79)] transition-colors duration-150"
        >
          登录 Aitroop
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="/zh-CN/blog"
          class="inline-flex items-center h-10 px-5 rounded-[6px] text-sm font-medium text-[var(--aw-color-text-muted)] hover:text-[var(--aw-color-text-default)] hover:bg-[rgba(0,0,0,0.04)] transition-colors duration-150"
        >
          阅读博客
        </a>
      </div>

    </div>
  </main>
</Layout>
