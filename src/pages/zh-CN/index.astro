---
import Layout from '~/layouts/PageLayout.astro';
import AnatomyFlow from '~/components/widgets/AnatomyFlow.astro';

const metadata = {
  title: 'Aitroop - 把 AI Agent 对话固化成 App',
  ignoreTitleTemplate: true,
};

const anatomySteps = [
  {
    title: 'AppInput',
    desc: '基于 Schema 的表单。text、select、daterange、file，声明一次，自动渲染。',
    foot: '4 种输入类型 · 内置校验',
  },
  {
    title: 'Stage',
    desc: '带明确目标的 Agent 会话，连入你的技能与集成。需要时多 Stage 串联成管道。',
    foot: '150+ 技能 · 20+ 集成',
  },
  {
    title: 'Artifact',
    desc: '可交付的产物。预览、导出，或直接喂给下一个 Stage。',
    foot: '7 种格式 · 预览 + 导出',
  },
];

const stats = [
  { value: '150+', label: '技能' },
  { value: '20+',  label: '集成' },
  { value: 'cron', label: '调度' },
  { value: '7',    label: '产物格式' },
];

const cases = [
  { slug: '/zh-CN/use-cases/gtm',     title: 'GTM',     desc: '线索挖掘、外部触达、客户留存、管道洞察。' },
  { slug: '/zh-CN/use-cases/finance', title: '财务',    desc: '月结、稽核、差异分析、报告。专为 CFO 团队设计。' },
];
---

<Layout metadata={metadata}>

  <!-- HERO — app showcase 布局 ────────────────────────────────────── -->
  <section class="aw-hero hero relative isolate overflow-hidden">
    <div aria-hidden="true" class="hero-dots"></div>
    <div aria-hidden="true" class="hero-glow"></div>
    <div class="aw-container-wide">
      <div class="hero-copy">
        <a href="/zh-CN/use-cases" class="hero-pill">
          <span class="pill-tag">NEW</span>
          <span class="pill-text">150+ 技能 · 20+ 集成</span>
          <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <h1 class="aw-display hero-display">
          强大的 Agent。<br />
          无尽的技能。<br />
          <span class="text-primary">一键即用的 App。</span>
        </h1>
        <p class="aw-lede hero-lede">
          一键就把刚刚跑通的 Agent 流程沉淀为 App，团队可以反复运行。不再重敲 prompt，不再写胶水代码。
        </p>
        <div class="aw-actions hero-actions">
          <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">免费开始</a>
          <a href="/zh-CN/use-cases" class="aw-btn aw-btn-ghost">查看案例</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS — quiet strip just below the fold ────────────────────── -->
  <section class="stats-section">
    <div class="aw-container">
      <ul class="stats" role="list">
        {stats.map((s) => (
          <li class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ANATOMY ──────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <AnatomyFlow
        eyebrow=""
        title="三块拼图。一条管道。"
        lede="输入喂给 Stage。Stage 产出 Artifact。Artifact 流向下游，或作为下一个 Stage 的输入。"
        steps={anatomySteps}
      />
    </div>
  </section>

  <!-- USE CASES ────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">案例</p>
        <h2 class="aw-h2">为团队真实在做的事而设计。</h2>
      </header>

      <ul class="cases">
        {cases.map((c) => (
          <li>
            <a href={c.slug}>
              <span class="case-title">{c.title}</span>
              <span class="case-desc">{c.desc}</span>
              <span class="case-arrow aw-arrow" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2 cta-h2">午饭前发布你的第一个 App。</h2>
      <p class="aw-lede">打开对话。点击 <code class="aw-code">存为 App</code>。整个流程就是这样。</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">免费开始</a>
        <a href="/zh-CN/contact" class="aw-btn aw-btn-ghost">联系我们</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ══════════════════════════════════════════════════════════════════
     HERO — shadcn-style "app showcase" layout
     ══════════════════════════════════════════════════════════════════ */
  .hero {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero-dots {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, rgba(10, 10, 10, 0.06) 1px, transparent 0);
    background-size: 22px 22px;
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 22%, #000 25%, transparent 82%);
            mask-image: radial-gradient(ellipse 70% 50% at 50% 22%, #000 25%, transparent 82%);
  }
  .hero-glow {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 80%;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 45% at 50% 10%, rgba(82, 153, 97, 0.08), transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 75% 60% at 50% 0%, #000 25%, transparent 85%);
            mask-image: radial-gradient(ellipse 75% 60% at 50% 0%, #000 25%, transparent 85%);
    animation: hero-breathe 14s ease-in-out infinite;
  }
  @keyframes hero-breathe {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  .hero-copy {
    text-align: center;
    max-width: 56rem;
    margin: 0 auto;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3125rem 0.875rem 0.3125rem 0.4375rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: border-color 200ms ease, color 200ms ease, transform 200ms ease;
  }
  .hero-pill:hover {
    border-color: rgba(82, 153, 97, 0.35);
    color: var(--aw-color-text-default);
  }
  .pill-tag {
    padding: 1px 7px;
    border-radius: 9999px;
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  .pill-arrow {
    width: 12px;
    height: 12px;
    color: var(--aw-color-text-muted);
    transition: transform 200ms ease;
  }
  .hero-pill:hover .pill-arrow { transform: translateX(2px); }

  .hero-display {
    font-size: clamp(2.5rem, 5.6vw, 4.25rem);
    line-height: 1.05;
    margin: 0 auto 1.5rem;
    max-width: 22ch;
  }
  .hero-lede {
    margin: 0 auto 2rem;
    max-width: 44rem;
    font-size: clamp(1.0625rem, 1.25vw, 1.1875rem);
  }
  .hero-actions {
    justify-content: center;
  }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
  .hero-pill,
  .hero-display,
  .hero-lede,
  .hero-actions {
    animation: hero-rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .hero-pill      { animation-delay: 0ms; }
  .hero-display   { animation-delay: 80ms; }
  .hero-lede      { animation-delay: 160ms; }
  .hero-actions   { animation-delay: 240ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow,
    .hero-pill,
    .hero-display,
    .hero-lede,
    .hero-actions {
      animation: none;
    }
  }

  .stats-section {
    padding: 2.5rem 0 4rem;
  }
  @media (min-width: 768px) {
    .stats-section { padding: 3.5rem 0 5rem; }
  }
  .stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem 1rem;
  }
  @media (min-width: 768px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .stat-value {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .cases {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cases li { border-top: 1px solid var(--aw-color-border); }
  .cases li:last-child { border-bottom: 1px solid var(--aw-color-border); }
  .cases a {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "title arrow"
      "desc  arrow";
    column-gap: 1rem;
    row-gap: 0.5rem;
    padding: 1.75rem 0;
    align-items: center;
  }
  @media (min-width: 768px) {
    .cases a {
      grid-template-columns: 12rem 1fr auto;
      grid-template-areas: "title desc arrow";
      column-gap: 2.5rem;
      padding: 2.25rem 0;
    }
  }

  .case-title {
    grid-area: title;
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .case-desc {
    grid-area: desc;
    color: var(--aw-color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .case-arrow {
    grid-area: arrow;
    color: var(--aw-color-text-muted);
    font-size: 1.125rem;
    line-height: 1;
  }

  .cta-h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin: 0 auto 1rem;
    max-width: 18ch;
  }
</style>
