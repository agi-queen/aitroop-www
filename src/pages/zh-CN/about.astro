---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = { title: '关于我们' };
---
<Layout metadata={metadata}>
  <Hero tagline="关于 Aitroop" image={{ src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80', alt: 'Aitroop 团队' }}>
    <Fragment slot="title">我们相信，掌握 AI 技能的人<br /><span class="text-accent dark:text-white">能够创造出过去无法想象的增长成果</span></Fragment>
    <Fragment slot="subtitle">获客难、留客靠感情、工具越用越多但效率越来越低——这些问题的根源不是努力不够，而是方法没有跟上时代。Aitroop 的使命，是让每一个人都能掌握 AI 驱动的获客与留客复合能力，以更少的资源，做出更可持续的增长。</Fragment>
  </Hero>
  <Stats title="我们的影响力" stats={[ { title: '服务客户', amount: '500+' }, { title: 'AI 生成触达内容（每月）', amount: '200万+' }, { title: '用户平均获客效率提升', amount: '8x' }, { title: '客户留存率', amount: '118% NRR' } ]} />
  <Features3 title="我们解决的核心问题" subtitle="Aitroop 的每一个功能，都源自一个真实存在的增长痛点。" columns={3} isBeforeContent={true} items={[ { title: '获客没有系统', description: '靠人脉、靠介绍、靠广告砸钱——这些方式不可复制。我们让获客变成一套可以持续运转的系统，而不是每次都从零开始。', icon: 'tabler:users-plus' }, { title: '个性化触达太费时', description: '要让对方感觉「这是为我写的」，原本需要大量的时间调研和撰写。AI 让这件事快 50 倍，且品质不打折。', icon: 'tabler:mail-bolt' }, { title: '工具越来越多，效率却没提高', description: '每加一个工具，就多一个切换的负担。我们把获客、触达、跟进、留存整合在一个平台，让你的注意力聚焦在增长本身。', icon: 'tabler:apps' } ]} />
  <Features3 columns={3} isAfterContent={true} items={[ { title: '增长缺乏可预测性', description: '不知道哪条渠道真的有效、下个月会来多少新客户——我们让增长有数据支撑，让预测成为决策的依据，而不是猜测。', icon: 'tabler:chart-arrows' }, { title: '重复性工作消耗最好的精力', description: '最有价值的时间，不应该花在填表、复制粘贴和手动跟进上。我们让 AI 处理这些，你专注在需要创意和判断力的事。', icon: 'tabler:clock-x' }, { title: '客户流失没有预警', description: '大多数流失都是可以避免的，只是太晚被发现。我们的健康度监测让你在流失信号出现的早期就能介入。', icon: 'tabler:trending-down' } ]} image={{ src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80', alt: 'Aitroop 解决问题' }} />
  <Steps2 title="我们的核心价值观" subtitle="这些价值观不是墙上的标语，而是我们每一个产品决策和客户互动背后的依据。" items={[ { title: '以用户成果为唯一衡量标准', description: '我们不在乎平台有多少功能，我们在乎的是你用了 Aitroop 之后，获客效率是否真的提升了、客户是否真的留住了、增长是否真的变得更可预测了。如果没有，我们还没有做到足够好。' }, { title: '让复杂的事情变简单', description: '增长本身已经够复杂了，工具不应该再增加认知负担。Aitroop 的设计原则是：任何人不需要技术背景，30 分钟内就能完成第一个完整的获客工作流。' }, { title: '技能比工具更重要', description: '工具会过时，技能不会。Aitroop 不只是让你用 AI，更是让你真正理解如何用 AI 思考和行动——这是别人无法轻易复制的竞争优势。' } ]} />
  <Steps2 title="里程碑" subtitle="从创立到现在，我们每一步都专注在一件事：让 B2B GTM 更智能、更高效。" isReversed={true} callToAction={{ text: '加入我们的旅程', href: '/zh-CN/contact' }} items={[ { title: '深度扎根 B2B GTM 领域', description: '创始团队来自 B2B 销售、营销和 AI 产品领域，深刻理解 GTM 团队的一线痛点，让产品从第一天起就贴近真实业务需求。', icon: 'tabler:plant' }, { title: '专注中国 B2B 市场的本地化', description: '深度整合中国本土商业数据库与主流国内 CRM，原生支持企业微信、微博等中国渠道，理解本土 B2B 销售文化——这不是海外产品汉化，而是为中国市场原生打造。', icon: 'tabler:map-pin' }, { title: '客户驱动的产品迭代', description: '我们的每一个新功能，都来自客户的真实使用场景和反馈。我们的 NPS 和客户留存率是我们最骄傲的产品成绩单。', icon: 'tabler:heart-handshake' } ]} />
  <Features2 title="立即与我们取得联系" tagline="联络方式" columns={2} items={[ { title: '预约产品示范', description: '与我们的顾问一对一交流，展示最适合你业务场景的解决方案。填写表单，我们将在 1 个工作日内回复安排。', icon: 'tabler:calendar' }, { title: '合作与商务洽谈', description: '如果你是数据供应商、CRM 厂商或系统集成商，欢迎探讨合作可能。我们期待与生态伙伴共同打造更完整的 GTM 解决方案。', icon: 'tabler:users' } ]} />
</Layout>
