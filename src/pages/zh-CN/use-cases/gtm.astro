---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'GTM 案例 — Aitroop',
};

const apps = [
  {
    n: '01',
    name: '线索挖掘 Prospecting',
    description: '基于公司信号、招聘动态、技术栈与意向数据找到高匹配账户，按你的 ICP 打分。',
    inputs: ['ICP 描述', '行业筛选', '公司规模', '技术关键词'],
    outputs: ['富化后的线索清单 (CSV)', 'ICP 评分依据 (Markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    n: '02',
    name: '外部触达 Outreach',
    description: '批量生成个性化冷邮件与 LinkedIn 消息。结合企业画像、最新触发事件和你的语气。',
    inputs: ['目标列表', '邮件模板', '发件人画像', '语气'],
    outputs: ['邮件草稿 (Markdown)', 'A/B 变体 (JSON)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    n: '03',
    name: '客户留存 Retention',
    description: '持续监控账户健康分。在客户流失之前预警——使用下滑、支持工单模式、关键人变动。',
    inputs: ['账户列表', '风险阈值', '回看窗口'],
    outputs: ['风险报告 (Markdown)', '账户评分 (CSV)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    n: '04',
    name: '管道洞察 Pipeline insights',
    description: '把管道数据转化为清晰的建议。哪些 deal 应该推、哪些应该降级、时间该投到哪里——一目了然。',
    inputs: ['销售阶段', '时间窗口', '负责人'],
    outputs: ['管道叙事 (Markdown)', 'Deal 评分 (CSV)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];

const why = [
  { title: '复合式产出',     desc: '每一次跑通的对话都变成可复用的 App。团队的集体经验逐周复利。' },
  { title: '原生 CRM 集成',  desc: '通过 OAuth 读写 Salesforce、HubSpot 和数据仓库——不用 Zapier，也不用自写脚本。' },
  { title: '设一次定时',     desc: '每日管道摘要、每周触达清单、每月留存报告。设好 cron 就忘掉它。' },
];
---

<Layout metadata={metadata}>

  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <section class="aw-hero">
    <div class="aw-container">
      <nav class="aw-crumbs">
        <a href="/zh-CN/use-cases">案例</a>
        <span aria-hidden="true">/</span>
        <span>GTM</span>
      </nav>
      <p class="aw-eyebrow">B2B 增长</p>
      <h1 class="aw-display" style="max-width: 14ch;">让管道自动运转。</h1>
      <p class="aw-lede" style="max-width: 52ch;">
        四个预置 App 端到端覆盖 GTM 流程——从找到线索到留住客户。每一个都自带所需的技能与集成，第一天就能跑起来。
      </p>
      <div class="aw-actions">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">安装 GTM 套件</a>
        <a href="/zh-CN/contact" class="aw-btn aw-btn-ghost">预约演示</a>
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">包含的 App</p>
        <h2 class="aw-h2">四个 App，一条营收主线。</h2>
      </header>

      <div class="apps">
        {apps.map((app) => (
          <article class="app">
            <div class="app-head">
              <span class="app-num">{app.n}</span>
              <h3 class="app-title">{app.name}</h3>
            </div>
            <div class="app-body">
              <p class="app-desc">{app.description}</p>
              <dl class="app-meta">
                <div>
                  <dt>输入</dt>
                  <dd>{app.inputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>产物</dt>
                  <dd>{app.outputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>技能</dt>
                  <dd class="mono">{app.skills.join(' · ')}</dd>
                </div>
                <div>
                  <dt>集成</dt>
                  <dd class="mono accent">{app.connects.join(' · ')}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">GTM 团队为什么选 Aitroop</p>
        <h2 class="aw-h2">为可复利的管道工作而设计。</h2>
      </header>
      <div class="why">
        {why.map((w, i) => (
          <article class="aw-piece">
            <span class="aw-piece-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="aw-piece-title">{w.title}</h3>
            <p class="aw-piece-desc">{w.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2" style="max-width: 18ch; margin: 0 auto 1rem;">从 GTM 套件开始。</h2>
      <p class="aw-lede">免费安装。连接 CRM，10 分钟内跑出第一个 App。</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">安装 GTM 套件</a>
        <a href="/zh-CN/use-cases/finance" class="aw-btn aw-btn-ghost">看财务套件</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .apps {
    display: grid;
    gap: 0;
  }
  .app {
    border-top: 1px solid var(--aw-color-text-heading);
    padding: 2rem 0 2.5rem;
  }
  .app:last-child { border-bottom: 1px solid var(--aw-color-border); }
  @media (min-width: 768px) {
    .app {
      display: grid;
      grid-template-columns: 16rem 1fr;
      gap: 3rem;
      padding: 2.25rem 0 2.75rem;
    }
  }
  .app-head {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .app-num {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .app-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.15;
  }
  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
    margin: 1rem 0 1.5rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .app-desc { margin: 0 0 1.5rem; }
  }
  .app-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .app-meta { grid-template-columns: repeat(2, 1fr); gap: 1.125rem 2rem; }
  }
  .app-meta dt {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
    margin: 0 0 0.3125rem;
    line-height: 1;
    font-weight: 600;
  }
  .app-meta dd {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
  }
  .mono { font-family: var(--aw-font-mono, ui-monospace, monospace); }
  .accent { color: var(--aw-color-primary); }

  .why {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .why { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }
</style>
