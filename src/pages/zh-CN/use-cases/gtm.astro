---
import Layout from '~/layouts/PageLayout.astro';
import UseCasePack from '~/components/widgets/UseCasePack.astro';

const metadata = { title: 'GTM 案例 · Aitroop' };

const labels = {
  useCases: '案例',
  inputs: '输入',
  outputs: '产物',
  skills: '技能',
  connects: '集成',
  appsHeading: '四个 App，一条营收主线。',
  nextPack: '下一个套件',
};

const apps = [
  {
    tag: '获客',
    name: '线索挖掘 Prospecting',
    description: '基于公司信号、招聘动态、技术栈与意向数据找到高匹配账户，按你的 ICP 打分。',
    inputs: ['ICP 描述', '行业筛选', '公司规模', '技术关键词'],
    outputs: ['富化后的线索清单 (CSV)', 'ICP 评分依据 (Markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    tag: '触达',
    name: '外部触达 Outreach',
    description: '批量生成个性化冷邮件与 LinkedIn 消息。结合企业画像、最新触发事件和你的语气。',
    inputs: ['目标列表', '邮件模板', '发件人画像', '语气'],
    outputs: ['邮件草稿 (Markdown)', 'A/B 变体 (JSON)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    tag: '留存',
    name: '客户留存 Retention',
    description: '持续监控账户健康分。在客户流失之前预警：使用下滑、支持工单模式、关键人变动。',
    inputs: ['账户列表', '风险阈值', '回看窗口'],
    outputs: ['风险报告 (Markdown)', '账户评分 (CSV)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    tag: 'RevOps',
    name: '管道洞察 Pipeline insights',
    description: '把管道数据转化为清晰的建议。哪些 deal 应该推、哪些应该降级、时间该投到哪里，一目了然。',
    inputs: ['销售阶段', '时间窗口', '负责人'],
    outputs: ['管道叙事 (Markdown)', 'Deal 评分 (CSV)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];
---

<Layout metadata={metadata}>
  <UseCasePack
    crumb="GTM"
    h1="让管道自动运转。"
    lede="四个预置 App 端到端覆盖 GTM 流程：从找到线索到留住客户。每一个都自带所需的技能与集成,第一天就能跑起来。"
    primaryCta={{ label: '安装 GTM 套件', href: 'https://app.aitroop.net' }}
    secondaryCta={{ label: '预约演示', href: '/zh-CN/contact' }}
    apps={apps}
    next={{ href: '/zh-CN/use-cases/finance', name: '财务', tagline: '更快地把账关掉。' }}
    hubHref="/zh-CN/use-cases"
    labels={labels}
  />
</Layout>
