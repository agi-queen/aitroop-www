---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '案例 · Aitroop',
};

const cases = [
  {
    slug: '/zh-CN/use-cases/gtm',
    eyebrow: 'B2B 增长',
    title: 'GTM',
    tagline: '让管道自动运转。',
    desc: '线索挖掘、外部触达、客户留存、管道洞察。为不想增加 headcount 又想持续放大产出的营收团队预置的 App 套件。',
    apps: ['线索挖掘', '外部触达', '客户留存', '管道洞察'],
  },
  {
    slug: '/zh-CN/use-cases/finance',
    eyebrow: '财务团队 · CFO',
    title: '财务',
    tagline: '更快地把账关掉。',
    desc: '月结、应收账款分析、费用合规、预算差异分析。让财务团队少花时间在表格上，多花时间在驱动决策的分析上。',
    apps: ['月结清单', '应收账龄', '费用稽核', '差异分析'],
  },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head">
    <div class="aw-container">
      <p class="aw-eyebrow">案例</p>
      <h1 class="aw-h2">
        团队真实在做的工作，都有预置 App 包。
      </h1>
      <p class="aw-page-head-desc">
        每个套件是策划好的一组 App、技能与集成，开箱即用。直接使用，或 fork 后定制成你团队的流程。
      </p>
    </div>
  </section>

  <!-- PACKS ────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <ul class="packs">
        {cases.map((c) => (
          <li>
            <a href={c.slug} class="group">
              <div class="pack-head">
                <p class="aw-eyebrow-mono">{c.eyebrow}</p>
                <h2 class="pack-title">{c.title}</h2>
                <p class="pack-tagline">{c.tagline}</p>
              </div>
              <div class="pack-body">
                <p class="pack-desc">{c.desc}</p>
                <ul class="pack-apps">
                  {c.apps.map((app) => <li class="aw-tag">{app}</li>)}
                </ul>
                <span class="pack-cta">
                  查看案例
                  <span class="aw-arrow" aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <div class="byo">
        <div class="byo-text">
          <p class="aw-eyebrow">自定义</p>
          <h3 class="byo-title">没找到你的场景？</h3>
          <p class="byo-desc">Aitroop 是把任意 AI 辅助工作流固化成可复用 App 的平台。聊聊你团队的具体场景。</p>
        </div>
        <a href="/zh-CN/contact" class="aw-btn aw-btn-ghost">联系我们</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .packs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .packs > li { border-top: 1px solid var(--aw-color-border-strong); }
  .packs > li:last-child { border-bottom: 1px solid var(--aw-color-border); }
  .packs a {
    display: grid;
    gap: 1.5rem;
    padding: 2rem 0 2.5rem;
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 768px) {
    .packs a {
      grid-template-columns: 16rem 1fr;
      gap: 3.5rem;
      padding: 2.5rem 0 3rem;
    }
  }
  .pack-title {
    font-size: clamp(1.875rem, 3.4vw, 2.375rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--aw-color-text-heading);
    margin: 0 0 0.5rem;
  }
  .pack-tagline {
    font-size: 1rem;
    font-weight: 500;
    color: var(--aw-color-text-default);
    margin: 0;
    line-height: 1.4;
  }
  .pack-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
    margin: 0 0 1.25rem;
    text-wrap: pretty;
  }
  .pack-apps {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pack-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--aw-color-primary);
  }

  .byo {
    margin-top: 3rem;
    padding: 2.5rem 0 0;
    border-top: 1px solid var(--aw-color-border);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .byo {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      margin-top: 4rem;
      padding-top: 3rem;
      gap: 3rem;
    }
  }
  .byo-text { flex: 1; }
  .byo-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
  }
  .byo-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--aw-color-text-muted);
    margin: 0;
    max-width: 56ch;
  }
</style>
