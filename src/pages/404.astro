---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = 'Error 404';
---

<Layout metadata={{ title }}>
  <section class="wrap">
    <div class="aw-container-narrow">
      <p class="aw-eyebrow">404</p>
      <h1 class="aw-display" style="max-width: 16ch; margin-left: auto; margin-right: auto;">
        This page doesn't exist.
      </h1>
      <p class="aw-lede" style="margin: 0 auto 2rem;">
        Try the homepage, or head into the docs to find what you were after.
      </p>
      <div class="aw-actions aw-actions-center">
        <a href={getHomePermalink()} class="aw-btn aw-btn-primary">Back to homepage</a>
        <a href="/docs" class="aw-btn aw-btn-ghost">Read the docs</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .wrap {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: 5rem 0;
  }
</style>
