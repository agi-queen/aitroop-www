---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'GTM 案例 · Aitroop',
};

const apps = [
  {
    tag: '獲客',
    name: '線索挖掘 Prospecting',
    description: '基於公司訊號、招聘動態、技術棧與意向資料找到高匹配帳戶，按你的 ICP 打分。',
    inputs: ['ICP 描述', '行業篩選', '公司規模', '技術關鍵字'],
    outputs: ['富化後的線索清單 (CSV)', 'ICP 評分依據 (Markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    tag: '觸達',
    name: '外部觸達 Outreach',
    description: '批量產生個性化冷郵件與 LinkedIn 訊息。結合企業畫像、最新觸發事件和你的語氣。',
    inputs: ['目標清單', '郵件範本', '寄件人畫像', '語氣'],
    outputs: ['郵件草稿 (Markdown)', 'A/B 變體 (JSON)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    tag: '留存',
    name: '客戶留存 Retention',
    description: '持續監控帳戶健康分。在客戶流失之前預警：使用下滑、支援工單模式、關鍵人變動。',
    inputs: ['帳戶清單', '風險閾值', '回看視窗'],
    outputs: ['風險報告 (Markdown)', '帳戶評分 (CSV)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    tag: 'RevOps',
    name: '管道洞察 Pipeline insights',
    description: '把管道資料轉化為清晰的建議。哪些 deal 應該推、哪些應該降級、時間該投到哪裡，一目了然。',
    inputs: ['銷售階段', '時間視窗', '負責人'],
    outputs: ['管道敘事 (Markdown)', 'Deal 評分 (CSV)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];

const why = [
  { title: '複合式產出',     desc: '每一次跑通的對話都變成可重複使用的 App。團隊的集體經驗逐週複利。' },
  { title: '原生 CRM 整合',  desc: '透過 OAuth 讀寫 Salesforce、HubSpot 和資料倉儲，不用 Zapier，也不用自寫腳本。' },
  { title: '設一次定時',     desc: '每日管道摘要、每週觸達清單、每月留存報告。設好 cron 就忘掉它。' },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head">
    <div class="aw-container">
      <nav class="aw-crumbs">
        <a href="/zh-TW/use-cases">案例</a>
        <span aria-hidden="true">/</span>
        <span>GTM</span>
      </nav>
      <h1 class="aw-h2">讓管道自動運轉。</h1>
      <p class="aw-page-head-desc">
        四個預置 App 端到端覆蓋 GTM 流程：從找到線索到留住客戶。每一個都自帶所需的技能與整合，第一天就能跑起來。
      </p>
      <div class="aw-actions">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">安裝 GTM 套件</a>
        <a href="/zh-TW/contact" class="aw-btn aw-btn-ghost">預約演示</a>
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <h2 class="aw-h2">四個 App，一條營收主線。</h2>
      </header>

      <div class="apps">
        {apps.map((app) => (
          <article class="app">
            <div class="app-head">
              <span class="app-tag">{app.tag}</span>
              <h3 class="app-title">{app.name}</h3>
            </div>
            <div class="app-body">
              <p class="app-desc">{app.description}</p>
              <dl class="app-meta">
                <div>
                  <dt>輸入</dt>
                  <dd>{app.inputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>產物</dt>
                  <dd>{app.outputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>技能</dt>
                  <dd class="mono">{app.skills.join(' · ')}</dd>
                </div>
                <div>
                  <dt>整合</dt>
                  <dd class="mono accent">{app.connects.join(' · ')}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <h2 class="aw-h2">為可複利的管道工作而設計。</h2>
      </header>
      <div class="why">
        {why.map((w) => (
          <article class="aw-piece">
            <h3 class="aw-piece-title">{w.title}</h3>
            <p class="aw-piece-desc">{w.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2" style="max-width: 18ch; margin: 0 auto 1rem;">從 GTM 套件開始。</h2>
      <p class="aw-lede">免費安裝。連接 CRM，10 分鐘內跑出第一個 App。</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">安裝 GTM 套件</a>
        <a href="/zh-TW/use-cases/finance" class="aw-btn aw-btn-ghost">看財務套件</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .apps {
    display: grid;
    gap: 0;
  }
  .app {
    border-top: 1px solid var(--aw-color-border-strong);
    padding: 2rem 0 2.5rem;
  }
  .app:last-child { border-bottom: 1px solid var(--aw-color-border); }
  @media (min-width: 768px) {
    .app {
      display: grid;
      grid-template-columns: 16rem 1fr;
      gap: 3rem;
      padding: 2.25rem 0 2.75rem;
    }
  }
  .app-head {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .app-tag {
    align-self: flex-start;
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1;
  }
  .app-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.15;
  }
  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
    margin: 1rem 0 1.5rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .app-desc { margin: 0 0 1.5rem; }
  }
  .app-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .app-meta { grid-template-columns: repeat(2, 1fr); gap: 1.125rem 2rem; }
  }
  .app-meta dt {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
    margin: 0 0 0.3125rem;
    line-height: 1;
    font-weight: 600;
  }
  .app-meta dd {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
  }
  .mono { font-family: var(--aw-font-mono, ui-monospace, monospace); }
  .accent { color: var(--aw-color-primary); }

  .why {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .why { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }
</style>
