---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'GTM 案例 — Aitroop',
};

const apps = [
  {
    icon: 'tabler:radar-2',
    name: '線索挖掘 Prospecting',
    description: '基於公司訊號、招聘動態、技術棧與意向資料找到高匹配帳戶，按你的 ICP 打分。',
    inputs: ['ICP 描述', '行業篩選', '公司規模', '技術關鍵字'],
    outputs: ['富化後的線索清單 (CSV)', 'ICP 評分依據 (markdown)'],
    skills: ['lead-finder', 'web-scrape', 'company-enrich'],
    connects: ['salesforce', 'hubspot'],
  },
  {
    icon: 'tabler:mail-forward',
    name: '外部觸達 Outreach',
    description: '批量產生個性化冷郵件與 LinkedIn 訊息。結合企業畫像、最新觸發事件和你的語氣。',
    inputs: ['目標清單', '郵件範本', '寄件人畫像', '語氣'],
    outputs: ['郵件草稿 (markdown)', 'A/B 變體 (json)'],
    skills: ['email-writer', 'linkedin-scrape', 'tone-match'],
    connects: ['gmail', 'linkedin'],
  },
  {
    icon: 'tabler:shield-check',
    name: '客戶留存 Retention',
    description: '持續監控帳戶健康分。在客戶流失之前預警——使用下滑、支援工單模式、關鍵人變動。',
    inputs: ['帳戶清單', '風險閾值', '回看視窗'],
    outputs: ['風險報告 (markdown)', '帳戶評分 (csv)'],
    skills: ['usage-analyzer', 'crm-query'],
    connects: ['salesforce', 'hubspot', 'segment'],
  },
  {
    icon: 'tabler:chart-line',
    name: '管道洞察 Pipeline insights',
    description: '把管道資料轉化為清晰的建議。哪些 deal 應該推、哪些應該降級、時間該投到哪裡——一目了然。',
    inputs: ['銷售階段', '時間視窗', '負責人'],
    outputs: ['管道敘事 (markdown)', 'Deal 評分 (csv)'],
    skills: ['pipeline-analyzer', 'forecast-model'],
    connects: ['salesforce', 'hubspot'],
  },
];
---

<Layout metadata={metadata}>
  <section class="border-b border-[var(--aw-color-border)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <nav class="text-[0.75rem] font-mono text-[var(--aw-color-text-muted)] mb-6">
        <a href="/zh-TW/use-cases" class="hover:text-[var(--aw-color-text-default)] transition-colors">案例</a>
        <span class="mx-2 opacity-50">/</span>
        <span class="text-[var(--aw-color-text-default)]">GTM</span>
      </nav>

      <p class="section-label">B2B 成長</p>
      <h1 class="text-[2.25rem] md:text-[3.25rem] font-black tracking-[-0.03em] leading-[1.05] text-[var(--aw-color-text-heading)] mb-5 max-w-[820px]">
        讓管道自動運轉。
      </h1>
      <p class="text-[1rem] md:text-[1.0625rem] text-[var(--aw-color-text-muted)] leading-[1.7] max-w-[640px] mb-8">
        四個預置 App 端到端覆蓋 GTM 流程——從找到線索到留住客戶。每一個都自帶所需的技能與整合，第一天就能跑起來。
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          安裝 GTM 套件
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/zh-TW/contact"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
          預約展示
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <div class="mb-12">
        <p class="section-label">包含的 APP</p>
        <h2 class="text-[1.75rem] md:text-[2rem] font-bold tracking-[-0.025em] text-[var(--aw-color-text-heading)]">四個 App，一條營收主線。</h2>
      </div>

      <div class="space-y-4">
        {apps.map((app) => (
          <div class="group p-6 md:p-8 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] hover:border-primary/25 transition-colors">
            <div class="grid md:grid-cols-[1fr_320px] gap-6 md:gap-10">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-lg bg-primary/[0.08] flex items-center justify-center text-primary">
                    <Icon name={app.icon} class="w-5 h-5" />
                  </div>
                  <h3 class="text-[1.25rem] font-semibold text-[var(--aw-color-text-heading)]">{app.name}</h3>
                </div>
                <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-5">{app.description}</p>

                <div class="flex flex-wrap gap-x-6 gap-y-3 text-[0.8125rem]">
                  <div>
                    <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-1">Skills</span>
                    <div class="flex flex-wrap gap-1.5">
                      {app.skills.map((s) => (
                        <span class="font-mono text-[0.6875rem] px-2 py-0.5 rounded-md bg-[var(--aw-color-bg-subtle)] text-[var(--aw-color-text-default)]">{s}</span>
                      ))}
                    </div>
                  </div>
                  <div>
                    <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-1">Connects</span>
                    <div class="flex flex-wrap gap-1.5">
                      {app.connects.map((c) => (
                        <span class="font-mono text-[0.6875rem] px-2 py-0.5 rounded-md bg-primary/[0.08] text-primary">{c}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              <div class="md:border-l md:border-[var(--aw-color-border)] md:pl-8">
                <div class="mb-4">
                  <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-2">輸入</span>
                  <ul class="space-y-1">
                    {app.inputs.map((i) => (
                      <li class="text-[0.8125rem] text-[var(--aw-color-text-default)] flex items-center gap-2">
                        <span class="w-1 h-1 rounded-full bg-[var(--aw-color-text-muted)] opacity-50"></span>
                        {i}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <span class="text-[0.6875rem] font-mono uppercase tracking-[0.12em] text-[var(--aw-color-text-muted)] block mb-2">產物</span>
                  <ul class="space-y-1">
                    {app.outputs.map((o) => (
                      <li class="text-[0.8125rem] text-[var(--aw-color-text-default)] flex items-center gap-2">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-primary/70 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                        {o}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)] py-16 md:py-24">
    <div class="mx-auto max-w-5xl px-6 md:px-10">
      <p class="section-label">為什麼 GTM 團隊選 AITROOP</p>
      <div class="grid md:grid-cols-3 gap-8 mt-6">
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">複利式產出</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">每一次跑通的對話都變成可重複使用的 App。團隊的集體經驗逐週複利。</p>
        </div>
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">原生 CRM 整合</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">透過 OAuth 讀寫 Salesforce、HubSpot 和資料倉儲——不用 Zapier，也不用自寫腳本。</p>
        </div>
        <div>
          <h3 class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">設一次定時</h3>
          <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-[1.7]">每日管道摘要、每週觸達清單、每月留存報告——設好 cron 就忘掉它。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-3xl px-6 md:px-10 text-center">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold tracking-[-0.025em] leading-[1.15] text-[var(--aw-color-text-heading)] mb-4">
        從 GTM 套件開始。
      </h2>
      <p class="text-[0.9375rem] text-[var(--aw-color-text-muted)] leading-[1.7] mb-7">
        免費安裝。連接 CRM，10 分鐘內跑出第一個 App。
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.aitroop.net"
           class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
          安裝 GTM 套件
        </a>
        <a href="/zh-TW/use-cases/finance"
           class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] transition-all">
          看財務套件 →
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-label {
    font-size: 0.6875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.875rem;
  }
</style>
