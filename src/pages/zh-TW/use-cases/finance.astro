---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '財務案例 · Aitroop',
};

const stats = [
  { value: '↓ 60%', label: '月結週期' },
  { value: '100%',  label: '審計可追溯' },
  { value: '7',     label: '產物格式' },
  { value: '∞',     label: '同形態複跑' },
];

const apps = [
  {
    tag: '月結週期',
    name: '月結清單 Month-end checklist',
    description: '按順序跑完整個月結：總帳核對、計提分錄、內部往來匹配、簽字確認。每一步都留下審計痕跡。',
    inputs: ['結算期間', '法人主體', '負責人分配'],
    outputs: ['月結清單 (Markdown)', '對帳報告 (CSV)'],
    skills: ['gl-reconcile', 'accrual-calc', 'intercompany-match'],
    connects: ['quickbooks', 'xero', 'netsuite'],
  },
  {
    tag: '應收',
    name: '應收帳齡 AR aging',
    description: '應收帳款按帳齡分桶，標記風險敞口，自動產生對帳與催款郵件草稿，一氣呵成。',
    inputs: ['基準日期', '帳齡分桶', '風險閾值'],
    outputs: ['帳齡報告 (CSV)', '催款郵件草稿 (Markdown)'],
    skills: ['ar-bucket', 'risk-score', 'email-writer'],
    connects: ['quickbooks', 'stripe', 'gmail'],
  },
  {
    tag: '內控',
    name: '費用稽核 Expense audit',
    description: '掃描費用報銷，識別政策違規、重複提交與異常項。Agent 解釋每個例外的理由，供人工複核。',
    inputs: ['期間', '政策文件', '閾值規則'],
    outputs: ['例外清單 (CSV)', '稽核摘要 (Markdown)'],
    skills: ['expense-classify', 'policy-match', 'anomaly-detect'],
    connects: ['expensify', 'concur', 'google-drive'],
  },
  {
    tag: 'FP&A',
    name: '差異分析 Variance analysis',
    description: '對比實際與預算，歸因每個差異背後的主驅動因素，產生可直接放進董事會材料的敘事說明。',
    inputs: ['期間', '部門篩選', '差異閾值'],
    outputs: ['差異明細 (CSV)', '執行層敘事 (Markdown)'],
    skills: ['variance-calc', 'driver-attribute', 'narrative-writer'],
    connects: ['netsuite', 'quickbooks', 'sheets'],
  },
];

const why = [
  { title: '預設可審計',     desc: '每一次 App 運行都產出結構化產物與完整執行日誌。可複現、可比對、可對外解釋。' },
  { title: '資料始終屬於你',  desc: '每個使用者在隔離沙箱中執行。OAuth 僅授權 Agent 看到的範圍。資料不會用於模型訓練。' },
  { title: '每週期同形態',    desc: '相同的 App 每次產出相同的結構化輸出。對下游消費者可預測，對董事會可審計。' },
];
---

<Layout metadata={metadata}>

  <!-- PAGE HEAD ────────────────────────────────────────────────────── -->
  <section class="aw-page-head aw-page-head-banner">
    <div class="aw-container">
      <nav class="aw-crumbs">
        <a href="/zh-TW/use-cases">案例</a>
        <span aria-hidden="true">/</span>
        <span>財務</span>
      </nav>
      <h1 class="aw-h2">更快地把帳關掉。</h1>
      <p class="aw-page-head-desc">
        四個預置 App 覆蓋月結與日常財務營運的常見環節。讓團隊少花時間在表格上，多花時間在驅動決策的分析上。
      </p>
      <div class="aw-actions">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">安裝財務套件</a>
        <a href="/zh-TW/contact" class="aw-btn aw-btn-ghost">聯絡顧問</a>
      </div>
    </div>
  </section>

  <!-- METRICS ──────────────────────────────────────────────────────── -->
  <section class="metrics-section">
    <div class="aw-container">
      <div class="metrics" role="list">
        {stats.map((s) => (
          <div class="metric" role="listitem">
            <span class="metric-value">{s.value}</span>
            <span class="metric-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- APPS ─────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <h2 class="aw-h2">四個 App，覆蓋財務週期。</h2>
      </header>

      <div class="apps">
        {apps.map((app) => (
          <article class="app">
            <div class="app-head">
              <span class="app-tag">{app.tag}</span>
              <h3 class="app-title">{app.name}</h3>
            </div>
            <div class="app-body">
              <p class="app-desc">{app.description}</p>
              <dl class="app-meta">
                <div>
                  <dt>輸入</dt>
                  <dd>{app.inputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>產物</dt>
                  <dd>{app.outputs.join(' · ')}</dd>
                </div>
                <div>
                  <dt>技能</dt>
                  <dd class="mono">{app.skills.join(' · ')}</dd>
                </div>
                <div>
                  <dt>整合</dt>
                  <dd class="mono accent">{app.connects.join(' · ')}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <h2 class="aw-h2">為可審計、可重複使用的工作而設計。</h2>
      </header>
      <div class="why">
        {why.map((w) => (
          <article class="aw-piece">
            <h3 class="aw-piece-title">{w.title}</h3>
            <p class="aw-piece-desc">{w.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2" style="max-width: 18ch; margin: 0 auto 1rem;">從財務套件開始。</h2>
      <p class="aw-lede">免費安裝。連接你的財務系統，一次會話內跑出第一個月結 App。</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">安裝財務套件</a>
        <a href="/zh-TW/use-cases/gtm" class="aw-btn aw-btn-ghost">看 GTM 套件</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .metrics-section {
    padding: 0 0 5rem;
  }
  @media (min-width: 768px) {
    .metrics-section { padding: 0 0 7rem; }
  }
  .metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--aw-color-border);
    border: 1px solid var(--aw-color-border);
    border-radius: 10px;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .metrics { grid-template-columns: repeat(4, 1fr); }
  }
  .metric {
    background: var(--aw-color-bg-page);
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .metric-value {
    font-size: clamp(1.625rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--aw-color-text-heading);
    font-variant-numeric: tabular-nums;
  }
  .metric-label {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--aw-color-text-muted);
    line-height: 1.3;
  }

  .apps {
    display: grid;
    gap: 0;
  }
  .app {
    border-top: 1px solid var(--aw-color-border-strong);
    padding: 2rem 0 2.5rem;
  }
  .app:last-child { border-bottom: 1px solid var(--aw-color-border); }
  @media (min-width: 768px) {
    .app {
      display: grid;
      grid-template-columns: 16rem 1fr;
      gap: 3rem;
      padding: 2.25rem 0 2.75rem;
    }
  }
  .app-head {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .app-tag {
    align-self: flex-start;
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--aw-color-primary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1;
  }
  .app-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.15;
  }
  .app-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--aw-color-text-muted);
    margin: 1rem 0 1.5rem;
    text-wrap: pretty;
  }
  @media (min-width: 768px) {
    .app-desc { margin: 0 0 1.5rem; }
  }
  .app-meta {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .app-meta { grid-template-columns: repeat(2, 1fr); gap: 1.125rem 2rem; }
  }
  .app-meta dt {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aw-color-text-muted);
    margin: 0 0 0.3125rem;
    line-height: 1;
    font-weight: 600;
  }
  .app-meta dd {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--aw-color-text-default);
  }
  .mono { font-family: var(--aw-font-mono, ui-monospace, monospace); }
  .accent { color: var(--aw-color-primary); }

  .why {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .why { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }
</style>
