---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: '文件 — Aitroop',
};
---

<Layout metadata={metadata}>
  <section class="wrap">
    <div class="aw-container-narrow">
      <div class="icon-badge">
        <Icon name="tabler:book-2" class="w-6 h-6" />
      </div>

      <p class="aw-eyebrow" style="justify-content: center;">Documentation</p>

      <h1 class="aw-display" style="margin: 0 auto 1rem;">文件即將上線。</h1>

      <p class="aw-lede" style="margin: 0 auto 2.25rem;">
        我們正在撰寫文件。在此之前，最快了解 Aitroop 的方法是打開對話直接問 Claude。
      </p>

      <div class="aw-actions aw-actions-center" style="margin-bottom: 3rem;">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">
          打開 App
        </a>
        <a href="/zh-TW/blog/aitroop-platform-complete-guide" class="aw-btn aw-btn-ghost">
          閱讀平台指南
        </a>
      </div>

      <div class="status-block">
        <code>
          <span class="status-prompt">$</span> aitroop docs --status<br/>
          <span class="status-key">→ getting-started</span>  <span class="status-active">drafting</span><br/>
          <span class="status-key">→ concepts</span>         <span class="status-active">drafting</span><br/>
          <span class="status-key">→ skills-reference</span> <span class="status-pending">planned</span><br/>
          <span class="status-key">→ api-reference</span>    <span class="status-pending">planned</span>
        </code>
      </div>
    </div>
  </section>
</Layout>

<style>
  .wrap {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 0;
    text-align: center;
  }
  .icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 14px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    color: var(--aw-color-primary);
    margin-bottom: 1.75rem;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      0 6px 18px -8px rgba(82, 153, 97, 0.22),
      0 2px 4px rgba(0, 0, 0, 0.03);
  }

  .status-block {
    display: inline-block;
    text-align: left;
    padding: 0.875rem 1.125rem;
    border-radius: 10px;
    background: var(--aw-color-bg-subtle);
    border: 1px solid var(--aw-color-border);
  }
  .status-block code {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    line-height: 1.75;
    color: var(--aw-color-text-default);
    display: block;
  }
  .status-prompt { color: var(--aw-color-primary); }
  .status-key   { color: var(--aw-color-text-muted); opacity: 0.85; }
  .status-active { color: var(--aw-color-primary); font-weight: 500; }
  .status-pending { color: var(--aw-color-text-muted); }
</style>
