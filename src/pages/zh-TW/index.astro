---
import Layout from '~/layouts/PageLayout.astro';
import ChatToAppDemo from '~/components/widgets/ChatToAppDemo.astro';
import AnatomyFlow from '~/components/widgets/AnatomyFlow.astro';

const metadata = {
  title: 'Aitroop - 把 AI Agent 對話固化成 App',
  ignoreTitleTemplate: true,
};

const anatomySteps = [
  {
    title: 'AppInput',
    desc: '基於 Schema 的表單。text、select、daterange、file，宣告一次，自動渲染。',
    foot: '4 種輸入類型 · 內建驗證',
  },
  {
    title: 'Stage',
    desc: '帶明確目標的 Agent 會話，連入你的技能與整合。需要時多 Stage 串聯成管道。',
    foot: '150+ 技能 · 20+ 整合',
  },
  {
    title: 'Artifact',
    desc: '可交付的產物。預覽、匯出，或直接餵給下一個 Stage。',
    foot: '7 種格式 · 預覽 + 匯出',
  },
];

const stats = [
  { value: '150+', label: '技能' },
  { value: '20+',  label: '整合' },
  { value: 'cron', label: '排程' },
  { value: '7',    label: '產物格式' },
];

const cases = [
  { slug: '/zh-TW/use-cases/gtm',     title: 'GTM',     desc: '線索挖掘、外部觸達、客戶留存、管道洞察。' },
  { slug: '/zh-TW/use-cases/finance', title: '財務',    desc: '月結、稽核、差異分析、報告。專為 CFO 團隊設計。' },
];

const demoStrings = {
  modeChatLabel: '模式 1 · Chat',
  modeAppsLabel: '模式 2 · Apps',
  modeAppLabel: '模式 3 · App',
  newChatLabel: '新對話',
  navAppsLabel: 'Apps',
  navArtifactsLabel: 'Artifacts',
  toolsLabel: '工具',
  navConnectLabel: 'Connect',
  navSkillsLabel: 'Skills',
  navSchedulesLabel: '排程任務',
  navSettingsLabel: '設定',
  composerPlaceholder: '問 AITroop 任何問題…',
  modelLabel: 'claude',
  promptParts: [
    '拉取 2025-05-01 至 05-07 的提交',
    '依倉庫分組、忽略 merge 提交，',
    '整理成英文工作日報。',
  ] as [string, string, string],
  promptCode: 'shop-frontend',
  skillTagLabel: '技能',
  connectTagLabel: '整合',
  toolSkillName: 'github-mcp',
  toolSkillStatusLoading: '拉取提交中…',
  toolSkillStatusDone: '已拉取 142 個提交',
  toolConnectName: 'github',
  toolConnectStatus: '已授權',
  agentReplyText: '完成。已從 4 個倉庫的 12 個 PR 產生 daily-report.md。',
  saveAsAppLabel: '提煉為 App',
  savedToastLabel: '已加入你的 App',
  appsHeaderLabel: '我的 App',
  appsCount: '6',
  newBadgeLabel: 'NEW',
  justNowLabel: '剛剛',
  appTitle: '工作日報',
  appVersion: 'v1 · public',
  skillsLabel: '技能',
  connectsLabel: '整合',
  skills: ['github-mcp', 'web-scrape'] as [string, string],
  connects: ['github', 'google-drive'] as [string, string],
  dateRangeLabel: '日期範圍',
  repoLabel: '程式碼倉庫',
  langLabel: '輸出語言',
  langValue: 'English',
  runLabel: '執行',
  runningLabel: '執行中…',
  artifactLabel: 'daily-report.md',
  artifactRows: [
    '## Mon · 12 PRs across 4 repos',
    '- feat(api): pagination on /v2/orders',
    '- fix(ui): cart total off by rounding',
    '- chore(deps): bump astro 5.2 → 5.4',
    '- perf(cart): memoize line totals',
  ],
  exportLabel: '匯出至 Drive',
};
---

<Layout metadata={metadata}>

  <!-- HERO ─────────────────────────────────────────────────────────── -->
  <section class="aw-hero relative isolate overflow-hidden">
    <div aria-hidden="true" class="hero-glow"></div>
    <div class="aw-container-wide">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="aw-eyebrow">AI Agent 平台</p>
          <h1 class="aw-display hero-display">
            把 Agent 對話<span class="text-primary">固化成 App。</span>
          </h1>
          <p class="aw-lede hero-lede">
            在 Chat 裡探索出有效方法後，儲存為帶表單與定時任務的 App。團隊拿到的是可重複使用的 AI 工作流，無需編碼。
          </p>
          <div class="aw-actions">
            <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">免費開始</a>
            <a href="/zh-TW/use-cases" class="aw-btn aw-btn-ghost">查看案例</a>
          </div>
        </div>
        <div class="hero-demo">
          <ChatToAppDemo {...demoStrings} />
        </div>
      </div>
    </div>
  </section>

  <!-- ANATOMY ──────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <AnatomyFlow
        eyebrow=""
        title="三塊拼圖。一條管道。"
        lede="輸入餵給 Stage。Stage 產出 Artifact。Artifact 流向下游，或作為下一個 Stage 的輸入。"
        steps={anatomySteps}
        labels={{ dateRange: '日期範圍', repo: '程式碼倉庫', language: '輸出語言', running: '正在整理 PR…' }}
      />

      <div class="stats" role="list">
        {stats.map((s) => (
          <div class="stat" role="listitem">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USE CASES ────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">案例</p>
        <h2 class="aw-h2">為團隊真實在做的事而設計。</h2>
      </header>

      <ul class="cases">
        {cases.map((c) => (
          <li>
            <a href={c.slug}>
              <span class="case-title">{c.title}</span>
              <span class="case-desc">{c.desc}</span>
              <span class="case-arrow aw-arrow" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA ──────────────────────────────────────────────────────────── -->
  <section class="aw-section">
    <div class="aw-container-narrow">
      <h2 class="aw-h2 cta-h2">午餐前發布你的第一個 App。</h2>
      <p class="aw-lede">打開對話。點擊 <code class="aw-code">存為 App</code>。整個流程就是這樣。</p>
      <div class="aw-actions aw-actions-center">
        <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">免費開始</a>
        <a href="/zh-TW/contact" class="aw-btn aw-btn-ghost">聯絡我們</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-glow {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 120%;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 50% at 22% 18%, rgba(82, 153, 97, 0.10), transparent 65%),
      radial-gradient(ellipse 50% 50% at 80% 30%, rgba(82, 153, 97, 0.06), transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 80%);
            mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, #000 30%, transparent 80%);
  }

  .hero-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 4.5rem;
    }
  }
  .hero-display {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.05;
    margin: 0 0 1.5rem;
    max-width: 20ch;
  }
  .hero-lede { max-width: 46ch; }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding-top: 1.75rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--aw-color-border);
    background: transparent;
  }
  .stat {
    background: transparent;
    flex: 1 1 50%;
    padding: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .stat {
      flex: 1 1 0;
      padding: 0.25rem 2rem;
      border-left: 1px solid var(--aw-color-border);
    }
    .stat:first-child {
      border-left: none;
      padding-left: 0;
    }
    .stat:last-child {
      padding-right: 0;
    }
  }
  .stat-value {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.015em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .cases {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cases li { border-top: 1px solid var(--aw-color-border); }
  .cases li:last-child { border-bottom: 1px solid var(--aw-color-border); }
  .cases a {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "title arrow"
      "desc  arrow";
    column-gap: 1rem;
    row-gap: 0.5rem;
    padding: 1.75rem 0;
    align-items: center;
    transition: padding-left 220ms ease;
  }
  @media (min-width: 768px) {
    .cases a {
      grid-template-columns: 12rem 1fr auto;
      grid-template-areas: "title desc arrow";
      column-gap: 2.5rem;
      padding: 2.25rem 0;
    }
  }
  .cases a:hover { padding-left: 0.25rem; }

  .case-title {
    grid-area: title;
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1.1;
    transition: color 200ms ease;
  }
  .case-desc {
    grid-area: desc;
    color: var(--aw-color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .case-arrow {
    grid-area: arrow;
    color: var(--aw-color-text-muted);
    font-size: 1.125rem;
    line-height: 1;
    transition: color 200ms ease, transform 220ms ease;
  }
  .cases a:hover .case-title { color: var(--aw-color-primary); }
  .cases a:hover .case-arrow { color: var(--aw-color-primary); }

  .cta-h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin: 0 auto 1rem;
    max-width: 18ch;
  }
</style>
