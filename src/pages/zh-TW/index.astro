---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI Agent 平台',
  ignoreTitleTemplate: true,
};

const features = [
  { icon: 'tabler:message-circle',   title: '對話',   desc: '在隔離沙箱中與 Claude 進行互動。探索、實驗，完整工具存取，自由迭代。' },
  { icon: 'tabler:stack-2',          title: 'App',    desc: '將任意 Claude 工作流封裝為一鍵工具。填寫表單即可取得結果，無需編寫程式碼。' },
  { icon: 'tabler:puzzle',           title: '技能',   desc: '150+ 內建能力——線索生成、CRM 同步、網頁抓取、SEO 分析、內容生成等。' },
  { icon: 'tabler:plug-connected',   title: '整合',   desc: 'OAuth 連結 Salesforce、HubSpot、GitHub、Google Drive、Notion 等 20+ 平台。' },
  { icon: 'tabler:calendar-clock',   title: '排程',   desc: '將任意 App 設定為定時任務，每天、每週或每小時自動執行，結果自動送達。' },
];

const steps = [
  { n: '01', title: '對話探索',      desc: '啟動 Claude 工作階段，使用內建技能和已連結的工具，找到最有效的方法。' },
  { n: '02', title: '封裝為 App',    desc: '將工作流儲存為參數化 App，定義輸入、階段和預期輸出，幾分鐘內完成。' },
  { n: '03', title: '執行與自動化', desc: '隨需執行或定時排程，每次執行均有完整的產出記錄。' },
];

const gtmApps = [
  { icon: 'tabler:radar-2',      title: '潛客挖掘', desc: '透過公司訊號、招聘動態、技術棧和意圖資料發掘高品質潛客。' },
  { icon: 'tabler:mail-forward', title: '外部觸達', desc: '大規模生成並發送個人化冷郵件和 LinkedIn 訊息。' },
  { icon: 'tabler:shield-check', title: '客戶留存', desc: '持續監控帳戶健康分，在客戶流失前提前預警。' },
  { icon: 'tabler:chart-line',   title: '洞察分析', desc: '將管道資料轉化為清晰建議，明確下一步聚焦方向。' },
];
---

<Layout metadata={metadata}>

  <!-- 主視覺 -->
  <section class="relative px-6 md:px-10 lg:px-16 pt-10 pb-10 md:pt-12 md:pb-14 overflow-hidden">
    <div class="absolute top-0 left-0 w-[520px] h-[420px] pointer-events-none -z-10"
      style="background:radial-gradient(ellipse at 20% 30%,rgba(82,153,97,0.10) 0%,transparent 65%);"
      aria-hidden="true"></div>

    <div class="mx-auto max-w-6xl">
      <div class="max-w-[680px]">

        <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] mb-3 font-normal tracking-wide">
          AI Agent 平台
        </p>

        <h1 class="text-[2rem] sm:text-[2.375rem] md:text-[2.75rem] lg:text-[3rem] font-black tracking-[-0.03em] leading-[1.1] text-[var(--aw-color-text-heading)] mb-4">
          為任意工作流<br/>建構 AI Agent。
        </h1>

        <p class="text-[1rem] md:text-[1.075rem] leading-[1.75] text-[var(--aw-color-text-muted)] mb-6 max-w-[540px]">
          將 Claude 對話轉化為可重複使用的 App——內建 150+ 技能、原生整合和自動排程。
          <span class="text-primary font-medium">任意工作流，無需程式碼。</span>
        </p>

        <div class="flex flex-wrap items-center gap-3">
          <a href="https://app.aitroop.net"
            class="inline-flex items-center gap-2 h-11 px-6 rounded-full bg-primary text-white text-[0.9375rem] font-semibold hover:bg-[rgb(61,133,79)] transition-colors duration-150 shadow-sm">
            開始建構
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#how-it-works"
            class="inline-flex items-center h-11 px-6 rounded-full text-[0.9375rem] font-medium text-[var(--aw-color-text-default)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.22)] hover:bg-[rgba(0,0,0,0.025)] transition-all duration-150">
            了解運作方式
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- 核心能力 -->
  <section class="py-16 md:py-24 px-4 border-t border-[var(--aw-color-border)]">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="section-title">建構 AI Agent 所需的一切。</h2>
        <p class="section-sub">五大核心能力，開箱即可協同運作。</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {features.map((f) => (
          <div class="p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] hover:border-primary/25 hover:shadow-[0_8px_30px_rgba(82,153,97,0.09)] hover:-translate-y-1 transition-all duration-200">
            <div class="mb-4 w-10 h-10 rounded-xl bg-primary/[0.08] flex items-center justify-center text-primary">
              <Icon name={f.icon} class="w-5 h-5" />
            </div>
            <h3 class="text-[0.9375rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{f.title}</h3>
            <p class="text-[0.875rem] text-[var(--aw-color-text-muted)] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 運作方式 -->
  <section id="how-it-works" class="py-16 md:py-24 px-4 bg-[rgba(0,0,0,0.015)] border-y border-[var(--aw-color-border)]">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <p class="section-label">設計簡潔</p>
        <h2 class="section-title">從對話到自動化工作流，只需幾分鐘。</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <div class="hidden md:block absolute top-[1.375rem] left-[calc(16.67%+1.375rem)] right-[calc(16.67%+1.375rem)] h-px bg-[var(--aw-color-border)]" aria-hidden="true"></div>

        {steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <div class="relative mb-5 w-11 h-11 rounded-full border-2 border-primary/20 bg-[var(--aw-color-bg-page)] flex items-center justify-center z-10">
              <span class="text-[0.6875rem] font-bold text-primary tracking-wider">{step.n}</span>
            </div>
            <h3 class="text-[0.9375rem] font-semibold text-[var(--aw-color-text-heading)] mb-2">{step.title}</h3>
            <p class="text-[0.8125rem] text-[var(--aw-color-text-muted)] leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 首個落地場景：GTM -->
  <section class="py-16 md:py-24 px-4">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <p class="section-label">首個落地場景</p>
        <h2 class="section-title">從 B2B 成長開始。</h2>
        <p class="section-sub">我們的 GTM 套件預載了潛客挖掘、外部觸達、客戶留存和洞察分析 App，開箱即用。</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {gtmApps.map((app) => (
          <div class="p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)]">
            <div class="mb-3 w-9 h-9 rounded-lg bg-primary/[0.08] flex items-center justify-center text-primary">
              <Icon name={app.icon} class="w-4 h-4" />
            </div>
            <h3 class="text-[0.875rem] font-semibold text-[var(--aw-color-text-heading)] mb-1.5">{app.title}</h3>
            <p class="text-[0.8125rem] text-[var(--aw-color-text-muted)] leading-relaxed">{app.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CallToAction
    id="cta-section"
    title="開始建構你的第一個 Agent。"
    subtitle="連結你的工具，選擇一個技能，幾分鐘內發布你的第一個 App。"
    actions={[
      { text: '免費開始', href: 'https://app.aitroop.net', variant: 'primary' },
      { text: '聯絡我們', href: '/contact', variant: 'secondary' },
    ]}
  />

</Layout>

<style>
  .section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--aw-color-primary, #529961);
    margin-bottom: 0.5rem;
    opacity: 0.85;
  }
  .section-title {
    font-size: clamp(1.625rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--aw-color-text-heading);
    margin-bottom: 0.75rem;
  }
  .section-sub {
    font-size: 0.9375rem;
    color: var(--aw-color-text-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.75;
  }
</style>
