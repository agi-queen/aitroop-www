---
import Layout from '~/layouts/PageLayout.astro';
import AnatomyFlow from '~/components/widgets/AnatomyFlow.astro';
import WorkflowLifecycle from '~/components/widgets/WorkflowLifecycle.astro';

const metadata = {
  title: 'Aitroop - 把 AI Agent 對話固化成 App',
  ignoreTitleTemplate: true,
};

const anatomySteps = [
  {
    title: 'AppInput',
    desc: '基於 Schema 的表單。text、select、daterange、file，宣告一次，自動渲染。',
    foot: '4 種輸入類型 · 內建驗證',
  },
  {
    title: 'Stage',
    desc: '帶明確目標的 Agent 會話，連入你的技能與整合。需要時多 Stage 串聯成管道。',
    foot: '150+ 技能 · 20+ 整合',
  },
  {
    title: 'Artifact',
    desc: '可交付的產物。預覽、匯出，或直接餵給下一個 Stage。',
    foot: '7 種格式 · 預覽 + 匯出',
  },
];

const stats = [
  { value: '150+', label: '技能' },
  { value: '20+',  label: '整合' },
  { value: 'cron', label: '排程' },
  { value: '7',    label: '產物格式' },
];

const features = [
  {
    title: '把對話存為 App',
    desc: '一鍵沉澱剛跑通的流程，變成帶型別化輸入、可重複執行的工作流程。',
    icon: 'M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z',
  },
  {
    title: '多 Stage 管道',
    desc: '單次 Agent 解不了的任務，就用 Stage 串聯起來。每個 Stage 擁有自己的模型、技能與 prompt。',
    icon: 'M4 6h16M4 12h16M4 18h10',
  },
  {
    title: '150+ 技能 · 20+ 整合',
    desc: 'GitHub、Gmail、Slack、Drive、Notion、網頁搜尋、程式碼執行，一鍵啟用。',
    icon: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z',
  },
  {
    title: '真實沙盒',
    desc: '每一次執行都跑在隔離環境中，提供檔案系統、網路和合適的工具鏈。',
    icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
  },
  {
    title: '排程與 Webhook',
    desc: '依 cron 定時、手動觸發，或由 Webhook 啟動。設定一次長期託管，執行歷史可追溯。',
    icon: 'M12 6v6l4 2M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z',
  },
  {
    title: '團隊共享',
    desc: '每個 App 都是帶權限的物件。可以分享給同事、外部協作者，或作為內部 API 暴露。',
    icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  },
];

const cases = [
  {
    slug: '/zh-TW/use-cases/gtm',
    title: 'GTM',
    desc: '線索挖掘、外部觸達、客戶留存、管道洞察。',
    points: ['規模化的 ICP 研究', '個人化外聯序列', '管道與留存報告'],
  },
  {
    slug: '/zh-TW/use-cases/finance',
    title: '財務',
    desc: '月結、稽核、差異分析、報告。專為 CFO 團隊設計。',
    points: ['月結報告包自動組裝', '差異與變動分析', '稽核就緒的匯出'],
  },
];

const faqs = [
  {
    q: '把對話存成 App，要不要重寫 prompt？',
    a: '不必。在已跑通的對話裡點一下「存為 App」，Aitroop 會把當時使用的技能、整合與 prompt 都打包成可執行的工作流程。',
  },
  {
    q: 'App 儲存好之後，誰來執行？',
    a: '每一次執行都跑在隔離沙盒中，自帶檔案系統、網路與 Agent 需要的工具。可以手動觸發、依 cron 定時，或由 Webhook 啟動。',
  },
  {
    q: '步驟需要用不同的工具，能串起來嗎？',
    a: '可以。Stage 讓你把一個 Agent 接到下一個 Agent，每個 Stage 擁有獨立的模型、技能與 prompt。前一個 Stage 的產物自動成為下一個的輸入。',
  },
  {
    q: 'App 發布之後誰可以使用？',
    a: 'App 是帶權限的物件。可以分享給同事、外部協作者，或作為內部 API 暴露。執行歷史對管理員可見。',
  },
];
---

<Layout metadata={metadata}>

  <!-- HERO ──────────────────────────────────────────────────────── -->
  <section class="aw-hero hero relative isolate overflow-hidden">
    <div aria-hidden="true" class="hero-dots"></div>
    <div aria-hidden="true" class="hero-glow"></div>
    <div class="aw-container-wide">
      <div class="hero-grid">
        <div class="hero-copy">
          <a href="/zh-TW/use-cases" class="hero-pill">
            <span class="pill-tag">NEW</span>
            <span class="pill-text">150+ 技能 · 20+ 整合</span>
            <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <h1 class="aw-display hero-display">
            強大的 Agent。<br />
            無盡的技能。<br />
            <span class="text-primary">一鍵即用的 App。</span>
          </h1>
          <p class="aw-lede hero-lede">
            一鍵就把剛剛跑通的 Agent 流程沉澱為 App，團隊可以反覆運行。不必再敲 prompt，不必再寫膠水程式碼。
          </p>
          <div class="aw-actions hero-actions">
            <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">免費開始</a>
            <a href="/zh-TW/use-cases" class="aw-btn aw-btn-ghost">查看案例</a>
          </div>
        </div>

        <ul class="hero-features" role="list">
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">把對話存為 App</p>
              <p class="feature-desc">一鍵沉澱。對話變成可重複執行的工作流程，團隊隨時取用。</p>
            </div>
          </li>
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">150+ 技能 · 20+ 整合</p>
              <p class="feature-desc">深度連接：GitHub、Gmail、Slack、Drive、網頁搜尋、程式碼執行。</p>
            </div>
          </li>
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">真實沙盒</p>
              <p class="feature-desc">每一次執行都在隔離環境中執行，支援檔案存取、網路和合適的工具。</p>
            </div>
          </li>
          <li class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/></svg>
            </span>
            <div class="feature-body">
              <p class="feature-title">排程 &amp; Webhook</p>
              <p class="feature-desc">每天早上 9 點自動執行，或透過 API 從你的系統觸發。設定一次，長期託管。</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- STATS ─────────────────────────────────────────────────────── -->
  <section class="stats-section">
    <div class="aw-container">
      <ul class="stats" role="list">
        {stats.map((s) => (
          <li class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- LIFECYCLE ─────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container">
      <header class="aw-section-head lifecycle-head">
        <h2 class="aw-h2">從對話到排程 App，閉環只需要一次設定。</h2>
        <p class="aw-lede lifecycle-lede">對話變成表單，表單驅動 Stage，Stage 產出 Artifact，Artifact 觸發下一次執行。</p>
      </header>
      <WorkflowLifecycle loopHint="然後不斷重複 — 依 cron、手動觸發、Webhook 呼叫" />
    </div>
  </section>

  <!-- ANATOMY ───────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section anatomy-borderless">
    <div class="aw-container">
      <AnatomyFlow
        eyebrow=""
        title="三塊拼圖。一條管道。"
        lede="輸入餵給 Stage。Stage 產出 Artifact。Artifact 流向下游，或作為下一個 Stage 的輸入。"
        steps={anatomySteps}
      />
    </div>
  </section>

  <!-- FEATURES ──────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">團隊為什麼選擇 Aitroop</p>
        <h2 class="aw-h2">讓一個 Agent 真正沉澱下來，所需要的一切。</h2>
      </header>
      <ul class="features-grid" role="list">
        {features.map((f) => (
          <li class="feature-tile">
            <span class="tile-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon} />
              </svg>
            </span>
            <h3 class="tile-title">{f.title}</h3>
            <p class="tile-desc">{f.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- USE CASES ─────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section">
    <div class="aw-container">
      <header class="aw-section-head">
        <p class="aw-eyebrow">案例</p>
        <h2 class="aw-h2">為團隊真實在做的事而設計。</h2>
      </header>

      <ul class="cases-grid" role="list">
        {cases.map((c) => (
          <li class="case-card">
            <a href={c.slug} class="case-link">
              <div class="case-head">
                <span class="case-title">{c.title}</span>
                <span class="case-arrow aw-arrow" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
              <p class="case-desc">{c.desc}</p>
              <ul class="case-points" role="list">
                {c.points.map((p) => (
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ ───────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container">
      <header class="aw-section-head faq-head">
        <p class="aw-eyebrow">FAQ</p>
        <h2 class="aw-h2">常見問題，一次說清。</h2>
      </header>
      <ul class="faq-list" role="list">
        {faqs.map((item) => (
          <li class="faq-item">
            <h3 class="faq-q">{item.q}</h3>
            <p class="faq-a">{item.a}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA ───────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section cta-section">
    <div class="aw-container">
      <div class="cta-card">
        <h2 class="aw-h2 cta-h2">午餐前發布你的第一個 App。</h2>
        <p class="aw-lede cta-lede">打開對話。點擊 <code class="aw-code">存為 App</code>。整個流程就是這樣。</p>
        <div class="aw-actions aw-actions-center">
          <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">免費開始</a>
          <a href="/zh-TW/contact" class="aw-btn aw-btn-ghost">聯絡我們</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ══════════════════════════════════════════════════════════════════
     HERO
     ══════════════════════════════════════════════════════════════════ */
  .hero {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero-dots {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, rgba(10, 10, 10, 0.06) 1px, transparent 0);
    background-size: 22px 22px;
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 22%, #000 25%, transparent 82%);
            mask-image: radial-gradient(ellipse 70% 50% at 50% 22%, #000 25%, transparent 82%);
  }
  .hero-glow {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 80%;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 45% at 50% 10%, rgba(82, 153, 97, 0.08), transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 75% 60% at 50% 0%, #000 25%, transparent 85%);
            mask-image: radial-gradient(ellipse 75% 60% at 50% 0%, #000 25%, transparent 85%);
    animation: hero-breathe 14s ease-in-out infinite;
  }
  @keyframes hero-breathe {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
    }
  }

  .hero-copy {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .hero-copy {
      text-align: left;
      max-width: none;
      margin: 0;
    }
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3125rem 0.875rem 0.3125rem 0.4375rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: border-color 200ms ease, color 200ms ease, transform 200ms ease;
  }
  .hero-pill:hover {
    border-color: rgba(82, 153, 97, 0.35);
    color: var(--aw-color-text-default);
  }
  .pill-tag {
    padding: 1px 7px;
    border-radius: 9999px;
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  .pill-arrow {
    width: 12px;
    height: 12px;
    color: var(--aw-color-text-muted);
    transition: transform 200ms ease;
  }
  .hero-pill:hover .pill-arrow { transform: translateX(2px); }

  .hero-display {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.05;
    margin: 0 auto 1.5rem;
    max-width: 22ch;
  }
  .hero-lede {
    margin: 0 auto 2rem;
    max-width: 40rem;
    font-size: clamp(1.0625rem, 1.25vw, 1.1875rem);
  }
  .hero-actions {
    justify-content: center;
  }
  @media (min-width: 1024px) {
    .hero-display { margin-left: 0; margin-right: 0; }
    .hero-lede    { margin-left: 0; margin-right: 0; }
    .hero-actions { justify-content: flex-start; }
  }

  .hero-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    border: 1px solid var(--aw-color-border);
    border-radius: 12px;
    background: var(--aw-color-bg-page);
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .feature-card:hover {
    border-color: rgba(82, 153, 97, 0.35);
    transform: translateY(-1px);
    box-shadow: 0 10px 28px -16px rgba(10, 10, 10, 0.10);
  }
  .feature-icon {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: rgba(82, 153, 97, 0.10);
    color: var(--aw-color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .feature-icon svg { width: 18px; height: 18px; }
  .feature-body { min-width: 0; }
  .feature-title {
    font-weight: 600;
    color: var(--aw-color-text-heading);
    font-size: 0.95rem;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }
  .feature-desc {
    font-size: 0.85rem;
    color: var(--aw-color-text-muted);
    line-height: 1.55;
    margin: 0;
  }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
  .hero-pill,
  .hero-display,
  .hero-lede,
  .hero-actions,
  .hero-features {
    animation: hero-rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .hero-pill      { animation-delay: 0ms; }
  .hero-display   { animation-delay: 80ms; }
  .hero-lede      { animation-delay: 160ms; }
  .hero-actions   { animation-delay: 240ms; }
  .hero-features  { animation-delay: 320ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-glow,
    .hero-pill,
    .hero-display,
    .hero-lede,
    .hero-actions,
    .hero-features {
      animation: none;
    }
  }

  .stats-section {
    padding: 2rem 0 3rem;
  }
  @media (min-width: 768px) {
    .stats-section { padding: 2.75rem 0 3.5rem; }
  }
  .stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem 1rem;
  }
  @media (min-width: 768px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .stat-value {
    font-family: var(--aw-font-mono, ui-monospace, monospace);
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  /* ── Home sections — divider-free rhythm via soft tints ──────── */
  .home-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .home-section { padding-top: 5.5rem; padding-bottom: 5.5rem; }
  }
  .home-section--soft {
    background: rgba(82, 153, 97, 0.025);
  }

  :global(.anatomy-borderless .step-card) {
    border-top: none !important;
    border-bottom: none !important;
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  @media (min-width: 1024px) {
