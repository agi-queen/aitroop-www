---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Aitroop — AI 驅動的成長平台',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- ═══════════════════════════════════════════════════════
       首屏 Hero
  ═══════════════════════════════════════════════════════ -->
  <main class="relative min-h-[calc(100vh-56px)] flex flex-col items-center justify-center px-4 overflow-hidden">

    <div class="absolute inset-0 -z-10" style="background-image: radial-gradient(circle, rgba(0,0,0,0.05) 1px, transparent 1px); background-size: 24px 24px;" aria-hidden="true"></div>

    <div class="absolute -z-10 hero-glow" style="width:700px;height:500px;top:50%;left:50%;margin-left:-350px;margin-top:-250px;border-radius:50%;background:radial-gradient(ellipse at center,rgba(82,153,97,0.11) 0%,transparent 65%);" aria-hidden="true"></div>

    <div class="absolute -z-10 hero-ring" style="width:460px;height:460px;top:50%;left:50%;margin-left:-230px;margin-top:-230px;border-radius:50%;border:1px solid rgba(82,153,97,0.08);" aria-hidden="true"></div>

    <div class="absolute -z-10 hero-ring-rev" style="width:640px;height:640px;top:50%;left:50%;margin-left:-320px;margin-top:-320px;border-radius:50%;border:1px solid rgba(82,153,97,0.05);" aria-hidden="true"></div>

    <!-- 網路節點 SVG -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none" style="z-index:-5;" aria-hidden="true" preserveAspectRatio="none">
      <line x1="10%" y1="22%" x2="89%" y2="18%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-1" />
      <line x1="89%" y1="18%" x2="86%" y2="79%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-2" />
      <line x1="86%" y1="79%" x2="11%" y2="76%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-3" />
      <line x1="11%" y1="76%" x2="10%" y2="22%" stroke="rgba(82,153,97,0.12)" stroke-width="0.75" class="net-line net-line-4" />
      <circle cx="10%" cy="22%" r="3"   fill="rgba(82,153,97,0.5)"  class="net-node" style="animation-delay:0s" />
      <circle cx="89%" cy="18%" r="4"   fill="rgba(82,153,97,0.4)"  class="net-node" style="animation-delay:0.6s" />
      <circle cx="86%" cy="79%" r="3"   fill="rgba(82,153,97,0.45)" class="net-node" style="animation-delay:1.2s" />
      <circle cx="11%" cy="76%" r="3.5" fill="rgba(82,153,97,0.4)"  class="net-node" style="animation-delay:1.8s" />
    </svg>

    <!-- 掃描光束 -->
    <div class="hero-scan absolute inset-x-0 pointer-events-none" style="z-index:-5;height:1px;" aria-hidden="true"></div>

    <div class="max-w-[640px] mx-auto flex flex-col items-center gap-4 text-center">

      <div class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-[rgba(82,153,97,0.08)] border border-[rgba(82,153,97,0.20)] px-3 py-1.5 rounded-full">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-primary"></span>
        </span>
        AI 智能體成長平台
      </div>

      <h1 class="text-[2rem] md:text-[2.625rem] font-bold tracking-[-0.02em] text-[var(--aw-color-text-heading)] leading-[1.2] -mt-1">
        精準獲客。快速轉化。<span class="hero-shimmer">持續留存。</span>
      </h1>

      <p class="text-[0.9375rem] md:text-[1rem] text-[var(--aw-color-text-muted)] max-w-[420px] leading-[1.8] -mt-1">
        一支 AI 智能體軍團，各司其職，覆蓋完整成長鏈路。情報、觸達、轉化、留存，一個平台全搞定。一個操盤手，整支團隊的戰鬥力。
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 mt-1">
        <a href="https://app.aitroop.net" class="inline-flex items-center gap-2 h-10 px-5 rounded-[7px] bg-primary text-white text-sm font-semibold shadow-[0_1px_3px_rgba(82,153,97,0.4),0_0_0_1px_rgba(82,153,97,0.2)] hover:bg-[rgb(61,133,79)] hover:shadow-[0_2px_6px_rgba(82,153,97,0.45)] transition-all duration-150">
          登入 Aitroop
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="/zh-TW/blog" class="inline-flex items-center h-10 px-5 rounded-[7px] text-sm font-medium text-[var(--aw-color-text-muted)] border border-[var(--aw-color-border)] hover:border-[rgba(0,0,0,0.2)] hover:text-[var(--aw-color-text-default)] hover:bg-[rgba(0,0,0,0.02)] transition-all duration-150">
          閱讀部落格
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px mt-3 w-full max-w-[440px] rounded-xl border border-[var(--aw-color-border)] overflow-hidden bg-[var(--aw-color-border)]">
        {[
          ['6×', '外發量提升'],
          ['90天', '流失預警'],
          ['80%+', '數據覆蓋'],
          ['15%', '回覆率'],
        ].map(([metric, label]) => (
          <div class="flex flex-col items-center gap-0.5 py-3 bg-[var(--aw-color-bg-page)]">
            <span class="text-[1rem] font-semibold text-[var(--aw-color-text-heading)] tabular-nums">{metric}</span>
            <span class="text-[0.65rem] text-[var(--aw-color-text-muted)] leading-tight px-1">{label}</span>
          </div>
        ))}
      </div>

    </div>

    <div class="absolute bottom-0 left-0 right-0 h-24 -z-10" style="background: linear-gradient(to top, rgba(255,255,255,1) 0%, transparent 100%);" aria-hidden="true"></div>
  </main>

  <!-- ═══════════════════════════════════════════════════════
       產業滾動標籤
  ═══════════════════════════════════════════════════════ -->
  <div class="border-y border-[var(--aw-color-border)] py-5 overflow-hidden" style="background:rgba(82,153,97,0.02);">
    <p class="text-center text-[0.65rem] uppercase tracking-[0.15em] text-[var(--aw-color-text-muted)] mb-4 font-medium">
      服務各產業成長團隊
    </p>
    <div class="relative flex overflow-hidden">
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0">
        {['B2B SaaS', '電商', '金融科技', '行銷技術', '業務團隊', '成長代理商', 'D2C 品牌', '企業 GTM', 'PLG 產品', '新創公司'].map(name => (
          <li class="text-sm font-medium text-[var(--aw-color-text-muted)] opacity-50 hover:opacity-90 transition-opacity cursor-default select-none whitespace-nowrap">{name}</li>
        ))}
      </ul>
      <ul class="flex shrink-0 gap-14 pr-14 marquee-track list-none m-0 p-0" aria-hidden="true">
        {['B2B SaaS', '電商', '金融科技', '行銷技術', '業務團隊', '成長代理商', 'D2C 品牌', '企業 GTM', 'PLG 產品', '新創公司'].map(name => (
          <li class="text-sm font-medium text-[var(--aw-color-text-muted)] opacity-50 whitespace-nowrap select-none">{name}</li>
        ))}
      </ul>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       六大智能體
  ═══════════════════════════════════════════════════════ -->
  <Features2
    id="agents"
    tagline="AI 成長軍團"
    title="六位專家，一個統一平台。"
    subtitle="每個智能體專為成長鏈路中的特定階段打造，全天候運轉，讓你的團隊專注於只有人類才能做的事。"
    columns={3}
    items={[
      { title: '探查智能體', description: '掃描海量訊號，精準浮現高匹配度線索——融合公司階段、招募動態、技術棧與意圖數據，構建精準目標名單。', icon: 'tabler:radar' },
      { title: '觸達智能體', description: '撰寫並發送高度個性化的冷郵件和 LinkedIn 訊息。無模板——每條訊息都針對每位收件人量身定制。', icon: 'tabler:mail-forward' },
      { title: '跟進智能體', description: '跨渠道智能跟進，根據每位潛客的互動訊號和對話歷史動態調整語氣與時機。', icon: 'tabler:messages' },
      { title: '轉化智能體', description: '在最關鍵的時刻為業務代表提供成交洞察——異議處理、社群證明、競品情報和下一步行動建議。', icon: 'tabler:target' },
      { title: '留存智能體', description: '持續監控使用模式和健康分，提前 90 天預警流失風險帳戶，讓你在還來得及時採取行動。', icon: 'tabler:shield-check' },
      { title: '洞察智能體', description: '將整條銷售管道提煉為清晰可執行的建議。明確告訴你下一步應聚焦在哪裡，以及為什麼——無需翻遍儀表板。', icon: 'tabler:chart-line' },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       使用流程
  ═══════════════════════════════════════════════════════ -->
  <Steps
    id="how-it-works"
    tagline="極簡設計"
    title="幾分鐘內啟動運轉。"
    subtitle="無需半年漫長部署，無需外部顧問團隊。Aitroop 追求快速落地，隨時間持續複利成長。"
    items={[
      { title: '接入你的工具棧', description: '10 分鐘內完成 CRM、郵件服務和 LinkedIn 的連接。原生支援 HubSpot、Salesforce、Apollo、Outreach 等主流工具。', icon: 'tabler:plug-connected' },
      { title: '部署你的智能體', description: '根據成長優先級選擇對應的智能體，配置好參數即可。無需撰寫任何程式碼，安裝精靈自動完成剩餘操作。', icon: 'tabler:robot' },
      { title: '智能體開始工作', description: '自動化的線索挖掘、個性化觸達和智能跟進持續運轉——夜間、週末、跨時區，永不停歇。', icon: 'tabler:rocket' },
      { title: '衡量與規模化', description: '洞察智能體呈現哪些在奏效、哪些不行。一鍵放大效果好的行銷活動，砍掉無效投入。', icon: 'tabler:trending-up' },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       數據指標 — 動態計數
  ═══════════════════════════════════════════════════════ -->
  <section id="stats-section" class="relative border-y border-[var(--aw-color-border)] overflow-hidden">
    <div class="absolute inset-0 -z-10 stats-gradient" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 md:px-6 py-14 md:py-20 text-default intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <div class="text-center mb-10">
        <p class="text-xs uppercase tracking-[0.15em] font-medium text-primary mb-2">真實成果</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[var(--aw-color-text-heading)]">驅動成長的數字。</h2>
        <p class="text-[var(--aw-color-text-muted)] mt-3 max-w-md mx-auto text-sm md:text-base">
          來自在生產環境中運行 Aitroop 智能體的成長團隊的匯總數據。
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <div class="stat-card text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1"><span class="stat-num" data-target="6">6</span><span>×</span></div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">外發容量提升</p>
        </div>
        <div class="stat-card text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1"><span class="stat-num" data-target="90">90</span><span>天</span></div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">平均流失預警週期</p>
        </div>
        <div class="stat-card text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1"><span class="stat-num" data-target="80">80</span><span>%+</span></div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">聯絡人數據覆蓋率</p>
        </div>
        <div class="stat-card text-center p-6 rounded-2xl border border-[var(--aw-color-border)] bg-[var(--aw-color-bg-page)] transition-all duration-300 hover:border-[rgba(82,153,97,0.35)] hover:shadow-[0_4px_24px_rgba(82,153,97,0.1)] hover:-translate-y-1">
          <div class="text-4xl md:text-5xl font-bold text-primary tabular-nums mb-1"><span class="stat-num" data-target="15">15</span><span>%</span></div>
          <p class="text-xs text-[var(--aw-color-text-muted)] leading-snug mt-1">平均回覆率</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       用戶評價
  ═══════════════════════════════════════════════════════ -->
  <Testimonials
    id="testimonials"
    tagline="團隊的聲音"
    title="成長團隊都愛用 Aitroop。"
    subtitle="無論是重度 SDR 外呼團隊，還是精簡 PLG 模型——Aitroop 適配你的成長方式。"
    testimonials={[
      { testimonial: '我們的外發序列從每月 200 條擴展到 1400 條，人員沒有增加。觸達智能體寫的冷郵件，說實話，比我們大多數 SDR 寫得還好。', name: '林曉晴', job: '成長負責人 · Patrly' },
      { testimonial: '90 天流失預警真的很厲害。上個季度我們靠 Aitroop 的預警保住了三個企業大客戶——比他們主動提出取消還早。', name: '陳志遠', job: '業務副總裁 · Clearflo' },
      { testimonial: '以前我們要把五個工具拼在一起完成這個流程。現在一個平台搞定。60 天內 GTM 速度翻倍，營運開銷反而下降了。', name: '王嘉怡', job: '行銷長 · Storyvault' },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════
       行動召喚
  ═══════════════════════════════════════════════════════ -->
  <CallToAction
    title="你的成長團隊，已準備就緒。"
    subtitle="幾分鐘內部署你的第一個 AI 智能體，看著銷售管道動起來。"
    actions={[
      { text: '立即開始', href: 'https://app.aitroop.net', variant: 'primary' },
      { text: '聯絡我們', href: '/zh-TW/contact', variant: 'secondary' },
    ]}
  />

</Layout>

<style>
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-100%); } }
  .marquee-track { animation: marquee 32s linear infinite; }

  @keyframes glow-breathe { 0%, 100% { opacity: 0.75; transform: scale(1); } 50% { opacity: 1; transform: scale(1.18); } }
  .hero-glow { animation: glow-breathe 7s ease-in-out infinite; transform-origin: center center; }

  @keyframes ring-spin     { to { transform: rotate(360deg); } }
  @keyframes ring-spin-rev { to { transform: rotate(-360deg); } }
  .hero-ring     { animation: ring-spin     28s linear infinite; transform-origin: center center; }
  .hero-ring-rev { animation: ring-spin-rev 40s linear infinite; transform-origin: center center; }

  @keyframes scan-down { 0% { top: 0%; opacity: 0; } 5% { opacity: 0.45; } 95% { opacity: 0.35; } 100% { top: 100%; opacity: 0; } }
  .hero-scan { background: linear-gradient(to right, transparent 0%, rgba(82,153,97,0.5) 50%, transparent 100%); animation: scan-down 5s ease-in-out infinite; animation-delay: 1.5s; }

  .net-line { stroke-dasharray: 800; stroke-dashoffset: 800; }
  .net-line-1 { animation: draw-line 1.2s ease forwards 0.3s, pulse-line 4s ease-in-out 1.5s infinite; }
  .net-line-2 { animation: draw-line 1.2s ease forwards 0.7s, pulse-line 4s ease-in-out 1.9s infinite; }
  .net-line-3 { animation: draw-line 1.2s ease forwards 1.1s, pulse-line 4s ease-in-out 2.3s infinite; }
  .net-line-4 { animation: draw-line 1.2s ease forwards 1.5s, pulse-line 4s ease-in-out 2.7s infinite; }
  @keyframes draw-line  { to { stroke-dashoffset: 0; } }
  @keyframes pulse-line { 0%, 100% { opacity: 0.12; } 50% { opacity: 0.35; } }

  .net-node { animation: float-node 4s ease-in-out infinite; }
  @keyframes float-node { 0%, 100% { transform: translateY(0); opacity: 0.5; } 50% { transform: translateY(-8px); opacity: 0.85; } }

  @keyframes text-shimmer { 0% { background-position: -200% center; } 100% { background-position: 200% center; } }
  .hero-shimmer {
    background: linear-gradient(90deg, #3d854f 0%, #529961 30%, #7fcf8f 55%, #529961 70%, #3d854f 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: text-shimmer 4s linear infinite;
  }

  #agents .rounded-lg { transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease; }
  #agents .rounded-lg:hover { transform: translateY(-5px); box-shadow: 0 12px 36px rgba(82,153,97,0.13), 0 2px 8px rgba(82,153,97,0.07); border-color: rgba(82,153,97,0.28) !important; }

  @keyframes stats-bg-shift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
  .stats-gradient { background: linear-gradient(135deg, rgba(82,153,97,0.04) 0%, transparent 40%, rgba(82,153,97,0.04) 100%); background-size: 200% 200%; animation: stats-bg-shift 8s ease-in-out infinite; }

  #testimonials .grid > div:nth-child(1) { animation-delay: 0ms !important; }
  #testimonials .grid > div:nth-child(2) { animation-delay: 120ms !important; }
  #testimonials .grid > div:nth-child(3) { animation-delay: 240ms !important; }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track, .hero-glow, .hero-ring, .hero-ring-rev,
    .hero-scan, .net-line, .net-node, .hero-shimmer, .stats-gradient { animation: none !important; }
    .hero-shimmer { -webkit-text-fill-color: #529961; color: #529961; }
  }
</style>

<script>
  const statsSection = document.getElementById('stats-section');
  if (statsSection) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        observer.unobserve(entry.target);
        entry.target.querySelectorAll<HTMLElement>('.stat-num[data-target]').forEach((el) => {
          const target = parseInt(el.dataset.target ?? '0', 10);
          if (isNaN(target)) return;
          const duration = 1600;
          const ease = (t: number) => t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
          let startTime: number | null = null;
          const step = (timestamp: number) => {
            if (!startTime) startTime = timestamp;
            const progress = Math.min((timestamp - startTime) / duration, 1);
            el.textContent = String(Math.round(ease(progress) * target));
            if (progress < 1) requestAnimationFrame(step);
            else el.textContent = String(target);
          };
          requestAnimationFrame(step);
        });
      });
    }, { threshold: 0.4 });
    observer.observe(statsSection);
  }
</script>
