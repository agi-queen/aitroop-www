---
import Layout from '~/layouts/PageLayout.astro';
import AnatomyFlow from '~/components/widgets/AnatomyFlow.astro';
import WorkflowLifecycle from '~/components/widgets/WorkflowLifecycle.astro';
import PopText from '~/components/ui/PopText.astro';
import Spotlight from '~/components/ui/Spotlight.astro';
import GridBackground from '~/components/ui/GridBackground.astro';
import BentoGrid from '~/components/ui/BentoGrid.astro';
import HoverGlow from '~/components/ui/HoverGlow.astro';
import HoverBorderGradient from '~/components/ui/HoverBorderGradient.astro';
import GlareHover from '~/components/ui/GlareHover.astro';
import Aurora from '~/components/ui/Aurora.astro';
import Sparkles from '~/components/ui/Sparkles.astro';
import Meteors from '~/components/ui/Meteors.astro';
import Marquee from '~/components/ui/Marquee.astro';
import Tilt3D from '~/components/ui/Tilt3D.astro';
import AnimatedCounter from '~/components/ui/AnimatedCounter.astro';

const metadata = {
  title: 'Aitroop - 把 AI Agent 對話固化成 App',
  ignoreTitleTemplate: true,
};

const anatomySteps = [
  {
    title: 'AppInput',
    desc: '基於 Schema 的表單。text、select、daterange、file，宣告一次，自動渲染。',
    foot: '4 種輸入類型 · 內建驗證',
  },
  {
    title: 'Stage',
    desc: '帶明確目標的 Agent 會話，連入你的技能與整合。需要時多 Stage 串聯成管道。',
    foot: '150+ 技能 · 20+ 整合',
  },
  {
    title: 'Artifact',
    desc: '可交付的產物。預覽、匯出，或直接餵給下一個 Stage。',
    foot: '7 種格式 · 預覽 + 匯出',
  },
];

const stats = [
  { value: 150, suffix: '+', label: '技能' },
  { value: 20,  suffix: '+', label: '整合' },
  { value: 7,   suffix: '',  label: '產物格式' },
  { value: 'cron', suffix: '', label: '排程' },
];

const skills = [
  'GitHub', 'Gmail', 'Slack', 'Notion', 'Drive', 'Linear',
  'Stripe', 'HubSpot', 'Salesforce', 'Figma', 'Jira', 'Asana',
  'Webhook', '網頁搜尋', '程式碼執行', 'PDF', 'CSV', 'Postgres',
  'Discord', 'Twitter', 'YouTube', '日曆', 'Sheets', 'Airtable',
];

const testimonials = [
  {
    quote: '我們用 3 個 App 取代了一個 4 人運營小組的日常循環。它們依 cron 自動運行，沒人需要再去碰它們。',
    name: 'Marta R.',
    title: '營收營運主管',
    company: 'Northbound',
  },
  {
    quote: '「存為 App」讓我那堆混亂的 prompt 筆記，變成了團隊真的能跑起來的東西。',
    name: 'Diego K.',
    title: '解決方案架構師',
    company: 'Plate',
  },
  {
    quote: '沙盒才是殺手鐧。真實的檔案存取、真實的工具、真實的產物——不是玩具 demo。',
    name: 'Priya S.',
    title: 'AI 總監',
    company: 'Vector Labs',
  },
];

const features = [
  {
    title: '把對話存為 App',
    desc: '一鍵沉澱剛跑通的流程，變成帶型別化輸入、可重複執行的工作流程。',
    icon: 'M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z',
  },
  {
    title: '多 Stage 管道',
    desc: '單次 Agent 解不了的任務，就用 Stage 串聯起來。每個 Stage 擁有自己的模型、技能與 prompt。',
    icon: 'M4 6h16M4 12h16M4 18h10',
  },
  {
    title: '150+ 技能 · 20+ 整合',
    desc: 'GitHub、Gmail、Slack、Drive、Notion、網頁搜尋、程式碼執行，一鍵啟用。',
    icon: 'M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z',
  },
  {
    title: '真實沙盒',
    desc: '每一次執行都跑在隔離環境中，提供檔案系統、網路和合適的工具鏈。',
    icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z',
  },
  {
    title: '排程與 Webhook',
    desc: '依 cron 定時、手動觸發，或由 Webhook 啟動。設定一次長期託管，執行歷史可追溯。',
    icon: 'M12 6v6l4 2M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z',
  },
  {
    title: '團隊共享',
    desc: '每個 App 都是帶權限的物件。可以分享給同事、外部協作者，或作為內部 API 暴露。',
    icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  },
];

const cases = [
  {
    slug: '/zh-TW/use-cases/gtm',
    title: 'GTM',
    desc: '線索挖掘、外部觸達、客戶留存、管道洞察。',
    points: ['規模化的 ICP 研究', '個人化外聯序列', '管道與留存報告'],
  },
  {
    slug: '/zh-TW/use-cases/finance',
    title: '財務',
    desc: '月結、稽核、差異分析、報告。專為 CFO 團隊設計。',
    points: ['月結報告包自動組裝', '差異與變動分析', '稽核就緒的匯出'],
  },
];

const faqs = [
  {
    q: '把對話存成 App，要不要重寫 prompt？',
    a: '不必。在已跑通的對話裡點一下「存為 App」，Aitroop 會把當時使用的技能、整合與 prompt 都打包成可執行的工作流程。',
  },
  {
    q: 'App 儲存好之後，誰來執行？',
    a: '每一次執行都跑在隔離沙盒中，自帶檔案系統、網路與 Agent 需要的工具。可以手動觸發、依 cron 定時，或由 Webhook 啟動。',
  },
  {
    q: '步驟需要用不同的工具，能串起來嗎？',
    a: '可以。Stage 讓你把一個 Agent 接到下一個 Agent，每個 Stage 擁有獨立的模型、技能與 prompt。前一個 Stage 的產物自動成為下一個的輸入。',
  },
  {
    q: 'App 發布之後誰可以使用？',
    a: 'App 是帶權限的物件。可以分享給同事、外部協作者，或作為內部 API 暴露。執行歷史對管理員可見。',
  },
];
---

<Layout metadata={metadata}>
  <Spotlight />
  <GlareHover />

  <!-- HERO — grid + aurora + sparkles ─────────────────────────────── -->
  <section class="aw-hero hero relative isolate overflow-hidden">
    <GridBackground variant="grid" tone="brand" />
    <Aurora intensity="subtle" position="top" />
    <Sparkles count={42} size={2} />
    <div class="aw-container-wide">
      <div class="hero-grid">
        <div class="hero-copy">
          <a href="/zh-TW/use-cases" class="hero-pill">
            <span class="pill-tag">NEW</span>
            <span class="pill-text">150+ 技能 · 20+ 整合</span>
            <svg class="pill-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <h1 class="aw-display hero-display">
            強大的 Agent。<br />
            無盡的技能。<br />
            <PopText
              text="一鍵即用的 App。"
              stagger={32}
              delay={260}
              duration={310}
              class="text-primary hero-pop"
            />
          </h1>
          <p class="aw-lede hero-lede">
            一鍵就把剛跑通的 Agent 流程沉澱為 App，團隊可以反覆運行。不必再敲 prompt，不必再寫膠水程式碼。
          </p>
          <div class="aw-actions hero-actions">
            <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">免費開始</a>
            <a href="/zh-TW/use-cases" class="aw-btn aw-btn-ghost">查看案例</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- STATS — animated counters strip ─────────────────────────────── -->
  <section class="stats-section">
    <div class="aw-container-wide">
      <ul class="stats" role="list">
        {stats.map((s) => (
          <li class="stat">
            <span class="stat-value">
              <AnimatedCounter value={s.value} suffix={s.suffix} />
            </span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- SKILLS MARQUEE — infinite scroller of connect chips ─────────── -->
  <section class="skills-section">
    <div class="aw-container-wide">
      <p class="skills-eyebrow">適配你團隊已經在用的工具</p>
    </div>
    <Marquee speed={45} class="skills-marquee">
      {skills.map((s) => (
        <span class="skill-chip">
          <span class="skill-dot" aria-hidden="true"></span>
          {s}
        </span>
      ))}
    </Marquee>
    <Marquee speed={55} direction="right" class="skills-marquee skills-marquee--second">
      {skills.slice().reverse().map((s) => (
        <span class="skill-chip skill-chip--ghost">
          <span class="skill-dot" aria-hidden="true"></span>
          {s}
        </span>
      ))}
    </Marquee>
  </section>

  <!-- LIFECYCLE — the loop, end to end ───────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head lifecycle-head">
        <h2 class="aw-h2">從對話到排程 App，閉環只需要一次設定。</h2>
        <p class="aw-lede lifecycle-lede">對話變成表單，表單驅動 Stage，Stage 產出 Artifact，Artifact 觸發下一次執行。</p>
      </header>
      <WorkflowLifecycle loopHint="然後不斷重複 — 依 cron、手動觸發、Webhook 呼叫" />
    </div>
  </section>

  <!-- ANATOMY ──────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section anatomy-borderless">
    <div class="aw-container-wide">
      <AnatomyFlow
        eyebrow=""
        title="三塊拼圖。一條管道。"
        lede="輸入餵給 Stage。Stage 產出 Artifact。Artifact 流向下游，或作為下一個 Stage 的輸入。"
        steps={anatomySteps}
      />
    </div>
  </section>

  <!-- FEATURES — bento grid ──────────────────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head">
        <p class="aw-eyebrow">團隊為什麼選擇 Aitroop</p>
        <h2 class="aw-h2">讓一個 Agent 真正沉澱下來，所需要的一切。</h2>
      </header>
      <BentoGrid items={features} />
    </div>
  </section>

  <!-- USE CASES — 3D tilt cards with cipher hover ─────────────────── -->
  <HoverGlow />
  <Tilt3D />
  <section class="aw-section-flush home-section">
    <div class="aw-container-wide">
      <header class="aw-section-head">
        <p class="aw-eyebrow">案例</p>
        <h2 class="aw-h2">為團隊真實在做的事而設計。</h2>
      </header>

      <ul class="cases-grid" role="list">
        {cases.map((c) => (
          <li class="case-card tilt-3d hover-glow glare-hover" data-tilt-3d data-hover-glow>
            <div class="hover-glow__cipher" aria-hidden="true"></div>
            <div class="hover-glow__mask" aria-hidden="true"></div>
            <a href={c.slug} class="case-link">
              <div class="case-head">
                <span class="case-title" data-tilt-pop>{c.title}</span>
                <span class="case-arrow aw-arrow" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
              <p class="case-desc">{c.desc}</p>
              <ul class="case-points" role="list">
                {c.points.map((p) => (
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- TESTIMONIALS — quote cards with glare + spotlight ───────────── -->
  <section class="aw-section-flush home-section home-section--soft testimonials-section">
    <div class="aw-container-wide">
      <header class="aw-section-head">
        <p class="aw-eyebrow">深得 AI 優先團隊信賴</p>
        <h2 class="aw-h2">已經把閉環跑通的營運者們。</h2>
      </header>

      <ul class="testimonials" role="list">
        {testimonials.map((t) => (
          <li class="testimonial spotlight-card glare-hover" data-spotlight>
            <svg class="testimonial__quote" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7.17 6A5.17 5.17 0 0 0 2 11.17V18h7v-6.83H5.5c0-1.93 1.57-3.5 3.5-3.5V6h-1.83zm10 0a5.17 5.17 0 0 0-5.17 5.17V18h7v-6.83h-3.5c0-1.93 1.57-3.5 3.5-3.5V6h-1.83z"/>
            </svg>
            <p class="testimonial__quote-text">{t.quote}</p>
            <div class="testimonial__author">
              <span class="testimonial__avatar" aria-hidden="true">{t.name.charAt(0)}</span>
              <div>
                <div class="testimonial__name">{t.name}</div>
                <div class="testimonial__title">{t.title} · {t.company}</div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ ──────────────────────────────────────────────────────────── -->
  <section class="aw-section-flush home-section home-section--soft">
    <div class="aw-container-wide">
      <header class="aw-section-head faq-head">
        <p class="aw-eyebrow">FAQ</p>
        <h2 class="aw-h2">常見問題，一次說清。</h2>
      </header>
      <ul class="faq-list" role="list">
        {faqs.map((item) => (
          <li class="faq-item">
            <h3 class="faq-q">{item.q}</h3>
            <p class="faq-a">{item.a}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA — conic border + meteors + aurora ──────────────────────── -->
  <section class="aw-section-flush home-section cta-section">
    <div class="aw-container-wide">
      <HoverBorderGradient radius="20px" thickness={1} class="cta-hbg">
        <div class="cta-card">
          <Aurora intensity="bold" position="center" class="cta-aurora" />
          <Meteors count={14} angle={215} class="cta-meteors" />
          <div class="cta-content">
            <h2 class="aw-h2 cta-h2">午餐前發布你的第一個 App。</h2>
            <p class="aw-lede cta-lede">打開對話。點擊 <code class="aw-code">存為 App</code>。整個流程就是這樣。</p>
            <div class="aw-actions aw-actions-center">
              <a href="https://app.aitroop.net" class="aw-btn aw-btn-primary">打開應用</a>
              <a href="/zh-TW/contact" class="aw-btn aw-btn-ghost">聯絡我們</a>
            </div>
          </div>
        </div>
      </HoverBorderGradient>
    </div>
  </section>

</Layout>

<style>
  /* ══════════════════════════════════════════════════════════════════
     HERO — split layout
     ══════════════════════════════════════════════════════════════════ */
  .hero {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero-grid {
    display: block;
  }

  .hero-copy {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3125rem 0.875rem 0.3125rem 0.4375rem;
    border-radius: 9999px;
    border: 1px solid var(--aw-color-border);
    background: var(--aw-color-bg-page);
    font-size: 0.8125rem;
    color: var(--aw-color-text-muted);
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: border-color 200ms ease, color 200ms ease, transform 200ms ease;
  }
  .hero-pill:hover {
    border-color: rgba(82, 153, 97, 0.35);
    color: var(--aw-color-text-default);
  }
  .pill-tag {
    padding: 1px 7px;
    border-radius: 9999px;
    background: rgba(82, 153, 97, 0.12);
    color: var(--aw-color-primary);
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-weight: 700;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    line-height: 1.5;
  }
  .pill-arrow {
    width: 12px;
    height: 12px;
    color: var(--aw-color-text-muted);
    transition: transform 200ms ease;
  }
  .hero-pill:hover .pill-arrow { transform: translateX(2px); }

  .hero-display {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.04;
    margin: 0 auto 1.5rem;
    max-width: 22ch;
  }
  :global(.hero-pop) {
    display: inline-flex;
    flex-wrap: nowrap;
    white-space: nowrap;
  }
  .hero-lede {
    margin: 0 auto 2rem;
    max-width: 40rem;
    font-size: clamp(1.0625rem, 1.25vw, 1.1875rem);
  }
  .hero-actions {
    justify-content: center;
  }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
  .hero-pill,
  .hero-display,
  .hero-lede,
  .hero-actions {
    animation: hero-rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .hero-pill    { animation-delay: 0ms; }
  .hero-display { animation-delay: 80ms; }
  .hero-lede    { animation-delay: 160ms; }
  .hero-actions { animation-delay: 240ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-pill,
    .hero-display,
    .hero-lede,
    .hero-actions {
      animation: none;
    }
  }

  /* ── Stats ─ minimal strip, no borders, lots of air ──────────── */
  .stats-section {
    padding: 2rem 0 3rem;
  }
  @media (min-width: 768px) {
    .stats-section { padding: 2.75rem 0 3.5rem; }
  }
  .stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem 1rem;
  }
  @media (min-width: 768px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .stat-value {
    font-family: var(--aw-font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--aw-color-text-muted);
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  /* ── Home sections — divider-free rhythm via soft tints ──────── */
  .home-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .home-section { padding-top: 5.5rem; padding-bottom: 5.5rem; }
  }
  .home-section--soft {
    background: rgba(82, 153, 97, 0.025);
  }

  /* Anatomy: remove the hairline borders inside the component */
  :global(.anatomy-borderless .step-card) {
    border-top: none !important;
    border-bottom: none !important;
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  @media (min-width: 1024px) {
    :global(.anatomy-borderless .step-card) {
      padding-top: 0 !important;
    }
  }

  /* Lifecycle section heading uses a tighter rhythm */
  .lifecycle-head { max-width: 56rem; margin-bottom: 2.5rem; }
  .lifecycle-lede { max-width: 52ch; margin: 0; }

  /* ── Use-case cards (no row borders) ─────────────────────────── */
  .cases-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .cases-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  }
  .case-card {
    border-radius: 16px;
    background: var(--aw-color-bg-page);
    border: 1px solid var(--aw-color-border);
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .case-card:hover {
    border-color: rgba(82, 153, 97, 0.35);
    transform: translateY(-2px);
    box-shadow: 0 18px 40px -22px rgba(10, 10, 10, 0.18);
  }
  .case-link {
    display: block;
    padding: 1.75rem 1.75rem 1.875rem;
    color: inherit;
    text-decoration: none;
  }
  .case-head {
