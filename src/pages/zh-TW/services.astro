---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';
import { generateAvatar } from '~/utils/avatar';

const metadata = {
  title: '功能特色',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="功能特色"
    title="找到、觸達、轉化、留住——每個環節都用 AI 提速"
    subtitle="Aitroop 覆蓋客戶增長的完整旅程。從識別精準客群到守住每一個現有客戶，四個核心支柱協同運作，讓你一個人能做出過去需要整個團隊才能完成的事。"
    actions={[{ variant: 'primary', text: '預約產品示範', href: '/zh-TW/contact' }]}
    image={{
      src: '/illustrations/real-time-analytics_50za.svg', width: 1024, height: 768,
      alt: 'Aitroop 功能特色',
    }}
  />

  <!-- PILLAR 1: FIND **************** -->

  <Features2
    tagline="第一步：找到"
    title="精準鎖定，找到真正值得溝通的人"
    subtitle="在你開口之前，先確認你找到的是對的人。Aitroop 讓目標識別從猜測變成科學。"
    columns={3}
    items={[
      {
        title: 'ICP 建模與客群分析',
        description:
          'AI 分析你現有的高價值客戶，提煉出可量化的理想客群特徵——行業、規模、技術棧、增長階段。ICP 匹配的線索成交率高出 25-40%，銷售週期縮短 30%。',
        icon: 'tabler:crosshair',
      },
      {
        title: 'Waterfall 智能資料富化',
        description:
          '上傳名單後自動補全有效郵箱、手機、LinkedIn、融資記錄。Waterfall 串聯多個數據源依序嘗試，有效聯繫人覆蓋率從 40% 提升到 80% 以上，跳出率從 15% 降到 3% 以下。',
        icon: 'tabler:database-search',
      },
      {
        title: 'AI 客戶研究助手',
        description:
          '輸入域名，AI 在 90 秒內自動瀏覽官網、新聞、LinkedIn，回答你預設的問題：主要客群、近期切入點、潛在痛點——結果直接填入外聯模板。',
        icon: 'tabler:robot',
      },
      {
        title: '匿名訪客識別',
        description:
          '97% 的網站訪客不填表就離開。Aitroop 通過 IP 反查識別訪客所屬公司，追蹤訪問頁面與停留時長，把每個月的隱形訪客轉化為可跟進的線索。',
        icon: 'tabler:eye',
      },
      {
        title: '買家意圖信號監控',
        description:
          '官網行為、第三方意圖數據、產品使用記錄——三個維度的購買信號融合成統一評分。高意圖客戶自動推入優先跟進隊列，讓你在最佳時機出現。',
        icon: 'tabler:radar',
      },
      {
        title: '企業事件即時監控',
        description:
          '融資、高管變動、招聘擴張、競品動向——系統 5-30 分鐘內發出預警，比傳統工具快 24-48 小時。信號觸發的外聯回覆率是冷外聯的 5-10 倍。',
        icon: 'tabler:bell',
      },
    ]}
  />

  <!-- PILLAR 2: ENGAGE ************** -->

  <Features2
    tagline="第二步：觸達"
    title="個性化 × 規模化，兩個不再是選擇題"
    subtitle="一個人做出整個外聯團隊的產出，每一封信都讓對方感覺是為他專屬寫的。"
    columns={3}
    items={[
      {
        title: '個性化外聯流水線',
        description:
          '名單上傳 → 自動富化 → AI 生成個性化首句（基於融資事件、招聘動態、CEO 文章）→ 一鍵啟動序列。原本需要一天的工作，現在一小時完成。回覆率提升 3-5 倍。',
        icon: 'tabler:send',
      },
      {
        title: '多渠道自動化序列',
        description:
          '郵件 + LinkedIn 混合序列，設定一次跟進節奏，系統持續運轉，有回覆自動暫停。多渠道觸達比純郵件回覆率高 37%，每個人每月預約量提升 2 倍以上。',
        icon: 'tabler:list-check',
      },
      {
        title: '郵件送達率基礎設施',
        description:
          '域名預熱、信譽監控、多域名智能輪轉——確保你精心撰寫的郵件進主收件箱而不是垃圾箱。主收件箱到達率穩定維持在 90% 以上。',
        icon: 'tabler:mail-check',
      },
      {
        title: 'AI 內容批量生成',
        description:
          '輸入話題和目標客群，90 秒內同時生成部落格、LinkedIn 貼文、郵件序列。每月內容產量提升 5 倍，行銷來源的商機線索增加 25-35%。',
        icon: 'tabler:pencil',
      },
      {
        title: '官網個性化',
        description:
          '根據訪客來源公司、行業、廣告渠道動態調整首頁文案和案例展示，不同的訪客看到最相關的內容。無需開發，Demo 申請率提升 20-40%。',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: '行銷自動化工作流',
        description:
          '視覺化旅程編排，基於行為和屬性觸發郵件、簡訊、站內消息。動態受眾每 15 分鐘自動更新，MQL→SQL 轉化率提升到 25-30%。',
        icon: 'tabler:settings-automation',
      },
    ]}
  />

  <!-- PILLAR 3: CONVERT ************* -->

  <Features2
    tagline="第三步：轉化"
    title="把每一個興趣信號，變成可預測的成交機會"
    subtitle="從線索到合約，每個環節都有 AI 幫你識別優先級、加快節奏、提升勝率。"
    columns={3}
    items={[
      {
        title: '線索評分與優先排序',
        description:
          'AI 綜合行為、意圖、公司屬性實時評分，搭配可解釋的評分理由。銷售每天的優先清單一目了然，SQL 成交率提升 2.7 倍，不再在低質線索上浪費時間。',
        icon: 'tabler:target',
      },
      {
        title: 'AI 提案自動生成',
        description:
          'AE 輸入客戶名稱，AI Research + CRM 數據自動生成 12-15 頁個性化提案——公司背景、定制方案、相關案例、定價框架。5 分鐘出稿，當天就能發出，比競爭對手快 3 天。',
        icon: 'tabler:file-description',
      },
      {
        title: 'Pipeline 管理與健康預警',
        description:
          'CRM 即時同步，自動標記超過正常推進週期的商機，AI 建議下一步行動。Win Rate 提升 10-15%，銷售週期縮短 20%，管理層週會從 4 小時縮到 1.5 小時。',
        icon: 'tabler:chart-arrows',
      },
      {
        title: '收入預測',
        description:
          'AI 分析 Pipeline 流速、歷史成交規律、代表偏差，生成樂觀/基準/悲觀三種情境預測。預測誤差從 ±30% 穩定到 ±10-15%，讓每一個資源決策都有可信依據。',
        icon: 'tabler:trending-up',
      },
      {
        title: 'PQL 識別',
        description:
          '從大量試用用戶中精準識別「正在達到 Aha 時刻」的那批人——功能啟用、用量接近上限、邀請隊友。AI 觸發即時跟進，免費轉付費轉化率提升 2.3 倍。',
        icon: 'tabler:user-check',
      },
      {
        title: '銷售通話分析與教練',
        description:
          'AI 自動轉錄、評分每一通銷售電話，提煉頂尖銷售的對話模式，生成個人化成長建議。新人培訓週期從 6 個月縮到 3 個月，整體團隊通話品質提升 15%。',
        icon: 'tabler:microphone',
      },
    ]}
  />

  <!-- PILLAR 4: RETAIN ************** -->

  <Features2
    tagline="第四步：留住"
    title="守住客戶，是成本最低、回報最高的增長策略"
    subtitle="獲客是開始，把現有客戶服務好才是複利增長的真正引擎。Aitroop 讓你在問題發生之前就採取行動。"
    columns={3}
    items={[
      {
        title: '客戶健康度即時評分',
        description:
          '持續追蹤產品使用深度、功能採用率、支援工單趨勢和互動頻率，自動計算健康評分。CSM 每週節省 4-6 小時的手動排查，NRR 平均提升 8-15 個百分點。',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: '流失預警：比客戶先知道',
        description:
          '健康評分持續下滑時，系統在流失發生前 90 天推送預警，並自動生成個性化挽回策略。提前介入的成功率是事後補救的 3-4 倍，且成本低 80%。',
        icon: 'tabler:bell-ringing',
      },
      {
        title: '續費與增購自動化',
        description:
          '基於客戶旅程和使用數據，自動觸發個性化的升級建議和續費提醒。不靠人工逐個盯，系統在最佳時機自動啟動，CSM 專注在真正需要人工介入的客戶上。',
        icon: 'tabler:arrow-up-circle',
      },
      {
        title: 'Champion 職位變動追蹤',
        description:
          '你的關鍵聯絡人離職是客戶流失的最大預警信號之一。Aitroop 自動監控帳戶內關鍵人職位變動，第一時間通知並建議關係維護行動。',
        icon: 'tabler:user-search',
      },
      {
        title: '推薦裂變自動化',
        description:
          '在客戶 NPS 最高的時機自動觸發推薦邀請，追蹤推薦鏈路，把滿意的客戶轉化成你最低成本的獲客渠道。',
        icon: 'tabler:share',
      },
      {
        title: 'CRM 雙向同步',
        description:
          '深度整合國內外主流 CRM，線索、聯繫人、商機、健康分數雙向即時同步。CRM 填寫率從 40% 提升到 85%，數據始終保持一致，不再靠人工複製貼上。',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- AI Assistant Content ********** -->

  <Content
    isReversed
    items={[
      {
        title: '會議自動轉錄 + CRM 自動填寫',
        description:
          '通話結束後 5 分鐘，AI 自動生成結構化摘要、BANT 資訊、待辦事項，直接同步到 CRM。跟進郵件在黃金 1 小時內發出，不靠記憶，不靠意志力。',
        icon: 'tabler:notes',
      },
      {
        title: '自然語言查詢數據',
        description:
          '用中文直接問：「上個月哪個行業的轉化率最高？」「本季 Pipeline 缺口多少？」不需要等分析師，不需要寫 SQL，30 秒得到答案。',
        icon: 'tabler:message-question',
      },
      {
        title: '實時 AI 話術輔助',
        description:
          '通話中 AI 即時推送相關案例、異議處理建議、競品對比回答，讓每一位銷售都能有頂尖銷售的表現水準，不只是頂尖那一位。',
        icon: 'tabler:message-chatbot',
      },
    ]}
    image={{
      src: '/illustrations/ai-agent_pdkp.svg', width: 1024, height: 768,
      alt: 'AI 助手',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">AI 助手：把每天 72% 的行政工作變回銷售時間</h3>
      頂尖銷售和普通銷售的差距，往往不在能力，而在他們用多少時間真正在做銷售。
    </Fragment>
  </Content>

  <!-- Features3: Why Aitroop ******** -->

  <Features3
    tagline="為什麼選擇 Aitroop"
    title="五個讓 Aitroop 與眾不同的特色"
    subtitle="我們不是在做一個「也能用」的增長工具，而是在重新定義個人和團隊的 AI 增長能力上限。"
    columns={2}
    items={[
      {
        title: '意圖雷達：三維信號融合',
        description:
          '官網訪問行為 + 第三方意圖數據 + 產品使用記錄，三個維度融合成統一評分。讓你在競爭對手意識到機會之前，已經出現在客戶面前。',
        icon: 'tabler:radar',
      },
      {
        title: 'Waterfall 智能富化引擎',
        description:
          '串聯多個數據源，依優先級自動嘗試，命中即停止。有效郵箱覆蓋率穩定 80% 以上，跳出率 3% 以下——單一數據源無法做到。',
        icon: 'tabler:filter-bolt',
      },
      {
        title: '全鏈路一體化，零工具切換',
        description:
          '從找到目標客戶到促成成交、守住續費，所有環節在一個平台完成。節省的不只是工具費用，更是每次切換、搜尋、複製貼上浪費的專注力。',
        icon: 'tabler:arrows-join',
      },
      {
        title: 'AI 助手懂中文商業語境',
        description:
          'AI 生成的外聯信件、會議摘要、提案內容理解中國 B2B 的業務慣例與溝通風格，不是套用西方範本的生硬翻譯，用起來更自然、更有效。',
        icon: 'tabler:message-chatbot',
      },
      {
        title: '可預測的增長引擎',
        description:
          '不只是外聯工具，更是增長運營平台。AI 收入預測誤差 < 15%、流失預警提前 90 天、Pipeline 健康實時可見——增長從靠感覺變成有依據。',
        icon: 'tabler:trending-up',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Features3: Integrations ******* -->

  <Features3
    title="整合你現有的每一個工具"
    subtitle="Aitroop 不是要替換你的工具，而是把它們連接起來，消除協作摩擦。"
    columns={2}
    items={[
      {
        title: 'CRM 整合',
        description: '國內外主流 CRM 全面支援——雙向即時同步，資料永遠一致，國內外平台均可接入。',
        icon: 'tabler:plug',
      },
      {
        title: '數據供應商',
        description: '深度整合國內外多個商業資料庫——Waterfall 智能策略自動選擇最優數據源，一站式覆蓋全球聯繫人資料。',
        icon: 'tabler:database',
      },
      {
        title: '溝通工具',
        description: '郵件客戶端、企業微信、Slack——通知和工作流直達你的日常協作工具。',
        icon: 'tabler:message',
      },
      {
        title: '行銷平台',
        description: '廣告歸因、UTM 管理、官網追蹤——從流量到成交，全路徑數據打通。',
        icon: 'tabler:chart-pie',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="他們用 Aitroop 改變了業績軌跡"
    testimonials={[
      {
        testimonial: `以前每天花兩三個小時調研客戶、寫個性化郵件，用了 Aitroop 之後，我只需要審核 AI 生成的內容，每天外聯量從 20 人增加到 100 人以上，預約率提升了將近一倍。`,
        name: '陳建宏',
        job: '企業軟體公司業務拓展',
        image: {
          src: '/illustrations/ai-agent_pdkp.svg', width: 1024, height: 768,
          alt: '陳建宏',
        },
      },
      {
        testimonial: `最讓我驚訝的是歸因功能。以前老闆問「這筆預算帶來了多少收入」我只能說大概，現在每個渠道的 ROI 清清楚楚，預算申請容易多了，行銷和銷售的摩擦也少了。`,
        name: '林雅婷',
        job: 'SaaS 公司行銷增長負責人',
        image: generateAvatar('Lin Yating'),
      },
      {
        testimonial: `收入預測這件事做了五年，誤差從沒低於 25%。Aitroop 上線三個季度後，我們的預測誤差穩定在 12% 以內。這對我們做人員規劃和預算分配意義重大。`,
        name: '王志強',
        job: '製造業數位化公司增長負責人',
        image: generateAvatar('Wang Zhiqiang'),
      },
    ]}
    callToAction={{
      text: '查看更多用戶故事',
      href: '/zh-TW/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '預約 30 分鐘產品示範',
        href: '/zh-TW/contact',
      },
    ]}
    title="親眼看看 Aitroop 如何改變你的增長效率"
    subtitle="讓我們的顧問根據你的業務場景，展示最適合你的工作流方案。"
  />
</Layout>
